<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — PRYM Server Admin</title>
    <link rel="icon" type="image/svg+xml" href="~/images/trace.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;550;600;700;750&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/server-dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
</head>
<body>
<div id="wrapper">

    <!-- ── Sidebar ──────────────────────────────────────────────────── -->
    <nav id="sidebar-wrapper" aria-label="Navigazione principale">

        <!-- Brand -->
        <div class="sidebar-brand">
            <div class="sidebar-logo-row">
                <img src="~/images/trace.svg" class="sidebar-logo-trace" alt="EventForge" />
                <img src="~/images/logoWhite.svg" class="sidebar-logo-wordmark" alt="EventForge" />
            </div>
            <div class="sidebar-brand-product">Serve Management</div>
            <button class="sidebar-brand-close d-lg-none" id="sidebarToggle" aria-label="Chiudi menu">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="sidebar-nav">

            <!-- Monitoring -->
            <div class="sidebar-section">
                <div class="sidebar-section-title">
                    <i class="bi bi-display"></i>Monitoring
                </div>
                <a href="/dashboard"
                   class="sidebar-item @(Context.Request.Path.Equals("/dashboard", StringComparison.OrdinalIgnoreCase) || Context.Request.Path.Equals("/Dashboard/Index", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                    <i class="bi bi-grid-1x2-fill"></i>Overview
                </a>
                <a href="/dashboard/health"
                   class="sidebar-item @(Context.Request.Path.StartsWithSegments("/dashboard/health", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                    <i class="bi bi-heart-pulse-fill"></i>Health Checks
                </a>
                <a href="/dashboard/performance"
                   class="sidebar-item @(Context.Request.Path.StartsWithSegments("/dashboard/performance", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                    <i class="bi bi-speedometer2"></i>Performance
                </a>
                <a href="/dashboard/logs"
                   class="sidebar-item @(Context.Request.Path.StartsWithSegments("/dashboard/logs", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                    <i class="bi bi-journals"></i>Logs
                </a>
                <a href="/dashboard/auditlog"
                   class="sidebar-item @(Context.Request.Path.StartsWithSegments("/dashboard/auditlog", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                    <i class="bi bi-clock-history"></i>Audit Log
                </a>
                <a href="/dashboard/maintenance"
                   class="sidebar-item @(Context.Request.Path.StartsWithSegments("/dashboard/maintenance", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                    <i class="bi bi-tools"></i>Manutenzione
                </a>
                <a href="/dashboard/settings"
                   class="sidebar-item @(Context.Request.Path.StartsWithSegments("/dashboard/settings", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                    <i class="bi bi-sliders"></i>Impostazioni
                </a>
            </div>

            <div class="sidebar-divider"></div>

            <!-- Multi-Tenant -->
            <div class="sidebar-section">
                <div class="sidebar-section-title">
                    <i class="bi bi-building"></i>Multi-Tenant
                </div>
                <a href="/dashboard/tenants"
                   class="sidebar-item @(Context.Request.Path.StartsWithSegments("/dashboard/tenant", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                    <i class="bi bi-building-fill"></i>Tenants
                </a>
                <a href="/dashboard/users"
                   class="sidebar-item @(Context.Request.Path.StartsWithSegments("/dashboard/user", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                    <i class="bi bi-people-fill"></i>Utenti
                </a>
                <a href="/dashboard/licenses"
                   class="sidebar-item @(Context.Request.Path.StartsWithSegments("/dashboard/license", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                    <i class="bi bi-award-fill"></i>Licenze
                </a>
                <a href="/dashboard/roles"
                   class="sidebar-item @(Context.Request.Path.StartsWithSegments("/dashboard/role", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                    <i class="bi bi-shield-fill-check"></i>Ruoli & Permessi
                </a>
                <a href="/dashboard/branding"
                   class="sidebar-item @(Context.Request.Path.StartsWithSegments("/dashboard/branding", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                    <i class="bi bi-palette2"></i>Branding
                </a>
            </div>

            <div class="sidebar-divider"></div>

            <!-- Developer -->
            <div class="sidebar-section">
                <div class="sidebar-section-title">
                    <i class="bi bi-terminal"></i>Developer
                </div>
                <a href="/swagger" target="_blank" class="sidebar-item">
                    <i class="bi bi-braces-asterisk"></i>Swagger API
                    <i class="bi bi-box-arrow-up-right sidebar-item-ext"></i>
                </a>
                <a href="/health" target="_blank" class="sidebar-item">
                    <i class="bi bi-activity"></i>Health JSON
                    <i class="bi bi-box-arrow-up-right sidebar-item-ext"></i>
                </a>
            </div>

        </div>

        @{
            var _userName  = User.Identity?.Name ?? "";
            var _namePart  = _userName.Contains('@') ? _userName.Split('@')[0] : _userName;
            var _initParts = _namePart.Split(new[]{' ','.'}, StringSplitOptions.RemoveEmptyEntries);
            var _initials  = _initParts.Length >= 2
                ? $"{_initParts[0][0]}{_initParts[1][0]}".ToUpper()
                : (_namePart.Length >= 2 ? _namePart[..2].ToUpper() : _namePart.ToUpper());
        }
        <!-- User footer -->
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <div class="sidebar-avatar">@_initials</div>
                    <div class="sidebar-user-info">
                        <div class="sidebar-user-name">@_userName</div>
                        <div class="sidebar-user-role">SuperAdmin</div>
                    </div>
                </div>
                <form method="post" asp-page="/Logout">
                    <button type="submit" class="sidebar-logout">
                        <i class="bi bi-box-arrow-right"></i> Disconnetti
                    </button>
                </form>
            </div>
        }
    </nav>

    <!-- ── Page content ─────────────────────────────────────────────── -->
    <div id="page-content-wrapper">

        <!-- Top bar -->
        <header class="ef-topbar">
            <button class="ef-topbar-toggle" id="sidebarToggleTop" aria-label="Toggle menu">
                <i class="bi bi-layout-sidebar"></i>
            </button>

            <nav class="ef-breadcrumb" aria-label="breadcrumb">
                <a href="/dashboard"><i class="bi bi-hdd-network me-1"></i>Dashboard</a>
                @if (!string.IsNullOrEmpty(ViewData["PageSection"]?.ToString()))
                {
                    <i class="bi bi-chevron-right ef-breadcrumb-sep"></i>
                    <span>@ViewData["PageSection"]</span>
                }
                @if (!string.IsNullOrEmpty(ViewData["Title"]?.ToString()) && ViewData["Title"]?.ToString() != "Overview")
                {
                    <i class="bi bi-chevron-right ef-breadcrumb-sep"></i>
                    <span class="ef-breadcrumb-active">@ViewData["Title"]</span>
                }
            </nav>

            <div class="ef-topbar-meta">
                <div class="ef-status-dot" title="Sistema operativo" id="topStatusDot"></div>
                <span class="ef-version-badge">
                    v@(System.Reflection.Assembly.GetExecutingAssembly().GetName().Version?.ToString(3) ?? "—")
                </span>
            </div>
        </header>

        <!-- Content -->
        <main class="ef-main">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="ef-footer">
            <span>PRYM Server Admin &copy; @DateTime.Now.Year</span>
            <span>Pannello di amministrazione SuperAdmin</span>
        </footer>

    </div>
</div>

<!-- ── Navigation guard overlay ─────────────────────────────────────── -->
<div id="ef-nav-guard-overlay" aria-hidden="true" aria-live="assertive">
    <div class="ef-nav-guard-card">
        <div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
        <span class="ef-nav-guard-msg">Operazione in corso, attendere…</span>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/sidebar.js"></script>
<script src="~/js/navigation-guard.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
