@page
@model EventForge.Server.Pages.Dashboard.LogsModel
@{
    ViewData["Title"] = "Logs";
    ViewData["PageSection"] = "Monitoring";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-file-text-fill me-2"></i>Log di sistema</h2>
    <span class="badge bg-secondary fs-6">@Model.TotalCount log totali</span>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage</div>
}

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small text-muted mb-1">Ricerca</label>
                <input type="text" asp-for="SearchTerm" class="form-control form-control-sm"
                       placeholder="Descrizione, operazione, utente..." />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Severità</label>
                <select asp-for="SeverityFilter" class="form-select form-select-sm">
                    <option value="">Tutte</option>
                    <option value="Information">Information</option>
                    <option value="Warning">Warning</option>
                    <option value="Error">Error</option>
                    <option value="Critical">Critical</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Categoria</label>
                <select asp-for="CategoryFilter" class="form-select form-select-sm">
                    <option value="">Tutte</option>
                    @foreach (var cat in Model.AvailableCategories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <div class="form-check ms-1">
                    <input class="form-check-input" type="checkbox" asp-for="ErrorsOnly" />
                    <label class="form-check-label small">Solo errori</label>
                </div>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">
                    <i class="bi bi-search me-1"></i>Cerca
                </button>
                <a href="/dashboard/logs" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Logs Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Logs.Any())
        {
            <div class="p-4 text-center text-muted">
                <i class="bi bi-inbox fs-3 d-block mb-2"></i>Nessun log trovato con i filtri selezionati.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle mb-0">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th style="width:150px">Timestamp</th>
                            <th style="width:90px">Severità</th>
                            <th style="width:110px">Categoria</th>
                            <th>Operazione / Descrizione</th>
                            <th style="width:110px">Eseguito da</th>
                            <th style="width:80px">Durata</th>
                            <th style="width:80px">Stato</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.Logs)
                        {
                            var (rowClass, sevBadge) = log.Severity switch
                            {
                                "Critical" => ("table-danger", "bg-danger"),
                                "Error"    => ("table-danger", "bg-danger"),
                                "Warning"  => ("table-warning", "bg-warning text-dark"),
                                _          => ("", "bg-secondary")
                            };
                            if (!log.Success) rowClass = "table-danger";
                            <tr class="@rowClass">
                                <td class="text-muted small">@log.CreatedAt.ToString("dd/MM HH:mm:ss")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.Severity))
                                    {
                                        <span class="badge @sevBadge">@log.Severity</span>
                                    }
                                </td>
                                <td class="text-muted small">@log.Category</td>
                                <td>
                                    <div class="fw-medium small">@(log.Operation ?? log.Action)</div>
                                    @if (!string.IsNullOrEmpty(log.Description))
                                    {
                                        <div class="text-muted" style="font-size:.75rem">@log.Description</div>
                                    }
                                    @if (!string.IsNullOrEmpty(log.ErrorMessage))
                                    {
                                        <div class="text-danger" style="font-size:.75rem"><i class="bi bi-bug me-1"></i>@log.ErrorMessage</div>
                                    }
                                </td>
                                <td class="text-muted small">@log.ExecutedBy</td>
                                <td class="text-muted small">
                                    @(log.DurationMs.HasValue ? $"{log.DurationMs.Value:N0} ms" : "—")
                                </td>
                                <td>
                                    @if (log.Success)
                                    {
                                        <span class="badge bg-success">OK</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Fail</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center p-3 border-top">
                    <small class="text-muted">
                        Pagina @Model.CurrentPage di @Model.TotalPages (@Model.TotalCount record)
                    </small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            @if (Model.CurrentPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="?CurrentPage=@(Model.CurrentPage - 1)@Model.GetFilterQueryString()">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                            }
                            @for (int p = Math.Max(1, Model.CurrentPage - 2); p <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); p++)
                            {
                                <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="?CurrentPage=@p@Model.GetFilterQueryString()">@p</a>
                                </li>
                            }
                            @if (Model.CurrentPage < Model.TotalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="?CurrentPage=@(Model.CurrentPage + 1)@Model.GetFilterQueryString()">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>
