@page
@model EventForge.Server.Pages.Dashboard.HealthModel
@using Microsoft.Extensions.Diagnostics.HealthChecks
@{
    ViewData["Title"] = "Health Checks";
    ViewData["PageSection"] = "Monitoring";
    var overallStatus = Model.Report?.Status ?? HealthStatus.Unhealthy;
    var (statusClass, statusIcon, statusLabel) = overallStatus switch
    {
        HealthStatus.Healthy    => ("success", "bi-check-circle-fill",  "Healthy"),
        HealthStatus.Degraded   => ("warning", "bi-exclamation-circle-fill", "Degraded"),
        _                       => ("danger",  "bi-x-circle-fill",      "Unhealthy")
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-heart-pulse-fill me-2"></i>Health Checks</h2>
    <a href="/dashboard/health" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage</div>
}
else if (Model.Report == null)
{
    <div class="alert alert-warning">Nessun dato disponibile.</div>
}
else
{
    <!-- Overall Status -->
    <div class="alert alert-@statusClass d-flex align-items-center mb-4">
        <i class="bi @statusIcon fs-4 me-3"></i>
        <div>
            <strong>Stato generale: @statusLabel</strong>
            <div class="small">Durata totale: @Model.Report.TotalDuration.TotalMilliseconds.ToString("N0") ms</div>
        </div>
    </div>

    <!-- Individual checks -->
    <div class="row g-3">
        @foreach (var entry in Model.Report.Entries.OrderBy(e => e.Value.Status))
        {
            var (cardClass, badgeClass, icon) = entry.Value.Status switch
            {
                HealthStatus.Healthy  => ("border-success", "bg-success",  "bi-check-circle-fill"),
                HealthStatus.Degraded => ("border-warning", "bg-warning",  "bi-exclamation-circle-fill"),
                _                     => ("border-danger",  "bg-danger",   "bi-x-circle-fill")
            };
            <div class="col-md-6">
                <div class="card border-2 @cardClass h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h6 class="card-title mb-1">
                                <i class="bi @icon me-1 text-@(entry.Value.Status == HealthStatus.Healthy ? "success" : entry.Value.Status == HealthStatus.Degraded ? "warning" : "danger")"></i>
                                @entry.Key
                            </h6>
                            <span class="badge @badgeClass">@entry.Value.Status</span>
                        </div>
                        @if (!string.IsNullOrEmpty(entry.Value.Description))
                        {
                            <p class="card-text small text-muted mb-1">@entry.Value.Description</p>
                        }
                        <small class="text-muted">Durata: @entry.Value.Duration.TotalMilliseconds.ToString("N0") ms</small>
                        @if (entry.Value.Exception != null)
                        {
                            <div class="mt-2 p-2 bg-danger bg-opacity-10 rounded small text-danger">
                                <i class="bi bi-bug me-1"></i>@entry.Value.Exception.Message
                            </div>
                        }
                        @if (entry.Value.Data.Any())
                        {
                            <ul class="mt-2 mb-0 small list-unstyled">
                                @foreach (var kv in entry.Value.Data)
                                {
                                    <li><span class="text-muted">@kv.Key:</span> @kv.Value</li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="text-muted small mt-3">
        <i class="bi bi-clock me-1"></i>Ultimo aggiornamento: @DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")
        — <a href="/health" target="_blank" class="text-muted">JSON endpoint <i class="bi bi-box-arrow-up-right"></i></a>
    </div>
}
