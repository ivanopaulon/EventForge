@page
@model EventForge.Server.Pages.Dashboard.LogBackupsModel
@{
    ViewData["Title"] = "Backup Log";
    ViewData["PageSection"] = "Monitoring";
    var hasViewer = !string.IsNullOrWhiteSpace(Model.ViewFileContent);
}

<div class="ef-page-header">
    <div class="ef-page-title">
        <div class="ef-page-title-icon monitoring"><i class="bi bi-archive-fill"></i></div>
        <div>
            <h1>Backup Log</h1>
            <p class="ef-page-subtitle">Archivi JSON creati da LogCleanupService prima di ogni eliminazione</p>
        </div>
    </div>
    <a href="/dashboard/logbackups" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-clockwise"></i> Aggiorna
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<!-- Directory info -->
<div class="ef-card mb-3">
    <div class="ef-card-body py-2">
        <small class="text-muted">
            <i class="bi bi-folder2-open me-1"></i>
            Directory backup: <code>@Model.BackupDirectoryPath</code>
            &nbsp;·&nbsp;
            <strong>@Model.Backups.Count</strong> backup trovati
            &nbsp;·&nbsp;
            <a href="/dashboard/settings#logging" class="text-decoration-none">
                <i class="bi bi-sliders me-1"></i>Configura
            </a>
        </small>
    </div>
</div>

@if (!Model.Backups.Any())
{
    <div class="ef-card">
        <div class="ef-card-body text-center py-5">
            <i class="bi bi-inbox display-4 text-muted"></i>
            <p class="mt-3 text-muted">Nessun backup trovato in <code>@Model.BackupDirectoryPath</code>.</p>
            <p class="text-muted small">I backup vengono creati automaticamente da LogCleanupService quando <strong>Logging.BackupEnabled = true</strong>.</p>
        </div>
    </div>
}
else
{
    foreach (var backup in Model.Backups)
    {
        <div class="ef-card mb-3">
            <div class="ef-card-header d-flex justify-content-between align-items-center">
                <div>
                    <i class="bi bi-archive me-2 text-info"></i>
                    <strong>@backup.DirectoryName</strong>
                    @if (backup.Timestamp > DateTime.MinValue)
                    {
                        <span class="text-muted ms-2">— @backup.Timestamp.ToString("dd/MM/yyyy HH:mm:ss") UTC</span>
                    }
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-secondary">@LogBackupsModel.FormatSize(backup.TotalSizeBytes)</span>
                    <span class="badge bg-light text-dark border">@backup.Files.Count file</span>
                    <form method="post" asp-page-handler="DeleteBackup" style="display:inline"
                          onsubmit="return confirm('Eliminare definitivamente il backup \'@backup.DirectoryName\'?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="backupName" value="@backup.DirectoryName" />
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-trash"></i> Elimina
                        </button>
                    </form>
                </div>
            </div>

            <div class="ef-card-body p-0">
                <table class="ef-table mb-0">
                    <thead>
                        <tr>
                            <th>File</th>
                            <th>Dimensione</th>
                            <th class="text-end">Azioni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var file in backup.Files)
                        {
                            var isViewing = hasViewer
                                && Model.ViewBackupName == backup.DirectoryName
                                && Model.ViewFileName   == file.FileName;
                            <tr class="@(isViewing ? "table-active" : "")">
                                <td>
                                    <i class="bi bi-filetype-json text-warning me-1"></i>
                                    @file.FileName
                                </td>
                                <td class="text-muted">@LogBackupsModel.FormatSize(file.SizeBytes)</td>
                                <td class="text-end">
                                    <a href="?ViewBackupName=@Uri.EscapeDataString(backup.DirectoryName)&ViewFileName=@Uri.EscapeDataString(file.FileName)"
                                       class="btn btn-outline-secondary btn-sm me-1">
                                        <i class="bi bi-eye"></i> Visualizza
                                    </a>
                                    <a href="/dashboard/logbackups?handler=DownloadFile&backupName=@Uri.EscapeDataString(backup.DirectoryName)&fileName=@Uri.EscapeDataString(file.FileName)"
                                       class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-download"></i> Scarica
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (hasViewer
                && Model.ViewBackupName == backup.DirectoryName
                && !string.IsNullOrWhiteSpace(Model.ViewFileName))
            {
                <div class="ef-card-body border-top">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>
                            <i class="bi bi-code-square me-1 text-warning"></i>
                            @Model.ViewFileName
                        </strong>
                        @if (Model.ViewFileTruncated)
                        {
                            <span class="badge bg-warning text-dark">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                Troncato a 1 MB — scarica il file per il contenuto completo
                            </span>
                        }
                        <a href="/dashboard/logbackups" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-x"></i> Chiudi
                        </a>
                    </div>
                    <pre class="bg-dark text-light p-3 rounded"
                         style="max-height:500px;overflow-y:auto;font-size:.78rem;white-space:pre-wrap;word-break:break-all">@Model.ViewFileContent</pre>
                </div>
            }
        </div>
    }
}
