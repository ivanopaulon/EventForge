@page "/dashboard/settings"
@model EventForge.Server.Pages.Dashboard.SettingsModel
@using EventForge.DTOs.SuperAdmin
@{
    ViewData["Title"] = "System Settings";
    ViewData["PageSection"] = "Monitoring";

    var activeTab = Request.Query["tab"].ToString() switch
    {
        "performance" => "performance",
        "features"    => "features",
        _             => "config"
    };

    var configActive      = activeTab == "config"      ? "show active" : "";
    var performanceActive = activeTab == "performance" ? "show active" : "";
    var featuresActive    = activeTab == "features"    ? "show active" : "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-gear me-2"></i>Impostazioni di sistema</h2>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle-fill me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Tabs -->
<ul class="nav nav-tabs mb-4" role="tablist">
    <li class="nav-item">
        <button class="nav-link @(activeTab == "config" ? "active" : "")"
                data-bs-toggle="tab" data-bs-target="#config" type="button">
            <i class="bi bi-sliders me-1"></i>Configurazione
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(activeTab == "performance" ? "active" : "")"
                data-bs-toggle="tab" data-bs-target="#performance" type="button">
            <i class="bi bi-speedometer2 me-1"></i>Performance
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(activeTab == "features" ? "active" : "")"
                data-bs-toggle="tab" data-bs-target="#features" type="button">
            <i class="bi bi-toggle-on me-1"></i>Feature Flags
        </button>
    </li>
</ul>

<div class="tab-content">

    <!-- ── Configuration Tab ────────────────────────────────────── -->
    <div class="tab-pane fade @configActive" id="config">

        <!-- SMTP -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent fw-semibold">
                <i class="bi bi-envelope me-2 text-primary"></i>Configurazione SMTP
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="UpdateSmtp">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Server SMTP</label>
                            <input type="text" asp-for="SmtpServer" class="form-control" placeholder="smtp.gmail.com" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Porta</label>
                            <input type="number" asp-for="SmtpPort" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Usa SSL</label>
                            <select asp-for="SmtpUseSsl" class="form-select">
                                <option value="True">S&igrave;</option>
                                <option value="False">No</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Username</label>
                            <input type="text" asp-for="SmtpUsername" class="form-control" autocomplete="off" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                Password
                                <small class="text-muted">(lasciare vuoto per non modificare)</small>
                            </label>
                            <input type="password" asp-for="SmtpPassword" class="form-control"
                                   placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" autocomplete="new-password" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email mittente</label>
                            <input type="email" asp-for="SmtpFromEmail" class="form-control"
                                   placeholder="noreply@eventforge.com" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Nome mittente</label>
                            <input type="text" asp-for="SmtpFromName" class="form-control" placeholder="PRYM" />
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i>Salva SMTP
                            </button>
                        </div>
                    </div>
                </form>

                <hr />
                <!-- Test SMTP -->
                <form method="post" asp-page-handler="TestSmtp">
                    @Html.AntiForgeryToken()
                    <div class="row g-2 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label small">Email di destinazione per il test</label>
                            <input type="email" name="testEmail" class="form-control form-control-sm"
                                   placeholder="test@esempio.com" required />
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-send me-1"></i>Invia email di test
                            </button>
                        </div>
                    </div>
                </form>
                @if (Model.SmtpTestResult != null)
                {
                    @if (Model.SmtpTestResult.Success)
                    {
                        <div class="alert alert-success mt-3 mb-0 py-2">
                            <i class="bi bi-check-circle-fill me-1"></i>
                            <strong>Email inviata</strong> in @(Model.SmtpTestResult.DurationMs) ms
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger mt-3 mb-0 py-2">
                            <i class="bi bi-x-circle-fill me-1"></i>
                            <strong>Errore:</strong> @Model.SmtpTestResult.ErrorMessage
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Logging -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent fw-semibold">
                <i class="bi bi-file-text me-2 text-info"></i>Configurazione logging
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="UpdateLogging">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Livello di log</label>
                            <select asp-for="LogLevel" class="form-select">
                                <option value="Trace">Trace</option>
                                <option value="Debug">Debug</option>
                                <option value="Information">Information</option>
                                <option value="Warning">Warning</option>
                                <option value="Error">Error</option>
                                <option value="Critical">Critical</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Retention log (giorni)</label>
                            <input type="number" asp-for="LogRetentionDays" class="form-control" min="1" max="365" />
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i>Salva logging
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ── Performance Tab ──────────────────────────────────────── -->
    <div class="tab-pane fade @performanceActive" id="performance">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent fw-semibold">
                <i class="bi bi-speedometer me-2 text-warning"></i>Rate limiting API
                <small class="text-muted ms-2">(riavvio necessario per applicare)</small>
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="UpdateRateLimit">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Login max tentativi (per 5 min)</label>
                            <input type="number" asp-for="LoginLimit" class="form-control" min="1" max="100" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">API max chiamate (per minuto)</label>
                            <input type="number" asp-for="ApiLimit" class="form-control" min="10" max="10000" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Token refresh max (per minuto)</label>
                            <input type="number" asp-for="TokenRefreshLimit" class="form-control" min="1" max="60" />
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i>Salva rate limiting
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Per cache e metriche in tempo reale visita
            <a href="/dashboard/maintenance" class="alert-link">Manutenzione</a> e
            <a href="/dashboard/performance" class="alert-link">Performance</a>.
        </div>
    </div>

    <!-- ── Feature Flags Tab ────────────────────────────────────── -->
    <div class="tab-pane fade @featuresActive" id="features">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">
                <i class="bi bi-toggles me-2 text-success"></i>Feature flags
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="UpdateFeatures">
                    @Html.AntiForgeryToken()
                    <div class="list-group mb-3">
                        <div class="list-group-item">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="FeatureDocumentCollaboration" role="switch" />
                                <label class="form-check-label">
                                    <strong>Collaborazione documenti (SignalR)</strong><br />
                                    <small class="text-muted">Abilita la modifica collaborativa in tempo reale</small>
                                </label>
                            </div>
                        </div>
                        <div class="list-group-item">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="FeatureAdvancedReporting" role="switch" />
                                <label class="form-check-label">
                                    <strong>Reporting avanzato</strong><br />
                                    <small class="text-muted">Esportazione PDF/Excel e report personalizzati</small>
                                </label>
                            </div>
                        </div>
                        <div class="list-group-item">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="FeatureDetailedAudit" role="switch" />
                                <label class="form-check-label">
                                    <strong>Audit log dettagliato</strong><br />
                                    <small class="text-muted text-warning">Traccia tutte le modifiche alle entit&agrave; (impatto sulle performance)</small>
                                </label>
                            </div>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Salva feature flags
                    </button>
                </form>
            </div>
        </div>
    </div>

</div>
