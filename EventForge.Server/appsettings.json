{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.SignalR": "Debug",
      "Microsoft.AspNetCore.Http.Connections": "Debug",
      "EventForge.Server.Services.Documents.DocumentHeaderService": "Debug",
      "EventForge.Server.Hubs.DocumentCollaborationHub": "Debug"
    }
  },

  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "https://localhost:7009", "http://localhost:5048" ]
  },
  "HttpClient": {
    "BaseAddress": "https://localhost",
    "Port": 7241
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=EventData;User Id=vsapp;Password=pass123!;TrustServerCertificate=True;",
    "SqlServer": "Server=localhost\\SQLEXPRESS;Database=EventData;User Id=vsapp;Password=pass123!;TrustServerCertificate=True;",
    "LogDb": "Server=localhost\\SQLEXPRESS;Database=EventLogger;User Id=vsapp;Password=pass123!;TrustServerCertificate=True;",
    "Redis": "localhost:6379"
  },
  "DatabaseProvider": "SqlServer",
  "SyncfusionLicenseKey": "Ngo9BigBOggjHTQxAR8/V1JHaF5cWWdCf1FpRmJGdld5fUVHYVZUTXxaS00DNHVRdkdlWXtedXVURWZeV0xxWEBWYEo=",

  "Security": {
    "EnforceHttps": true,
    "EnableHsts": true,
    "HstsMaxAge": 31536000
  },

  "Authentication": {
    "Jwt": {
      "Issuer": "EventForge",
      "Audience": "EventForge",
      "SecretKey": "DevelopmentSecretKeyThatIsAtLeast32CharsLong!!",
      "ExpirationMinutes": 600,
      "ClockSkewMinutes": 5
    },
    "PasswordPolicy": {
      "MinimumLength": 8,
      "MaximumLength": 128,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigits": true,
      "RequireSpecialCharacters": true,
      "SpecialCharacters": "!@#$%^&*()_+-=[]{}|;:,.<>?",
      "MaxPasswordAge": 90,
      "PasswordHistory": 5
    },
    "AccountLockout": {
      "MaxFailedAttempts": 5,
      "LockoutDurationMinutes": 30,
      "ResetFailedAttemptsOnSuccess": true
    }
  },

  "Bootstrap": {
    "SuperAdminPassword": "EventForge@2024!",
    "DefaultAdminUsername": "superadmin",
    "DefaultAdminEmail": "superadmin@localhost",
    "AutoCreateAdmin": true,
    "StoreOperatorPassword": "Operator@2025!"
  },

  "FiscalPrinterMonitor": {
    "PollingIntervalSeconds": 10
  },

  "Performance": {
    "SlowRequestThresholdMs": 200,
    "Monitoring": {
      "SlowQueryThreshold": "00:00:02",
      "MaxSlowQueryHistory": 100,
      "EnableDetailedLogging": true,
      "LogAllQueries": false
    }
  },

  "QzSigning": {
    "PrivateKeyPath": "private-key.pem",
    "CertificatePath": "digital-certificate.txt",
    "IntermediateCertificatePath": "intermediate-certificate.txt"
  },

  "PriceHistory": {
    "RetentionDays": 730,
    "EnableAutoLogging": true,
    "CacheStatisticsDurationMinutes": 5,
    "DefaultPageSize": 20,
    "MaxPageSize": 100,
    "SignificantChangePercentage": 5.0
  },

  "VatLookup": {
    "RestProviderUrlTemplate": "https://api.vatcomply.com/vat?vat={country}{vat}",
    "RestTimeoutSeconds": 10
  },

  "SupplierSuggestion": {
    "Weights": {
      "Price": 0.4,
      "LeadTime": 0.25,
      "Reliability": 0.2,
      "Trend": 0.15
    },
    "MinDataPointsForTrend": 3,
    "TrendAnalysisPeriodDays": 180,
    "CacheScoresDurationMinutes": 5,
    "ConfidenceThresholds": {
      "Low": 60,
      "High": 80
    },
    "EnableAutoSuggestions": true,
    "PriceChangeThresholdPercentage": 10.0
  },

  "SupplierAlerts": {
    "DefaultThresholds": {
      "PriceIncreasePercentage": 5.0,
      "PriceDecreasePercentage": 10.0,
      "VolatilityPercentage": 15.0,
      "DaysWithoutUpdate": 90
    },
    "NotificationSettings": {
      "EnableEmail": true,
      "DefaultFrequency": "Immediate",
      "MaxAlertsPerDigest": 50
    },
    "AlertRetention": {
      "DaysToKeepResolved": 90,
      "DaysToKeepDismissed": 30
    },
    "SignalR": {
      "HeartbeatIntervalSeconds": 30
    }
  },

  "CsvImport": {
    "MaxFileSizeBytes": 10485760,
    "BatchSize": 100,
    "DefaultCurrency": "EUR",
    "MaxRowsPreview": 10
  },

  "Pagination": {
    "DefaultPageSize": 20,
    "MaxPageSize": 1000,
    "MaxExportPageSize": 10000,
    "RecommendedPageSize": 100,
    "EndpointOverrides": {
      "/api/v1/stock/overview": 5000,
      "/api/v1/export/*": 10000,
      "/api/v1/events/date-range": 1000,
      "/api/v1/calendar-reminders/date-range": 1000,
      "/api/v1/product-management/price-lists": 1000,
      "/api/v1/storeusers": 1000,
      "/api/v1/businessparties": 500
    },
    "RoleBasedLimits": {
      "User": 1000,
      "Admin": 5000,
      "SuperAdmin": 10000
    }
  },

  "RateLimiting": {
    "Enabled": true,
    "LoginLimit": 5,
    "ApiLimit": 100,
    "TokenRefreshLimit": 30
  },

  "_Comment_Serilog": "NOTE: The Serilog section below is not used at runtime. Serilog is configured programmatically in ServiceCollectionExtensions.cs using the LogDb connection string.",
  "Serilog": {
    "EnableConsole": false,
    "FilePath": "Logs/log-.log",
    "FileRetention": 7,
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "NOT_USED_SEE_LOGDB_CONNECTION_STRING",
          "tableName": "Logs",
          "autoCreateSqlTable": true
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },

  "_Comment_Configuration": "Single-file config. Environment-specific overrides live in 'Environments:{env}' below, automatically applied at startup by Program.cs based on ASPNETCORE_ENVIRONMENT (Development | Production).",
  "Environments": {
    "_Comment": "Dev: launchSettings.json sets ASPNETCORE_ENVIRONMENT=Development. Prod IIS: defaults to Production when env var is not set.",
    "Development": {
      "Security": {
        "EnableHsts": false
      }
    },
    "Production": {
      "HttpClient": {
        "Port": 7242
      },
      "Logging": {
        "LogLevel": {
          "Default": "Warning",
          "Microsoft.AspNetCore": "Error",
          "Microsoft.AspNetCore.SignalR": "Warning",
          "Microsoft.AspNetCore.Http.Connections": "Warning",
          "EventForge.Server.Services.Documents.DocumentHeaderService": "Warning",
          "EventForge.Server.Hubs.DocumentCollaborationHub": "Warning"
        }
      },
      "Swagger": {
        "Enabled": false
      },
      "Bootstrap": {
        "AutoCreateAdmin": false
      },
      "Performance": {
        "SlowRequestThresholdMs": 500,
        "Monitoring": {
          "EnableDetailedLogging": false,
          "LogAllQueries": false
        }
      },
      "RateLimiting": {
        "TokenRefreshLimit": 1
      },
      "DailyClosureReminder": {
        "NotificationTime": "23:00:00",
        "CriticalAlertTime": "08:00:00"
      }
    }
  }
}
