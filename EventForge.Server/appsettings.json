    "SqlServer": "Server=localhost\\SQLEXPRESS;Database=EventData;User Id=vsapp;Password=pass123!;TrustServerCertificate=True;",
    "LogDb": "Server=localhost\\SQLEXPRESS;Database=EventLogger;User Id=vsapp;Password=pass123!;TrustServerCertificate=True;",
    "Redis": "localhost:6379"
  },
  "DatabaseProvider": "SqlServer",
  "SyncfusionLicenseKey": "Ngo9BigBOggjHTQxAR8/V1JHaF5cWWdCf1FpRmJGdld5fUVHYVZUTXxaS00DNHVRdkdlWXtedXVURWZeV0xxWEBWYEo=",

  "Security": {
    "EnforceHttps": true,
    "EnableHsts": true,
    "HstsMaxAge": 31536000
  },

  "Authentication": {
    "Jwt": {
      "Issuer": "EventForge",
      "Audience": "EventForge",
      "SecretKey": "DevelopmentSecretKeyThatIsAtLeast32CharsLong!!",
      "ExpirationMinutes": 600,
      "ClockSkewMinutes": 5
    },
    "PasswordPolicy": {
      "MinimumLength": 8,
      "MaximumLength": 128,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigits": true,
      "RequireSpecialCharacters": true,
      "SpecialCharacters": "!@#$%^&*()_+-=[]{}|;:,.<>?",
      "MaxPasswordAge": 90,
      "PasswordHistory": 5
    },
    "AccountLockout": {
      "MaxFailedAttempts": 5,
      "LockoutDurationMinutes": 30,
      "ResetFailedAttemptsOnSuccess": true
    }
  },

  "Bootstrap": {
    "SuperAdminPassword": "EventForge@2024!",
    "DefaultAdminUsername": "superadmin",
    "DefaultAdminEmail": "superadmin@localhost",
    "AutoCreateAdmin": true,
    "StoreOperatorPassword": "Operator@2025!"
  },

  "FiscalPrinterMonitor": {
    "PollingIntervalSeconds": 10
  },

  "Performance": {
    "SlowRequestThresholdMs": 200,
    "Monitoring": {
      "SlowQueryThreshold": "00:00:02",
      "MaxSlowQueryHistory": 100,
      "EnableDetailedLogging": true,
      "LogAllQueries": false
    }
  },

  "PriceHistory": {
    "RetentionDays": 730,
    "EnableAutoLogging": true,
    "CacheStatisticsDurationMinutes": 5,
    "DefaultPageSize": 20,
    "MaxPageSize": 100,
    "SignificantChangePercentage": 5.0
  },

  "VatLookup": {
    "RestProviderUrlTemplate": "https://api.vatcomply.com/vat?vat={country}{vat}",
    "RestTimeoutSeconds": 10
  },

  "SupplierSuggestion": {
    "Weights": {
      "Price": 0.4,
      "LeadTime": 0.25,
      "Reliability": 0.2,
      "Trend": 0.15
    },
    "MinDataPointsForTrend": 3,
    "TrendAnalysisPeriodDays": 180,
    "CacheScoresDurationMinutes": 5,
    "ConfidenceThresholds": {
      "Low": 60,
      "High": 80
    },
    "EnableAutoSuggestions": true,
    "PriceChangeThresholdPercentage": 10.0
  },

  "SupplierAlerts": {
    "DefaultThresholds": {
      "PriceIncreasePercentage": 5.0,
      "PriceDecreasePercentage": 10.0,
      "VolatilityPercentage": 15.0,
      "DaysWithoutUpdate": 90
    },
    "NotificationSettings": {
      "EnableEmail": true,
      "DefaultFrequency": "Immediate",
      "MaxAlertsPerDigest": 50
    },
    "AlertRetention": {
      "DaysToKeepResolved": 90,
      "DaysToKeepDismissed": 30
    },
    "SignalR": {
      "HeartbeatIntervalSeconds": 30
    }
  },

  "CsvImport": {
    "MaxFileSizeBytes": 10485760,
    "BatchSize": 100,
    "DefaultCurrency": "EUR",
    "MaxRowsPreview": 10
  },

  "Pagination": {
    "DefaultPageSize": 20,
    "MaxPageSize": 1000,
    "MaxExportPageSize": 10000,
    "RecommendedPageSize": 100,
    "EndpointOverrides": {
      "/api/v1/stock/overview": 5000,
      "/api/v1/export/*": 10000,
      "/api/v1/events/date-range": 1000,
      "/api/v1/calendar-reminders/date-range": 1000,
      "/api/v1/product-management/price-lists": 1000,
      "/api/v1/storeusers": 1000,
      "/api/v1/businessparties": 500
    },
    "RoleBasedLimits": {
      "User": 1000,
      "Admin": 5000,
      "SuperAdmin": 10000
    }
  },

  "RateLimiting": {
    "Enabled": true,
    "LoginLimit": 5,
    "ApiLimit": 100,
    "TokenRefreshLimit": 30
  },

  "_Comment_Serilog": "NOTE: The Serilog section below is not used at runtime. Serilog is configured programmatically in ServiceCollectionExtensions.cs using the LogDb connection string.",
  "Serilog": {
    "EnableConsole": false,
    "FilePath": "Logs/log-.log",
    "FileRetention": 7,
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "NOT_USED_SEE_LOGDB_CONNECTION_STRING",
          "tableName": "Logs",
          "autoCreateSqlTable": true
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },

  "_Comment_WhatsApp": "Meta WhatsApp Cloud API integration. Register a webhook at https://developers.facebook.com → App → WhatsApp → Configuration. Set the Callback URL to https://<your-host>/api/v1/whatsapp/webhook and copy the Verify Token below. Generate an Access Token (System User or temporary) and paste it here together with the Phone Number ID from the WhatsApp dashboard.",
  "WhatsApp": {
    "VerifyToken": "REPLACE_WITH_YOUR_VERIFY_TOKEN",
    "AccessToken": "REPLACE_WITH_YOUR_WHATSAPP_ACCESS_TOKEN",
    "PhoneNumberId": "REPLACE_WITH_YOUR_PHONE_NUMBER_ID",
    "ApiVersion": "v19.0"
  },

  "_Comment_Configuration": "Single-file config. Environment-specific overrides live in 'Environments:{env}' below, automatically applied at startup by Program.cs based on ASPNETCORE_ENVIRONMENT (Development | Production).",

  "_Comment_UpdateHub": "UpdateHub integration. Set BaseUrl + AdminApiKey to enable SuperAdmin update management. MaintenanceSecret must match the Agent's Components:Server/Client:MaintenanceSecret. AvailableRefreshIntervalSeconds: how often (seconds) to poll Hub for package count badge (default 60).",
  "UpdateHub": {
    "BaseUrl": "",
    "AdminApiKey": "",
    "MaintenanceSecret": "REPLACE_WITH_STRONG_SECRET",
    "AvailableRefreshIntervalSeconds": 60
  },

  "_Comment_Agent": "Local UpdateAgent probe. LocalUrl = http://localhost:{Agent.UI.Port}. PollIntervalSeconds: how often to probe. AutoRestartAfterMinutes: 0 = disabled, >0 = auto-restart Windows service after N minutes of unreachability. Username/Password must match UpdateAgent:UI:Username/Password in the Agent appsettings.",
  "Agent": {
    "LocalUrl": "http://localhost:5780",
    "Username": "admin",
    "Password": "Admin#123!",
    "PollIntervalSeconds": 30,
    "AutoRestartAfterMinutes": 5
