@page
@model EventForge.UpdateHub.Pages.LogsModel
@{
    ViewData["Title"] = "Log";
    ViewData["PageSection"] = "Diagnostica";
}

<div class="ef-page-header">
    <div class="ef-page-title">
        <div class="ef-page-title-icon monitoring"><i class="bi bi-journals"></i></div>
        <div>
            <h1>Log Hub</h1>
            <p class="ef-page-subtitle">Ultimi @Model.Lines.Count messaggi — @(Model.LogFile ?? "nessun file trovato")</p>
        </div>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        @* File selector *@
        @if (Model.AvailableFiles.Count > 1)
        {
            <select id="fileSelect" class="form-select form-select-sm" style="width:auto"
                    onchange="location.href='/logs?level=@Model.FilterLevel&file='+encodeURIComponent(this.value)">
                @foreach (var f in Model.AvailableFiles)
                {
                    if (f == Model.LogFile)
                    {
                        <option value="@f" selected>@f</option>
                    }
                    else
                    {
                        <option value="@f">@f</option>
                    }
                }
            </select>
        }
        @* Level filter buttons *@
        <div class="d-flex gap-1">
            @foreach (var lv in new[] { "All", "Information", "Warning", "Error", "Fatal", "Debug" })
            {
                var label = lv == "All" ? "Tutti" : lv;
                var active = Model.FilterLevel == lv ? "btn-primary" : "btn-outline-secondary";
                <a href="/logs?level=@lv&file=@Uri.EscapeDataString(Model.LogFile ?? string.Empty)"
                   class="btn btn-sm @active">@label</a>
            }
        </div>
        <a href="/logs?file=@Uri.EscapeDataString(Model.LogFile ?? string.Empty)"
           class="btn btn-outline-secondary btn-sm" title="Aggiorna">
            <i class="bi bi-arrow-clockwise"></i>
        </a>
    </div>
</div>

@if (Model.LogFile is null)
{
    <div class="alert alert-warning d-flex align-items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <span>Nessun file di log trovato nella directory <code>@Model.LogDirectory</code>.</span>
    </div>
}
else
{
    <div class="ef-card">
        <div class="ef-card-header">
            <i class="bi bi-terminal"></i>
            <code style="font-size:.8rem">@Model.LogFile</code>
            <span class="ef-badge ef-badge-neutral ms-auto">@Model.Lines.Count righe</span>
            <span class="ef-badge ef-badge-info ms-2" id="refreshBadge">
                <i class="bi bi-arrow-clockwise me-1"></i>Live
            </span>
        </div>
        <div class="ef-card-body p-0">
            <div class="ef-table-wrap">
                <table class="ef-table" id="logTable">
                    <thead>
                        <tr>
                            <th style="width:80px">Orario</th>
                            <th style="width:90px">Livello</th>
                            <th>Messaggio</th>
                        </tr>
                    </thead>
                    <tbody id="logBody">
                        @foreach (var entry in Model.Lines)
                        {
                            var rowCls = entry.Level is "Error" or "Fatal"
                                ? "row-danger"
                                : entry.Level == "Warning" ? "row-warning" : "";
                            var badgeCls = entry.Level switch
                            {
                                "Error" or "Fatal" => "ef-badge-danger",
                                "Warning"          => "ef-badge-warning",
                                "Information"      => "ef-badge-success",
                                _                  => "ef-badge-neutral"
                            };
                            <tr class="@rowCls">
                                <td class="text-muted" style="white-space:nowrap;font-size:.75rem">@entry.Timestamp</td>
                                <td><span class="ef-badge @badgeCls">@entry.Level</span></td>
                                <td style="word-break:break-word;max-width:0">
                                    @entry.Message
                                    @if (!string.IsNullOrEmpty(entry.Exception))
                                    {
                                        <details class="mt-1">
                                            <summary class="text-danger" style="font-size:.75rem;cursor:pointer">
                                                <i class="bi bi-bug me-1"></i>Eccezione
                                            </summary>
                                            <pre style="font-size:.72rem;white-space:pre-wrap;color:var(--ef-danger);margin-top:.4rem">@entry.Exception</pre>
                                        </details>
                                    }
                                </td>
                            </tr>
                        }
                        @if (Model.Lines.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                    Nessuna riga corrisponde al filtro selezionato.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
(function () {
    const badge      = document.getElementById('refreshBadge');
    const tbody      = document.getElementById('logBody');
    if (!tbody) return;

    const level   = '@Model.FilterLevel';
    const logFile = '@(Model.LogFile ?? string.Empty)';

    const BADGE_CLS = {
        'Error':'ef-badge-danger','Fatal':'ef-badge-danger',
        'Warning':'ef-badge-warning','Information':'ef-badge-success'
    };
    const ROW_CLS  = { 'Error':'row-danger','Fatal':'row-danger','Warning':'row-warning' };

    function esc(t) {
        return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    async function refresh() {
        try {
            badge.innerHTML = '<i class="bi bi-arrow-clockwise me-1 spin"></i>Aggiornamento…';
            const url = '/logs?handler=Lines&level=' + encodeURIComponent(level)
                      + '&file=' + encodeURIComponent(logFile);
            const res = await fetch(url);
            if (!res.ok) return;
            const entries = await res.json();
            if (!entries || !entries.length) return;

            tbody.innerHTML = entries.map(e => {
                const lvl   = e.level || 'Information';
                const rowC  = ROW_CLS[lvl]   || '';
                const badC  = BADGE_CLS[lvl] || 'ef-badge-neutral';
                const excHtml = e.exception
                    ? `<details class="mt-1"><summary class="text-danger" style="font-size:.75rem;cursor:pointer"><i class="bi bi-bug me-1"></i>Eccezione</summary><pre style="font-size:.72rem;white-space:pre-wrap;color:var(--ef-danger);margin-top:.4rem">${esc(e.exception)}</pre></details>`
                    : '';
                return `<tr class="${rowC}">
                    <td class="text-muted" style="white-space:nowrap;font-size:.75rem">${esc(e.timestamp)}</td>
                    <td><span class="ef-badge ${badC}">${esc(lvl)}</span></td>
                    <td style="word-break:break-word;max-width:0">${esc(e.message)}${excHtml}</td>
                </tr>`;
            }).join('');
        } catch { /* ignore */ }
        badge.innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>Live';
    }

    setInterval(refresh, 10000);

    const style = document.createElement('style');
    style.textContent = '.spin{animation:spin 1s linear infinite}@@keyframes spin{to{transform:rotate(360deg)}}';
    document.head.appendChild(style);
})();
</script>
}

