@page
@model EventForge.UpdateHub.Pages.HistoryModel
@using EventForge.UpdateHub.Data.Entities
@{
    ViewData["Title"] = "Cronologia";
    ViewData["PageSection"] = "Hub";
    int succeeded  = Model.History.Count(r => r.History.Status == UpdateHistoryStatus.Succeeded);
    int failed     = Model.History.Count(r => r.History.Status == UpdateHistoryStatus.Failed);
    int inProgress = Model.History.Count(r => r.History.Status == UpdateHistoryStatus.InProgress);
    int rolledBack = Model.History.Count(r => r.History.RolledBack);
}

<div class="ef-page-header">
    <div class="ef-page-title">
        <div class="ef-page-title-icon blue"><i class="bi bi-clock-history"></i></div>
        <div>
            <h1>Cronologia aggiornamenti</h1>
            <p class="ef-page-subtitle">Registro degli aggiornamenti inviati alle installazioni (ultimi 500)</p>
        </div>
    </div>
    <span class="ef-badge ef-badge-neutral">@Model.History.Count eventi</span>
</div>

<!-- KPI -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card green">
            <div class="ef-kpi-label"><i class="bi bi-check-circle me-1"></i>Completati</div>
            <div class="ef-kpi-value">@succeeded</div>
            <div class="ef-kpi-sub">con successo</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card @(failed > 0 ? "amber" : "green")">
            <div class="ef-kpi-label"><i class="bi bi-x-circle me-1"></i>Falliti</div>
            <div class="ef-kpi-value">@failed</div>
            <div class="ef-kpi-sub">con errore</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card @(inProgress > 0 ? "amber" : "cyan")">
            <div class="ef-kpi-label"><i class="bi bi-arrow-repeat me-1"></i>In corso</div>
            <div class="ef-kpi-value">@inProgress</div>
            <div class="ef-kpi-sub">in esecuzione</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card @(rolledBack > 0 ? "amber" : "cyan")">
            <div class="ef-kpi-label"><i class="bi bi-arrow-counterclockwise me-1"></i>Rollback</div>
            <div class="ef-kpi-value">@rolledBack</div>
            <div class="ef-kpi-sub">ripristinati</div>
        </div>
    </div>
</div>

<!-- Tabella cronologia -->
<div class="ef-card">
    <div class="ef-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-clock-history me-2"></i>Storico aggiornamenti</span>
        <div class="d-flex gap-2">
            <select id="filterStatus" class="form-select form-select-sm" style="max-width:180px" onchange="filterTable()">
                <option value="">Tutti gli stati</option>
                <option value="succeeded">Completati</option>
                <option value="failed">Falliti</option>
                <option value="inprogress">In corso</option>
                <option value="pending">In attesa</option>
                <option value="rolledback">Rollback</option>
            </select>
            <input type="text" id="searchInput" class="form-control form-control-sm" style="max-width:220px"
                   placeholder="🔍 Filtra installazione…" oninput="filterTable()" />
        </div>
    </div>
    <div class="ef-card-body p-0">
        <div class="ef-table-wrap">
            <table class="ef-table" id="histTable">
                <thead>
                    <tr>
                        <th>Stato</th>
                        <th>Installazione</th>
                        <th>Componente</th>
                        <th>Versione</th>
                        <th>Da → A</th>
                        <th>Fase</th>
                        <th>Avviato il</th>
                        <th>Completato il</th>
                        <th>Durata</th>
                        <th>Errore</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.History)
                {
                    var h = row.History;
                    var statusCss = h.Status switch {
                        UpdateHistoryStatus.Succeeded  => "ef-badge-success",
                        UpdateHistoryStatus.Failed     => "ef-badge-danger",
                        UpdateHistoryStatus.InProgress => "ef-badge-warning",
                        UpdateHistoryStatus.RolledBack => "ef-badge-neutral",
                        _                              => "ef-badge-neutral"
                    };
                    var rowCss = h.Status == UpdateHistoryStatus.Failed ? "row-danger"
                               : h.Status == UpdateHistoryStatus.InProgress ? "row-warning"
                               : "";
                    var duration = h.CompletedAt.HasValue
                        ? (h.CompletedAt.Value - h.StartedAt).TotalSeconds
                        : (double?)null;
                    var compCss  = row.Component == PackageComponent.Server ? "ef-badge-blue" : "ef-badge-info";
                    <tr class="@rowCss"
                        data-status="@h.Status.ToString().ToLower()"
                        data-search="@row.InstallationName.ToLower()">
                        <td>
                            <span class="ef-badge @statusCss">
                                @if (h.RolledBack) { <i class="bi bi-arrow-counterclockwise me-1"></i> }
                                @h.Status
                            </span>
                        </td>
                        <td class="fw-semibold small">@row.InstallationName</td>
                        <td>
                            @if (row.Component.HasValue)
                            {
                                <span class="ef-badge @compCss">@row.Component</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td><code class="text-muted">@row.PackageVersion</code></td>
                        <td class="small text-muted" style="white-space:nowrap">
                            <code>@(h.FromVersion ?? "—")</code>
                            <i class="bi bi-arrow-right mx-1"></i>
                            <code>@(h.ToVersion ?? "—")</code>
                        </td>
                        <td class="text-muted small">@(h.PhaseDescription ?? "—")</td>
                        <td class="text-muted small" style="white-space:nowrap">
                            <span title="@h.StartedAt.ToString("u")">@h.StartedAt.ToString("dd/MM/yy HH:mm:ss")</span>
                        </td>
                        <td class="text-muted small" style="white-space:nowrap">
                            @if (h.CompletedAt.HasValue)
                            {
                                <span title="@h.CompletedAt.Value.ToString("u")">@h.CompletedAt.Value.ToString("dd/MM/yy HH:mm:ss")</span>
                            }
                            else { <span>—</span> }
                        </td>
                        <td class="text-muted small">
                            @if (duration.HasValue)
                            {
                                @(duration < 60
                                    ? $"{(int)duration}s"
                                    : $"{(int)(duration / 60)}m {(int)(duration % 60)}s")
                            }
                            else { <span>—</span> }
                        </td>
                        <td class="text-danger small" style="max-width:200px">
                            @if (!string.IsNullOrEmpty(h.ErrorMessage))
                            {
                                <span title="@h.ErrorMessage">
                                    @(h.ErrorMessage.Length > 60 ? h.ErrorMessage[..60] + "…" : h.ErrorMessage)
                                </span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                    </tr>
                }
                @if (!Model.History.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center text-muted py-5">
                            <i class="bi bi-clock-history fs-3 d-block mb-2"></i>
                            Nessun aggiornamento registrato. La cronologia apparirà qui dopo il primo deploy.
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
function filterTable() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    const s = document.getElementById('filterStatus').value.toLowerCase();
    document.querySelectorAll('#histTable tbody tr').forEach(tr => {
        const name   = tr.getAttribute('data-search') || '';
        const status = tr.getAttribute('data-status') || '';
        const matchQ = !q || name.includes(q);
        const matchS = !s || status === s;
        tr.style.display = (matchQ && matchS) ? '' : 'none';
    });
}
</script>
}
