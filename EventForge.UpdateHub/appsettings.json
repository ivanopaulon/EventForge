{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "UpdateHub": "Data Source=updatehub.db"
  },
  "UpdateHub": {
    "PackageStorePath": "packages",
    "IncomingPackagesPath": "packages/incoming",
    "AdminApiKey": "",
    "EnrollmentToken": "",
    "AllowAutoEnrollment": false,
    "BaseUrl": null,
    "ServerCallbackUrl": null,
    "MaintenanceCallbackSecret": "",
    "HeartbeatTimeoutSeconds": 120,
    "AgentStatusCheckIntervalSeconds": 60,
    "MaxConcurrentUpdates": 1,
    "DefaultServerDeployPath": null,
    "DefaultClientDeployPath": null,
    "MaxUploadSizeMb": 500,
    "PackageRetentionDays": 90,
    "PackageCleanupIntervalHours": 24,
    "Logging": {
      "RetentionDays": 30,
      "DirectoryPath": null
    },
    "UI": {
      "HttpsPort": 7244,
      "HttpPort": 7243,
      "Username": "admin",
      "Password": "Admin#123!"
    }
  },

  "_Comment_Configuration": "Single-file config. Environment-specific overrides live in 'Environments:{env}' below, automatically applied at startup by Program.cs based on ASPNETCORE_ENVIRONMENT.",
  "Environments": {
    "Development": {
      "Logging": {
        "LogLevel": {
          "Default": "Debug",
          "Microsoft.AspNetCore": "Information",
          "Microsoft.EntityFrameworkCore": "Information"
        }
      },
      "UpdateHub": {
        "AdminApiKey": "dev-admin-key",
        "EnrollmentToken": "dev-enrollment-token",
        "AllowAutoEnrollment": true,
        "BaseUrl": "http://localhost:7243",
        "ServerCallbackUrl": "http://localhost:5000",
        "MaintenanceCallbackSecret": "dev-maintenance-secret-2024"
      }
    },
    "Production": {
      "Logging": {
        "LogLevel": {
          "Default": "Warning",
          "Microsoft.AspNetCore": "Error",
          "Microsoft.EntityFrameworkCore": "Warning"
        }
      },
      "UpdateHub": {
        "AdminApiKey": "REPLACE_WITH_STRONG_ADMIN_KEY",
        "EnrollmentToken": "REPLACE_WITH_STRONG_ENROLLMENT_TOKEN",
        "AllowAutoEnrollment": false,
        "BaseUrl": "http://localhost:7243",
        "ServerCallbackUrl": "REPLACE_WITH_EVENTFORGE_SERVER_URL",
        "MaintenanceCallbackSecret": "REPLACE_WITH_STRONG_MAINTENANCE_SECRET",
        "UI": {
          "Username": "admin",
          "Password": "REPLACE_WITH_STRONG_PASSWORD"
        }
      }
    }
  }
}
