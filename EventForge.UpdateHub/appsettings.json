{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "UpdateHub": "Data Source=updatehub.db"
  },
  "UpdateHub": {
    "PackageStorePath": "packages",
    "IncomingPackagesPath": "packages/incoming",
    "AdminApiKey": "",
    "EnrollmentToken": "",
    "AllowAutoEnrollment": false,
    "BaseUrl": null,
    "HeartbeatTimeoutSeconds": 120,
    "AgentStatusCheckIntervalSeconds": 60,
    "MaxConcurrentUpdates": 1,
    "DefaultServerDeployPath": null,
    "DefaultClientDeployPath": null,
    "MaxUploadSizeMb": 500,
    "PackageRetentionDays": 90,
    "PackageCleanupIntervalHours": 24,
    "Logging": {
      "RetentionDays": 30,
      "DirectoryPath": null
    },
    "UI": {
      "HttpsPort": 7244,
      "HttpPort": 7243,
      "Username": "admin",
      "Password": "Admin#123!"
    }
  },

  "_Comment_Configuration": "Single-file config. Environment-specific overrides live in 'Environments:{env}' below, automatically applied at startup by Program.cs based on ASPNETCORE_ENVIRONMENT.",
  "Environments": {
    "Development": {
      "Logging": {
        "LogLevel": {
          "Default": "Debug",
          "Microsoft.AspNetCore": "Information",
          "Microsoft.EntityFrameworkCore": "Information"
        }
      },
      "UpdateHub": {
        "EnrollmentToken": "dev-enrollment-token",
        "AllowAutoEnrollment": true
      }
    }
  }
}
