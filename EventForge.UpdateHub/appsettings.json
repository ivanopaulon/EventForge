{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "UpdateHub": "Data Source=updatehub.db"
  },
  "UpdateHub": {
    "PackageStorePath": "packages",
    "IncomingPackagesPath": "packages/incoming",
    "HeartbeatTimeoutSeconds": 120,
    "AdminApiKey": ""
  },
  "_comments": {
    "AdminApiKey": "REQUIRED: Set a strong random API key before deploying. Example: use `openssl rand -hex 32` or a GUID. Leave empty to disable admin API access."
  }
}
