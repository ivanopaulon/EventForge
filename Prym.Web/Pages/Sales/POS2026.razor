@page "/sales/pos2026"
@* Eccezione documentata (Categoria D — WorkspacePage):
   questa è la pagina POS (Point of Sale) — un workspace full-screen specializzato
   con touchscreen layout, carrello, prodotti, pagamento e integrazione stampante fiscale.
   Non ha struttura tabellare principale. EntityManagementPage e EFTable non sono adatti
   per questo tipo di interfaccia operativa. POS.razor e POSTouch.razor sono stati eliminati;
   questa è l'unica pagina POS attiva del progetto. *@
@using Prym.Web.ViewModels
@using Prym.Web.Models.Sales
@using Prym.Web.Shared.Components.Sales.Pos26
@using Prym.Web.Shared.Components.Sales
@using Prym.Web.Shared.Components.Dialogs.Sales
@using Prym.Web.Services.Sales
@using Prym.Web.Services.Store
@using Prym.DTOs.Analytics
@using Prym.DTOs.Constants
@using Prym.DTOs.Products
@using Prym.DTOs.Store
@using Prym.DTOs.Business
@using Prym.DTOs.Business.Fidelity
@using Prym.DTOs.FiscalPrinting
@using Prym.DTOs.Warehouse
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@attribute [Authorize]
@inject POSViewModel ViewModel
@inject IDialogService DialogService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JSRuntime
@inject ISalesService SalesService
@inject IFiscalPrintingService FiscalPrintingService
@inject IFiscalDrawerService FiscalDrawerService
@inject Prym.Web.Services.Store.IShiftService ShiftService
@inject IProductService ProductService
@inject IPaymentMethodService PaymentMethodService
@inject IAnalyticsService AnalyticsService
@inject IEntityManagementService EntityManagementService
@inject ITableManagementService TableManagementService
@inject ILogger<POS2026> Logger
@inject NavigationManager NavigationManager
@inject IHttpClientFactory HttpClientFactory
@inject IAuthService AuthService
@inject IStockService StockService

<PageTitle>POS 2026</PageTitle>
<PageLoadingOverlay Visible="ViewModel.IsLoading || _isLoadingProducts"
                    Message="Caricamento…" />

<div class="pos2026-wrap">

    @* ===== BANNER AVVISO CHIUSURA GIORNALIERA MANCANTE ===== *@
    @if (_previousDayClosureMissing && _fiscalPrinterId.HasValue)
    {
        <MudAlert Severity="Severity.Error"
                  Icon="@Icons.Material.Filled.Warning"
                  Class="pos2026-closure-banner"
                  ShowCloseIcon="false"
                  Dense="false">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle2">
                        ⛔ Chiusura Giornaliera Mancante
                    </MudText>
                    <MudText Typo="Typo.body2">
                        La chiusura fiscale del giorno precedente
                        @(_lastClosureDate.HasValue
                            ? $"(ultima: {_lastClosureDate.Value.ToLocalTime():dd/MM/yyyy})"
                            : "(nessuna chiusura registrata)")
                        non è stata eseguita. Eseguire la chiusura prima di iniziare nuove vendite.
                    </MudText>
                </MudStack>
                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                           OnClick="@OpenEndOfDayWizardAsync"
                           StartIcon="@Icons.Material.Filled.EventNote">
                    Esegui Chiusura
                </MudButton>
            </MudStack>
        </MudAlert>
    }

    @* ===== BANNER AVVISO SESSIONE CASSETTO NON APERTA (Parte G.4) =====
       Mostrato solo se è configurato un cassetto fiscale (_fiscalDrawerSummary non null); se
       nessun cassetto è configurato non c'è nulla da bloccare, coerente con la gestione
       esistente del caso "nessuna stampante fiscale". *@
    @if (_fiscalDrawerSummary is not null && _fiscalDrawerSummary.HasOpenSession == false)
    {
        <MudAlert Severity="Severity.Error"
                  Icon="@Icons.Material.Filled.Warning"
                  Class="pos2026-closure-banner"
                  ShowCloseIcon="false"
                  Dense="false">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle2">
                        ⛔ Sessione Cassetto Non Aperta
                    </MudText>
                    <MudText Typo="Typo.body2">
                        Nessuna sessione del cassetto fiscale è attualmente aperta. Aprire una sessione
                        prima di avviare vendite o registrare pagamenti.
                    </MudText>
                </MudStack>
                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                           OnClick="@OpenDrawerSessionAsync"
                           StartIcon="@Icons.Material.Filled.Inbox">
                    Apri Sessione
                </MudButton>
            </MudStack>
        </MudAlert>
    }

    @if (!string.IsNullOrWhiteSpace(_shiftGuardMessage))
    {
        <MudAlert Severity="Severity.Warning"
                  Icon="@Icons.Material.Filled.AccessTime"
                  Class="mb-4">
            @_shiftGuardMessage
        </MudAlert>
    }


    @* ===========================================================================================
       STEP 0 — Nessun operatore selezionato: griglia operatori a schermo intero
       =========================================================================================== *@
    @if (!ViewModel.SelectedOperatorId.HasValue)
    {
        <div class="pos2026-step-wrap">
            <POSTouchOperatorGrid Operators="@ViewModel.AvailableOperators"
                                  SelectedOperatorId="@ViewModel.SelectedOperatorId"
                                  OnOperatorSelected="@OnOperatorCardSelectedAsync" />
        </div>
    }

    @* ===========================================================================================
       STEP 1 — Operatore selezionato, cassa non selezionata: griglia casse a schermo intero
       =========================================================================================== *@
    else if (!ViewModel.SelectedPosId.HasValue)
    {
        <div class="pos2026-step-wrap">
            <div class="d-flex flex-column align-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.PointOfSale"
                         Style="font-size: 3rem; opacity: 0.25; margin-bottom: 8px;" />
                <MudText Typo="Typo.h5" Class="mb-1">Seleziona Cassa</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Scegli il terminale da utilizzare
                </MudText>
            </div>

            <div class="d-flex justify-center mb-3">
                <MudChip T="string"
                         Icon="@Icons.Material.Filled.Person"
                         Color="Color.Primary"
                         Size="Size.Small"
                         Variant="Variant.Outlined">
                    @(ViewModel.AvailableOperators.FirstOrDefault(o => o.Id == ViewModel.SelectedOperatorId)?.Name ?? "—")
                </MudChip>
            </div>

            <MudGrid Spacing="3" Justify="Justify.Center">
                @foreach (var pos in ViewModel.AvailablePos)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="3"
                                  Class="pos-touch-pos-card ef-touch-card"
                                  @onclick="@(() => OnPosCardSelectedAsync(pos))">
                            <MudStack AlignItems="AlignItems.Center" Spacing="1" Class="pa-5">
                                <MudIcon Icon="@Icons.Material.Filled.PointOfSale"
                                         Color="Color.Primary"
                                         Style="font-size: 2.5rem;" />
                                <MudText Typo="Typo.h6" Class="fw-semibold" Align="Align.Center">
                                    @pos.Name
                                </MudText>
                                @if (!string.IsNullOrEmpty(pos.Location))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @pos.Location
                                    </MudText>
                                }
                                @* Indicatore stampante fiscale configurata *@
                                @if (pos.DefaultFiscalPrinterId.HasValue)
                                {
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="Color.Success"
                                             Variant="Variant.Outlined"
                                             Icon="@Icons.Material.Outlined.Print"
                                             title="@($"Stampante: {pos.DefaultFiscalPrinterName ?? "configurata"}")"
                                             Class="text-xs mt-1">
                                        @(pos.DefaultFiscalPrinterName ?? "Stampante")
                                    </MudChip>
                                }
                                else
                                {
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="Color.Default"
                                             Variant="Variant.Outlined"
                                             Icon="@Icons.Material.Outlined.PrintDisabled"
                                             title="Nessuna stampante fiscale configurata"
                                             Class="text-xs mt-1">
                                        Senza stampante
                                    </MudChip>
                                }
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>

            <div class="d-flex justify-center mt-4">
                <MudButton Variant="Variant.Text"
                           StartIcon="@Icons.Material.Outlined.ArrowBack"
                           OnClick="@DeselectOperator">
                    Indietro
                </MudButton>
            </div>
        </div>
    }

    @* ===========================================================================================
       STEP 2 — Operatore e cassa selezionati: interfaccia vendita completa a due colonne
       =========================================================================================== *@
    else
    {

    @* ===== CONTENUTO PRINCIPALE (due colonne) ===== *@
    <div class="pos2026-content @(_mobileTab == 1 ? "pos2026-content--tab-receipt" : "")">

    @* ===== COLONNA SINISTRA ===== *@
    <div class="pos2026-left">

        @* Status bar operatore/cassa/stampante/cassetto — sostituisce POSHeader (Task 1) *@
        <Pos26StatusBar SelectedOperatorName="@SelectedOperatorName"
                        SelectedOperatorId="@ViewModel.SelectedOperatorId"
                        AvailableOperators="@ViewModel.AvailableOperators"
                        SelectedPosName="@SelectedPosName"
                        IsUpdatingItems="@ViewModel.IsUpdatingItems"
                        LoadingTooltipText="@GetLoadingTooltipText()"
                         FiscalDrawerSummary="@_fiscalDrawerSummary"
                         OnOpenDrawerSessionClick="@OpenDrawerSessionAsync"
                         OnDepositClick="@(() => OpenDrawerTransactionDialogAsync(FiscalDrawerTransactionType.Deposit))"
                         OnWithdrawalClick="@(() => OpenDrawerTransactionDialogAsync(FiscalDrawerTransactionType.Withdrawal))"
                         HasFiscalPrinter="@_fiscalPrinterId.HasValue"
                         IsFiscalPrinterOnline="@(_fiscalPrinterStatus?.IsOnline == true)"
                         IsDailyClosureRequired="@(_fiscalPrinterStatus?.IsDailyClosureRequired == true)"
                         OnOperatorSwitch="@OnOperatorSwitchedAsync"
                         OnOpenPhysicalDrawerClick="@OpenPhysicalDrawerAsync"
                         OnDailyClosureClick="@OpenEndOfDayWizardAsync" />

        @* Riga ricerca *@
        <Pos26SearchBar @ref="_searchBar"
                        SearchTerm="@_searchTerm"
                        SearchTermChanged="@OnSearchTermChanged"
                        Customer="@ViewModel.SelectedCustomer"
                        CustomerChanged="@OnSelectedCustomerChangedAsync"
                        OnBarcodeDetected="@HandleBarcodeAsync"
                        OnCameraClick="@OpenCameraBarcodeScannerAsync"
                        FidelityCard="@_fidelityCard" />

        @* ===== TOOLBAR AZIONI — due righe fisse, tutte le azioni sempre visibili =====
           Nessun pulsante apre più un pannello inline che spinge il contenuto della pagina:
           Tavolo/Asporto, Note, Coupon e Sospese aprono ora un MudDialog dedicato (Finding 3),
           stesso pattern di "Dividi conto"/"Unisci sessioni". Le 10 azioni sono distribuite su
           due righe fisse, raggruppate per competenza (Riga 1: vendita corrente; Riga 2: conto
           & turno), con larghezza uniforme (.pos26-fn-btn-uniform, Finding 1). *@
        <div class="pos26-fn-toolbar">
            @* ----- Riga 1 — Vendita corrente ----- *@
            <div class="pos26-fn-toolbar-row">
                @* Rimuovi ultimo articolo (azione primaria di emergenza) *@
                <MudTooltip Text="Rimuovi ultimo articolo (F4)">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               Size="Size.Small"
                               Class="pos26-fn-btn-uniform"
                               StartIcon="@Icons.Material.Outlined.RemoveCircle"
                               Disabled="@(ViewModel.CurrentSession?.Items.Any() != true || ViewModel.IsUpdatingItems)"
                               OnClick="RemoveLastItemAsync">
                        Rimuovi
                    </MudButton>
                </MudTooltip>

                @* Tavolo / Asporto — apre Pos26TablePickerDialog (Finding 3); include anche il
                   toggle "Assegna e parcheggia" (Finding 1, Opzione A: assorbe il vecchio
                   pulsante icona separato "Parcheggia su tavolo"). *@
                <MudTooltip Text="Tavolo / Asporto">
                    <MudButton Variant="@(!string.IsNullOrEmpty(ViewModel.CurrentSession?.TableNumber) ? Variant.Filled : Variant.Outlined)"
                               Color="@(!string.IsNullOrEmpty(ViewModel.CurrentSession?.TableNumber) ? Color.Primary : Color.Default)"
                               Size="Size.Small"
                               Class="pos26-fn-btn-uniform"
                               StartIcon="@Icons.Material.Outlined.TableBar"
                               OnClick="OpenTablePickerDialogAsync">
                        @if (!string.IsNullOrEmpty(ViewModel.CurrentSession?.TableNumber))
                        { @($"Tavolo {ViewModel.CurrentSession.TableNumber}") }
                        else if (ViewModel.CurrentSession?.SaleType == SaleTypes.Takeaway)
                        { @("Asporto") }
                        else
                        { @("Tavolo") }
                    </MudButton>
                </MudTooltip>

                @* Pulsante Note ordine — apre SessionNoteDialog (Finding 3) *@
                <MudTooltip Text="Note ordine">
                    <MudBadge Content="@(ViewModel.CurrentSession?.Notes.Count ?? 0)"
                              Color="Color.Primary"
                              Overlap="true"
                              Visible="@(ViewModel.CurrentSession?.Notes.Any() == true)">
                        <MudButton Variant="@(ViewModel.CurrentSession?.Notes.Any() == true ? Variant.Filled : Variant.Outlined)"
                                   Color="@(ViewModel.CurrentSession?.Notes.Any() == true ? Color.Primary : Color.Default)"
                                   Size="Size.Small"
                                   Class="pos26-fn-btn-uniform"
                                   StartIcon="@Icons.Material.Outlined.Note"
                                   OnClick="OpenNoteDialogAsync">
                            Note
                        </MudButton>
                    </MudBadge>
                </MudTooltip>

                @* Pulsante Coupon — apre CouponInputDialog (Finding 3) *@
                <MudTooltip Text="Coupon">
                    <MudBadge Content="@(ViewModel.ActiveCouponCodes?.Count ?? 0)"
                              Color="Color.Primary"
                              Overlap="true"
                              Visible="@(ViewModel.ActiveCouponCodes?.Any() == true)">
                        <MudButton Variant="@(ViewModel.ActiveCouponCodes?.Any() == true ? Variant.Filled : Variant.Outlined)"
                                   Color="@(ViewModel.ActiveCouponCodes?.Any() == true ? Color.Primary : Color.Default)"
                                   Size="Size.Small"
                                   Class="pos26-fn-btn-uniform"
                                   StartIcon="@Icons.Material.Outlined.LocalOffer"
                                   OnClick="OpenCouponDialogAsync">
                            Coupon
                        </MudButton>
                    </MudBadge>
                </MudTooltip>
            </div>

            @* ----- Riga 2 — Conto & Turno ----- *@
            <div class="pos26-fn-toolbar-row">
                @* Parcheggia conto (azione primaria: unico modo per attivarla su terminale touch,
                   prima raggiungibile solo tramite la scorciatoia da tastiera F3) *@
                <MudTooltip Text="Parcheggia conto (F3)">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Warning"
                               Size="Size.Small"
                               Class="pos26-fn-btn-uniform"
                               StartIcon="@Icons.Material.Outlined.PauseCircleOutline"
                               Disabled="@(!ViewModel.HasActiveSession)"
                               OnClick="ParkSessionAsync">
                        Parcheggia
                    </MudButton>
                </MudTooltip>

                @* Sessioni parcheggiate — apre Pos26ParkedSessionsDialog (Finding 3) *@
                <MudTooltip Text="Sessioni sospese">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               Size="Size.Small"
                               Class="pos26-fn-btn-uniform"
                               StartIcon="@Icons.Material.Outlined.History"
                               OnClick="OpenParkedSessionsDialogAsync">
                        Sospese
                    </MudButton>
                </MudTooltip>

                @* Dividi conto *@
                @if (_canSplit)
                {
                    <MudTooltip Text="Dividi conto">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   Class="pos26-fn-btn-uniform"
                                   StartIcon="@Icons.Material.Outlined.CallSplit"
                                   OnClick="OpenSplitFromMenu">
                            Dividi
                        </MudButton>
                    </MudTooltip>
                }

                @* Unisci sessioni *@
                @if (_openSessions.Count >= 2)
                {
                    <MudTooltip Text="Unisci sessioni">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   Class="pos26-fn-btn-uniform"
                                   StartIcon="@Icons.Material.Outlined.MergeType"
                                   OnClick="OpenMergeFromMenu">
                            Unisci
                        </MudButton>
                    </MudTooltip>
                }

                @* Giornata (ex "Flusso Giornaliero") *@
                <MudTooltip Text="Giornata">
                    <MudButton Variant="@(_isDailyFlowOpen ? Variant.Filled : Variant.Outlined)"
                               Color="@(_isDailyFlowOpen ? Color.Primary : Color.Default)"
                               Size="Size.Small"
                               Class="pos26-fn-btn-uniform"
                               StartIcon="@Icons.Material.Outlined.EventNote"
                               aria-pressed="@(_isDailyFlowOpen.ToString().ToLowerInvariant())"
                               OnClick="ToggleDailyFlowAsync">
                        Giornata
                    </MudButton>
                </MudTooltip>
            </div>
        </div>

        @* FilterBar: chip categoria + ordinamento — riposizionata adiacente all'area
           prodotti (fuori da .pos2026-product-area, che ha overflow-y: auto, per restare
           fissa durante lo scroll verticale della griglia/best-seller). *@
        <Pos26FilterBar SortMode="@_sortMode"
                        OnSortChanged="@OnSortModeChangedAsync"
                        HasCustomer="@(ViewModel.SelectedCustomer != null)"
                        Customer="@ViewModel.SelectedCustomer"
                        Categories="@_categories"
                        SelectedCategory="@_selectedCategory"
                        OnCategorySelected="@OnCategorySelectedAsync" />

        <Pos26DailyFlowPanel IsOpen="@_isDailyFlowOpen"
                             IsOpenChanged="OnDailyFlowOpenChangedAsync"
                             DailyFlow="@_dailyFlow"
                             IsBusy="@_isDailyFlowLoading"
                             CurrentSaleSessionId="@ViewModel.CurrentSession?.Id"
                             SelectedOperatorId="@ViewModel.SelectedOperatorId"
                             SelectedPosId="@ViewModel.SelectedPosId"
                             OnRefreshRequested="LoadDailyFlowAsync"
                             OnSessionOpened="HandleDailyFlowSessionOpenedAsync" />

        @* ===== AREA PRODOTTI ===== *@
        <div class="pos2026-product-area">

            @* ===== AZIONE 6: Riga best sellers rapida (orizzontale, scrollabile) ===== *@
            @if (_topBestSellers.Count > 0 && string.IsNullOrWhiteSpace(_searchTerm))
            {
                <div class="pos26-bestseller-row-wrap">
                    <div class="pos26-bestseller-row-label">
                        <MudIcon Icon="@Icons.Material.Outlined.TrendingUp" Size="Size.Small" Class="mr-1" />
                        Top venduti
                    </div>
                    <div class="pos26-bestseller-row">
                        @foreach (var product in _topBestSellers)
                        {
                            <Pos26ProductCard @key="@($"bs-{product.Id}")"
                                              Product="@product"
                                              CartQuantity="@(_cartQuantities.TryGetValue(product.Id, out var q) ? q : 0)"
                                              IsLastPurchase="@_lastPurchaseIds.Contains(product.Id)"
                                              IsBestSeller="true"
                                              StockAvailable="@(_stockByProductId.TryGetValue(product.Id, out var sq) ? sq : (decimal?)null)"
                                              OnAddToCart="@OnAddProductToCartAsync"
                                              OnLongPress="@OpenProductDetailAsync" />
                        }
                    </div>
                </div>
            }

            @* Griglia articoli *@
            <Pos26ProductGrid Products="@_filteredProducts"
                              CartQuantities="@_cartQuantities"
                              LastPurchaseIds="@_lastPurchaseIds"
                              BestSellerIds="@_bestSellerIds"
                              StockAvailability="@_stockByProductId"
                              OnAddToCart="@OnAddProductToCartAsync"
                              OnLongPress="@OpenProductDetailAsync"
                              IsLoading="@_isLoadingProducts" />
        </div>

    </div>

    @* ===== COLONNA DESTRA ===== *@
    <div class="pos2026-right">

        <Pos26Receipt Session="@ViewModel.CurrentSession"
                      Customer="@ViewModel.SelectedCustomer"
                      FidelityCard="@_fidelityCard"
                      Items="@ViewModel.CurrentSession?.Items"
                      Subtotal="@(ViewModel.CurrentSession?.OriginalTotal ?? 0m)"
                      TotalDiscount="@(ViewModel.CurrentSession?.DiscountAmount ?? 0m)"
                      TotalVat="@(ViewModel.CurrentSession?.TaxAmount ?? 0m)"
                      GrandTotal="@ViewModel.GrandTotal"
                      OnClearCart="@ClearCartAsync"
                      OnIncrease="@IncreaseQuantity"
                      OnDecrease="@DecreaseQuantity"
                      OnEditItemNotes="@EditItemNotesAsync"
                      OnEditItem="@EditLineItemAsync">
            <ExtraContent>
                @* Zona sconto dedicata (Task 6) — interposta tra righe e totali dentro Pos26Receipt
                   tramite RenderFragment ExtraContent (approccio a minor refactoring rispetto
                   a estrarre i totali fuori dal componente). *@
                <Pos26DiscountZone OnApplyDiscount="@ApplyDiscountAsync"
                                   OnApplyFixedDiscount="@ApplyFixedDiscountAsync"
                                   OnRemoveDiscount="@RemoveDiscountAsync"
                                   CurrentDiscountPercent="@CurrentDiscountPercent"
                                   CurrentDiscountAmount="@(ViewModel.CurrentSession?.DiscountAmount ?? 0m)" />
            </ExtraContent>
        </Pos26Receipt>

        <Pos26Numpad CanPay="@ViewModel.CanPay"
                     OnPay="@OpenPaymentDialogAsync"
                     OnCancel="@CancelSessionAsync"
                     HasFiscalPrinter="@_fiscalPrinterId.HasValue"
                     OnPrintReceipt="@PrintBrowserReceiptAsync" />

    </div>

    </div>@* fine pos2026-content *@

    }@* fine else (Step 2) *@

</div>

@* Shortcut tastiera (stesso pattern POS.razor) *@
@if (ViewModel.HasActiveSession)
{
    @* Tab bar mobile: visibile solo su schermi <600px, sopra la shortcut bar *@
    <div class="pos2026-mobile-tabbar" aria-label="Navigazione sezioni">
        <button class="pos2026-mobile-tab @(_mobileTab == 0 ? "pos2026-mobile-tab--active" : "")"
                @onclick="@(() => _mobileTab = 0)">
            <MudIcon Icon="@Icons.Material.Outlined.GridView" Size="Size.Small" />
            Prodotti
        </button>
        <button class="pos2026-mobile-tab @(_mobileTab == 1 ? "pos2026-mobile-tab--active" : "")"
                @onclick="@(() => _mobileTab = 1)">
            <MudIcon Icon="@Icons.Material.Outlined.Receipt" Size="Size.Small" />
            Scontrino
        </button>
    </div>
    <div class="pos2026-shortcuts-bar" aria-label="Scorciatoie tastiera">
        <span><strong>F2</strong> Paga</span>
        <span><strong>F3</strong> Parcheggia</span>
        <span><strong>F4</strong> Rimuovi ultimo</span>
        <span><strong>F8</strong> Scanner</span>
        <span><strong>F12</strong> Chiudi</span>
        <span><strong>ESC</strong> Annulla</span>
    </div>
}
