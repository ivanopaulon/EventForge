@namespace Prym.Web.Pages.FiscalAdmin
@page "/admin/fiscal-closures"
@using Prym.DTOs.FiscalPrinting
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,StoreManager")]
@inject IFiscalPrintingService FiscalPrintingService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ILogger<AllClosuresHistory> Logger

<PageTitle>Storico Chiusure Giornaliere</PageTitle>

<PageLoadingOverlay Visible="@_isLoading" Message="Caricamento storico chiusure…" />

@if (!_isLoading)
{
<div class="ef-flex-col-fill">
    <ManagementPageHeader Title="Storico Chiusure Giornaliere"
                          Icon="@Icons.Material.Outlined.EventNote"
                          BreadcrumbItems="_breadcrumbs" />

@* ──────────────────── FILTRI ──────────────────── *@
<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid Spacing="2">
        <MudItem xs="12" md="3">
            <MudDatePicker @bind-Date="_filterFromDate"
                           Label="Data da"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           DateFormat="dd/MM/yyyy"
                           Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudDatePicker @bind-Date="_filterToDate"
                           Label="Data a"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           DateFormat="dd/MM/yyyy"
                           Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="ClosureType?" @bind-Value="_filterClosureType"
                       Label="Tipo chiusura"
                       Variant="Variant.Outlined"
                       Clearable="true"
                       Margin="Margin.Dense">
                <MudSelectItem T="ClosureType?" Value="@((ClosureType?)null)">Tutti</MudSelectItem>
                <MudSelectItem T="ClosureType?" Value="@((ClosureType?)ClosureType.Fiscale)">Fiscale</MudSelectItem>
                <MudSelectItem T="ClosureType?" Value="@((ClosureType?)ClosureType.NonFiscale)">Non Fiscale</MudSelectItem>
                <MudSelectItem T="ClosureType?" Value="@((ClosureType?)ClosureType.SoloDatabase)">Solo Database</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="bool?" @bind-Value="_filterPending"
                       Label="Stato pendente"
                       Variant="Variant.Outlined"
                       Clearable="true"
                       Margin="Margin.Dense">
                <MudSelectItem T="bool?" Value="@((bool?)null)">Tutti</MudSelectItem>
                <MudSelectItem T="bool?" Value="@((bool?)true)">Solo pendenti</MudSelectItem>
                <MudSelectItem T="bool?" Value="@((bool?)false)">Solo completate</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12">
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Search"
                           OnClick="ApplyFilters">
                    Cerca
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Clear"
                           OnClick="ClearFilters">
                    Pulisci
                </MudButton>
                <MudSpacer />
                <MudTooltip Text="Esporta CSV">
                    <MudIconButton Icon="@Icons.Material.Filled.Download"
                                   OnClick="ExportCsvAsync"
                                   Disabled="@(_closures.Count == 0)" />
                </MudTooltip>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudPaper>

@* ──────────────────── TABELLA ──────────────────── *@
<MudPaper Elevation="1">
    <MudTable T="DailyClosureHistoryDto"
              Items="@_closuresFiltered"
              Dense="true"
              Hover="true"
              Striped="true"
              Loading="@_isLoading"
              LoadingProgressColor="Color.Primary">
        <ToolBarContent>
            <MudText Typo="Typo.subtitle1">
                Chiusure (@_closuresFiltered.Count di @_closures.Count totali)
            </MudText>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel T="DailyClosureHistoryDto" SortBy="c => c.ClosedAt" InitialDirection="SortDirection.Descending">Data/Ora</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="DailyClosureHistoryDto" SortBy="c => c.PrinterName">Stampante / POS</MudTableSortLabel></MudTh>
            <MudTh>Tipo</MudTh>
            <MudTh><MudTableSortLabel T="DailyClosureHistoryDto" SortBy="c => c.ZReportNumber">N° Z-Report</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="DailyClosureHistoryDto" SortBy="c => c.ReceiptCount">Scontrini</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="DailyClosureHistoryDto" SortBy="c => c.TotalAmount">Totale</MudTableSortLabel></MudTh>
            <MudTh>Operatore</MudTh>
            <MudTh>Azioni</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Data/Ora">@context.ClosedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
            <MudTd DataLabel="Stampante / POS">@(context.PrinterName ?? "—")</MudTd>
            <MudTd DataLabel="Tipo">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                         Color="@ClosureTypeColor(context.ClosureType)"
                         Icon="@ClosureTypeIcon(context.ClosureType)">
                    @ClosureTypeLabel(context.ClosureType)
                </MudChip>
            </MudTd>
            <MudTd DataLabel="N° Z-Report">
                @if (context.ZReportNumber > 0)
                {
                    <b>#@context.ZReportNumber</b>
                }
                else
                {
                    <span>—</span>
                }
                @if (context.FiscalClosurePending)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Warning"
                             Variant="Variant.Filled" Class="ml-1" Style="height:20px">Pendente</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Scontrini">@context.ReceiptCount</MudTd>
            <MudTd DataLabel="Totale">@context.TotalAmount.ToString("C2")</MudTd>
            <MudTd DataLabel="Operatore">@(context.Operator ?? "—")</MudTd>
            <MudTd>
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true">
                    <MudMenuItem Icon="@Icons.Material.Filled.PictureAsPdf"
                                 Disabled="@(!context.HasPdf)"
                                 OnClick="@(() => DownloadPdfAsync(context.Id))">
                        Scarica PDF
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Print"
                                 Disabled="@(context.PrinterId == Guid.Empty)"
                                 OnClick="@(() => ReprintAsync(context.Id, context.ZReportNumber))">
                        Ristampa Z-Report
                    </MudMenuItem>
                    @if (context.PrinterId != Guid.Empty)
                    {
                        <MudMenuItem Icon="@Icons.Material.Filled.History"
                                     OnClick="@(() => NavigationManager.NavigateTo($"/admin/fiscal-printers/{context.PrinterId}/closures"))">
                            Vai allo Storico Stampante
                        </MudMenuItem>
                    }
                    @if (context.FiscalClosurePending)
                    {
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Filled.Refresh"
                                     OnClick="@(() => RetryFiscalClosureAsync(context.Id))">
                            Riprova Chiusura Fiscale
                        </MudMenuItem>
                    }
                </MudMenu>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 20, 50, 100 }" />
        </PagerContent>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Outlined.EventNote" Size="Size.Large" Color="Color.Default" />
                <MudText Typo="Typo.body1">Nessuna chiusura trovata</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Modifica i filtri o esegui la prima chiusura giornaliera</MudText>
            </MudStack>
        </NoRecordsContent>
    </MudTable>
</MudPaper>
</div>
}

@code {
    // ─────────────────────────────────────────────────────────
    //  State
    // ─────────────────────────────────────────────────────────

    private bool _isLoading = true;
    private List<DailyClosureHistoryDto> _closures = new();
    private List<DailyClosureHistoryDto> _closuresFiltered = new();

    // Filters
    private DateTime? _filterFromDate;
    private DateTime? _filterToDate;
    private ClosureType? _filterClosureType;
    private bool? _filterPending;

    private List<BreadcrumbItem> _breadcrumbs =
    [
        new BreadcrumbItem("Home", href: "/"),
        new BreadcrumbItem("Storico Chiusure", href: null, disabled: true)
    ];

    // ─────────────────────────────────────────────────────────
    //  Lifecycle
    // ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadHistoryAsync();
    }

    // ─────────────────────────────────────────────────────────
    //  Data loading
    // ─────────────────────────────────────────────────────────

    private async Task LoadHistoryAsync()
    {
        _isLoading = true;
        try
        {
            _closures = await FiscalPrintingService.GetAllClosureHistoryAsync(
                page: 1, pageSize: 200) ?? new();
            ApplyLocalFilters();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "LoadHistoryAsync failed for all closures");
            AppNotification.ShowError("Errore nel caricamento dello storico.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ─────────────────────────────────────────────────────────
    //  Filters
    // ─────────────────────────────────────────────────────────

    private void ApplyLocalFilters()
    {
        IEnumerable<DailyClosureHistoryDto> query = _closures;

        if (_filterFromDate.HasValue)
            query = query.Where(c => c.ClosedAt >= _filterFromDate.Value);

        if (_filterToDate.HasValue)
            query = query.Where(c => c.ClosedAt <= _filterToDate.Value.AddDays(1));

        if (_filterClosureType.HasValue)
            query = query.Where(c => c.ClosureType == _filterClosureType.Value);

        if (_filterPending.HasValue)
            query = query.Where(c => c.FiscalClosurePending == _filterPending.Value);

        _closuresFiltered = query.ToList();
    }

    private void ApplyFilters() => ApplyLocalFilters();

    private void ClearFilters()
    {
        _filterFromDate = null;
        _filterToDate = null;
        _filterClosureType = null;
        _filterPending = null;
        ApplyLocalFilters();
    }

    // ─────────────────────────────────────────────────────────
    //  Actions
    // ─────────────────────────────────────────────────────────

    private async Task DownloadPdfAsync(Guid closureId)
    {
        AppNotification.ShowInfo("PDF in generazione…");
        try
        {
            var pdfBytes = await FiscalPrintingService.DownloadClosurePdfAsync(closureId);
            if (pdfBytes is null || pdfBytes.Length == 0)
            {
                AppNotification.ShowError("PDF non disponibile per questa chiusura.");
                return;
            }
            var fileName = $"ZReport_{closureId:N}.pdf";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, pdfBytes, "application/pdf");
            AppNotification.ShowSuccess("PDF scaricato.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "DownloadPdfAsync failed for closure {ClosureId}.", closureId);
            AppNotification.ShowError($"Errore download PDF: {ex.Message}");
        }
    }

    private async Task ReprintAsync(Guid closureId, int zNumber)
    {
        try
        {
            var result = await FiscalPrintingService.ReprintZReportAsync(closureId);
            if (result?.Success == true)
                AppNotification.ShowSuccess($"Z-Report #{zNumber} ristampato.");
            else
                AppNotification.ShowError($"Ristampa fallita: {result?.ErrorMessage ?? "errore"}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore durante la ristampa del Z-Report #{ZNumber} per la chiusura {ClosureId}.", zNumber, closureId);
            AppNotification.ShowWarning("Si è verificato un errore.");
        }
    }

    private async Task RetryFiscalClosureAsync(Guid closureId)
    {
        try
        {
            AppNotification.ShowInfo("Tentativo di chiusura fiscale hardware in corso…");
            var result = await FiscalPrintingService.RetryFiscalClosureAsync(closureId);
            if (result?.Success == true)
            {
                AppNotification.ShowSuccess("Chiusura fiscale hardware completata.");
                await LoadHistoryAsync();
            }
            else
            {
                AppNotification.ShowError($"Chiusura fiscale fallita: {result?.ErrorMessage ?? "errore"}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore durante il retry della chiusura fiscale {ClosureId}.", closureId);
            AppNotification.ShowWarning("Si è verificato un errore.");
        }
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var sb = new System.Text.StringBuilder();
            sb.AppendLine("Data/Ora,Stampante/POS,Tipo,N° Z-Report,Scontrini,Totale,Contanti,Carte,Operatore,Pendente");
            foreach (var c in _closuresFiltered)
            {
                sb.AppendLine(string.Join(",",
                    c.ClosedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm"),
                    $"\"{c.PrinterName ?? ""}\"",
                    c.ClosureType,
                    c.ZReportNumber,
                    c.ReceiptCount,
                    c.TotalAmount.ToString("F2"),
                    c.CashAmount.ToString("F2"),
                    c.CardAmount.ToString("F2"),
                    $"\"{c.Operator ?? ""}\"",
                    c.FiscalClosurePending ? "Sì" : "No"));
            }

            var csvBytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
            var fileName = $"Chiusure_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, csvBytes, "text/csv;charset=utf-8");
            AppNotification.ShowSuccess($"CSV esportato: {fileName}");
        }
        catch (Exception ex)
        {
            AppNotification.ShowError($"Errore export CSV: {ex.Message}");
        }
    }

    // ─────────────────────────────────────────────────────────
    //  Chip helpers
    // ─────────────────────────────────────────────────────────

    private static Color ClosureTypeColor(ClosureType ct) => ct switch
    {
        ClosureType.Fiscale      => Color.Success,
        ClosureType.NonFiscale   => Color.Info,
        ClosureType.SoloDatabase => Color.Warning,
        _                        => Color.Default
    };

    private static string ClosureTypeIcon(ClosureType ct) => ct switch
    {
        ClosureType.Fiscale      => Icons.Material.Filled.ReceiptLong,
        ClosureType.NonFiscale   => Icons.Material.Filled.EventNote,
        ClosureType.SoloDatabase => Icons.Material.Filled.Storage,
        _                        => Icons.Material.Filled.Help
    };

    private static string ClosureTypeLabel(ClosureType ct) => ct switch
    {
        ClosureType.Fiscale      => "Fiscale",
        ClosureType.NonFiscale   => "Non Fiscale",
        ClosureType.SoloDatabase => "Solo Database",
        _                        => ct.ToString()
    };
}
