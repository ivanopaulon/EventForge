@namespace Prym.Web.Pages.FiscalAdmin
@page "/admin/fiscal-printers/{PrinterId:guid}/closures"
@using Prym.DTOs.FiscalPrinting
@using Prym.Web.Shared.Management
@using Prym.Web.Shared.Management.Adapters
@using Microsoft.AspNetCore.SignalR.Client
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager")]
@inject IFiscalPrintingService FiscalPrintingService
@inject IHttpClientService HttpClientService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ILogger<ClosureHistory> Logger
@implements IAsyncDisposable

<PageTitle>Storico Chiusure Fiscali</PageTitle>

@* ──────────────────── FILTER PANEL ──────────────────── *@
<MudPaper Class="pa-4 mb-0" Elevation="1">
    <MudGrid Spacing="2">
        <MudItem xs="12" md="4">
            <MudDatePicker @bind-Date="_filterFromDate"
                           Label="Data da"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           DateFormat="dd/MM/yyyy"
                           Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudDatePicker @bind-Date="_filterToDate"
                           Label="Data a"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           DateFormat="dd/MM/yyyy"
                           Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_filterZReport"
                          Label="N° Z-Report"
                          Variant="Variant.Outlined"
                          Clearable="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12">
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Search"
                           OnClick="ApplyFiltersAsync">
                    Cerca
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Clear"
                           OnClick="ClearFiltersAsync">
                    Pulisci
                </MudButton>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudPaper>

<EntityManagementPage TEntity="DailyClosureHistoryDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      ExternalFilters="_externalFilters">
    <PageHeader>
        <ManagementPageHeader Title="@(_printerName is not null ? $"Storico Chiusure – {_printerName}" : "Storico Chiusure")"
                              Icon="@Icons.Material.Outlined.EventNote"
                              BreadcrumbItems="_breadcrumbs">
            <ExtraActions>
                <MudButton Variant="Variant.Filled" Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.EventNote"
                           Size="Size.Small"
                           OnClick="OpenDailyClosureDialogAsync">
                    Nuova Chiusura
                </MudButton>
            </ExtraActions>
        </ManagementPageHeader>
    </PageHeader>

    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "ClosedAt")
            {
                <EFTableColumnHeader TItem="DailyClosureHistoryDto" PropertyName="ClosedAt">
                    <MudTableSortLabel SortBy="@(new Func<DailyClosureHistoryDto, object>(x => x.ClosedAt))">Data/Ora</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ZReportNumber")
            {
                <EFTableColumnHeader TItem="DailyClosureHistoryDto" PropertyName="ZReportNumber">
                    <MudTableSortLabel SortBy="@(new Func<DailyClosureHistoryDto, object>(x => x.ZReportNumber))">N° Z-Report</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ClosureType")
            {
                <EFTableColumnHeader TItem="DailyClosureHistoryDto" PropertyName="ClosureType">Tipo</EFTableColumnHeader>
            }
            else if (column.PropertyName == "ReceiptCount")
            {
                <EFTableColumnHeader TItem="DailyClosureHistoryDto" PropertyName="ReceiptCount">
                    <MudTableSortLabel SortBy="@(new Func<DailyClosureHistoryDto, object>(x => x.ReceiptCount))">Scontrini</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "TotalAmount")
            {
                <EFTableColumnHeader TItem="DailyClosureHistoryDto" PropertyName="TotalAmount">
                    <MudTableSortLabel SortBy="@(new Func<DailyClosureHistoryDto, object>(x => x.TotalAmount))">Totale</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Operator")
            {
                <EFTableColumnHeader TItem="DailyClosureHistoryDto" PropertyName="Operator">
                    <MudTableSortLabel SortBy="@(new Func<DailyClosureHistoryDto, object>(x => x.Operator ?? string.Empty))">Operatore</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center ef-min-120">Azioni</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "ClosedAt")
            {
                <MudTd DataLabel="Data/Ora">@ctx.Item.ClosedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
            }
            else if (column.PropertyName == "ZReportNumber")
            {
                <MudTd DataLabel="N° Z-Report">
                    @if (ctx.Item.ZReportNumber > 0)
                    {
                        <b>#@ctx.Item.ZReportNumber</b>
                    }
                    else
                    {
                        <span>—</span>
                    }
                    @if (ctx.Item.FiscalClosurePending)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                 Icon="@Icons.Material.Filled.Warning"
                                 Variant="Variant.Filled" Class="ml-1" Style="height:20px">Pendente</MudChip>
                    }
                </MudTd>
            }
            else if (column.PropertyName == "ClosureType")
            {
                <MudTd DataLabel="Tipo">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Color="@ClosureTypeColor(ctx.Item.ClosureType)"
                             Icon="@ClosureTypeIcon(ctx.Item.ClosureType)">
                        @ClosureTypeLabel(ctx.Item.ClosureType)
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "ReceiptCount")
            {
                <MudTd DataLabel="Scontrini">@ctx.Item.ReceiptCount</MudTd>
            }
            else if (column.PropertyName == "TotalAmount")
            {
                <MudTd DataLabel="Totale">@ctx.Item.TotalAmount.ToString("C2")</MudTd>
            }
            else if (column.PropertyName == "Operator")
            {
                <MudTd DataLabel="Operatore">@(ctx.Item.Operator ?? "—")</MudTd>
            }
        }
        <MudTd Class="text-center">
            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true">
                <MudMenuItem Icon="@Icons.Material.Filled.PictureAsPdf"
                             Disabled="@(!ctx.Item.HasPdf)"
                             OnClick="@(() => DownloadPdfAsync(ctx.Item.Id))">
                    Scarica PDF
                </MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Print"
                             OnClick="@(() => ReprintAsync(ctx.Item.Id, ctx.Item.ZReportNumber))">
                    Ristampa Z-Report
                </MudMenuItem>
                @if (ctx.Item.FiscalClosurePending)
                {
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Refresh"
                                 OnClick="@(() => RetryFiscalClosureAsync(ctx.Item.Id, ctx.Item.ZReportNumber))">
                        Riprova Chiusura Fiscale
                    </MudMenuItem>
                }
            </MudMenu>
        </MudTd>
    </RowTemplate>
</EntityManagementPage>

@code {
    [Parameter] public Guid PrinterId { get; set; }

    private EntityManagementPage<DailyClosureHistoryDto>? _entityPage;
    private IEntityManagementService<DailyClosureHistoryDto> _service = null!;

    private string? _printerName;
    private HubConnection? _hubConnection;

    private DateTime? _filterFromDate;
    private DateTime? _filterToDate;
    private string _filterZReport = string.Empty;

    private Dictionary<string, object?> _externalFilters = new();
    private List<BreadcrumbItem> _breadcrumbs = [];

    private readonly EntityManagementConfig<DailyClosureHistoryDto> _config = new()
    {
        ComponentKey     = "ClosureHistory",
        PageTitleKey     = "closures.printerHistory.title",
        PageTitleDefault = "Storico Chiusure",
        EntityIcon       = Icons.Material.Outlined.EventNote,
        PageRootCssClass = "management-page-root ef-flex-col-fill",
        BaseRoute        = "/admin/fiscal-closures",
        EntityTypeName   = "Chiusura",
        GetId            = c => c.Id,
        GetDisplayName   = c => $"Z-Report #{c.ZReportNumber} — {c.ClosedAt.ToLocalTime():dd/MM/yyyy}",
        ShowCreate       = false,
        ShowEdit         = false,
        ShowDelete       = false,
        ShowAuditLog     = false,
        ShowExport       = true,
        ExcelFileName    = "StoricoChiusureStampante",
        Columns =
        [
            new EFTableColumnConfiguration { PropertyName = "ClosedAt",      DisplayName = "Data/Ora",    IsVisible = true, Order = 0 },
            new EFTableColumnConfiguration { PropertyName = "ZReportNumber", DisplayName = "N° Z-Report", IsVisible = true, Order = 1 },
            new EFTableColumnConfiguration { PropertyName = "ClosureType",   DisplayName = "Tipo",        IsVisible = true, Order = 2 },
            new EFTableColumnConfiguration { PropertyName = "ReceiptCount",  DisplayName = "Scontrini",   IsVisible = true, Order = 3 },
            new EFTableColumnConfiguration { PropertyName = "TotalAmount",   DisplayName = "Totale",      IsVisible = true, Order = 4 },
            new EFTableColumnConfiguration { PropertyName = "Operator",      DisplayName = "Operatore",   IsVisible = true, Order = 5 },
        ],
        QuickFilters =
        [
            new QuickFilter<DailyClosureHistoryDto> { Id = "all",     Label = "Tutte",    Predicate = _ => true },
            new QuickFilter<DailyClosureHistoryDto> { Id = "pending", Label = "Pendenti", Predicate = c => c.FiscalClosurePending },
            new QuickFilter<DailyClosureHistoryDto> { Id = "fiscal",  Label = "Fiscali",  Predicate = c => c.ClosureType == ClosureType.Fiscale },
        ]
    };

    protected override async Task OnInitializedAsync()
    {
        _service = new ClosureHistoryManagementService(FiscalPrintingService);

        // Load printer name for header/breadcrumbs
        try
        {
            var printer = await HttpClientService.GetAsync<Prym.DTOs.Station.PrinterDto>(
                $"api/v1/stations/printers/{PrinterId}");
            _printerName = printer?.Name;
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Could not load printer name for {PrinterId}.", PrinterId); }

        _breadcrumbs =
        [
            new BreadcrumbItem("Home", href: "/"),
            new BreadcrumbItem("Stampanti Fiscali", href: "/admin/fiscal-printers"),
            new BreadcrumbItem(_printerName ?? PrinterId.ToString("N")[..8], href: null, disabled: true),
            new BreadcrumbItem("Storico Chiusure", href: null, disabled: true)
        ];

        _externalFilters = new Dictionary<string, object?> { ["PrinterId"] = PrinterId };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _hubConnection is not null) return;
        await ConnectToHubAsync();
    }

    // ─────────────────────────────────────────────────────────
    //  Filters
    // ─────────────────────────────────────────────────────────

    private async Task ApplyFiltersAsync()
    {
        _externalFilters = new Dictionary<string, object?> { ["PrinterId"] = PrinterId };
        if (_filterFromDate.HasValue) _externalFilters["From"] = _filterFromDate.Value;
        if (_filterToDate.HasValue)   _externalFilters["To"]   = _filterToDate.Value;
        if (!string.IsNullOrWhiteSpace(_filterZReport) && int.TryParse(_filterZReport, out var z))
            _externalFilters["ZReport"] = z;

        if (_entityPage is not null) await _entityPage.RefreshAsync();
    }

    private async Task ClearFiltersAsync()
    {
        _filterFromDate  = null;
        _filterToDate    = null;
        _filterZReport   = string.Empty;
        _externalFilters = new Dictionary<string, object?> { ["PrinterId"] = PrinterId };
        if (_entityPage is not null) await _entityPage.RefreshAsync();
    }

    // ─────────────────────────────────────────────────────────
    //  SignalR
    // ─────────────────────────────────────────────────────────

    private async Task ConnectToHubAsync()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl("/hubs/fiscal-printer")
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<Guid, string>("ClosureRequired", async (printerId, _) =>
            {
                if (printerId != PrinterId) return;
                await InvokeAsync(async () =>
                {
                    if (_entityPage is not null) await _entityPage.RefreshAsync();
                    StateHasChanged();
                });
            });

            _hubConnection.Reconnected += async _ =>
            {
                try { await _hubConnection.SendAsync("SubscribeToPrinter", PrinterId); }
                catch (Exception ex) { Logger.LogWarning(ex, "ClosureHistory: failed to re-subscribe to printer {PrinterId} after reconnect", PrinterId); }
            };

            await _hubConnection.StartAsync();
            await _hubConnection.SendAsync("SubscribeToPrinter", PrinterId);
            Logger.LogDebug("ClosureHistory: subscribed to printer {PrinterId}", PrinterId);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "ClosureHistory: could not connect to SignalR hub for printer {PrinterId}", PrinterId);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            try
            {
                await _hubConnection.SendAsync("UnsubscribeFromPrinter", PrinterId);
                await _hubConnection.DisposeAsync();
            }
            catch { /* intentionally swallowed during disposal */ }
            _hubConnection = null;
        }
    }

    // ─────────────────────────────────────────────────────────
    //  Row actions
    // ─────────────────────────────────────────────────────────

    private async Task OpenDailyClosureDialogAsync()
    {
        try
        {
            var parameters = new DialogParameters
            {
                [nameof(DailyClosureDialog.PrinterId)]   = PrinterId,
                [nameof(DailyClosureDialog.PrinterName)] = _printerName
            };

            var dialog = await DialogService.ShowAsync<DailyClosureDialog>(
                string.Empty, parameters, EFDialogDefaults.Options);

            var result = await dialog.Result;
            if (result?.Canceled == false && _entityPage is not null)
                await _entityPage.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore durante l'apertura del dialogo di chiusura giornaliera.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task DownloadPdfAsync(Guid closureId)
    {
        AppNotification.ShowInfo("PDF in generazione…");
        try
        {
            var pdfBytes = await FiscalPrintingService.DownloadClosurePdfAsync(closureId);
            if (pdfBytes is null || pdfBytes.Length == 0)
            {
                AppNotification.ShowError("PDF non disponibile per questa chiusura.");
                return;
            }
            var fileName = $"ZReport_{closureId:N}.pdf";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, pdfBytes, "application/pdf");
            AppNotification.ShowSuccess("PDF scaricato.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "DownloadPdfAsync failed for closure {ClosureId}.", closureId);
            AppNotification.ShowError($"Errore download PDF: {ex.Message}");
        }
    }

    private async Task ReprintAsync(Guid closureId, int zNumber)
    {
        try
        {
            var result = await FiscalPrintingService.ReprintZReportAsync(closureId);
            if (result?.Success == true)
                AppNotification.ShowSuccess($"Z-Report #{zNumber} ristampato.");
            else
                AppNotification.ShowError($"Ristampa fallita: {result?.ErrorMessage ?? "errore"}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore ristampa Z-Report #{ZNumber} per chiusura {ClosureId}.", zNumber, closureId);
            AppNotification.ShowWarning("Si è verificato un errore.");
        }
    }

    private async Task RetryFiscalClosureAsync(Guid closureId, int zNumber)
    {
        try
        {
            AppNotification.ShowInfo("Tentativo di chiusura fiscale hardware in corso…");
            var result = await FiscalPrintingService.RetryFiscalClosureAsync(closureId);
            if (result?.Success == true)
            {
                AppNotification.ShowSuccess("Chiusura fiscale hardware completata.");
                if (_entityPage is not null) await _entityPage.RefreshAsync();
            }
            else
            {
                AppNotification.ShowError($"Chiusura fiscale fallita: {result?.ErrorMessage ?? "errore"}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore retry chiusura fiscale {ClosureId}.", closureId);
            AppNotification.ShowWarning("Si è verificato un errore.");
        }
    }

    // ─────────────────────────────────────────────────────────
    //  Chip helpers
    // ─────────────────────────────────────────────────────────

    private static Color ClosureTypeColor(ClosureType ct) => ct switch
    {
        ClosureType.Fiscale      => Color.Success,
        ClosureType.NonFiscale   => Color.Info,
        ClosureType.SoloDatabase => Color.Warning,
        _                        => Color.Default
    };

    private static string ClosureTypeIcon(ClosureType ct) => ct switch
    {
        ClosureType.Fiscale      => Icons.Material.Filled.ReceiptLong,
        ClosureType.NonFiscale   => Icons.Material.Filled.EventNote,
        ClosureType.SoloDatabase => Icons.Material.Filled.Storage,
        _                        => Icons.Material.Filled.Help
    };

    private static string ClosureTypeLabel(ClosureType ct) => ct switch
    {
        ClosureType.Fiscale      => "Fiscale",
        ClosureType.NonFiscale   => "Non Fiscale",
        ClosureType.SoloDatabase => "Solo Database",
        _                        => ct.ToString()
    };
}
