@page "/warehouse/lot-management"
@using Prym.DTOs.Warehouse
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,Operator")]
@inject ILotService LotService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<LotManagement> Logger

<PageTitle>@TranslationService.GetTranslation("warehouse.lotManagement", "Gestione Lotti")</PageTitle>

<EntityManagementPage TEntity="LotDto"
                      @ref="_managementPage"
                      Config="_config"
                      Service="_service"
                      ExternalFilters="_filters"
                      OnCreateOverride="@(() => OpenDetailDialogAsync(null))"
                      OnEditOverride="@(id => OpenDetailDialogAsync(id))"
                      OnQuickFilterChanged="@OnQuickFilterChanged"
                      OnClearFilters="@ClearFiltersAsync">
    <AdditionalToolbarContent>
        <PrymSelect T="string"
                    @bind-Value="_selectedStatus"
                    @bind-Value:after="OnFilterChanged"
                    Label="@TranslationService.GetTranslation("warehouse.status", "Stato")"
                    Clearable="true"
                    Class="ml-2 min-width-150">
            <MudSelectItem Value="@("Active")">@TranslationService.GetTranslation("warehouse.active", "Attivo")</MudSelectItem>
            <MudSelectItem Value="@("Blocked")">@TranslationService.GetTranslation("warehouse.blocked", "Bloccato")</MudSelectItem>
            <MudSelectItem Value="@("Expired")">@TranslationService.GetTranslation("warehouse.expired", "Scaduto")</MudSelectItem>
            <MudSelectItem Value="@("Recalled")">@TranslationService.GetTranslation("warehouse.recalled", "Richiamato")</MudSelectItem>
        </PrymSelect>
    </AdditionalToolbarContent>

    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Code")
            {
                <EFTableColumnHeader TItem="LotDto" PropertyName="Code" OnDragStartCallback="@_managementPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<LotDto, object>(x => x.Code))">@TranslationService.GetTranslation("warehouse.lotCode", "Codice Lotto")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ProductName")
            {
                <EFTableColumnHeader TItem="LotDto" PropertyName="ProductName" OnDragStartCallback="@_managementPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<LotDto, object>(x => x.ProductName ?? string.Empty))">@TranslationService.GetTranslation("warehouse.product", "Prodotto")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Status")
            {
                <EFTableColumnHeader TItem="LotDto" PropertyName="Status" OnDragStartCallback="@_managementPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<LotDto, object>(x => x.Status))">@TranslationService.GetTranslation("warehouse.status", "Stato")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "QualityStatus")
            {
                <EFTableColumnHeader TItem="LotDto" PropertyName="QualityStatus" OnDragStartCallback="@_managementPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<LotDto, object>(x => x.QualityStatus))">@TranslationService.GetTranslation("warehouse.qualityStatus", "Qualità")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "AvailableQuantity")
            {
                <EFTableColumnHeader TItem="LotDto" PropertyName="AvailableQuantity" OnDragStartCallback="@_managementPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<LotDto, object>(x => x.AvailableQuantity))">@TranslationService.GetTranslation("warehouse.availableQuantity", "Disponibile")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ExpiryDate")
            {
                <EFTableColumnHeader TItem="LotDto" PropertyName="ExpiryDate" OnDragStartCallback="@_managementPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="@(new Func<LotDto, object>(x => x.ExpiryDate ?? DateTime.MaxValue))">@TranslationService.GetTranslation("warehouse.expiryDate", "Data Scadenza")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center" Style="min-width:160px;">@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Code")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("warehouse.lotCode", "Codice Lotto")">
                    <div>
                        <MudText Typo="Typo.body2" Class="fw-semibold">@ctx.Item.Code</MudText>
                        @if (!string.IsNullOrEmpty(ctx.Item.Barcode))
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@ctx.Item.Barcode</MudText>
                        }
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "ProductName")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("warehouse.product", "Prodotto")">
                    <div>
                        <MudText Typo="Typo.body2">@ctx.Item.ProductName</MudText>
                        @if (!string.IsNullOrEmpty(ctx.Item.ProductCode))
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@ctx.Item.ProductCode</MudText>
                        }
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "Status")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("warehouse.status", "Stato")">
                    <LotStatusBadge Status="@ctx.Item.Status" />
                </MudTd>
            }
            else if (column.PropertyName == "QualityStatus")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("warehouse.qualityStatus", "Qualità")">
                    <QualityStatusBadge Status="@ctx.Item.QualityStatus" />
                </MudTd>
            }
            else if (column.PropertyName == "AvailableQuantity")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("warehouse.availableQuantity", "Disponibile")">
                    <MudText Typo="Typo.body2">@ctx.Item.AvailableQuantity.ToString("N2")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "ExpiryDate")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("warehouse.expiryDate", "Data Scadenza")">
                    @if (ctx.Item.ExpiryDate.HasValue)
                    {
                        var daysToExpiry = (ctx.Item.ExpiryDate.Value - DateTime.Now).Days;
                        <MudText Typo="Typo.body2" Color="@(daysToExpiry <= 30 ? Color.Warning : Color.Default)">
                            @ctx.Item.ExpiryDate.Value.ToString("dd/MM/yyyy")
                        </MudText>
                        @if (daysToExpiry <= 30 && daysToExpiry > 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning">
                                @TranslationService.GetTranslation("warehouse.expireInDays", "{0} giorni", daysToExpiry)
                            </MudText>
                        }
                        else if (daysToExpiry <= 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error">
                                @TranslationService.GetTranslation("warehouse.expired", "Scaduto")
                            </MudText>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">-</MudText>
                    }
                </MudTd>
            }
        }
    </RowTemplate>

    <AdditionalRowActions Context="item">
        @if (item.Status != "Blocked")
        {
            <MudTooltip Text="@TranslationService.GetTranslation("warehouse.block", "Blocca lotto")">
                <PrymIconButton Icon="@Icons.Material.Outlined.Lock"
                                Color="Color.Warning"
                                Size="Size.Small"
                                Class="ef-row-actionbutton"
                                OnClick="@(() => BlockLot(item))" />
            </MudTooltip>
        }
        else
        {
            <MudTooltip Text="@TranslationService.GetTranslation("warehouse.unblock", "Sblocca lotto")">
                <PrymIconButton Icon="@Icons.Material.Outlined.LockOpen"
                                Color="Color.Success"
                                Size="Size.Small"
                                Class="ef-row-actionbutton"
                                OnClick="@(() => UnblockLot(item))" />
            </MudTooltip>
        }
    </AdditionalRowActions>
</EntityManagementPage>

@code {
    private EntityManagementPage<LotDto> _managementPage = null!;
    private IEntityManagementService<LotDto> _service = null!;
    private EntityManagementConfig<LotDto> _config = null!;

    private string? _selectedStatus;
    private readonly Dictionary<string, object?> _filters = new();

    protected override void OnInitialized()
    {
        _service = new LotManagementService(LotService);
        _config = new EntityManagementConfig<LotDto>
        {
            ComponentKey = "LotManagement",
            PageTitleKey = "warehouse.lotManagement",
            PageTitleDefault = "Gestione Lotti",
            EntityIcon = Icons.Material.Outlined.QrCode,
            PageRootCssClass = "lot-page-root",
            BaseRoute = "/warehouse/lot-management",
            ExcelFileName = "Lotti",
            SearchPlaceholderKey = "common.search",
            SearchPlaceholderDefault = "Cerca",
            DefaultPageSize = 25,
            UseServerSidePaging = true,
            CreateTooltip = "common.create",
            EntityTypeName = "Lot",
            ShowView = true,
            ShowEdit = true,
            ShowDelete = true,
            ShowAuditLog = false,
            ShowToggleStatus = false,
            DeleteConfirmMessageKey = "lot.confirmDelete",
            DeleteSuccessMessageKey = "lot.deleted",
            DeleteErrorMessageKey = "lot.deleteError",
            BulkDeleteConfirmMessageKey = "lot.confirmDeleteMultiple",
            GetDisplayName = l => l.Code,
            GetId = l => l.Id,
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Magazzino", null, disabled: true),
                new BreadcrumbItem("Gestione Lotti", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Code", DisplayName = "Codice Lotto", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "ProductName", DisplayName = "Prodotto", IsVisible = true, Order = 1, IsSearchable = true },
                new() { PropertyName = "Status", DisplayName = "Stato", IsVisible = true, Order = 2, IsSearchable = false },
                new() { PropertyName = "QualityStatus", DisplayName = "Qualità", IsVisible = true, Order = 3, IsSearchable = false },
                new() { PropertyName = "AvailableQuantity", DisplayName = "Disponibile", IsVisible = true, Order = 4, IsSearchable = false },
                new() { PropertyName = "ExpiryDate", DisplayName = "Data Scadenza", IsVisible = true, Order = 5, IsSearchable = false }
            },
            QuickFilters = new()
            {
                new() { Id = "all", Label = "Tutti", Predicate = _ => true, Description = "Mostra tutti i lotti" },
                new() { Id = "active", Label = "Attivi", Predicate = l => l.Status == "Active", Color = Color.Success, Icon = Icons.Material.Outlined.CheckCircle, Description = "Solo lotti attivi" },
                new() { Id = "blocked", Label = "Bloccati", Predicate = l => l.Status == "Blocked", Color = Color.Error, Icon = Icons.Material.Outlined.Block, Description = "Lotti bloccati" },
                new() { Id = "expired", Label = "Scaduti", Predicate = l => l.Status == "Expired", Color = Color.Default, Icon = Icons.Material.Outlined.EventBusy, Description = "Lotti scaduti" },
                new() { Id = "recalled", Label = "Richiamati", Predicate = l => l.Status == "Recalled", Color = Color.Error, Icon = Icons.Material.Outlined.Report, Description = "Lotti richiamati" },
                new() { Id = "expiring_soon", Label = "In Scadenza", Predicate = l => l.ExpiryDate.HasValue && l.ExpiryDate.Value <= DateTime.UtcNow.AddDays(30) && l.ExpiryDate.Value > DateTime.UtcNow, Color = Color.Warning, Icon = Icons.Material.Outlined.Warning, Description = "Lotti in scadenza entro 30 giorni" },
                new() { Id = "recent", Label = "Recenti", Predicate = l => l.CreatedAt >= DateTime.UtcNow.AddDays(-30), Color = Color.Info, Icon = Icons.Material.Outlined.NewReleases, Description = "Creati negli ultimi 30 giorni" }
            }
        };
    }

    private async Task OnFilterChanged()
    {
        if (string.IsNullOrWhiteSpace(_selectedStatus))
            _filters.Remove("status");
        else
            _filters["status"] = _selectedStatus;

        _filters.Remove("expiringSoon");
        _filters.Remove("recent");
        await _managementPage.RefreshAsync();
    }

    private async Task OnQuickFilterChanged(QuickFilter<LotDto>? filter)
    {
        _selectedStatus = null;
        _filters.Clear();

        switch (filter?.Id)
        {
            case "active":
                _filters["status"] = "Active";
                break;
            case "blocked":
                _filters["status"] = "Blocked";
                break;
            case "expired":
                _filters["status"] = "Expired";
                break;
            case "recalled":
                _filters["status"] = "Recalled";
                break;
            case "expiring_soon":
                _filters["expiringSoon"] = true;
                break;
            case "recent":
                _filters["recent"] = true;
                break;
        }

        await _managementPage.RefreshAsync();
    }

    private async Task ClearFiltersAsync()
    {
        _selectedStatus = null;
        _filters.Clear();
        await _managementPage.RefreshAsync();
    }

    private async Task BlockLot(LotDto lot)
    {
        var parameters = new DialogParameters
        {
            [nameof(LotBlockDialog.LotCode)] = lot.Code
        };
        var dialog = await DialogService.ShowAsync<LotBlockDialog>(string.Empty, parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = false
        });
        var dialogResult = await dialog.Result;

        if (dialogResult is { Canceled: false })
        {
            var reason = (dialogResult.Data as string) ?? string.Empty;
            if (string.IsNullOrWhiteSpace(reason))
                reason = TranslationService.GetTranslation("warehouse.defaultBlockReason", "Blocco manuale da operatore");

            try
            {
                var result = await LotService.BlockLotAsync(lot.Id, reason);
                if (result)
                {
                    AppNotification.ShowSuccess(TranslationService.GetTranslation("warehouse.lotBlocked", "Lotto bloccato"));
                    await _managementPage.RefreshAsync();
                }
                else
                {
                    AppNotification.ShowError(TranslationService.GetTranslation("common.error", "Errore"));
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error blocking lot {LotId}.", lot.Id);
                AppNotification.ShowWarning("Si è verificato un errore nel blocco del lotto.");
            }
        }
    }

    private async Task UnblockLot(LotDto lot)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            TranslationService.GetTranslation("common.confirm", "Conferma"),
            TranslationService.GetTranslation("warehouse.confirmUnblock", "Sbloccare il lotto '{0}'?", lot.Code),
            yesText: TranslationService.GetTranslation("warehouse.unblock", "Sblocca"),
            cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));

        if (confirmed == true)
        {
            try
            {
                var result = await LotService.UnblockLotAsync(lot.Id);
                if (result)
                {
                    AppNotification.ShowSuccess(TranslationService.GetTranslation("warehouse.lotUnblocked", "Lotto sbloccato"));
                    await _managementPage.RefreshAsync();
                }
                else
                {
                    AppNotification.ShowError(TranslationService.GetTranslation("common.error", "Errore"));
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error unblocking lot {LotId}.", lot.Id);
                AppNotification.ShowWarning("Si è verificato un errore nello sblocco del lotto.");
            }
        }
    }

    private async Task OpenDetailDialogAsync(Guid? id)
    {
        try
        {
            var parameters = new DialogParameters
            {
                [nameof(LotDetailDialog.EntityId)] = id
            };
            var dialog = await DialogService.ShowAsync<LotDetailDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await (_managementPage?.RefreshAsync() ?? Task.CompletedTask);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening lot detail dialog for ID {Id}.", id);
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }
}
