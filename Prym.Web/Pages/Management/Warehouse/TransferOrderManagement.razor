@page "/warehouse/transfers"
@using Prym.DTOs.Warehouse
@attribute [Authorize]
@inject ITransferOrderService TransferOrderService
@inject IWarehouseService WarehouseService
@inject NavigationManager NavigationManager
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<TransferOrderManagement> Logger

<PageTitle>@TranslationService.GetTranslation("transferOrder.title", "Transfer Orders")</PageTitle>

<EntityManagementPage TEntity="TransferOrderDto"
                      @ref="_managementPage"
                      Config="_config"
                      Service="_service"
                      OnCreateOverride="@CreateTransferOrder"
                      OnViewEntity="@(id => OpenDetailDialogAsync(id))"
                      AdditionalFilter="@(t => (!_selectedSourceWarehouseId.HasValue || t.SourceWarehouseId == _selectedSourceWarehouseId.Value)
                                            && (!_selectedDestinationWarehouseId.HasValue || t.DestinationWarehouseId == _selectedDestinationWarehouseId.Value)
                                            && (string.IsNullOrEmpty(_selectedStatus) || t.Status == _selectedStatus))">
    <AdditionalToolbarContent>
        <PrymSelect T="Guid?"
                    @bind-Value="_selectedSourceWarehouseId"
                    @bind-Value:after="OnFilterChanged"
                    Label="@TranslationService.GetTranslation("transferOrder.sourceWarehouse", "Source Warehouse")"
                    Clearable="true"
                    Class="ml-2 ef-min-200">
            @foreach (var warehouse in _warehouses)
            {
                <MudSelectItem Value="@((Guid?)warehouse.Id)">@warehouse.Name</MudSelectItem>
            }
        </PrymSelect>
        <PrymSelect T="Guid?"
                    @bind-Value="_selectedDestinationWarehouseId"
                    @bind-Value:after="OnFilterChanged"
                    Label="@TranslationService.GetTranslation("transferOrder.destinationWarehouse", "Destination Warehouse")"
                    Clearable="true"
                    Class="ml-2 ef-min-200">
            @foreach (var warehouse in _warehouses)
            {
                <MudSelectItem Value="@((Guid?)warehouse.Id)">@warehouse.Name</MudSelectItem>
            }
        </PrymSelect>
        <PrymSelect T="string"
                    @bind-Value="_selectedStatus"
                    @bind-Value:after="OnFilterChanged"
                    Label="@TranslationService.GetTranslation("common.status", "Status")"
                    Clearable="true"
                    Class="ml-2 min-width-150">
            <MudSelectItem Value="@("Pending")">@TranslationService.GetTranslation("transferOrder.status.pending", "Pending")</MudSelectItem>
            <MudSelectItem Value="@("Shipped")">@TranslationService.GetTranslation("transferOrder.status.shipped", "Shipped")</MudSelectItem>
            <MudSelectItem Value="@("InTransit")">@TranslationService.GetTranslation("transferOrder.status.inTransit", "In Transit")</MudSelectItem>
            <MudSelectItem Value="@("Completed")">@TranslationService.GetTranslation("transferOrder.status.completed", "Completed")</MudSelectItem>
            <MudSelectItem Value="@("Cancelled")">@TranslationService.GetTranslation("transferOrder.status.cancelled", "Cancelled")</MudSelectItem>
        </PrymSelect>
    </AdditionalToolbarContent>

    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Number")
            {
                <EFTableColumnHeader TItem="TransferOrderDto" PropertyName="Number">
                    <MudTableSortLabel SortBy="@(new Func<TransferOrderDto, object>(x => x.Number))">@TranslationService.GetTranslation("transferOrder.column.number", "Number")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "OrderDate")
            {
                <EFTableColumnHeader TItem="TransferOrderDto" PropertyName="OrderDate">
                    <MudTableSortLabel SortBy="@(new Func<TransferOrderDto, object>(x => x.OrderDate))">@TranslationService.GetTranslation("transferOrder.column.orderDate", "Order Date")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "SourceWarehouseName")
            {
                <EFTableColumnHeader TItem="TransferOrderDto" PropertyName="SourceWarehouseName">
                    <MudTableSortLabel SortBy="@(new Func<TransferOrderDto, object>(x => x.SourceWarehouseName ?? string.Empty))">@TranslationService.GetTranslation("transferOrder.column.source", "Source")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "DestinationWarehouseName")
            {
                <EFTableColumnHeader TItem="TransferOrderDto" PropertyName="DestinationWarehouseName">
                    <MudTableSortLabel SortBy="@(new Func<TransferOrderDto, object>(x => x.DestinationWarehouseName ?? string.Empty))">@TranslationService.GetTranslation("transferOrder.column.destination", "Destination")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Status")
            {
                <EFTableColumnHeader TItem="TransferOrderDto" PropertyName="Status">
                    <MudTableSortLabel SortBy="@(new Func<TransferOrderDto, object>(x => x.Status))">@TranslationService.GetTranslation("common.status", "Status")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ItemsCount")
            {
                <EFTableColumnHeader TItem="TransferOrderDto" PropertyName="ItemsCount">
                    <MudTableSortLabel SortBy="@(new Func<TransferOrderDto, object>(x => x.Rows.Count))">@TranslationService.GetTranslation("transferOrder.column.items", "Items")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center ef-min-200">@TranslationService.GetTranslation("common.actions", "Actions")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Number")
            {
                <MudTd DataLabel="Number">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                        @ctx.Item.Number
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "OrderDate")
            {
                <MudTd DataLabel="Order Date">
                    <MudText Typo="Typo.body2">@ctx.Item.OrderDate.ToString("yyyy-MM-dd")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "SourceWarehouseName")
            {
                <MudTd DataLabel="Source">
                    <MudText Typo="Typo.body2">@ctx.Item.SourceWarehouseName</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "DestinationWarehouseName")
            {
                <MudTd DataLabel="Destination">
                    <MudText Typo="Typo.body2">@ctx.Item.DestinationWarehouseName</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Status")
            {
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@GetStatusColor(ctx.Item.Status)" Size="Size.Small">@ctx.Item.Status</MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "ItemsCount")
            {
                <MudTd DataLabel="Items">
                    <MudText Typo="Typo.body2">@ctx.Item.Rows.Count</MudText>
                </MudTd>
            }
        }
    </RowTemplate>

    <AdditionalRowActions Context="item">
        @if (item.Status == "Pending")
        {
            <MudTooltip Text="@TranslationService.GetTranslation("transferOrder.action.ship", "Spedisci ordine")">
                <PrymIconButton Icon="@Icons.Material.Outlined.LocalShipping"
                                Color="Color.Primary"
                                Size="Size.Small"
                                Class="ef-row-actionbutton"
                                OnClick="@(() => ShipOrder(item))" />
            </MudTooltip>
        }
        @if (item.Status == "Shipped" || item.Status == "InTransit")
        {
            <MudTooltip Text="@TranslationService.GetTranslation("transferOrder.action.receive", "Ricevi merce")">
                <PrymIconButton Icon="@Icons.Material.Outlined.Inventory"
                                Color="Color.Success"
                                Size="Size.Small"
                                Class="ef-row-actionbutton"
                                OnClick="@(() => ReceiveOrder(item))" />
            </MudTooltip>
        }
    </AdditionalRowActions>
</EntityManagementPage>

@code {
    private EntityManagementPage<TransferOrderDto> _managementPage = null!;
    private IEntityManagementService<TransferOrderDto> _service = null!;
    private EntityManagementConfig<TransferOrderDto> _config = null!;

    private Guid? _selectedSourceWarehouseId;
    private Guid? _selectedDestinationWarehouseId;
    private string? _selectedStatus;
    private List<StorageFacilityDto> _warehouses = new();

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Large,
        FullWidth = true,
        CloseButton = true
    };

    protected override void OnInitialized()
    {
        _service = new TransferOrderManagementService(TransferOrderService);
        _config = new EntityManagementConfig<TransferOrderDto>
        {
            ComponentKey = "TransferOrderManagement",
            PageTitleKey = "transferOrder.title",
            PageTitleDefault = "Transfer Orders",
            EntityIcon = Icons.Material.Outlined.SwapHoriz,
            PageRootCssClass = "transfer-order-page-root",
            BaseRoute = "/warehouse/transfers",
            ExcelFileName = "Trasferimenti",
            SearchPlaceholderKey = "common.search",
            SearchPlaceholderDefault = "Search",
            CreateTooltip = "transferOrder.createTooltip",
            EntityTypeName = "TransferOrder",
            ShowView = true,
            ShowEdit = false,
            ShowDelete = true,
            ShowAuditLog = false,
            ShowToggleStatus = false,
            DeleteConfirmMessageKey = "transferOrder.cancelConfirm",
            DeleteSuccessMessageKey = "transferOrder.cancelSuccess",
            DeleteErrorMessageKey = "transferOrder.cancelFailed",
            BulkDeleteConfirmMessageKey = "transferOrder.cancelMultipleConfirm",
            CanDelete = t => t.Status == "Pending",
            CannotDeleteMessageKey = "transferOrder.onlyPendingCanCancel",
            GetDisplayName = t => t.Number,
            GetId = t => t.Id,
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Magazzino", null, disabled: true),
                new BreadcrumbItem("Ordini di Trasferimento", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Number", DisplayName = "Number", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "OrderDate", DisplayName = "Order Date", IsVisible = true, Order = 1, IsSearchable = false },
                new() { PropertyName = "SourceWarehouseName", DisplayName = "Source", IsVisible = true, Order = 2, IsSearchable = true },
                new() { PropertyName = "DestinationWarehouseName", DisplayName = "Destination", IsVisible = true, Order = 3, IsSearchable = true },
                new() { PropertyName = "Status", DisplayName = "Status", IsVisible = true, Order = 4, IsSearchable = false },
                new() { PropertyName = "ItemsCount", DisplayName = "Items", IsVisible = true, Order = 5, IsSearchable = false }
            },
            QuickFilters = new()
            {
                new() { Id = "all", Label = "Tutti", Predicate = _ => true, Description = "Mostra tutti gli ordini di trasferimento" },
                new() { Id = "pending", Label = "In Sospeso", Predicate = t => t.Status == "Pending", Color = Color.Warning, Icon = Icons.Material.Outlined.Schedule, Description = "Ordini in attesa di elaborazione" },
                new() { Id = "in_transit", Label = "In Transito", Predicate = t => t.Status == "InTransit", Color = Color.Info, Icon = Icons.Material.Outlined.LocalShipping, Description = "Ordini in transito" },
                new() { Id = "completed", Label = "Completati", Predicate = t => t.Status == "Completed", Color = Color.Success, Icon = Icons.Material.Outlined.CheckCircle, Description = "Ordini completati" },
                new() { Id = "cancelled", Label = "Annullati", Predicate = t => t.Status == "Cancelled", Color = Color.Default, Icon = Icons.Material.Outlined.Cancel, Description = "Ordini annullati" },
                new() { Id = "recent", Label = "Recenti", Predicate = t => t.CreatedAt >= DateTime.UtcNow.AddDays(-30), Color = Color.Primary, Icon = Icons.Material.Outlined.NewReleases, Description = "Creati negli ultimi 30 giorni" }
            }
        };
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadWarehousesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing TransferOrderManagement.");
        }
    }

    private async Task LoadWarehousesAsync()
    {
        try
        {
            var result = await WarehouseService.GetStorageFacilitiesAsync(1, 100);
            _warehouses = result?.Items?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            AppNotification.ShowError(TranslationService.GetTranslation("transferOrder.loadWarehousesError", "Error loading warehouses: {0}", ex.Message));
            Logger.LogError(ex, "Error loading warehouses");
        }
    }

    private void OnFilterChanged()
    {
        StateHasChanged();
    }

    private async Task ShipOrder(TransferOrderDto order)
    {
        try
        {
            var parameters = new DialogParameters<ShipTransferOrderDialog>
            {
                { x => x.TransferOrder, order }
            };
            var dialog = await DialogService.ShowAsync<ShipTransferOrderDialog>(
                TranslationService.GetTranslation("transferOrder.shipDialog", "Ship Transfer Order"), parameters, _dialogOptions);
            var result = await dialog.Result;
            if (result is { Canceled: false })
            {
                await _managementPage.RefreshAsync();
                AppNotification.ShowSuccess(TranslationService.GetTranslation("transferOrder.shipSuccess", "Transfer order shipped successfully"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in ShipOrder.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task ReceiveOrder(TransferOrderDto order)
    {
        try
        {
            var parameters = new DialogParameters<ReceiveTransferOrderDialog>
            {
                { x => x.TransferOrder, order }
            };
            var dialog = await DialogService.ShowAsync<ReceiveTransferOrderDialog>(
                TranslationService.GetTranslation("transferOrder.receiveDialog", "Receive Transfer Order"), parameters, _dialogOptions);
            var result = await dialog.Result;
            if (result is { Canceled: false })
            {
                await _managementPage.RefreshAsync();
                AppNotification.ShowSuccess(TranslationService.GetTranslation("transferOrder.receiveSuccess", "Transfer order received successfully"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in ReceiveOrder.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task OpenDetailDialogAsync(Guid id)
    {
        try
        {
            var parameters = new DialogParameters { [nameof(TransferOrderDetailDialog.EntityId)] = (Guid?)id };
            var dialog = await DialogService.ShowAsync<TransferOrderDetailDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            await dialog.Result;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OpenDetailDialogAsync.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task CreateTransferOrder()
    {
        try
        {
            var dialog = await DialogService.ShowAsync<CreateTransferOrderDialog>(
                TranslationService.GetTranslation("transferOrder.createDialog", "Create Transfer Order"), _dialogOptions);
            var result = await dialog.Result;
            if (result is { Canceled: false })
            {
                await _managementPage.RefreshAsync();
                AppNotification.ShowSuccess(TranslationService.GetTranslation("transferOrder.createSuccess", "Transfer order created successfully"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in CreateTransferOrder.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private Color GetStatusColor(string status)
    {
        return status switch
        {
            "Pending" => Color.Warning,
            "Shipped" => Color.Info,
            "InTransit" => Color.Primary,
            "Completed" => Color.Success,
            "Cancelled" => Color.Error,
            _ => Color.Default
        };
    }
}
