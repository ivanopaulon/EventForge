@page "/management/promotions"
@using Prym.DTOs.Promotions
@attribute [Authorize]
@inject IPromotionClientService PromotionService
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject ILogger<PromotionManagement> Logger
@inject IAppNotificationService AppNotification

<PageTitle>@TranslationService.GetTranslation("promotion.management.title", "Gestione Promozioni")</PageTitle>
<EntityManagementPage TEntity="PromotionDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      OnEditOverride="@(id => OpenDetailDialogAsync(id))"
                      OnCreateOverride="@(() => OpenDetailDialogAsync(null))">
    <AdditionalToolbarContent>
        <PrymButton Variant="Variant.Text" Color="Color.Success"
                    StartIcon="@Icons.Material.Outlined.CheckCircle"
                    OnClick="@BulkActivate">
            @TranslationService.GetTranslation("promotion.bulkActivate", "Attiva")
        </PrymButton>
        <PrymButton Variant="Variant.Text" Color="Color.Warning"
                    StartIcon="@Icons.Material.Outlined.Pause"
                    OnClick="@BulkSuspend">
            @TranslationService.GetTranslation("promotion.bulkSuspend", "Sospendi")
        </PrymButton>
    </AdditionalToolbarContent>

    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Name")
            {
                <EFTableColumnHeader TItem="PromotionDto" PropertyName="Name" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<PromotionDto, object>(x => x.Name))">@TranslationService.GetTranslation("field.name", "Nome")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "StartDate")
            {
                <EFTableColumnHeader TItem="PromotionDto" PropertyName="StartDate" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<PromotionDto, object>(x => x.StartDate))">@TranslationService.GetTranslation("field.startDate", "Inizio")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "EndDate")
            {
                <EFTableColumnHeader TItem="PromotionDto" PropertyName="EndDate" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<PromotionDto, object>(x => x.EndDate))">@TranslationService.GetTranslation("field.endDate", "Fine")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Priority")
            {
                <EFTableColumnHeader TItem="PromotionDto" PropertyName="Priority" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<PromotionDto, object>(x => x.Priority))">@TranslationService.GetTranslation("field.priority", "Priorità")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "MaxUses")
            {
                <EFTableColumnHeader TItem="PromotionDto" PropertyName="MaxUses" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<PromotionDto, object>(x => x.MaxUses ?? int.MaxValue))">@TranslationService.GetTranslation("field.maxUses", "Utilizzi")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Status")
            {
                <EFTableColumnHeader TItem="PromotionDto" PropertyName="Status" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<PromotionDto, object>(x => x.Status))">@TranslationService.GetTranslation("common.status", "Stato")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "CouponCode")
            {
                <EFTableColumnHeader TItem="PromotionDto" PropertyName="CouponCode" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<PromotionDto, object>(x => x.CouponCode ?? string.Empty))">@TranslationService.GetTranslation("field.couponCode", "Coupon")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "IsCombinable")
            {
                <EFTableColumnHeader TItem="PromotionDto" PropertyName="IsCombinable" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<PromotionDto, object>(x => x.IsCombinable))">@TranslationService.GetTranslation("field.isCombinable", "Combinabile")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "CreatedAt")
            {
                <EFTableColumnHeader TItem="PromotionDto" PropertyName="CreatedAt" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="@(new Func<PromotionDto, object>(x => x.CreatedAt))">@TranslationService.GetTranslation("field.createdAt", "Creato il")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center ef-min-120" >@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @{
            var isExpired = ctx.Item.EndDate < DateTime.UtcNow;
            var isExpiringSoon = !isExpired && ctx.Item.EndDate <= DateTime.UtcNow.AddDays(7);
        }
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Name")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.name", "Nome")">
                    <div class="d-flex align-center gap-1 flex-wrap">
                        <MudText Typo="Typo.body2">@ctx.Item.Name</MudText>
                        @if (ctx.Item.IsCombinable)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" title="@TranslationService.GetTranslation("promotion.combinable", "Combinabile")">C</MudChip>
                        }
                        @if (!string.IsNullOrEmpty(ctx.Item.CouponCode))
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.LocalOffer" Size="Size.Small" Color="Color.Secondary" title="@TranslationService.GetTranslation("promotion.hasCoupon", "Ha coupon")" />
                        }
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "StartDate")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.startDate", "Inizio")">
                    <div class="d-flex align-center gap-1">
                        @if (isExpired)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" title="@TranslationService.GetTranslation("promotion.expired", "Scaduta")" />
                        }
                        <MudText Typo="Typo.body2">@ctx.Item.StartDate.ToShortDateString()</MudText>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "EndDate")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.endDate", "Fine")">
                    <div class="d-flex align-center gap-1">
                        @if (isExpired)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" title="@TranslationService.GetTranslation("promotion.expired", "Scaduta")" />
                        }
                        else if (isExpiringSoon)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" title="@TranslationService.GetTranslation("promotion.expiringSoon", "In scadenza")" />
                        }
                        <MudText Typo="Typo.body2">@ctx.Item.EndDate.ToShortDateString()</MudText>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "Priority")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.priority", "Priorità")">
                    <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(ctx.Item.Priority)">@ctx.Item.Priority</MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "MaxUses")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.maxUses", "Utilizzi")">
                    @if (ctx.Item.MaxUses.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@ctx.Item.CurrentUses / @ctx.Item.MaxUses</MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">∞</MudText>
                    }
                </MudTd>
            }
            else if (column.PropertyName == "Status")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("common.status", "Stato")">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(ctx.Item.Status)" Icon="@GetStatusIcon(ctx.Item.Status)">
                        @TranslationService.GetTranslation($"promotion.status.{ctx.Item.Status.ToString().ToLower()}", ctx.Item.Status.ToString())
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "CouponCode")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.couponCode", "Coupon")">
                    @if (!string.IsNullOrEmpty(ctx.Item.CouponCode))
                    {
                        <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.LocalOffer" Color="Color.Secondary">@ctx.Item.CouponCode</MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">-</MudText>
                    }
                </MudTd>
            }
            else if (column.PropertyName == "IsCombinable")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.isCombinable", "Combinabile")">
                    @if (ctx.Item.IsCombinable)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Default" Size="Size.Small" />
                    }
                </MudTd>
            }
            else if (column.PropertyName == "CreatedAt")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.createdAt", "Creato il")">
                    <MudText Typo="Typo.body2">@ctx.Item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudText>
                </MudTd>
            }
        }
    </RowTemplate>
</EntityManagementPage>

@code {
    private EntityManagementPage<PromotionDto> _entityPage = null!;
    private IEntityManagementService<PromotionDto> _service = null!;
    private EntityManagementConfig<PromotionDto> _config = null!;

    protected override void OnInitialized()
    {
        _service = new PromotionManagementService(PromotionService);
        _config = new EntityManagementConfig<PromotionDto>
        {
            ComponentKey = "PromotionManagement",
            PageTitleKey = "promotion.management.title",
            PageTitleDefault = "Gestione Promozioni",
            EntityIcon = Icons.Material.Outlined.LocalOffer,
            PageRootCssClass = "management-page-root",
            BaseRoute = "/management/promotions",
            ExcelFileName = "Promozioni",
            SearchPlaceholderKey = "common.search",
            SearchPlaceholderDefault = "Cerca...",
            CreateTooltip = "promotion.create",
            EntityTypeName = "Promotion",
            ShowToggleStatus = false,
            ShowAuditLog = true,
            DeleteConfirmMessageKey = "promotion.confirmDelete",
            DeleteSuccessMessageKey = "promotion.deleted",
            DeleteErrorMessageKey = "promotion.deleteError",
            BulkDeleteConfirmMessageKey = "promotion.confirmDeleteMultiple",
            GetDisplayName = p => p.Name,
            GetId = p => p.Id,
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Commerciale", null, disabled: true),
                new BreadcrumbItem("Promozioni", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Name", DisplayName = "Nome", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "StartDate", DisplayName = "Inizio", IsVisible = true, Order = 1, IsSearchable = false },
                new() { PropertyName = "EndDate", DisplayName = "Fine", IsVisible = true, Order = 2, IsSearchable = false },
                new() { PropertyName = "Priority", DisplayName = "Priorità", IsVisible = true, Order = 3, IsSearchable = false },
                new() { PropertyName = "MaxUses", DisplayName = "Utilizzi", IsVisible = true, Order = 4, IsSearchable = false },
                new() { PropertyName = "CouponCode", DisplayName = "Coupon", IsVisible = true, Order = 5, IsSearchable = false },
                new() { PropertyName = "IsCombinable", DisplayName = "Combinabile", IsVisible = true, Order = 6, IsSearchable = false },
                new() { PropertyName = "Status", DisplayName = "Stato", IsVisible = true, Order = 7, IsSearchable = false },
                new() { PropertyName = "CreatedAt", DisplayName = "Creato il", IsVisible = false, Order = 8, IsSearchable = false }
            },
            QuickFilters = new()
            {
                new() { Id = "all", Label = "Tutti", Predicate = _ => true, Description = "Mostra tutte le promozioni" },
                new() { Id = "active", Label = "Attive", Predicate = p => p.IsCurrentlyActive, Color = Color.Success, Icon = Icons.Material.Outlined.CheckCircle, Description = "Promozioni attive" },
                new() { Id = "suspended", Label = "Sospese", Predicate = p => p.Status == PromotionStatus.Suspended, Color = Color.Warning, Icon = Icons.Material.Outlined.Pause, Description = "Promozioni sospese" },
                new() { Id = "expired", Label = "Scadute", Predicate = p => p.EndDate < DateTime.UtcNow, Color = Color.Error, Icon = Icons.Material.Outlined.EventBusy, Description = "Promozioni scadute" },
                new() { Id = "expiring", Label = "In scadenza", Predicate = p => p.IsCurrentlyActive && p.EndDate <= DateTime.UtcNow.AddDays(7), Color = Color.Warning, Icon = Icons.Material.Outlined.AccessTime, Description = "In scadenza entro 7 giorni" },
                new() { Id = "coupon", Label = "Con coupon", Predicate = p => !string.IsNullOrEmpty(p.CouponCode), Color = Color.Secondary, Icon = Icons.Material.Outlined.LocalOffer, Description = "Promozioni con codice coupon" },
                new() { Id = "combinable", Label = "Combinabili", Predicate = p => p.IsCombinable, Color = Color.Info, Icon = Icons.Material.Outlined.MergeType, Description = "Promozioni combinabili" }
            }
        };
    }

    private Color GetPriorityColor(int priority) => priority switch
    {
        <= 10 => Color.Error,
        <= 50 => Color.Warning,
        _ => Color.Info
    };

    private Color GetStatusColor(PromotionStatus status) => status switch
    {
        PromotionStatus.Active => Color.Success,
        PromotionStatus.Suspended => Color.Warning,
        PromotionStatus.Archived => Color.Default,
        PromotionStatus.Draft => Color.Info,
        _ => Color.Default
    };

    private string GetStatusIcon(PromotionStatus status) => status switch
    {
        PromotionStatus.Active => Icons.Material.Filled.CheckCircle,
        PromotionStatus.Suspended => Icons.Material.Filled.Pause,
        PromotionStatus.Archived => Icons.Material.Filled.Archive,
        PromotionStatus.Draft => Icons.Material.Filled.EditNote,
        _ => Icons.Material.Filled.Circle
    };

    private async Task BulkActivate()
    {
        var selected = _entityPage?.SelectedItems;
        if (selected == null || selected.Count == 0)
        {
            AppNotification.ShowInfo("Seleziona almeno una promozione da attivare");
            return;
        }
        try
        {
            var toActivate = selected.Where(p => p.Status != PromotionStatus.Active).ToList();
            if (toActivate.Count == 0)
            {
                AppNotification.ShowInfo("Tutte le promozioni selezionate sono già attive");
                return;
            }
            var tasks = toActivate.Select(p => PromotionService.UpdateAsync(p.Id, new UpdatePromotionDto
            {
                Name = p.Name,
                Description = p.Description,
                StartDate = p.StartDate,
                EndDate = p.EndDate,
                MinOrderAmount = p.MinOrderAmount,
                MaxUses = p.MaxUses,
                CouponCode = p.CouponCode,
                Priority = p.Priority,
                IsCombinable = p.IsCombinable,
                MaxTotalDiscountPercentage = p.MaxTotalDiscountPercentage,
                MaxUsesPerCustomer = p.MaxUsesPerCustomer,
                Status = PromotionStatus.Active,
                RowVersion = p.RowVersion
            }, CancellationToken.None));
            await Task.WhenAll(tasks);
            await _entityPage!.RefreshAsync();
            AppNotification.ShowSuccess($"{toActivate.Count} promozione/i attivata/e");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error bulk-activating promotions.");
            AppNotification.ShowError("Errore durante l'attivazione massiva.");
        }
    }

    private async Task BulkSuspend()
    {
        var selected = _entityPage?.SelectedItems;
        if (selected == null || selected.Count == 0)
        {
            AppNotification.ShowInfo("Seleziona almeno una promozione da sospendere");
            return;
        }
        try
        {
            var toSuspend = selected.Where(p => p.Status != PromotionStatus.Suspended).ToList();
            if (toSuspend.Count == 0)
            {
                AppNotification.ShowInfo("Tutte le promozioni selezionate sono già sospese");
                return;
            }
            var tasks = toSuspend.Select(p => PromotionService.UpdateAsync(p.Id, new UpdatePromotionDto
            {
                Name = p.Name,
                Description = p.Description,
                StartDate = p.StartDate,
                EndDate = p.EndDate,
                MinOrderAmount = p.MinOrderAmount,
                MaxUses = p.MaxUses,
                CouponCode = p.CouponCode,
                Priority = p.Priority,
                IsCombinable = p.IsCombinable,
                MaxTotalDiscountPercentage = p.MaxTotalDiscountPercentage,
                MaxUsesPerCustomer = p.MaxUsesPerCustomer,
                Status = PromotionStatus.Suspended,
                RowVersion = p.RowVersion
            }, CancellationToken.None));
            await Task.WhenAll(tasks);
            await _entityPage!.RefreshAsync();
            AppNotification.ShowSuccess($"{toSuspend.Count} promozione/i sospesa/e");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error bulk-suspending promotions.");
            AppNotification.ShowError("Errore durante la sospensione massiva.");
        }
    }

    private async Task OpenDetailDialogAsync(Guid? id)
    {
        try
        {
            var parameters = new DialogParameters { [nameof(PromotionDetailDialog.EntityId)] = id };
            var dialog = await DialogService.ShowAsync<PromotionDetailDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await _entityPage.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening promotion detail dialog.");
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }
}
