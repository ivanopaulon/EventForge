@page "/product-management/products"
@using Prym.DTOs.Products
@using Prym.DTOs.Common
@attribute [Authorize]
@inject IProductService ProductService
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject ILogger<ProductManagement> Logger
@inject IAppNotificationService AppNotification

<PageTitle>@TranslationService.GetTranslation("product.management", "Gestione Prodotti")</PageTitle>
<EntityManagementPage @ref="_entityPage"
                      TEntity="ProductDto"
                      Config="_config"
                      Service="_service"
                      ExternalFilters="_externalFilters"
                      OnCreateOverride="@(() => OpenDetailDialogAsync(null))"
                      OnEditOverride="@(id => OpenDetailDialogAsync(id))"
                      OnQuickFilterChanged="@HandleQuickFilterChangedAsync">
    <AdditionalToolbarContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            @if (_selectedClassificationNode != null)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Info" OnClose="ClearClassificationFilter"
                         Icon="@Icons.Material.Outlined.AccountTree">
                    @_selectedClassificationNode.Name
                </MudChip>
            }
            <MudTooltip Text="@TranslationService.GetTranslation("product.filterByClassification", "Filtra per Classificazione")">
                <PrymIconButton Icon="@Icons.Material.Outlined.AccountTree"
                                Color="@(_selectedClassificationNode != null ? Color.Info : Color.Default)"
                                Size="Size.Small"
                                OnClick="OpenClassificationFilterAsync" />
            </MudTooltip>
            <MudDivider Vertical FlexItem />
            <MudTooltip Text="@TranslationService.GetTranslation("product.bulkCatalogUpdate", "Aggiornamento Catalogo in Blocco")">
                <PrymIconButton Icon="@Icons.Material.Outlined.AutoFixHigh"
                                Color="Color.Default"
                                Size="Size.Small"
                                OnClick="OpenBulkUpdateDialogAsync" />
            </MudTooltip>
        </MudStack>
    </AdditionalToolbarContent>
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Code")
            {
                <EFTableColumnHeader TItem="ProductDto" PropertyName="Code" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<ProductDto, object>(x => x.Code))">@TranslationService.GetTranslation("field.code", "Codice")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Name")
            {
                <EFTableColumnHeader TItem="ProductDto" PropertyName="Name" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<ProductDto, object>(x => x.Name))">@TranslationService.GetTranslation("field.name", "Nome")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ShortDescription")
            {
                <EFTableColumnHeader TItem="ProductDto" PropertyName="ShortDescription" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<ProductDto, object>(x => x.ShortDescription ?? string.Empty))">@TranslationService.GetTranslation("field.shortDescription", "Descrizione Breve")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "DefaultPrice")
            {
                <EFTableColumnHeader TItem="ProductDto" PropertyName="DefaultPrice" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<ProductDto, object>(x => x.DefaultPrice ?? 0))">@TranslationService.GetTranslation("field.price", "Prezzo")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center ef-min-120" >@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>
    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Code")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.code", "Codice")">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                        @ctx.Item.Code
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "Name")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.name", "Nome")">
                    <div class="d-flex align-center">
                        <MudAvatar Color="@(ctx.Item.IsActive ? Color.Primary : Color.Default)" Size="Size.Small" Class="mr-2">
                            <MudIcon Icon="@Icons.Material.Outlined.Inventory2" />
                        </MudAvatar>
                        <div>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText Typo="Typo.body2">@ctx.Item.Name</MudText>
                                @if (!ctx.Item.IsActive)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" Icon="@Icons.Material.Outlined.PauseCircle">
                                        @TranslationService.GetTranslation("common.inactive", "Inattivo")
                                    </MudChip>
                                }
                            </MudStack>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">ID: @(ctx.Item.Id.ToString()[..Math.Min(8, ctx.Item.Id.ToString().Length)])...</MudText>
                        </div>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "ShortDescription")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.shortDescription", "Descrizione Breve")">
                    <MudText Typo="Typo.body2" Class="text-truncate ef-max-400" >
                        @(string.IsNullOrEmpty(ctx.Item.ShortDescription) ? "-" : ctx.Item.ShortDescription)
                    </MudText>
                </MudTd>
            }
            else if (column.PropertyName == "DefaultPrice")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.price", "Prezzo")" >
                    @if (ctx.Item.DefaultPrice.HasValue)
                    {
                        <MudText Typo="Typo.body2" Class="fw-semibold">@ctx.Item.DefaultPrice.Value.ToString("C2")</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">-</MudText>
                    }
                </MudTd>
            }
        }
    </RowTemplate>
    <AdditionalRowActions Context="item">
        <MudTooltip Text="@TranslationService.GetTranslation("audit.viewHistory", "Cronologia Modifiche")">
            <PrymIconButton Icon="@Icons.Material.Outlined.History"
                            Color="Color.Default"
                            Size="Size.Small"
                            Class="ef-row-actionbutton"
                            OnClick="@(() => ViewProductAuditLog(item))" />
        </MudTooltip>
    </AdditionalRowActions>
</EntityManagementPage>

@code {
    private readonly DialogOptions _auditDialogOptions = new()
    {
        FullScreen = true,
        CloseButton = true,
        MaxWidth = MaxWidth.False
    };

    private EntityManagementPage<ProductDto>? _entityPage;
    private IEntityManagementService<ProductDto> _service = null!;
    private EntityManagementConfig<ProductDto> _config = null!;

    private ClassificationNodeDto? _selectedClassificationNode;
    private string? _activeQuickFilterId;
    private Dictionary<string, object?> _externalFilters = new();

    protected override void OnInitialized()
    {
        _service = new ProductManagementService(ProductService);
        // Default: includeInactive=true so the management page always shows all products
        _externalFilters = BuildFilters();
        _config = new EntityManagementConfig<ProductDto>
        {
            ComponentKey = "ProductManagement",
            PageTitleKey = "product.management",
            PageTitleDefault = "Gestione Prodotti",
            EntityIcon = Icons.Material.Outlined.Inventory2,
            PageRootCssClass = "product-page-root",
            BaseRoute = "/product-management/products",
            ExcelFileName = "Prodotti",
            SearchPlaceholderKey = "product.search",
            SearchPlaceholderDefault = "Cerca prodotti (nome, codice, barcode...)",
            CreateTooltip = "product.createNew",
            EntityTypeName = "Product",
            ShowToggleStatus = false,
            ShowAuditLog = false,
            UseServerSidePaging = true,
            GetDisplayName = p => p.Name,
            GetId = p => p.Id,
            DeleteConfirmMessageKey = "product.confirmDelete",
            BulkDeleteConfirmMessageKey = "product.confirmDeleteMultiple",
            DeleteSuccessMessageKey = "product.productDeleted",
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Catalogo", null, disabled: true),
                new BreadcrumbItem("Prodotti", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Code", DisplayName = "Codice", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "Name", DisplayName = "Nome", IsVisible = true, Order = 1, IsSearchable = true },
                new() { PropertyName = "ShortDescription", DisplayName = "Descrizione Breve", IsVisible = true, Order = 2, IsSearchable = true },
                new() { PropertyName = "DefaultPrice", DisplayName = "Prezzo", IsVisible = true, Order = 3, IsSearchable = false }
            },
            // Quick filters are handled server-side (no client-side Predicate needed).
            // Filter IDs must match the quickFilter values accepted by the server.
            QuickFilters = new()
            {
                new() { Id = "all", Label = "Tutti" },
                new() { Id = "active", Label = "Attivi", Color = Color.Success, Icon = Icons.Material.Outlined.CheckCircle },
                new() { Id = "inactive", Label = "Inattivi", Color = Color.Warning, Icon = Icons.Material.Outlined.PauseCircle },
                new() { Id = "bundle", Label = "Bundle", Color = Color.Info, Icon = Icons.Material.Outlined.Inventory },
                new() { Id = "simple", Label = "Semplici", Color = Color.Primary, Icon = Icons.Material.Outlined.ShoppingBag },
                new() { Id = "with_images", Label = "Con Immagini", Color = Color.Secondary, Icon = Icons.Material.Outlined.Image },
                new() { Id = "recent", Label = "Recenti", Color = Color.Warning, Icon = Icons.Material.Outlined.NewReleases }
            }
        };
    }

    private Dictionary<string, object?> BuildFilters()
    {
        var filters = new Dictionary<string, object?>();
        // Management page always includes inactive products so admins can find and reactivate them.
        filters["IncludeInactive"] = true;
        if (_selectedClassificationNode != null)
            filters["ClassificationNodeId"] = _selectedClassificationNode.Id;
        // Pass active quick filter to server (null / "all" means no additional filter).
        if (!string.IsNullOrEmpty(_activeQuickFilterId) && _activeQuickFilterId != "all")
            filters["QuickFilter"] = _activeQuickFilterId;
        return filters;
    }

    private async Task OpenBulkUpdateDialogAsync()
    {
        try
        {
            var dialog = await DialogService.ShowAsync<BulkProductCatalogUpdateDialog>(string.Empty, EFDialogDefaults.Options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await (_entityPage?.RefreshAsync() ?? Task.CompletedTask);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening bulk catalog update dialog.");
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }

    /// <summary>
    /// Translates the quick filter selection to a server-side ExternalFilter and reloads the list.
    /// Quick filters use server-side paging, so the Predicate is not used.
    /// </summary>
    private async Task HandleQuickFilterChangedAsync(QuickFilter<ProductDto>? filter)
    {
        _activeQuickFilterId = filter?.Id;
        _externalFilters = BuildFilters();
        await (_entityPage?.RefreshAsync() ?? Task.CompletedTask);
    }

    private async Task OpenDetailDialogAsync(Guid? id)
    {
        try
        {
            var parameters = new DialogParameters
            {
                [nameof(ProductDetailDialog.EntityId)] = id
            };
            var dialog = await DialogService.ShowAsync<ProductDetailDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await (_entityPage?.RefreshAsync() ?? Task.CompletedTask);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening product detail dialog for ID {Id}.", id);
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }

    private async Task OpenClassificationFilterAsync()
    {
        try
        {
            var parameters = new DialogParameters
            {
                { "Type", ProductClassificationType.Category },
                { "InitialSelectedId", _selectedClassificationNode?.Id },
                { "Title", TranslationService.GetTranslation("product.filterByClassification", "Filtra per Classificazione") }
            };
            var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ClassificationNodePicker>(string.Empty, parameters, options);
            var result = await dialog.Result;
            if (result is { Canceled: false } && result.Data is ClassificationNodeDto selected)
            {
                _selectedClassificationNode = selected;
                _externalFilters = BuildFilters();
                await (_entityPage?.RefreshAsync() ?? Task.CompletedTask);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening classification filter picker.");
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del selettore.");
        }
    }

    private async Task ClearClassificationFilter()
    {
        _selectedClassificationNode = null;
        _externalFilters = BuildFilters();
        await (_entityPage?.RefreshAsync() ?? Task.CompletedTask);
    }

    private async Task ViewProductAuditLog(ProductDto product)
    {
        try
        {
            var parameters = new DialogParameters<AuditHistoryDialog>
            {
                { x => x.EntityType, "Product" },
                { x => x.EntityId, product.Id },
                { x => x.EntityName, product.Name }
            };

            await DialogService.ShowAsync<AuditHistoryDialog>(
                TranslationService.GetTranslation("audit.historyDialog.title", "Cronologia Modifiche"),
                parameters,
                _auditDialogOptions);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening audit log for product {ProductId}.", product.Id);
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }
}
