@page "/management/price-history"
@using Prym.DTOs.Business
@using Prym.DTOs.PriceHistory
@using Prym.Web.Shared.Management
@using Prym.Web.Shared.Management.Adapters
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager")]
@inject ISupplierPriceHistoryService PriceHistoryService
@inject IBusinessPartyService BusinessPartyService
@inject IProductService ProductService
@inject IAppNotificationService AppNotification
@inject ILogger<SupplierPriceHistoryManagement> Logger

<PageTitle>Storico Prezzi Fornitori</PageTitle>

@* ──────────────────── KPI CARDS ──────────────────── *@
<MudGrid Class="mb-0">
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="1" Class="pa-3">
            <MudText Typo="Typo.caption">Variazione media %</MudText>
            <MudText Typo="Typo.h5" Color="@GetChangeColor(_statistics.AveragePriceChange)">
                @($"{GetChangeSign(_statistics.AveragePriceChange)}{_statistics.AveragePriceChange:N2}%")
            </MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="1" Class="pa-3">
            <MudText Typo="Typo.caption">Totale variazioni</MudText>
            <MudText Typo="Typo.h5">@_statistics.TotalChanges</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="1" Class="pa-3">
            <MudText Typo="Typo.caption">Aumenti</MudText>
            <MudText Typo="Typo.h5" Color="Color.Error">@_statistics.TotalIncreases</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="1" Class="pa-3">
            <MudText Typo="Typo.caption">Riduzioni</MudText>
            <MudText Typo="Typo.h5" Color="Color.Success">@_statistics.TotalDecreases</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@* ──────────────────── FILTER PANEL ──────────────────── *@
<MudPaper Elevation="1" Class="pa-3 mb-0">
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <PrymTextField @bind-Value="_supplierNameFilter" Label="Fornitore" Clearable="true" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <PrymTextField @bind-Value="_productNameFilter" Label="Prodotto" Clearable="true" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <PrymDatePicker @bind-Date="_fromDate" Label="Da" Class="ef-datepicker" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <PrymDatePicker @bind-Date="_toDate" Label="A" Class="ef-datepicker" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <PrymNullableNumericField T="decimal" @bind-Value="_minChangePercentage"
                             Label="Min. variazione %"
                             Min="0"
                             Clearable="true" />
        </MudItem>
        <MudItem xs="12">
            <MudStack Row Spacing="2" Wrap="Wrap.Wrap">
                <MudButton StartIcon="@Icons.Material.Outlined.Search"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="ApplyFiltersAsync">
                    Cerca
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Refresh"
                           Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           OnClick="ResetFiltersAsync">
                    Reset
                </MudButton>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudPaper>

<EntityManagementPage TEntity="PriceHistoryItem"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      ExternalFilters="_externalFilters"
                      OnAfterInitialized="@SyncStatistics">
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "ProductName")
            {
                <EFTableColumnHeader TItem="PriceHistoryItem" PropertyName="ProductName">
                    <MudTableSortLabel SortBy="@(new Func<PriceHistoryItem, object>(x => x.ProductName))">Prodotto</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "SupplierName")
            {
                <EFTableColumnHeader TItem="PriceHistoryItem" PropertyName="SupplierName">
                    <MudTableSortLabel SortBy="@(new Func<PriceHistoryItem, object>(x => x.SupplierName))">Fornitore</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "OldPrice")
            {
                <EFTableColumnHeader TItem="PriceHistoryItem" PropertyName="OldPrice">
                    <MudTableSortLabel SortBy="@(new Func<PriceHistoryItem, object>(x => x.OldPrice))">Prezzo Prec.</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "NewPrice")
            {
                <EFTableColumnHeader TItem="PriceHistoryItem" PropertyName="NewPrice">
                    <MudTableSortLabel SortBy="@(new Func<PriceHistoryItem, object>(x => x.NewPrice))">Nuovo Prezzo</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "PriceChangePercentage")
            {
                <EFTableColumnHeader TItem="PriceHistoryItem" PropertyName="PriceChangePercentage">
                    <MudTableSortLabel SortBy="@(new Func<PriceHistoryItem, object>(x => x.PriceChangePercentage))">Var. %</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ChangeSource")
            {
                <EFTableColumnHeader TItem="PriceHistoryItem" PropertyName="ChangeSource">Fonte</EFTableColumnHeader>
            }
            else if (column.PropertyName == "ChangedByUserName")
            {
                <EFTableColumnHeader TItem="PriceHistoryItem" PropertyName="ChangedByUserName">Modificato da</EFTableColumnHeader>
            }
            else if (column.PropertyName == "ChangedAt")
            {
                <EFTableColumnHeader TItem="PriceHistoryItem" PropertyName="ChangedAt">
                    <MudTableSortLabel SortBy="@(new Func<PriceHistoryItem, object>(x => x.ChangedAt))">Data</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "ProductName")
            {
                <MudTd DataLabel="Prodotto">
                    <MudText Typo="Typo.body2">@ctx.Item.ProductName</MudText>
                    @if (!string.IsNullOrWhiteSpace(ctx.Item.ProductCode))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@ctx.Item.ProductCode</MudText>
                    }
                </MudTd>
            }
            else if (column.PropertyName == "SupplierName")
            {
                <MudTd DataLabel="Fornitore">@ctx.Item.SupplierName</MudTd>
            }
            else if (column.PropertyName == "OldPrice")
            {
                <MudTd DataLabel="Prezzo Prec.">@FormatPrice(ctx.Item.OldPrice, ctx.Item.Currency)</MudTd>
            }
            else if (column.PropertyName == "NewPrice")
            {
                <MudTd DataLabel="Nuovo Prezzo">@FormatPrice(ctx.Item.NewPrice, ctx.Item.Currency)</MudTd>
            }
            else if (column.PropertyName == "PriceChangePercentage")
            {
                <MudTd DataLabel="Var. %">
                    <MudChip T="string" Size="Size.Small" Color="@GetChangeColor(ctx.Item.PriceChangePercentage)">
                        @($"{GetChangeSign(ctx.Item.PriceChangePercentage)}{ctx.Item.PriceChangePercentage:N2}%")
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "ChangeSource")
            {
                <MudTd DataLabel="Fonte">@ctx.Item.ChangeSource</MudTd>
            }
            else if (column.PropertyName == "ChangedByUserName")
            {
                <MudTd DataLabel="Modificato da">@(string.IsNullOrWhiteSpace(ctx.Item.ChangedByUserName) ? "—" : ctx.Item.ChangedByUserName)</MudTd>
            }
            else if (column.PropertyName == "ChangedAt")
            {
                <MudTd DataLabel="Data">@ctx.Item.ChangedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
            }
        }
    </RowTemplate>
</EntityManagementPage>

@code {
    private EntityManagementPage<PriceHistoryItem>? _entityPage;
    private SupplierPriceHistoryManagementService _service = null!;

    private PriceHistoryStatistics _statistics = new();
    private string? _supplierNameFilter;
    private string? _productNameFilter;
    private DateTime? _fromDate = DateTime.Today.AddMonths(-1);
    private DateTime? _toDate = DateTime.Today;
    private decimal? _minChangePercentage;

    private Dictionary<string, object?> _externalFilters = new();

    private readonly EntityManagementConfig<PriceHistoryItem> _config = new()
    {
        ComponentKey       = "SupplierPriceHistoryManagement",
        PageTitleKey       = "priceHistory.title",
        PageTitleDefault   = "Storico Prezzi Fornitori",
        EntityIcon         = Icons.Material.Outlined.TrendingUp,
        PageRootCssClass   = "management-page-root ef-flex-col-fill",
        BaseRoute          = "/management/price-history",
        EntityTypeName     = "Variazione prezzo",
        GetId              = x => x.Id,
        GetDisplayName     = x => $"{x.ProductName} — {x.SupplierName}",
        ShowCreate         = false,
        ShowEdit           = false,
        ShowDelete         = false,
        ShowAuditLog       = false,
        ShowExport         = true,
        ExcelFileName      = "StoricoPrezzi",
        BreadcrumbItems    =
        [
            new BreadcrumbItem("Home", href: "/"),
            new BreadcrumbItem("Storico Prezzi", href: null, disabled: true)
        ],
        Columns =
        [
            new EFTableColumnConfiguration { PropertyName = "ProductName",          DisplayName = "Prodotto",      IsVisible = true, Order = 0 },
            new EFTableColumnConfiguration { PropertyName = "SupplierName",         DisplayName = "Fornitore",     IsVisible = true, Order = 1 },
            new EFTableColumnConfiguration { PropertyName = "OldPrice",             DisplayName = "Prezzo Prec.",  IsVisible = true, Order = 2 },
            new EFTableColumnConfiguration { PropertyName = "NewPrice",             DisplayName = "Nuovo Prezzo",  IsVisible = true, Order = 3 },
            new EFTableColumnConfiguration { PropertyName = "PriceChangePercentage",DisplayName = "Var. %",        IsVisible = true, Order = 4 },
            new EFTableColumnConfiguration { PropertyName = "ChangeSource",         DisplayName = "Fonte",         IsVisible = true, Order = 5 },
            new EFTableColumnConfiguration { PropertyName = "ChangedByUserName",    DisplayName = "Modificato da", IsVisible = true, Order = 6 },
            new EFTableColumnConfiguration { PropertyName = "ChangedAt",            DisplayName = "Data",          IsVisible = true, Order = 7 },
        ]
    };

    protected override void OnInitialized()
    {
        _service = new SupplierPriceHistoryManagementService(PriceHistoryService, BusinessPartyService, ProductService);
        BuildExternalFilters();
    }

    private Task SyncStatistics()
    {
        _statistics = _service.Statistics;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task ApplyFiltersAsync()
    {
        BuildExternalFilters();
        if (_entityPage is not null) await _entityPage.RefreshAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _supplierNameFilter  = null;
        _productNameFilter   = null;
        _fromDate            = DateTime.Today.AddMonths(-1);
        _toDate              = DateTime.Today;
        _minChangePercentage = null;
        BuildExternalFilters();
        if (_entityPage is not null) await _entityPage.RefreshAsync();
    }

    private void BuildExternalFilters()
    {
        _externalFilters = new Dictionary<string, object?>();
        if (!string.IsNullOrWhiteSpace(_supplierNameFilter)) _externalFilters["SupplierName"]        = _supplierNameFilter;
        if (!string.IsNullOrWhiteSpace(_productNameFilter))  _externalFilters["ProductName"]         = _productNameFilter;
        if (_fromDate.HasValue)                              _externalFilters["From"]                = _fromDate.Value;
        if (_toDate.HasValue)                                _externalFilters["To"]                  = _toDate.Value;
        if (_minChangePercentage.HasValue)                   _externalFilters["MinChangePercentage"] = _minChangePercentage.Value;
    }

    private static string FormatPrice(decimal value, string currency) => $"{value:N2} {currency}";

    private Color GetChangeColor(decimal pct) => pct > 0 ? Color.Error : pct < 0 ? Color.Success : Color.Default;

    private string GetChangeSign(decimal pct) => pct > 0 ? "+" : "";
}
