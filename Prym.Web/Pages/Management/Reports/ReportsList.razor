@page "/management/reports"
@using Prym.DTOs.Reports
@attribute [Authorize]

@inject IReportDefinitionService ReportService
@inject ITranslationService TranslationService
@inject IAppNotificationService AppNotification
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ILogger<ReportsList> Logger

<PageTitle>@TranslationService.GetTranslation("reports.title", "Gestione Report")</PageTitle>

<EntityManagementPage TEntity="ReportListItemDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      OnCreateOverride="OpenNewReportDialogAsync"
                      OnEditOverride="@(id => { OpenDesigner(id); return Task.CompletedTask; })">
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Name")
            {
                <EFTableColumnHeader TItem="ReportListItemDto" PropertyName="Name">
                    <MudTableSortLabel SortBy="@(new Func<ReportListItemDto, object>(x => x.Name))">@TranslationService.GetTranslation("field.name", "Nome")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Category")
            {
                <EFTableColumnHeader TItem="ReportListItemDto" PropertyName="Category">
                    <MudTableSortLabel SortBy="@(new Func<ReportListItemDto, object>(x => x.Category ?? string.Empty))">@TranslationService.GetTranslation("reports.category", "Categoria")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "HasDesign")
            {
                <EFTableColumnHeader TItem="ReportListItemDto" PropertyName="HasDesign">
                    <MudTh>@TranslationService.GetTranslation("reports.hasDesign", "Design")</MudTh>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "IsPublic")
            {
                <EFTableColumnHeader TItem="ReportListItemDto" PropertyName="IsPublic">
                    <MudTh>@TranslationService.GetTranslation("reports.visibility", "Visibilità")</MudTh>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "CreatedAt")
            {
                <EFTableColumnHeader TItem="ReportListItemDto" PropertyName="CreatedAt">
                    <MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="@(new Func<ReportListItemDto, object>(x => x.CreatedAt))">@TranslationService.GetTranslation("field.createdAt", "Creato il")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center ef-min-120">@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Name")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.name", "Nome")">
                    <div class="d-flex align-center">
                        <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2">
                            <MudIcon Icon="@Icons.Material.Outlined.Assessment" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2">@ctx.Item.Name</MudText>
                            @if (!string.IsNullOrWhiteSpace(ctx.Item.Description))
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@ctx.Item.Description</MudText>
                            }
                        </div>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "Category")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("reports.category", "Categoria")">
                    @if (!string.IsNullOrWhiteSpace(ctx.Item.Category))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@ctx.Item.Category</MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">-</MudText>
                    }
                </MudTd>
            }
            else if (column.PropertyName == "HasDesign")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("reports.hasDesign", "Design")">
                    @if (ctx.Item.HasDesign)
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.RadioButtonUnchecked" Color="Color.Default" Size="Size.Small" />
                    }
                </MudTd>
            }
            else if (column.PropertyName == "IsPublic")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("reports.visibility", "Visibilità")">
                    <MudChip T="string" Size="Size.Small" Color="@(ctx.Item.IsPublic ? Color.Success : Color.Default)">
                        @(ctx.Item.IsPublic
                            ? TranslationService.GetTranslation("reports.public", "Pubblico")
                            : TranslationService.GetTranslation("reports.private", "Privato"))
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "CreatedAt")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.createdAt", "Creato il")">
                    <MudText Typo="Typo.body2">@ctx.Item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudText>
                </MudTd>
            }
        }
    </RowTemplate>

    <AdditionalRowActions Context="item">
        <MudIconButton Icon="@Icons.Material.Outlined.Draw"
                       Size="Size.Small"
                       Color="Color.Primary"
                       Title="@TranslationService.GetTranslation("reports.designer", "Apri Designer")"
                       OnClick="@(() => OpenDesigner(item.Id))" />
        <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                       Size="Size.Small"
                       Color="Color.Secondary"
                       Disabled="@(!item.HasDesign)"
                       Title="@TranslationService.GetTranslation("reports.viewer", "Visualizza Report")"
                       OnClick="@(() => OpenViewer(item.Id))" />
    </AdditionalRowActions>
</EntityManagementPage>

@code {
    private EntityManagementPage<ReportListItemDto>? _entityPage;
    private IEntityManagementService<ReportListItemDto> _service = null!;
    private EntityManagementConfig<ReportListItemDto> _config = null!;

    protected override void OnInitialized()
    {
        _service = new ReportManagementService(ReportService);
        _config = new EntityManagementConfig<ReportListItemDto>
        {
            ComponentKey = "ReportManagement",
            PageTitleKey = "reports.title",
            PageTitleDefault = "Gestione Report",
            EntityIcon = Icons.Material.Outlined.Assessment,
            PageRootCssClass = "reports-page-root",
            BaseRoute = "/management/reports",
            ExcelFileName = "Report",
            SearchPlaceholderKey = "reports.search",
            SearchPlaceholderDefault = "Cerca report",
            CreateTooltip = "reports.newReport",
            EntityTypeName = "Report",
            ShowToggleStatus = false,
            ShowEdit = false,
            GetDisplayName = r => r.Name,
            GetId = r => r.Id,
            GetIsActive = r => r.IsActive,
            BreadcrumbItems =
            [
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Gestione", null, disabled: true),
                new BreadcrumbItem("Report", null, disabled: true)
            ],
            Columns =
            [
                new() { PropertyName = "Name",      DisplayName = "Nome",       IsVisible = true, Order = 0, IsSearchable = true  },
                new() { PropertyName = "Category",  DisplayName = "Categoria",  IsVisible = true, Order = 1, IsSearchable = true  },
                new() { PropertyName = "HasDesign", DisplayName = "Design",     IsVisible = true, Order = 2, IsSearchable = false },
                new() { PropertyName = "IsPublic",  DisplayName = "Visibilità", IsVisible = true, Order = 3, IsSearchable = false },
                new() { PropertyName = "CreatedAt", DisplayName = "Creato il",  IsVisible = true, Order = 4, IsSearchable = false }
            ],
            QuickFilters =
            [
                new() { Id = "all",        Label = "Tutti",         Predicate = _ => true,              Description = "Mostra tutti i report" },
                new() { Id = "with_design",Label = "Con Design",    Predicate = r => r.HasDesign,        Color = Color.Success, Icon = Icons.Material.Outlined.Draw,          Description = "Report con RDLC salvato" },
                new() { Id = "public",     Label = "Pubblici",      Predicate = r => r.IsPublic,         Color = Color.Info,    Icon = Icons.Material.Outlined.Public,         Description = "Report visibili a tutti i ruoli" },
                new() { Id = "private",    Label = "Privati",       Predicate = r => !r.IsPublic,        Color = Color.Default, Icon = Icons.Material.Outlined.Lock,           Description = "Report riservati" },
                new() { Id = "no_design",  Label = "Senza Design",  Predicate = r => !r.HasDesign,       Color = Color.Warning, Icon = Icons.Material.Outlined.DesignServices, Description = "Report senza RDLC" }
            ]
        };
    }

    private void OpenDesigner(Guid reportId)
        => Navigation.NavigateTo($"/management/reports/designer/{reportId}");

    private void OpenViewer(Guid reportId)
        => Navigation.NavigateTo($"/management/reports/viewer/{reportId}");

    private async Task OpenNewReportDialogAsync()
    {
        try
        {
            var parameters = new DialogParameters
            {
                ["OnReportCreated"] = EventCallback.Factory.Create<ReportDefinitionDto>(this, OnReportCreatedAsync),
            };
            var options = EFDialogDefaults.Options;
            await DialogService.ShowAsync<CreateReportDialog>(string.Empty, parameters, options);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening CreateReportDialog.");
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }

    private async Task OnReportCreatedAsync(ReportDefinitionDto created)
    {
        await (_entityPage?.RefreshAsync() ?? Task.CompletedTask);
        Navigation.NavigateTo($"/management/reports/designer/{created.Id}");
    }
}
