@page "/store/cart-sessions"
@using Blazored.LocalStorage
@using Prym.DTOs.RetailCart
@using Prym.Web.Shared.Management
@using Prym.Web.Shared.Management.Adapters
@using Prym.Web.Shared.Components.Dialogs.Store
@attribute [Authorize]
@inject IRetailCartSessionService CartService
@inject ILocalStorageService LocalStorage
@inject IDialogService DialogService
@inject IAppNotificationService AppNotification
@inject ILogger<RetailCartManagement> Logger

<PageTitle>Sessioni Carrello</PageTitle>

@* ──────────────────── FILTER PANEL ──────────────────── *@
<MudPaper Elevation="1" Class="pa-3 mb-0">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="6" md="2">
            <MudDatePicker @bind-Date="_filterFrom"
                           Label="Da"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="ef-datepicker" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudDatePicker @bind-Date="_filterTo"
                           Label="A"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="ef-datepicker" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudTextField @bind-Value="_filterSalesChannel"
                          Label="Canale vendita"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Clearable="true" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudTextField @bind-Value="_lookupSessionId"
                          Label="Carica sessione da ID"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Placeholder="GUID sessione" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudTextField @bind-Value="_newSessionChannel"
                          Label="Canale nuova sessione"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Placeholder="POS" />
        </MudItem>
        <MudItem xs="12">
            <MudStack Row Spacing="2" Wrap="Wrap.Wrap">
                <MudButton StartIcon="@Icons.Material.Outlined.Search"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           OnClick="ApplyFiltersAsync">
                    Aggiorna
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Link"
                           Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           OnClick="LoadSessionByIdAsync"
                           Disabled="@string.IsNullOrWhiteSpace(_lookupSessionId)">
                    Carica Sessione
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Clear"
                           Variant="Variant.Text"
                           OnClick="ResetFiltersAsync">
                    Ripristina filtri
                </MudButton>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudPaper>

<EntityManagementPage TEntity="CartSessionDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      ExternalFilters="_externalFilters"
                      OnCreateOverride="CreateSessionAsync">
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Id")
            {
                <EFTableColumnHeader TItem="CartSessionDto" PropertyName="Id">Sessione</EFTableColumnHeader>
            }
            else if (column.PropertyName == "SalesChannel")
            {
                <EFTableColumnHeader TItem="CartSessionDto" PropertyName="SalesChannel">Canale</EFTableColumnHeader>
            }
            else if (column.PropertyName == "FinalTotal")
            {
                <EFTableColumnHeader TItem="CartSessionDto" PropertyName="FinalTotal">
                    <MudTableSortLabel SortBy="@(new Func<CartSessionDto, object>(x => x.FinalTotal))">Totale</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ItemsCount")
            {
                <EFTableColumnHeader TItem="CartSessionDto" PropertyName="ItemsCount">Articoli</EFTableColumnHeader>
            }
            else if (column.PropertyName == "CreatedAt")
            {
                <EFTableColumnHeader TItem="CartSessionDto" PropertyName="CreatedAt">
                    <MudTableSortLabel SortBy="@(new Func<CartSessionDto, object>(x => x.CreatedAt))">Creata</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "UpdatedAt")
            {
                <EFTableColumnHeader TItem="CartSessionDto" PropertyName="UpdatedAt">
                    <MudTableSortLabel SortBy="@(new Func<CartSessionDto, object>(x => x.UpdatedAt))">Aggiornata</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center ef-min-120">Azioni</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Id")
            {
                <MudTd DataLabel="Sessione">
                    <MudText Typo="Typo.body2">@ShortId(ctx.Item.Id)</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@ctx.Item.Id</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "SalesChannel")
            {
                <MudTd DataLabel="Canale">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                        @(string.IsNullOrWhiteSpace(ctx.Item.SalesChannel) ? "N/D" : ctx.Item.SalesChannel)
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "FinalTotal")
            {
                <MudTd DataLabel="Totale">@FormatCurrency(ctx.Item.FinalTotal, ctx.Item.Currency)</MudTd>
            }
            else if (column.PropertyName == "ItemsCount")
            {
                <MudTd DataLabel="Articoli">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(ctx.Item)" Variant="Variant.Filled">
                        @ctx.Item.Items.Count — @GetStatusText(ctx.Item)
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "CreatedAt")
            {
                <MudTd DataLabel="Creata">@ctx.Item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
            }
            else if (column.PropertyName == "UpdatedAt")
            {
                <MudTd DataLabel="Aggiornata">@ctx.Item.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
            }
        }
        <MudTd Class="text-center">
            <MudStack Row Spacing="0" Justify="Justify.Center">
                <MudTooltip Text="Dettagli sessione">
                    <MudIconButton Icon="@Icons.Material.Outlined.Info"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   Class="ef-row-actionbutton"
                                   OnClick="@(() => OpenDetailDialogAsync(ctx.Item))" />
                </MudTooltip>
                <MudTooltip Text="Svuota sessione">
                    <MudIconButton Icon="@Icons.Material.Outlined.DeleteSweep"
                                   Size="Size.Small"
                                   Color="Color.Warning"
                                   Class="ef-row-actionbutton"
                                   OnClick="@(() => ClearSessionItemsAsync(ctx.Item))" />
                </MudTooltip>
            </MudStack>
        </MudTd>
    </RowTemplate>
</EntityManagementPage>

@code {
    private EntityManagementPage<CartSessionDto>? _entityPage;
    private RetailCartManagementService _service = null!;

    private DateTime? _filterFrom = DateTime.Today.AddDays(-30);
    private DateTime? _filterTo;
    private string? _filterSalesChannel;
    private string? _lookupSessionId;
    private string? _newSessionChannel;

    private Dictionary<string, object?> _externalFilters = new();

    private readonly EntityManagementConfig<CartSessionDto> _config = new()
    {
        ComponentKey     = "RetailCartManagement",
        PageTitleKey     = "cart.sessions.title",
        PageTitleDefault = "Sessioni Carrello",
        EntityIcon       = Icons.Material.Outlined.ShoppingCart,
        PageRootCssClass = "management-page-root ef-flex-col-fill",
        BaseRoute        = "/store/cart-sessions",
        EntityTypeName   = "Sessione carrello",
        GetId            = s => s.Id,
        GetDisplayName   = s => $"{ShortId(s.Id)} — {(string.IsNullOrWhiteSpace(s.SalesChannel) ? "N/D" : s.SalesChannel)}",
        ShowEdit         = false,
        ShowAuditLog     = false,
        ShowExport       = true,
        ExcelFileName    = "SessioniCarrello",
        BreadcrumbItems  =
        [
            new BreadcrumbItem("Home", href: "/"),
            new BreadcrumbItem("Sessioni Carrello", href: null, disabled: true)
        ],
        Columns =
        [
            new EFTableColumnConfiguration { PropertyName = "Id",          DisplayName = "Sessione",  IsVisible = true, Order = 0 },
            new EFTableColumnConfiguration { PropertyName = "SalesChannel",DisplayName = "Canale",    IsVisible = true, Order = 1 },
            new EFTableColumnConfiguration { PropertyName = "FinalTotal",  DisplayName = "Totale",    IsVisible = true, Order = 2 },
            new EFTableColumnConfiguration { PropertyName = "ItemsCount",  DisplayName = "Articoli",  IsVisible = true, Order = 3 },
            new EFTableColumnConfiguration { PropertyName = "CreatedAt",   DisplayName = "Creata",    IsVisible = true, Order = 4 },
            new EFTableColumnConfiguration { PropertyName = "UpdatedAt",   DisplayName = "Aggiornata",IsVisible = true, Order = 5 },
        ],
        QuickFilters =
        [
            new QuickFilter<CartSessionDto> { Id = "all",     Label = "Tutte",       Predicate = _ => true },
            new QuickFilter<CartSessionDto> { Id = "active",  Label = "Con articoli",Predicate = s => s.Items.Count > 0 },
            new QuickFilter<CartSessionDto> { Id = "empty",   Label = "Vuote",       Predicate = s => s.Items.Count == 0 },
            new QuickFilter<CartSessionDto> { Id = "discount",Label = "Con sconto",  Predicate = s => s.TotalDiscountAmount > 0 },
        ]
    };

    protected override void OnInitialized()
    {
        _service = new RetailCartManagementService(CartService, LocalStorage);
        BuildExternalFilters();
    }

    private async Task ApplyFiltersAsync()
    {
        BuildExternalFilters();
        if (_entityPage is not null) await _entityPage.RefreshAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _filterFrom         = DateTime.Today.AddDays(-30);
        _filterTo           = null;
        _filterSalesChannel = null;
        BuildExternalFilters();
        if (_entityPage is not null) await _entityPage.RefreshAsync();
    }

    private void BuildExternalFilters()
    {
        _externalFilters = new Dictionary<string, object?>();
        if (_filterFrom.HasValue)                             _externalFilters["From"]         = _filterFrom.Value;
        if (_filterTo.HasValue)                               _externalFilters["To"]           = _filterTo.Value;
        if (!string.IsNullOrWhiteSpace(_filterSalesChannel)) _externalFilters["SalesChannel"] = _filterSalesChannel;
    }

    private async Task CreateSessionAsync()
    {
        try
        {
            var channel = string.IsNullOrWhiteSpace(_newSessionChannel) ? "POS" : _newSessionChannel.Trim();
            await _service.CreateSessionAsync(channel);
            AppNotification.ShowSuccess($"Sessione creata (canale: {channel}).");
            if (_entityPage is not null) await _entityPage.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating cart session.");
            AppNotification.ShowError("Errore durante la creazione della sessione.");
        }
    }

    private async Task LoadSessionByIdAsync()
    {
        if (!Guid.TryParse(_lookupSessionId?.Trim(), out var sessionId))
        {
            AppNotification.ShowError("ID sessione non valido.");
            return;
        }

        try
        {
            var session = await _service.LoadByIdAsync(sessionId);
            if (session is null)
            {
                AppNotification.ShowWarning("Sessione non trovata.");
                return;
            }
            AppNotification.ShowSuccess("Sessione caricata.");
            _lookupSessionId = null;
            if (_entityPage is not null) await _entityPage.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading session by ID {SessionId}.", sessionId);
            AppNotification.ShowError("Errore durante il caricamento della sessione.");
        }
    }

    private async Task OpenDetailDialogAsync(CartSessionDto session)
    {
        var parameters = new DialogParameters<CartSessionDetailDialog>
        {
            { x => x.Session, session }
        };
        await DialogService.ShowAsync<CartSessionDetailDialog>(string.Empty, parameters, EFDialogDefaults.Options);
    }

    private async Task ClearSessionItemsAsync(CartSessionDto session)
    {
        if (session.Items.Count == 0)
        {
            AppNotification.ShowInfo("La sessione è già vuota.");
            return;
        }

        try
        {
            await _service.ClearSessionAsync(session.Id);
            AppNotification.ShowSuccess("Sessione svuotata.");
            if (_entityPage is not null) await _entityPage.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error clearing cart session {SessionId}.", session.Id);
            AppNotification.ShowError("Errore durante lo svuotamento della sessione.");
        }
    }

    // ─────────────────────────────────────────────────────────
    //  Helpers
    // ─────────────────────────────────────────────────────────

    private static string ShortId(Guid id) => id.ToString("N")[..8].ToUpperInvariant();

    private static string FormatCurrency(decimal value, string currency)
        => $"{value:N2} {currency}";

    private static Color GetStatusColor(CartSessionDto session)
        => session.Items.Count == 0 ? Color.Default : session.TotalDiscountAmount > 0 ? Color.Success : Color.Primary;

    private static string GetStatusText(CartSessionDto session)
        => session.Items.Count == 0 ? "Vuota" : session.TotalDiscountAmount > 0 ? "Con sconto" : "Attiva";
}
