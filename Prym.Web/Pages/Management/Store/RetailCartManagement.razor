@page "/store/cart-sessions"
@using Blazored.LocalStorage
@using Prym.DTOs.RetailCart
@using System.Globalization
@attribute [Authorize]
@inject IRetailCartSessionService CartService
@inject ILocalStorageService LocalStorage
@inject IAppNotificationService AppNotification
@inject ILogger<RetailCartManagement> Logger

<PageTitle>Sessioni Carrello</PageTitle>

<div class="management-page-root ef-flex-col-fill">
    <div class="ef-flex-col-fill gap-3">

        <MudPaper Elevation="1" Class="pa-3">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                <MudIcon Icon="@Icons.Material.Outlined.ShoppingCart" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h5">Sessioni Carrello</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_newSessionSalesChannel"
                              Label="Canale nuova sessione"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="ef-min-180" />
                <MudButton StartIcon="@Icons.Material.Outlined.Add"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="CreateSessionAsync"
                           Disabled="_isLoading">
                    Nuova Sessione
                </MudButton>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-3">
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker @bind-Date="_filterFrom"
                                   Label="Da"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="ef-datepicker" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker @bind-Date="_filterTo"
                                   Label="A"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="ef-datepicker" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField @bind-Value="_filterSalesChannel"
                                  Label="Canale vendita"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Clearable="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField @bind-Value="_lookupSessionId"
                                  Label="Carica sessione da ID"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="GUID sessione" />
                </MudItem>
                <MudItem xs="12">
                    <MudStack Row Spacing="2" Wrap="Wrap.Wrap">
                        <MudButton StartIcon="@Icons.Material.Outlined.Search"
                                   Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   OnClick="LoadDataAsync"
                                   Disabled="_isLoading">
                            Aggiorna
                        </MudButton>
                        <MudButton StartIcon="@Icons.Material.Outlined.Link"
                                   Variant="Variant.Outlined"
                                   Color="Color.Secondary"
                                   OnClick="LoadSessionByIdAsync"
                                   Disabled="_isLoading || string.IsNullOrWhiteSpace(_lookupSessionId)">
                            Carica Sessione
                        </MudButton>
                        <MudButton StartIcon="@Icons.Material.Outlined.Clear"
                                   Variant="Variant.Text"
                                   OnClick="ResetFilters">
                            Ripristina filtri
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Elevation="2" Class="flex-grow-1">
            @if (_isLoading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }

            <MudTable Items="FilteredSessions"
                      Dense="true"
                      Hover="true"
                      Striped="true"
                      Loading="_isLoading"
                      T="CartSessionDto"
                      Class="ef-table-sticky-header">
                <HeaderContent>
                    <MudTh>Sessione</MudTh>
                    <MudTh>Cliente</MudTh>
                    <MudTh>Canale</MudTh>
                    <MudTh>Totale</MudTh>
                    <MudTh>Stato</MudTh>
                    <MudTh>Creata</MudTh>
                    <MudTh>Aggiornata</MudTh>
                    <MudTh Class="text-center">Azioni</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Sessione">
                        <MudText Typo="Typo.body2">@ShortId(context.Id)</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Id</MudText>
                    </MudTd>
                    <MudTd DataLabel="Cliente">
                        <MudText Typo="Typo.body2">@GetCustomerText(context.CustomerId)</MudText>
                    </MudTd>
                    <MudTd DataLabel="Canale">
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                            @(string.IsNullOrWhiteSpace(context.SalesChannel) ? "N/D" : context.SalesChannel)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Totale">
                        <MudText Typo="Typo.body2">@FormatCurrency(context.FinalTotal, context.Currency)</MudText>
                    </MudTd>
                    <MudTd DataLabel="Stato">
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context)">
                            @GetStatusText(context)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Creata">
                        <MudText Typo="Typo.body2">@context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                    </MudTd>
                    <MudTd DataLabel="Aggiornata">
                        <MudText Typo="Typo.body2">@context.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                    </MudTd>
                    <MudTd Class="text-center">
                        <MudStack Row Spacing="0" Justify="Justify.Center">
                            <MudIconButton Icon="@(IsExpanded(context.Id) ? Icons.Material.Outlined.ExpandLess : Icons.Material.Outlined.ExpandMore)"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           Title="Dettagli"
                                           OnClick="@(() => ToggleExpanded(context.Id))" />
                            <MudIconButton Icon="@Icons.Material.Outlined.DeleteSweep"
                                           Size="Size.Small"
                                           Color="Color.Warning"
                                           Title="Svuota sessione"
                                           OnClick="@(() => ClearSessionAsync(context))" />
                        </MudStack>
                    </MudTd>
                </RowTemplate>
                <ChildRowContent>
                    @if (IsExpanded(context.Id))
                    {
                        <MudTr>
                            <td colspan="8" class="pa-0">
                                <MudPaper Class="pa-3 ma-2" Elevation="0">
                                    <MudGrid>
                                        <MudItem xs="12" md="4">
                                            <MudText Typo="Typo.subtitle2">Riepilogo</MudText>
                                            <MudText Typo="Typo.body2">Articoli: @context.Items.Count</MudText>
                                            <MudText Typo="Typo.body2">Totale originale: @FormatCurrency(context.OriginalTotal, context.Currency)</MudText>
                                            <MudText Typo="Typo.body2">Sconto totale: @FormatCurrency(context.TotalDiscountAmount, context.Currency)</MudText>
                                            <MudText Typo="Typo.body2">Totale finale: @FormatCurrency(context.FinalTotal, context.Currency)</MudText>
                                        </MudItem>
                                        <MudItem xs="12" md="4">
                                            <MudText Typo="Typo.subtitle2">Coupon</MudText>
                                            @if (context.CouponCodes.Count > 0)
                                            {
                                                <MudStack Row Wrap="Wrap.Wrap" Spacing="1" Class="mt-1">
                                                    @foreach (var coupon in context.CouponCodes)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@coupon</MudChip>
                                                    }
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Class="mud-text-secondary">Nessun coupon applicato.</MudText>
                                            }
                                        </MudItem>
                                        <MudItem xs="12" md="4">
                                            <MudText Typo="Typo.subtitle2">Promozioni</MudText>
                                            @if (context.AppliedPromotions.Count > 0)
                                            {
                                                <MudList T="string" Dense="true" DisablePadding="true">
                                                    @foreach (var promotion in context.AppliedPromotions)
                                                    {
                                                        <MudListItem T="string">
                                                            <MudText Typo="Typo.body2">@promotion.PromotionName (@FormatCurrency(promotion.DiscountAmount, context.Currency))</MudText>
                                                        </MudListItem>
                                                    }
                                                </MudList>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Class="mud-text-secondary">Nessuna promozione applicata.</MudText>
                                            }
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudDivider Class="my-2" />
                                            <MudText Typo="Typo.subtitle2" Class="mb-2">Dettaglio articoli</MudText>
                                            @if (context.Items.Count > 0)
                                            {
                                                <MudSimpleTable Dense="true" Hover="true" Class="overflow-x-auto">
                                                    <thead>
                                                        <tr>
                                                            <th>Prodotto</th>
                                                            <th class="text-right">Q.tà</th>
                                                            <th class="text-right">Prezzo</th>
                                                            <th class="text-right">Sconto</th>
                                                            <th class="text-right">Totale</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var item in context.Items)
                                                        {
                                                            <tr>
                                                                <td>
                                                                    <MudText Typo="Typo.body2">@item.ProductName</MudText>
                                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@(string.IsNullOrWhiteSpace(item.ProductCode) ? item.ProductId.ToString() : item.ProductCode)</MudText>
                                                                </td>
                                                                <td class="text-right">@item.Quantity</td>
                                                                <td class="text-right">@FormatCurrency(item.UnitPrice, context.Currency)</td>
                                                                <td class="text-right">@FormatCurrency(item.PromotionDiscount, context.Currency)</td>
                                                                <td class="text-right">@FormatCurrency(item.FinalLineTotal, context.Currency)</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </MudSimpleTable>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Class="mud-text-secondary">La sessione non contiene articoli.</MudText>
                                            }
                                        </MudItem>
                                    </MudGrid>
                                </MudPaper>
                            </td>
                        </MudTr>
                    }
                </ChildRowContent>
                <NoRecordsContent>
                    <MudText Class="pa-4 mud-text-secondary">Nessuna sessione carrello trovata. Crea una nuova sessione o caricane una tramite ID.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>
    </div>
</div>

@code {
    private const string StorageKey = "retail-cart-management-session-ids";
    private const int MaxTrackedSessions = 50;

    private List<CartSessionDto> _sessions = [];
    private List<Guid> _trackedSessionIds = [];
    private HashSet<Guid> _expandedSessionIds = [];
    private bool _isLoading;

    private DateTime? _filterFrom = DateTime.Today.AddDays(-30);
    private DateTime? _filterTo = DateTime.Today;
    private string? _filterSalesChannel;
    private string _newSessionSalesChannel = "POS";
    private string? _lookupSessionId;

    private IReadOnlyList<CartSessionDto> FilteredSessions =>
        _sessions
            .Where(MatchesDateFilter)
            .Where(MatchesSalesChannelFilter)
            .OrderByDescending(session => session.UpdatedAt)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadTrackedSessionIdsAsync();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        try
        {
            if (_trackedSessionIds.Count == 0)
            {
                _sessions = [];
                _expandedSessionIds.Clear();
                return;
            }

            var loadedSessions = await Task.WhenAll(_trackedSessionIds.Select(LoadTrackedSessionAsync));
            _sessions = loadedSessions
                .Where(session => session is not null)
                .Select(session => session!)
                .OrderByDescending(session => session.UpdatedAt)
                .ToList();

            var validIds = _sessions.Select(session => session.Id).ToList();
            if (validIds.Count != _trackedSessionIds.Count)
            {
                _trackedSessionIds = validIds;
                await SaveTrackedSessionIdsAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading retail cart sessions");
            AppNotification.ShowError("Errore durante il caricamento delle sessioni carrello.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CreateSessionAsync()
    {
        _isLoading = true;
        try
        {
            var session = await CartService.CreateSessionAsync(new CreateCartSessionDto
            {
                SalesChannel = string.IsNullOrWhiteSpace(_newSessionSalesChannel) ? "POS" : _newSessionSalesChannel.Trim(),
                Currency = "EUR"
            });

            await TrackSessionAsync(session.Id);
            ReplaceSession(session);
            _expandedSessionIds.Add(session.Id);

            AppNotification.ShowSuccess($"Sessione carrello #{ShortId(session.Id)} creata.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating retail cart session");
            AppNotification.ShowError("Errore durante la creazione della sessione carrello.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadSessionByIdAsync()
    {
        if (!Guid.TryParse(_lookupSessionId, out var sessionId))
        {
            AppNotification.ShowWarning("Inserisci un ID sessione valido.");
            return;
        }

        _isLoading = true;
        try
        {
            var session = await CartService.GetSessionAsync(sessionId);
            if (session is null)
            {
                AppNotification.ShowWarning("Sessione carrello non trovata.");
                return;
            }

            await TrackSessionAsync(session.Id);
            ReplaceSession(session);
            _expandedSessionIds.Add(session.Id);
            _lookupSessionId = string.Empty;

            AppNotification.ShowSuccess($"Sessione #{ShortId(session.Id)} caricata.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading retail cart session {SessionId}", sessionId);
            AppNotification.ShowError("Errore durante il caricamento della sessione carrello.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ClearSessionAsync(CartSessionDto session)
    {
        _isLoading = true;
        try
        {
            var clearedSession = await CartService.ClearSessionAsync(session.Id);
            if (clearedSession is null)
            {
                _sessions.RemoveAll(current => current.Id == session.Id);
                _trackedSessionIds.RemoveAll(id => id == session.Id);
                _expandedSessionIds.Remove(session.Id);
                await SaveTrackedSessionIdsAsync();
                AppNotification.ShowWarning("Sessione carrello non trovata.");
                return;
            }

            ReplaceSession(clearedSession);
            await TrackSessionAsync(clearedSession.Id);

            AppNotification.ShowSuccess($"Sessione #{ShortId(clearedSession.Id)} svuotata.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error clearing retail cart session {SessionId}", session.Id);
            AppNotification.ShowError("Errore durante lo svuotamento della sessione carrello.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ResetFilters()
    {
        _filterFrom = DateTime.Today.AddDays(-30);
        _filterTo = DateTime.Today;
        _filterSalesChannel = null;
    }

    private async Task LoadTrackedSessionIdsAsync()
    {
        _trackedSessionIds = await LocalStorage.GetItemAsync<List<Guid>>(StorageKey) ?? [];
        _trackedSessionIds = _trackedSessionIds.Distinct().Take(MaxTrackedSessions).ToList();
    }

    private async Task SaveTrackedSessionIdsAsync()
    {
        _trackedSessionIds = _trackedSessionIds.Distinct().Take(MaxTrackedSessions).ToList();
        await LocalStorage.SetItemAsync(StorageKey, _trackedSessionIds);
    }

    private async Task TrackSessionAsync(Guid sessionId)
    {
        _trackedSessionIds.RemoveAll(id => id == sessionId);
        _trackedSessionIds.Insert(0, sessionId);
        await SaveTrackedSessionIdsAsync();
    }

    private async Task<CartSessionDto?> LoadTrackedSessionAsync(Guid sessionId)
    {
        try
        {
            return await CartService.GetSessionAsync(sessionId);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Unable to load retail cart session {SessionId}", sessionId);
            return null;
        }
    }

    private void ReplaceSession(CartSessionDto session)
    {
        _sessions.RemoveAll(current => current.Id == session.Id);
        _sessions.Add(session);
        _sessions = _sessions
            .OrderByDescending(current => current.UpdatedAt)
            .ToList();
    }

    private void ToggleExpanded(Guid sessionId)
    {
        if (!_expandedSessionIds.Add(sessionId))
        {
            _expandedSessionIds.Remove(sessionId);
        }
    }

    private bool IsExpanded(Guid sessionId) => _expandedSessionIds.Contains(sessionId);

    private bool MatchesDateFilter(CartSessionDto session)
    {
        var referenceDate = session.UpdatedAt.ToLocalTime().Date;
        var fromDate = _filterFrom?.Date;
        var toDate = _filterTo?.Date;

        if (fromDate.HasValue && referenceDate < fromDate.Value)
            return false;

        if (toDate.HasValue && referenceDate > toDate.Value)
            return false;

        return true;
    }

    private bool MatchesSalesChannelFilter(CartSessionDto session)
    {
        if (string.IsNullOrWhiteSpace(_filterSalesChannel))
            return true;

        return string.Equals(
            session.SalesChannel?.Trim(),
            _filterSalesChannel.Trim(),
            StringComparison.OrdinalIgnoreCase);
    }

    private static string ShortId(Guid id) => id.ToString()[..8];

    private static string GetCustomerText(Guid? customerId) =>
        customerId.HasValue ? customerId.Value.ToString()[..8] : "—";

    private static string FormatCurrency(decimal amount, string? currency)
    {
        var culture = CultureInfo.GetCultureInfo("it-IT");
        return string.Format(culture, "{0:N2} {1}", amount, string.IsNullOrWhiteSpace(currency) ? "EUR" : currency);
    }

    private static string GetStatusText(CartSessionDto session)
    {
        if (session.Items.Count == 0)
            return "Vuota";

        if (session.TotalDiscountAmount > 0 || session.CouponCodes.Count > 0 || session.AppliedPromotions.Count > 0)
            return "Promozioni";

        return "Attiva";
    }

    private static Color GetStatusColor(CartSessionDto session) => GetStatusText(session) switch
    {
        "Vuota" => Color.Default,
        "Promozioni" => Color.Success,
        _ => Color.Info
    };
}
