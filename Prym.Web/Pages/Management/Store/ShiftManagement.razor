@page "/store/shifts"
@using Prym.DTOs.Store
@using Prym.Web.Services.Store
@using Prym.Web.Shared.Components.Dialogs.Store
@using Prym.Web.Shared.Management.Adapters
@attribute [Authorize]
@inject IShiftService ShiftService
@inject IStoreUserService StoreUserService
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject IAppNotificationService AppNotification
@inject ILogger<ShiftManagement> Logger

<PageTitle>@TranslationService.GetTranslation("shift.management", "Gestione Turni")</PageTitle>

@* Date/operator filter panel — sits above EntityManagementPage *@
<MudPaper Elevation="1" Class="pa-3 mb-0">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="4">
            <MudDatePicker @bind-Date="_filterFrom"
                           Label="@TranslationService.GetTranslation("shift.filter.from", "Da")"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="ef-datepicker" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudDatePicker @bind-Date="_filterTo"
                           Label="@TranslationService.GetTranslation("shift.filter.to", "A")"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="ef-datepicker" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudSelect @bind-Value="_filterOperatorId"
                       Label="@TranslationService.GetTranslation("shift.filter.operator", "Operatore")"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Clearable="true"
                       Class="ef-select">
                @foreach (var op in _operators)
                {
                    <MudSelectItem Value="@((Guid?)op.Id)">@op.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12">
            <MudStack Row Spacing="2">
                <PrymButton Variant="Variant.Filled" Color="Color.Primary"
                            StartIcon="@Icons.Material.Outlined.Search"
                            OnClick="ApplyFiltersAsync">
                    @TranslationService.GetTranslation("common.search", "Cerca")
                </PrymButton>
                <PrymButton Variant="Variant.Outlined" Color="Color.Default"
                            StartIcon="@Icons.Material.Outlined.Clear"
                            OnClick="ClearFiltersAsync">
                    @TranslationService.GetTranslation("common.clear", "Pulisci")
                </PrymButton>
                <MudSpacer />
                <PrymIconButton Icon="@Icons.Material.Outlined.CalendarMonth"
                                Title="@TranslationService.GetTranslation("shift.calendar", "Calendario Turni")"
                                Href="/store/shifts/calendar"
                                Color="Color.Primary"
                                Variant="Variant.Outlined" />
            </MudStack>
        </MudItem>
    </MudGrid>
</MudPaper>

<EntityManagementPage TEntity="CashierShiftDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      ExternalFilters="_externalFilters"
                      OnCreateOverride="@(() => OpenDialogAsync(null))"
                      OnEditOverride="@(id => OpenDialogAsync(id))">
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "StoreUserName")
            {
                <EFTableColumnHeader TItem="CashierShiftDto" PropertyName="StoreUserName" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<CashierShiftDto, object>(x => x.StoreUserName))">@TranslationService.GetTranslation("shift.operator", "Operatore")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "PosName")
            {
                <EFTableColumnHeader TItem="CashierShiftDto" PropertyName="PosName" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<CashierShiftDto, object>(x => x.PosName ?? string.Empty))">@TranslationService.GetTranslation("shift.pos", "Cassa")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ShiftStart")
            {
                <EFTableColumnHeader TItem="CashierShiftDto" PropertyName="ShiftStart" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<CashierShiftDto, object>(x => x.ShiftStart))">@TranslationService.GetTranslation("shift.start", "Inizio")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ShiftEnd")
            {
                <EFTableColumnHeader TItem="CashierShiftDto" PropertyName="ShiftEnd" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<CashierShiftDto, object>(x => x.ShiftEnd))">@TranslationService.GetTranslation("shift.end", "Fine")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Status")
            {
                <EFTableColumnHeader TItem="CashierShiftDto" PropertyName="Status" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<CashierShiftDto, object>(x => x.Status))">@TranslationService.GetTranslation("field.status", "Stato")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Notes")
            {
                <EFTableColumnHeader TItem="CashierShiftDto" PropertyName="Notes" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudText Typo="Typo.body2">@TranslationService.GetTranslation("shift.notes", "Note")</MudText>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center ef-min-120">@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "StoreUserName")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("shift.operator", "Operatore")">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">@ctx.Item.StoreUserName</MudText>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "PosName")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("shift.pos", "Cassa")">
                    @if (!string.IsNullOrEmpty(ctx.Item.PosName))
                    {
                        <MudText Typo="Typo.body2">@ctx.Item.PosName</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                    }
                </MudTd>
            }
            else if (column.PropertyName == "ShiftStart")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("shift.start", "Inizio")">
                    <MudText Typo="Typo.body2">@ctx.Item.ShiftStart.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "ShiftEnd")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("shift.end", "Fine")">
                    <MudText Typo="Typo.body2">@ctx.Item.ShiftEnd.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Status")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.status", "Stato")">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(ctx.Item.Status)">
                        @GetStatusText(ctx.Item.Status)
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "Notes")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("shift.notes", "Note")">
                    <MudText Typo="Typo.body2">@(ctx.Item.Notes ?? "—")</MudText>
                </MudTd>
            }
        }
    </RowTemplate>
</EntityManagementPage>

@code {
    private EntityManagementPage<CashierShiftDto>? _entityPage;
    private IEntityManagementService<CashierShiftDto> _service = null!;
    private EntityManagementConfig<CashierShiftDto> _config = null!;
    private Dictionary<string, object?> _externalFilters = new();

    private List<StoreUserDto> _operators = [];
    private DateTime? _filterFrom = DateTime.Today;
    private DateTime? _filterTo = DateTime.Today.AddDays(30);
    private Guid? _filterOperatorId;

    protected override async Task OnInitializedAsync()
    {
        _service = new ShiftManagementService(ShiftService);
        _config = new EntityManagementConfig<CashierShiftDto>
        {
            ComponentKey = "ShiftManagement",
            PageTitleKey = "shift.management",
            PageTitleDefault = "Gestione Turni",
            EntityIcon = Icons.Material.Outlined.Schedule,
            PageRootCssClass = "shift-management-page-root",
            BaseRoute = "/store/shifts",
            ExcelFileName = "Turni",
            SearchPlaceholderKey = "shift.search",
            SearchPlaceholderDefault = "Cerca per operatore, cassa o note…",
            EntityTypeName = "Shift",
            ShowDelete = true,
            ShowEdit = true,
            ShowAuditLog = false,
            DeleteConfirmMessageKey = "shift.confirmDelete",
            DeleteSuccessMessageKey = "shift.deleted",
            DeleteErrorMessageKey = "shift.deleteError",
            BulkDeleteConfirmMessageKey = "shift.confirmDeleteMultiple",
            GetDisplayName = s => $"{s.StoreUserName} {s.ShiftStart.ToLocalTime():dd/MM/yyyy HH:mm}",
            GetId = s => s.Id,
            BreadcrumbItems =
            [
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Store", null, disabled: true),
                new BreadcrumbItem("Turni", null, disabled: true)
            ],
            Columns =
            [
                new() { PropertyName = "StoreUserName", DisplayName = "Operatore", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "PosName", DisplayName = "Cassa", IsVisible = true, Order = 1, IsSearchable = true },
                new() { PropertyName = "ShiftStart", DisplayName = "Inizio", IsVisible = true, Order = 2, IsSearchable = false },
                new() { PropertyName = "ShiftEnd", DisplayName = "Fine", IsVisible = true, Order = 3, IsSearchable = false },
                new() { PropertyName = "Status", DisplayName = "Stato", IsVisible = true, Order = 4, IsSearchable = false },
                new() { PropertyName = "Notes", DisplayName = "Note", IsVisible = true, Order = 5, IsSearchable = true }
            ],
            QuickFilters =
            [
                new() { Id = "all",         Label = "Tutti",       Predicate = _ => true,                                              Description = "Mostra tutti i turni" },
                new() { Id = "scheduled",   Label = "Pianificati", Predicate = s => s.Status == ShiftStatus.Scheduled,   Color = Color.Info,    Icon = Icons.Material.Outlined.Event,        Description = "Turni pianificati" },
                new() { Id = "inprogress",  Label = "In corso",    Predicate = s => s.Status == ShiftStatus.InProgress,  Color = Color.Warning, Icon = Icons.Material.Outlined.PlayArrow,    Description = "Turni in corso" },
                new() { Id = "completed",   Label = "Completati",  Predicate = s => s.Status == ShiftStatus.Completed,   Color = Color.Success, Icon = Icons.Material.Outlined.CheckCircle,  Description = "Turni completati" },
                new() { Id = "cancelled",   Label = "Annullati",   Predicate = s => s.Status == ShiftStatus.Cancelled,   Color = Color.Error,   Icon = Icons.Material.Outlined.Cancel,       Description = "Turni annullati" }
            ]
        };

        _operators = await StoreUserService.GetAllAsync();
        RebuildExternalFilters();
    }

    private void RebuildExternalFilters()
    {
        _externalFilters = new Dictionary<string, object?>();
        if (_filterFrom.HasValue)
            _externalFilters["From"] = DateOnly.FromDateTime(_filterFrom.Value);
        if (_filterTo.HasValue)
            _externalFilters["To"] = DateOnly.FromDateTime(_filterTo.Value);
        if (_filterOperatorId.HasValue)
            _externalFilters["OperatorId"] = _filterOperatorId.Value;
    }

    private async Task ApplyFiltersAsync()
    {
        RebuildExternalFilters();
        await (_entityPage?.RefreshAsync() ?? Task.CompletedTask);
    }

    private async Task ClearFiltersAsync()
    {
        _filterFrom = DateTime.Today;
        _filterTo = DateTime.Today.AddDays(30);
        _filterOperatorId = null;
        RebuildExternalFilters();
        await (_entityPage?.RefreshAsync() ?? Task.CompletedTask);
    }

    private async Task OpenDialogAsync(Guid? shiftId)
    {
        try
        {
            var parameters = new DialogParameters<ShiftDetailDialog>
            {
                { x => x.ShiftId, shiftId }
            };

            var dialog = await DialogService.ShowAsync<ShiftDetailDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            var result = await dialog.Result;

            if (result is { Canceled: false })
                await ApplyFiltersAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening shift dialog for ID {ShiftId}.", shiftId);
            AppNotification.ShowWarning(TranslationService.GetTranslation("shift.dialogOpenError", "Si è verificato un errore nell'apertura del dialogo."));
        }
    }

    private static Color GetStatusColor(ShiftStatus status) => status switch
    {
        ShiftStatus.Scheduled  => Color.Info,
        ShiftStatus.InProgress => Color.Warning,
        ShiftStatus.Completed  => Color.Success,
        ShiftStatus.Cancelled  => Color.Error,
        _                      => Color.Default
    };

    private string GetStatusText(ShiftStatus status) => status switch
    {
        ShiftStatus.Scheduled  => TranslationService.GetTranslation("shift.status.scheduled", "Pianificato"),
        ShiftStatus.InProgress => TranslationService.GetTranslation("shift.status.inProgress", "In corso"),
        ShiftStatus.Completed  => TranslationService.GetTranslation("shift.status.completed", "Completato"),
        ShiftStatus.Cancelled  => TranslationService.GetTranslation("shift.status.cancelled", "Annullato"),
        _                      => status.ToString()
    };
}
