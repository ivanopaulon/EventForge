@page "/business/fidelity-cards"
@using Prym.DTOs.Business.Fidelity
@using Prym.Web.Shared.Components.Fidelity
@using Prym.Web.Shared.Management.Adapters
@attribute [Authorize]
@inject IFidelityService FidelityService
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject IAppNotificationService AppNotification
@inject ILogger<FidelityCardManagement> Logger

<PageTitle>@TranslationService.GetTranslation("fidelity.management", "Gestione Carte Fedeltà")</PageTitle>

<EntityManagementPage TEntity="FidelityCardDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      OnCreateOverride="@(() => OpenCreateDialogAsync(null))"
                      OnEditOverride="@(id => OpenCreateDialogAsync(id))">
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "CardNumber")
            {
                <EFTableColumnHeader TItem="FidelityCardDto" PropertyName="CardNumber" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<FidelityCardDto, object>(x => x.CardNumber))">@TranslationService.GetTranslation("fidelity.cardNumber", "Numero Carta")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "TierName")
            {
                <EFTableColumnHeader TItem="FidelityCardDto" PropertyName="TierName" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<FidelityCardDto, object>(x => x.TierName ?? string.Empty))">@TranslationService.GetTranslation("fidelity.tier", "Livello")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Status")
            {
                <EFTableColumnHeader TItem="FidelityCardDto" PropertyName="Status" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<FidelityCardDto, object>(x => x.Status.ToString()))">@TranslationService.GetTranslation("field.status", "Stato")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "CurrentPoints")
            {
                <EFTableColumnHeader TItem="FidelityCardDto" PropertyName="CurrentPoints" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<FidelityCardDto, object>(x => x.CurrentPoints))">@TranslationService.GetTranslation("fidelity.points", "Punti")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "DiscountPercentage")
            {
                <EFTableColumnHeader TItem="FidelityCardDto" PropertyName="DiscountPercentage" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<FidelityCardDto, object>(x => x.DiscountPercentage))">@TranslationService.GetTranslation("fidelity.discountPercentage", "Sconto %")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ValidTo")
            {
                <EFTableColumnHeader TItem="FidelityCardDto" PropertyName="ValidTo" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<FidelityCardDto, object>(x => x.ValidTo))">@TranslationService.GetTranslation("fidelity.validTo", "Scadenza")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center ef-min-120">@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "CardNumber")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("fidelity.cardNumber", "Numero Carta")">
                    <div class="d-flex align-center">
                        <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2" Style="@GetTierAvatarStyle(ctx.Item.TierColor)">
                            <MudIcon Icon="@Icons.Material.Outlined.CardMembership" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2" Class="fw-semibold">@ctx.Item.CardNumber</MudText>
                            @if (ctx.Item.BusinessPartyId.HasValue)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@TranslationService.GetTranslation("fidelity.associatedCustomer", "Cliente associato")</MudText>
                            }
                        </div>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "TierName")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("fidelity.tier", "Livello")">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Style="@GetTierChipStyle(ctx.Item.TierColor)">@(ctx.Item.TierName ?? "—")</MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "Status")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.status", "Stato")">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(ctx.Item.Status)" Variant="Variant.Filled">
                        @GetStatusLabel(ctx.Item.Status)
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "CurrentPoints")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("fidelity.points", "Punti")">
                    <MudText Typo="Typo.body2" Class="fw-semibold">@ctx.Item.CurrentPoints</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">/ @ctx.Item.TotalPointsEarned @TranslationService.GetTranslation("fidelity.totalPoints", "totali")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "DiscountPercentage")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("fidelity.discountPercentage", "Sconto %")">
                    @if (ctx.Item.DiscountPercentage > 0)
                    {
                        <MudText Typo="Typo.body2">@ctx.Item.DiscountPercentage.ToString("F1")%</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                    }
                </MudTd>
            }
            else if (column.PropertyName == "ValidTo")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("fidelity.validTo", "Scadenza")">
                    <MudText Typo="Typo.body2" Color="@(ctx.Item.ValidTo < DateTime.UtcNow ? Color.Error : Color.Default)">
                        @ctx.Item.ValidTo.ToString("dd/MM/yyyy")
                    </MudText>
                </MudTd>
            }
        }
    </RowTemplate>

    <AdditionalRowActions Context="card">
        <MudTooltip Text="@TranslationService.GetTranslation("fidelity.managePoints", "Gestisci Punti")">
            <PrymIconButton Icon="@Icons.Material.Outlined.AddCircleOutline"
                            Size="Size.Small"
                            Color="Color.Primary"
                            Class="ef-row-actionbutton"
                            OnClick="@(() => OpenManagePointsDialogAsync(card))" />
        </MudTooltip>
        <MudTooltip Text="@TranslationService.GetTranslation("fidelity.pointsHistory", "Storico Transazioni")">
            <PrymIconButton Icon="@Icons.Material.Outlined.History"
                            Size="Size.Small"
                            Color="Color.Info"
                            Class="ef-row-actionbutton"
                            OnClick="@(() => OpenHistoryDialogAsync(card))" />
        </MudTooltip>
        @if (card.Status == FidelityCardStatus.Active)
        {
            <MudTooltip Text="@TranslationService.GetTranslation("fidelity.suspend", "Sospendi")">
                <PrymIconButton Icon="@Icons.Material.Outlined.PauseCircleOutline"
                                Size="Size.Small"
                                Color="Color.Warning"
                                Class="ef-row-actionbutton"
                                OnClick="@(() => SuspendCardAsync(card))" />
            </MudTooltip>
        }
        @if (card.Status == FidelityCardStatus.Suspended)
        {
            <MudTooltip Text="@TranslationService.GetTranslation("fidelity.activate", "Attiva")">
                <PrymIconButton Icon="@Icons.Material.Outlined.PlayCircleOutline"
                                Size="Size.Small"
                                Color="Color.Success"
                                Class="ef-row-actionbutton"
                                OnClick="@(() => ActivateCardAsync(card))" />
            </MudTooltip>
        }
        @if (card.Status != FidelityCardStatus.Revoked)
        {
            <MudTooltip Text="@TranslationService.GetTranslation("fidelity.revoke", "Revoca")">
                <PrymIconButton Icon="@Icons.Material.Outlined.Cancel"
                                Size="Size.Small"
                                Color="Color.Error"
                                Class="ef-row-actionbutton"
                                OnClick="@(() => RevokeCardAsync(card))" />
            </MudTooltip>
        }
    </AdditionalRowActions>
</EntityManagementPage>

@code {
    private EntityManagementPage<FidelityCardDto>? _entityPage;
    private IEntityManagementService<FidelityCardDto> _service = null!;
    private EntityManagementConfig<FidelityCardDto> _config = null!;

    protected override void OnInitialized()
    {
        _service = new FidelityCardManagementService(FidelityService);
        _config = new EntityManagementConfig<FidelityCardDto>
        {
            ComponentKey = "FidelityCardManagement",
            PageTitleKey = "fidelity.management",
            PageTitleDefault = "Gestione Carte Fedeltà",
            EntityIcon = Icons.Material.Outlined.CardMembership,
            PageRootCssClass = "fidelity-card-page-root",
            BaseRoute = "/business/fidelity-cards",
            ExcelFileName = "CarteFedeltà",
            SearchPlaceholderKey = "fidelity.search",
            SearchPlaceholderDefault = "Cerca per numero carta…",
            EntityTypeName = "FidelityCard",
            CreateTooltip = "fidelity.createNew",
            ShowDelete = true,
            ShowEdit = true,
            ShowAuditLog = false,
            ShowToggleStatus = false,
            GetDisplayName = c => c.CardNumber,
            GetId = c => c.Id,
            CanDelete = c => c.Status == FidelityCardStatus.Revoked || c.Status == FidelityCardStatus.Expired,
            DeleteConfirmMessageKey = "fidelity.confirmDelete",
            DeleteSuccessMessageKey = "fidelity.deleted",
            DeleteErrorMessageKey = "fidelity.deleteError",
            BulkDeleteConfirmMessageKey = "fidelity.confirmDeleteMultiple",
            BreadcrumbItems =
            [
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Anagrafiche", null, disabled: true),
                new BreadcrumbItem("Carte Fedeltà", null, disabled: true)
            ],
            Columns =
            [
                new() { PropertyName = "CardNumber", DisplayName = "Numero Carta", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "TierName", DisplayName = "Livello", IsVisible = true, Order = 1, IsSearchable = false },
                new() { PropertyName = "Status", DisplayName = "Stato", IsVisible = true, Order = 2, IsSearchable = false },
                new() { PropertyName = "CurrentPoints", DisplayName = "Punti", IsVisible = true, Order = 3, IsSearchable = false },
                new() { PropertyName = "DiscountPercentage", DisplayName = "Sconto %", IsVisible = true, Order = 4, IsSearchable = false },
                new() { PropertyName = "ValidTo", DisplayName = "Scadenza", IsVisible = true, Order = 5, IsSearchable = false }
            ],
            QuickFilters =
            [
                new() { Id = "all",       Label = "Tutte",    Predicate = _ => true,                                         Description = "Mostra tutte le carte" },
                new() { Id = "active",    Label = "Attive",   Predicate = c => c.Status == FidelityCardStatus.Active,   Color = Color.Success, Icon = Icons.Material.Outlined.CheckCircle,   Description = "Carte attive" },
                new() { Id = "suspended", Label = "Sospese",  Predicate = c => c.Status == FidelityCardStatus.Suspended, Color = Color.Warning, Icon = Icons.Material.Outlined.PauseCircle,   Description = "Carte sospese" },
                new() { Id = "expired",   Label = "Scadute",  Predicate = c => c.Status == FidelityCardStatus.Expired,   Color = Color.Error,   Icon = Icons.Material.Outlined.Schedule,      Description = "Carte scadute" },
                new() { Id = "revoked",   Label = "Revocate", Predicate = c => c.Status == FidelityCardStatus.Revoked,   Color = Color.Default, Icon = Icons.Material.Outlined.Cancel,        Description = "Carte revocate" }
            ]
        };
    }

    private async Task OpenCreateDialogAsync(Guid? id)
    {
        try
        {
            IDialogReference dialog;

            if (id.HasValue)
            {
                var card = await FidelityService.GetCardByIdAsync(id.Value);
                if (card is null)
                {
                    AppNotification.ShowWarning(TranslationService.GetTranslation("fidelity.notFound", "Carta fedeltà non trovata."));
                    return;
                }
                var parameters = new DialogParameters { [nameof(EditFidelityCardDialog.Card)] = card };
                dialog = await DialogService.ShowAsync<EditFidelityCardDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            }
            else
            {
                dialog = await DialogService.ShowAsync<CreateFidelityCardDialog>(string.Empty, new DialogParameters(), EFDialogDefaults.Options);
            }

            var result = await dialog.Result;
            if (result is { Canceled: false })
                await _entityPage!.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening fidelity card dialog for ID {Id}.", id);
            AppNotification.ShowWarning(TranslationService.GetTranslation("fidelity.dialogOpenError", "Si è verificato un errore nell'apertura del dialogo."));
        }
    }

    private async Task OpenManagePointsDialogAsync(FidelityCardDto card)
    {
        try
        {
            var parameters = new DialogParameters
            {
                ["CardId"] = card.Id,
                ["CardNumber"] = card.CardNumber,
                ["CurrentPoints"] = card.CurrentPoints
            };
            var dialog = await DialogService.ShowAsync<ManageFidelityPointsDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await _entityPage!.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening manage points dialog for fidelity card {CardId}.", card.Id);
            AppNotification.ShowWarning(TranslationService.GetTranslation("fidelity.dialogOpenError", "Si è verificato un errore nell'apertura del dialogo."));
        }
    }

    private async Task OpenHistoryDialogAsync(FidelityCardDto card)
    {
        try
        {
            var parameters = new DialogParameters
            {
                ["CardId"] = card.Id,
                ["CardNumber"] = card.CardNumber
            };
            await DialogService.ShowAsync<FidelityPointsHistoryDialog>(string.Empty, parameters, EFDialogDefaults.Options);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening points history dialog for fidelity card {CardId}.", card.Id);
            AppNotification.ShowWarning(TranslationService.GetTranslation("fidelity.dialogOpenError", "Si è verificato un errore nell'apertura del dialogo."));
        }
    }

    private async Task SuspendCardAsync(FidelityCardDto card)
    {
        try
        {
            await FidelityService.SuspendCardAsync(card.Id);
            AppNotification.ShowSuccess(TranslationService.GetTranslationFormatted("fidelity.suspended", "Carta {0} sospesa.", card.CardNumber));
            await _entityPage!.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error suspending fidelity card {CardId}", card.Id);
            AppNotification.ShowError(TranslationService.GetTranslation("fidelity.suspendError", "Errore durante la sospensione della carta."));
        }
    }

    private async Task ActivateCardAsync(FidelityCardDto card)
    {
        try
        {
            await FidelityService.ActivateCardAsync(card.Id);
            AppNotification.ShowSuccess(TranslationService.GetTranslationFormatted("fidelity.activated", "Carta {0} attivata.", card.CardNumber));
            await _entityPage!.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error activating fidelity card {CardId}", card.Id);
            AppNotification.ShowError(TranslationService.GetTranslation("fidelity.activateError", "Errore durante l'attivazione della carta."));
        }
    }

    private async Task RevokeCardAsync(FidelityCardDto card)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            TranslationService.GetTranslation("fidelity.confirmRevokeTitle", "Conferma Revoca"),
            TranslationService.GetTranslationFormatted("fidelity.confirmRevokeMessage", "Revocare definitivamente la carta {0}? L'operazione non è reversibile.", card.CardNumber),
            yesText: TranslationService.GetTranslation("fidelity.revoke", "Revoca"),
            cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
        if (result != true) return;

        try
        {
            await FidelityService.RevokeCardAsync(card.Id);
            AppNotification.ShowSuccess(TranslationService.GetTranslationFormatted("fidelity.revoked", "Carta {0} revocata.", card.CardNumber));
            await _entityPage!.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error revoking fidelity card {CardId}", card.Id);
            AppNotification.ShowError(TranslationService.GetTranslation("fidelity.revokeError", "Errore durante la revoca della carta."));
        }
    }

    private static string GetTierAvatarStyle(string? tierColor)
    {
        var safeColor = Prym.Web.Shared.Utils.CssColorSanitizer.SanitizeOrNull(tierColor);
        return safeColor is null ? string.Empty : $"background-color: {safeColor};";
    }

    private static string GetTierChipStyle(string? tierColor)
    {
        var safeColor = Prym.Web.Shared.Utils.CssColorSanitizer.SanitizeOrNull(tierColor);
        return safeColor is null ? string.Empty : $"background-color: {safeColor}; color: #fff;";
    }

    private static Color GetStatusColor(FidelityCardStatus status) => status switch
    {
        FidelityCardStatus.Active    => Color.Success,
        FidelityCardStatus.Suspended => Color.Warning,
        FidelityCardStatus.Expired   => Color.Error,
        FidelityCardStatus.Revoked   => Color.Error,
        _                            => Color.Default
    };

    private string GetStatusLabel(FidelityCardStatus status) => status switch
    {
        FidelityCardStatus.Active    => TranslationService.GetTranslation("fidelity.status.active", "Attiva"),
        FidelityCardStatus.Suspended => TranslationService.GetTranslation("fidelity.status.suspended", "Sospesa"),
        FidelityCardStatus.Expired   => TranslationService.GetTranslation("fidelity.status.expired", "Scaduta"),
        FidelityCardStatus.Revoked   => TranslationService.GetTranslation("fidelity.status.revoked", "Revocata"),
        _                            => status.ToString()
    };
}
