@page "/documents/list"
@using System.Linq
@using Prym.DTOs.Documents
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,Operator")]
@inject IDocumentHeaderService DocumentHeaderService
@inject IDocumentTypeService DocumentTypeService
@inject IDocumentStatusService DocumentStatusService
@inject ITranslationService TranslationService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ILogger<DocumentList> Logger

<PageTitle>@TranslationService.GetTranslation("documents.management", "Gestione Documenti")</PageTitle>

<EntityManagementPage TEntity="DocumentHeaderDto"
                      @ref="_managementPage"
                      Config="_config"
                      Service="_service"
                      OnCreateOverride="@(() => OpenDocumentDialogAsync(null))"
                      OnEditOverride="@(id => OpenDocumentDialogAsync(id))">
    <AdditionalToolbarContent>
        <PrymSelect T="Guid?"
                    Label="@TranslationService.GetTranslation("documents.documentType", "Tipo Documento")"
                    Class="ef-select ef-min-200 mr-2"
                    Value="_service.DocumentTypeId"
                    ValueChanged="@OnDocumentTypeChanged"
                    Clearable="true">
            @foreach (var type in _documentTypes)
            {
                <MudSelectItem T="Guid?" Value="@type.Id">@type.Name</MudSelectItem>
            }
        </PrymSelect>
        <PrymSelect T="DocumentStatus?"
                    Label="@TranslationService.GetTranslation("documents.status", "Stato")"
                    Class="ef-select min-width-150 mr-2"
                    Value="_service.Status"
                    ValueChanged="@OnStatusChanged"
                    Clearable="true">
            <MudSelectItem T="DocumentStatus?" Value="@DocumentStatus.Active">@TranslationService.GetTranslation("status.active", "Attivo")</MudSelectItem>
            <MudSelectItem T="DocumentStatus?" Value="@DocumentStatus.Archived">@TranslationService.GetTranslation("status.archived", "Archiviato")</MudSelectItem>
        </PrymSelect>
        @{
            var activeSelected = ActiveSelectedDocuments;
        }
        @if (activeSelected.Count > 0)
        {
            <MudTooltip Text="@TranslationService.GetTranslation("documents.archiveSelected", "Archivia selezionati")">
                <MudIconButton Icon="@Icons.Material.Outlined.Archive"
                               Color="Color.Warning"
                               OnClick="@BulkArchiveSelectedAsync" />
            </MudTooltip>
        }
    </AdditionalToolbarContent>

    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Number")
            {
                <EFTableColumnHeader TItem="DocumentHeaderDto" PropertyName="Number">
                    <MudTableSortLabel SortBy="@(new Func<DocumentHeaderDto, object>(x => x.Number))">@TranslationService.GetTranslation("documents.number", "Numero")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "DocumentTypeName")
            {
                <EFTableColumnHeader TItem="DocumentHeaderDto" PropertyName="DocumentTypeName">
                    <MudTableSortLabel SortBy="@(new Func<DocumentHeaderDto, object>(x => x.DocumentTypeName ?? string.Empty))">@TranslationService.GetTranslation("documents.type", "Tipo")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Date")
            {
                <EFTableColumnHeader TItem="DocumentHeaderDto" PropertyName="Date">
                    <MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="@(new Func<DocumentHeaderDto, object>(x => x.Date))">@TranslationService.GetTranslation("documents.date", "Data")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "CustomerName")
            {
                <EFTableColumnHeader TItem="DocumentHeaderDto" PropertyName="CustomerName">
                    <MudTableSortLabel SortBy="@(new Func<DocumentHeaderDto, object>(x => x.BusinessPartyName ?? x.CustomerName ?? string.Empty))">@TranslationService.GetTranslation("documents.customer", "Cliente")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "TotalGrossAmount")
            {
                <EFTableColumnHeader TItem="DocumentHeaderDto" PropertyName="TotalGrossAmount">
                    <MudTableSortLabel SortBy="@(new Func<DocumentHeaderDto, object>(x => x.TotalGrossAmount))">@TranslationService.GetTranslation("documents.amount", "Importo")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Status")
            {
                <EFTableColumnHeader TItem="DocumentHeaderDto" PropertyName="Status">
                    <MudTableSortLabel SortBy="@(new Func<DocumentHeaderDto, object>(x => x.Status))">@TranslationService.GetTranslation("documents.status", "Stato")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center ef-min-120" >@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Number")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("documents.number", "Numero")">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                        @if (!string.IsNullOrEmpty(ctx.Item.Series))
                        {
                            <text>@ctx.Item.Series/@ctx.Item.Number</text>
                        }
                        else
                        {
                            <text>@ctx.Item.Number</text>
                        }
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "DocumentTypeName")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("documents.type", "Tipo")">
                    <div class="d-flex align-center">
                        <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2">
                            <MudIcon Icon="@Icons.Material.Outlined.Description" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2">@ctx.Item.DocumentTypeName</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">ID: @(ctx.Item.Id.ToString()[..Math.Min(8, ctx.Item.Id.ToString().Length)])...</MudText>
                        </div>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "Date")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("documents.date", "Data")">
                    <MudText Typo="Typo.body2">@ctx.Item.Date.ToLocalTime().ToString("dd/MM/yyyy")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "CustomerName")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("documents.customer", "Cliente")">
                    <MudText Typo="Typo.body2">@(ctx.Item.BusinessPartyName ?? ctx.Item.CustomerName ?? "-")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "TotalGrossAmount")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("documents.amount", "Importo")" >
                    <MudText Typo="Typo.body2" Class="fw-semibold">@ctx.Item.TotalGrossAmount.ToString("C2")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Status")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("documents.status", "Stato")">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(ctx.Item.Status)">
                        @TranslationService.GetTranslation($"documents.status.{ctx.Item.Status.ToString().ToLower()}", ctx.Item.Status.ToString())
                    </MudChip>
                </MudTd>
            }
        }
    </RowTemplate>

    <AdditionalRowActions Context="doc">
        <MudTooltip Text="@TranslationService.GetTranslation("common.view", "Visualizza")">
            <PrymIconButton Icon="@Icons.Material.Outlined.Visibility"
                            Size="Size.Small"
                            Color="Color.Primary"
                            Class="ef-row-actionbutton"
                            OnClick="@(() => OpenDocumentDialogAsync(doc.Id))" />
        </MudTooltip>
        @{
            var transitions = _service.GetAvailableTransitions(doc.Id)
                .Where(status => status != doc.Status)
                .ToList();
        }
        @if (transitions.Count > 0)
        {
            <MudMenu Icon="@Icons.Material.Outlined.SwapHoriz"
                     Size="Size.Small"
                     Dense="true"
                     Class="ef-row-actionbutton"
                     Title="@TranslationService.GetTranslation("documents.changeStatus", "Cambia stato")">
                @foreach (var transition in transitions)
                {
                    <MudMenuItem Icon="@GetStatusIcon(transition)"
                                 OnClick="@(async () => await ChangeDocumentStatusAsync(doc.Id, doc.Status, transition))">
                        @TranslationService.GetTranslation($"documents.statusTransition.{transition.ToString().ToLower()}", GetStatusTransitionLabel(transition))
                    </MudMenuItem>
                }
            </MudMenu>
        }
    </AdditionalRowActions>
</EntityManagementPage>

@code {
    private static readonly DialogOptions _fullScreenDialogOptions = new()
    {
        FullScreen = true,
        CloseButton = false,
        BackdropClick = false,
        MaxWidth = MaxWidth.False
    };

    private EntityManagementPage<DocumentHeaderDto> _managementPage = null!;
    private DocumentListManagementService _service = null!;
    private EntityManagementConfig<DocumentHeaderDto> _config = null!;
    private List<DocumentTypeDto> _documentTypes = new();

    protected override void OnInitialized()
    {
        _service = new DocumentListManagementService(DocumentHeaderService, DocumentStatusService);
        _config = new EntityManagementConfig<DocumentHeaderDto>
        {
            ComponentKey = "DocumentManagement",
            PageTitleKey = "documents.management",
            PageTitleDefault = "Gestione Documenti",
            EntityIcon = Icons.Material.Outlined.Description,
            PageRootCssClass = "document-page-root",
            BaseRoute = "/documents/list",
            ExcelFileName = "Documenti",
            SearchPlaceholderKey = "documents.search",
            SearchPlaceholderDefault = "Cerca documenti",
            CreateTooltip = "documents.create",
            EntityTypeName = "Document",
            ShowToggleStatus = false,
            ShowAuditLog = false,
            ShowView = false,
            ShowEdit = true,
            ShowDelete = true,
            CanEdit = d => d.Status == DocumentStatus.Active,
            CanDelete = d => d.Status == DocumentStatus.Active,
            GetDisplayName = d => string.IsNullOrEmpty(d.Series) ? d.Number : $"{d.Series}/{d.Number}",
            GetId = d => d.Id,
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Documenti", null, disabled: true),
                new BreadcrumbItem("Gestione", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Number", DisplayName = "Numero", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "DocumentTypeName", DisplayName = "Tipo", IsVisible = true, Order = 1, IsSearchable = true },
                new() { PropertyName = "Date", DisplayName = "Data", IsVisible = true, Order = 2, IsSearchable = false },
                new() { PropertyName = "CustomerName", DisplayName = "Cliente", IsVisible = true, Order = 3, IsSearchable = true },
                new() { PropertyName = "TotalGrossAmount", DisplayName = "Importo", IsVisible = true, Order = 4, IsSearchable = false },
                new() { PropertyName = "Status", DisplayName = "Stato", IsVisible = true, Order = 5, IsSearchable = false }
            },
            QuickFilters = new()
            {
                new() { Id = "all", Label = "Tutti", Predicate = _ => true, Description = "Mostra tutti i documenti" },
                new() { Id = "active", Label = "Attivi", Predicate = d => d.Status == DocumentStatus.Active, Color = Color.Info, Icon = Icons.Material.Outlined.Description, Description = "Documenti attivi" },
                new() { Id = "archived", Label = "Archiviati", Predicate = d => d.Status == DocumentStatus.Archived, Color = Color.Secondary, Icon = Icons.Material.Outlined.Archive, Description = "Documenti archiviati" },
                new() { Id = "recent", Label = "Recenti", Predicate = d => d.Date >= DateTime.UtcNow.AddDays(-30), Color = Color.Primary, Icon = Icons.Material.Outlined.NewReleases, Description = "Documenti degli ultimi 30 giorni" }
            }
        };
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var allTypes = await DocumentTypeService.GetAllDocumentTypesAsync();
            _documentTypes = allTypes?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading document types");
            AppNotification.ShowError(TranslationService.GetTranslation("documents.errorLoadingTypes", "Errore durante il caricamento dei tipi di documento"));
        }
    }

    private async Task OnDocumentTypeChanged(Guid? value)
    {
        _service.DocumentTypeId = value;
        await _managementPage.RefreshAsync();
    }

    private async Task OpenDocumentDialogAsync(Guid? id)
    {
        try
        {
            var parameters = new DialogParameters
            {
                [nameof(DocumentDetailDialog.DocumentId)] = id
            };
            var dialog = await DialogService.ShowAsync<DocumentDetailDialog>(string.Empty, parameters, _fullScreenDialogOptions);
            var result = await dialog.Result;
            if (result is { Canceled: false, Data: true })
                await _managementPage.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening document detail dialog for ID {Id}.", id);
            AppNotification.ShowWarning(TranslationService.GetTranslation("common.dialogOpenError", "Si è verificato un errore nell'apertura del dialogo."));
        }
    }

    private async Task OnStatusChanged(DocumentStatus? value)
    {
        _service.Status = value;
        await _managementPage.RefreshAsync();
    }

    private Color GetStatusColor(DocumentStatus status) => status switch
    {
        DocumentStatus.Active => Color.Success,
        DocumentStatus.Archived => Color.Secondary,
        _ => Color.Default
    };

    private async Task ChangeDocumentStatusAsync(Guid documentId, DocumentStatus currentStatus, DocumentStatus newStatus)
    {
        try
        {
            var confirmMessage = GetStatusTransitionConfirmation(currentStatus, newStatus);
            var confirmed = await DialogService.ShowMessageBoxAsync(
                TranslationService.GetTranslation("documents.changeStatus", "Cambio stato documento"),
                confirmMessage,
                yesText: TranslationService.GetTranslation("common.confirm", "Conferma"),
                cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));

            if (confirmed != true) return;

            var result = await DocumentStatusService.ChangeStatusAsync(documentId, newStatus);
            if (result != null)
            {
                AppNotification.ShowSuccess(TranslationService.GetTranslation("documents.statusChangeSuccess", "Stato documento aggiornato con successo"));
                await _managementPage.RefreshAsync();
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslation("documents.statusChangeError", "Errore durante il cambio di stato del documento"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error changing status for document {DocumentId} to {NewStatus}", documentId, newStatus);
            AppNotification.ShowError(TranslationService.GetTranslation("documents.statusChangeError", "Errore durante il cambio di stato del documento"));
        }
    }

    private static string GetStatusTransitionLabel(DocumentStatus status) => status switch
    {
        DocumentStatus.Active => "Attiva",
        DocumentStatus.Archived => "Archivia",
        _ => status.ToString()
    };

    private static string GetStatusIcon(DocumentStatus status) => status switch
    {
        DocumentStatus.Active => Icons.Material.Outlined.LockOpen,
        DocumentStatus.Archived => Icons.Material.Outlined.Archive,
        _ => Icons.Material.Outlined.SwapHoriz
    };

    private static string GetStatusTransitionConfirmation(DocumentStatus from, DocumentStatus to) => (from, to) switch
    {
        (DocumentStatus.Active, DocumentStatus.Archived) => "Archiviare il documento? Questa azione è IRREVERSIBILE e il documento diventerà immutabile.",
        (DocumentStatus.Archived, DocumentStatus.Active) => "Riattivare il documento archiviato?",
        _ => $"Confermare la transizione di stato?"
    };

    private List<DocumentHeaderDto> ActiveSelectedDocuments =>
        _managementPage?.SelectedItems.Where(d => d.Status == DocumentStatus.Active).ToList() ?? new();

    private async Task BulkArchiveSelectedAsync()
    {
        var activeSelected = ActiveSelectedDocuments;
        if (activeSelected.Count == 0) return;

        var confirmed = await DialogService.ShowMessageBoxAsync(
            TranslationService.GetTranslation("documents.bulkArchive", "Archiviazione massiva"),
            $"Archiviare {activeSelected.Count} documento/i selezionato/i?",
            yesText: TranslationService.GetTranslation("common.confirm", "Conferma"),
            cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));

        if (confirmed != true) return;

        try
        {
            var bulkDto = new Prym.DTOs.Bulk.BulkStatusChangeDto
            {
                DocumentIds = activeSelected.Select(d => d.Id).ToList(),
                NewStatus = DocumentStatus.Archived.ToString()
            };

            var result = await DocumentHeaderService.BulkStatusChangeAsync(bulkDto);
            if (result != null)
            {
                if (result.FailedCount == 0)
                {
                    AppNotification.ShowSuccess(
                        $"{TranslationService.GetTranslation("documents.bulkArchiveSuccess", "Archiviazione completata")}: {result.SuccessCount} documento/i archiviato/i");
                }
                else
                {
                    var failedIds = string.Join(", ", result.Errors.Select(e => e.ItemId.ToString()[..8]));
                    Logger.LogWarning("Bulk archive partial failure: {SuccessCount} succeeded, {FailedCount} failed. IDs: {FailedIds}",
                        result.SuccessCount, result.FailedCount, failedIds);
                    AppNotification.ShowWarning(
                        $"Archiviazione parziale: {result.SuccessCount} riusciti, {result.FailedCount} falliti.");
                }
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslation("documents.statusChangeError", "Errore durante l'archiviazione massiva"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error bulk archiving documents");
            AppNotification.ShowError(TranslationService.GetTranslation("documents.statusChangeError", "Errore durante l'archiviazione massiva"));
        }
        finally
        {
            await _managementPage.RefreshAsync();
        }
    }
}
