@using Prym.DTOs.Products
@using Prym.DTOs.UnitOfMeasures
@using Prym.DTOs.VatRates

@* UnifiedProductSelector Component - Unified product search with barcode scanning and product info display *@
<MudStack Spacing="2" Class="@Class" Style="@Style">
    @if (!string.IsNullOrEmpty(Title))
    {
        <!-- Header with Title and Action Buttons -->
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.subtitle1" Class="fw-semibold">
                <MudIcon Icon="@Icons.Material.Outlined.Inventory" Size="Size.Small" Class="mr-1" />
                @Title
            </MudText>
            @* In Full/None modes show Edit+Clear in the title bar.
               In Compact/SearchOnly the buttons live inside the compact strip instead. *@
            @if (SelectedProduct != null && (EffectiveDisplayMode == ProductInfoDisplayMode.Full || EffectiveDisplayMode == ProductInfoDisplayMode.None))
            {
                <MudStack Row="true" Spacing="1">
                    @if (EditMode != ProductEditMode.None)
                    {
                        <MudTooltip Text="@TranslationService.GetTranslation("products.editProduct", "Modifica prodotto")">
                            <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="HandleEditClick" />
                        </MudTooltip>
                    }
                    @if (AllowClear)
                    {
                        <MudTooltip Text="@TranslationService.GetTranslation("common.clear", "Pulisci")">
                            <MudIconButton Icon="@Icons.Material.Outlined.Clear"
                                           Size="Size.Small"
                                           Color="Color.Default"
                                           OnClick="ClearSelection" />
                        </MudTooltip>
                    }
                </MudStack>
            }
        </MudStack>

        <MudDivider />
    }

    @if (_showNotFoundPrompt)
    {
        <MudAlert Severity="Severity.Warning" Class="mt-2">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.body2">
                    @TranslationService.GetTranslation("products.notFoundPrompt", 
                        $"Prodotto '{_notFoundBarcode}' non trovato.")
                </MudText>
                <MudButton Size="Size.Small" 
                           Color="Color.Primary" 
                           Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Outlined.Add"
                           OnClick="@(() => OpenQuickCreateDialog(_notFoundBarcode))">
                    @TranslationService.GetTranslation("products.createNew", "Crea Nuovo")
                </MudButton>
            </MudStack>
        </MudAlert>
    }

    @if (SelectedProduct == null && SearchMode != ProductSearchMode.None)
    {
        <!-- SEARCH MODE: Autocomplete for product search with barcode support -->
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <div class="flex-1 min-w-0">
                <MudAutocomplete T="ProductDto"
                                 @ref="_autocomplete"
                                 Value="SelectedProduct"
                                 ValueChanged="@OnProductSelectionChangedAsync"
                                 @bind-Text="_searchText"
                                 SearchFunc="@SearchProductsAsync"
                                 ToStringFunc="@(p => p?.Name ?? string.Empty)"
                                 Variant="Variant.Outlined"
                                 Dense="@Dense"
                                 Margin="Margin.Dense"
                                 MinCharacters="@MinSearchCharacters"
                                 DebounceInterval="@DebounceMs"
                                 ShowProgressIndicator="true"
                                 Clearable="@AllowClear"
                                 Disabled="@Disabled"
                                 Placeholder="@Placeholder"
                                 HelperText="@SearchHelperText"
                                 CoerceText="false"
                                 CoerceValue="false"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Outlined.Search"
                                 AdornmentColor="Color.Primary"
                                 @onkeydown="@HandleSearchKeyDown">
                    <!-- ItemTemplate -->
                    <ItemTemplate Context="product">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <div>
                                <MudText Typo="Typo.body2"><strong>@product.Name</strong></MudText>
                                @if (!string.IsNullOrEmpty(product.Code))
                                {
                                    <MudText Typo="Typo.caption" Class="text-secondary-color">
                                        @product.Code
                                    </MudText>
                                }
                            </div>
                            @if (product.DefaultPrice.HasValue)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">
                                    @product.DefaultPrice.Value.ToString("C2")
                                </MudChip>
                            }
                        </MudStack>
                    </ItemTemplate>
                    
                    <!-- NoItemsTemplate -->
                    <NoItemsTemplate>
                        <MudText Typo="Typo.body2" Class="text-disabled">
                            @TranslationService.GetTranslation("documents.noProductsFound", "Nessun prodotto trovato")
                        </MudText>
                    </NoItemsTemplate>
                </MudAutocomplete>
            </div>

            @if (ShowBarcodeScanner)
            {
                <MudTooltip Text="@TranslationService.GetTranslation("camera.scanWithCamera", "Scansiona con la fotocamera")">
                    <MudIconButton Icon="@Icons.Material.Outlined.PhotoCamera"
                                   Color="Color.Secondary"
                                   Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Disabled="@Disabled"
                                   OnClick="@OpenCameraScannerAsync" />
                </MudTooltip>
            }
        </MudStack>
    }

    @if (SelectedProduct != null && EffectiveDisplayMode == ProductInfoDisplayMode.Full)
    {
        <!-- VIEW MODE Full: Display complete product information grid -->
        @if (!SelectedProduct.IsActive)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-1">
                @TranslationService.GetTranslation("products.inactiveWarning", "Questo prodotto è inattivo. Potrebbe non essere disponibile per nuove operazioni.")
            </MudAlert>
        }
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @TranslationService.GetTranslation("products.code", "Codice")
                </MudText>
                <MudText Typo="Typo.body2" Class="fw-semibold">
                    @SelectedProduct.Code
                </MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @TranslationService.GetTranslation("products.name", "Nome")
                </MudText>
                <MudText Typo="Typo.body2" Class="fw-semibold">
                    @SelectedProduct.Name
                </MudText>
            </MudItem>
            @if (ShowDescription)
            {
            <MudItem xs="12">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @TranslationService.GetTranslation("products.description", "Descrizione")
                </MudText>
                <MudText Typo="Typo.body2">
                    @(string.IsNullOrWhiteSpace(SelectedProduct.Description) ? "-" : SelectedProduct.Description)
                </MudText>
            </MudItem>
            }
            @if (ShowCommercialInfo)
            {
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @TranslationService.GetTranslation("products.unitOfMeasure", "Unità di Misura")
                </MudText>
                <MudText Typo="Typo.body2">
                    @(_currentUnitName ?? "-")
                </MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @TranslationService.GetTranslation("products.vatRate", "IVA")
                </MudText>
                <MudText Typo="Typo.body2">
                    @(_currentVatName ?? "-")
                </MudText>
            </MudItem>
            @if (SelectedProduct.DefaultPrice.HasValue)
            {
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @TranslationService.GetTranslation("products.price", "Prezzo")
                    </MudText>
                    <MudText Typo="Typo.body2" Class="fw-semibold">
                        @SelectedProduct.DefaultPrice.Value.ToString("C2")
                    </MudText>
                </MudItem>
            }
            }
            @if (ShowCurrentStock && CurrentStockQuantity.HasValue)
            {
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @TranslationService.GetTranslation("warehouse.currentStock", "Giacenza Attuale")
                    </MudText>
                    <MudText Typo="Typo.body2" Class="fw-semibold">
                        @CurrentStockQuantity.Value.ToString("N2") @(_currentUnitSymbol ?? "")
                    </MudText>
                </MudItem>
            }
        </MudGrid>
    }

    @if (SelectedProduct != null && (EffectiveDisplayMode == ProductInfoDisplayMode.Compact || EffectiveDisplayMode == ProductInfoDisplayMode.SearchOnly))
    {
        <!-- VIEW MODE Compact/SearchOnly: Single-row chip with action buttons -->
        <MudPaper Elevation="0" Class="pa-2 mt-1 border rounded" Style="border-color: var(--mud-palette-divider);">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="min-width:0; overflow:hidden;">
                    <MudIcon Icon="@Icons.Material.Outlined.Inventory"
                             Size="Size.Small"
                             Color="@(SelectedProduct.IsActive ? Color.Primary : Color.Warning)" />
                    <div style="min-width:0; overflow:hidden;">
                        <MudText Typo="Typo.body2" Class="fw-semibold text-truncate">@SelectedProduct.Name</MudText>
                        @if (!string.IsNullOrEmpty(SelectedProduct.Code))
                        {
                            <MudText Typo="Typo.caption" Class="text-secondary-color text-truncate">@SelectedProduct.Code</MudText>
                        }
                        @if (!SelectedProduct.IsActive)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" Icon="@Icons.Material.Outlined.PauseCircle" Class="mt-1">
                                @TranslationService.GetTranslation("common.inactive", "Inattivo")
                            </MudChip>
                        }
                    </div>
                </MudStack>
                <MudStack Row="true" Spacing="0" Style="flex-shrink:0;">
                    @if (EffectiveDisplayMode == ProductInfoDisplayMode.SearchOnly && OnProductDetailRequested.HasDelegate)
                    {
                        <MudTooltip Text="@TranslationService.GetTranslation("products.viewDetails", "Visualizza dettagli")">
                            <MudIconButton Icon="@Icons.Material.Outlined.Info"
                                           Size="Size.Small"
                                           Color="Color.Info"
                                           OnClick="HandleDetailClick" />
                        </MudTooltip>
                    }
                    @if (EditMode != ProductEditMode.None)
                    {
                        <MudTooltip Text="@TranslationService.GetTranslation("products.editProduct", "Modifica prodotto")">
                            <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="HandleEditClick" />
                        </MudTooltip>
                    }
                    @if (AllowClear)
                    {
                        <MudTooltip Text="@TranslationService.GetTranslation("common.clear", "Pulisci")">
                            <MudIconButton Icon="@Icons.Material.Outlined.Clear"
                                           Size="Size.Small"
                                           Color="Color.Default"
                                           OnClick="ClearSelection" />
                        </MudTooltip>
                    }
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</MudStack>
