@* Pos26SearchBar — barra ricerca con chip cliente *@
@using Prym.DTOs.Business
@using Prym.DTOs.Business.Fidelity
@using Prym.Web.Shared.Components.Business
@implements IDisposable

<div class="pos26-searchbar-wrap">
    <div class="pos26-searchbar-input-wrap">
        <span class="pos26-searchbar-icon">
            <MudIcon Icon="@Icons.Material.Outlined.Search" Size="Size.Small" />
        </span>
        <input @ref="_inputRef"
               type="text"
               class="pos26-searchbar-input"
               placeholder="@Placeholder"
               value="@SearchTerm"
               data-barcode-input="true"
               @oninput="OnInputChanged"
               @onkeydown="OnKeyDown" />
        @if (!string.IsNullOrEmpty(SearchTerm))
        {
            <button class="pos26-searchbar-clear" @onclick="ClearSearch" title="Cancella ricerca">
                <MudIcon Icon="@Icons.Material.Outlined.Close" Size="Size.Small" />
            </button>
        }
        <button class="pos26-searchbar-camera"
                @onclick="OnCameraClick"
                title="Scansiona con fotocamera">
            <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Size="Size.Small" />
        </button>
    </div>

    <button class="pos26-customer-chip @(Customer != null ? "pos26-customer-chip--active" : "")"
            @onclick="OpenCustomerSelector"
            title="@(Customer != null ? $"Cliente: {Customer.Name}" : "Nessun cliente selezionato")">
        @if (Customer != null)
        {
            <span class="pos26-customer-initials">@GetInitials(Customer.Name)</span>
            <span class="pos26-customer-name">@GetShortName(Customer.Name)</span>
            @if (FidelityCard is not null)
            {
                <span class="pos26-customer-points" title="Punti fedeltà">⭐ @FidelityCard.CurrentPoints pt</span>
            }
            <span class="pos26-customer-remove"
                  @onclick:stopPropagation="true"
                  @onclick="ClearCustomer">
                <MudIcon Icon="@Icons.Material.Outlined.Close" Size="Size.Small" />
            </span>
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Small" />
            <span>Nessun cliente</span>
        }
    </button>
</div>

@if (_showCustomerSelector)
{
    <div class="pos26-customer-selector-overlay" @onclick="CloseCustomerSelector">
        <div class="pos26-customer-selector-panel" @onclick:stopPropagation="true">
            <UnifiedBusinessPartySelector
                SelectedBusinessParty="@Customer"
                SelectedBusinessPartyChanged="@OnCustomerSelected"
                Title="Cerca cliente"
                FilterByType="BusinessPartyType.Customer"
                AllowClear="true" />
            <button class="pos26-btn-text" @onclick="CloseCustomerSelector">Chiudi</button>
        </div>
    </div>
}

@code {
    [Parameter] public string SearchTerm { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SearchTermChanged { get; set; }
    [Parameter] public BusinessPartyDto? Customer { get; set; }
    [Parameter] public EventCallback<BusinessPartyDto?> CustomerChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Cerca articolo o scansiona codice…";
    [Parameter] public EventCallback<string> OnBarcodeDetected { get; set; }
    [Parameter] public EventCallback OnCameraClick { get; set; }
    [Parameter] public FidelityCardDto? FidelityCard { get; set; }

    private ElementReference _inputRef;
    private CancellationTokenSource? _debounceCts;
    private bool _showCustomerSelector = false;
    private string _currentInput = string.Empty;  // always in sync with the real input value

    // --- Rilevamento barcode hardware via timing ---
    private DateTime _lastKeyTime = DateTime.MinValue;
    private int _rapidKeyCount = 0;
    private CancellationTokenSource? _barcodeTimerCts;

    private const int DebounceDelayMs = 300;
    /// <summary>Intervallo massimo tra tasti consecutivi per classificare come barcode hardware (ms).</summary>
    private const int BarcodeMaxIntervalMs = 50;
    /// <summary>Numero minimo di caratteri rapidi prima di attivare il rilevamento barcode.</summary>
    private const int BarcodeMinChars = 4;
    /// <summary>Silenzio post-sequenza prima di sparare OnBarcodeDetected (ms).</summary>
    private const int BarcodeSilenceMs = 80;

    private void OnInputChanged(ChangeEventArgs e)
    {
        _currentInput = e.Value?.ToString() ?? string.Empty;
        _ = DebounceSearchAsync(_currentInput);
    }

    private async Task DebounceSearchAsync(string value)
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(DebounceDelayMs, _debounceCts.Token);
            await SearchTermChanged.InvokeAsync(value);
            StateHasChanged();
        }
        catch (OperationCanceledException) { /* superseded by a newer keystroke */ }
        catch (ObjectDisposedException) { /* component disposed — ignore */ }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        var now = DateTime.UtcNow;
        var intervalMs = (now - _lastKeyTime).TotalMilliseconds;
        _lastKeyTime = now;

        // Rilevamento barcode: Enter dopo sequenza di tasti rapida (comportamento primario).
        // Usa _currentInput (aggiornata sincronamente) invece del parametro SearchTerm
        // che potrebbe essere stale se il debounce non ha ancora completato.
        if (e.Key == "Enter" && !string.IsNullOrEmpty(_currentInput))
        {
            _debounceCts?.Cancel();
            _debounceCts?.Dispose();
            _debounceCts = null;
            _barcodeTimerCts?.Cancel();
            _barcodeTimerCts?.Dispose();
            _barcodeTimerCts = null;
            _rapidKeyCount = 0;
            await OnBarcodeDetected.InvokeAsync(_currentInput);
            return;
        }

        // Rilevamento barcode via timing (fallback per lettori che non inviano Enter).
        if (e.Key.Length == 1 && intervalMs < BarcodeMaxIntervalMs)
        {
            _rapidKeyCount++;
        }
        else
        {
            // Intervallo troppo lungo: reset contatore sequenza rapida
            _rapidKeyCount = 1;
        }

        if (_rapidKeyCount >= BarcodeMinChars)
        {
            // Avvia/riavvia timer di silenzio: se non arriva nessun altro tasto entro BarcodeSilenceMs,
            // scatta il barcode detected con il valore corrente.
            _barcodeTimerCts?.Cancel();
            _barcodeTimerCts?.Dispose();
            _barcodeTimerCts = new CancellationTokenSource();
            var token = _barcodeTimerCts.Token;
            _ = Task.Delay(BarcodeSilenceMs, token).ContinueWith(async t =>
            {
                if (t.IsCompletedSuccessfully && !string.IsNullOrEmpty(_currentInput))
                {
                    await InvokeAsync(async () =>
                    {
                        _debounceCts?.Cancel();
                        _debounceCts?.Dispose();
                        _debounceCts = null;
                        _rapidKeyCount = 0;
                        await OnBarcodeDetected.InvokeAsync(_currentInput);
                    });
                }
            }, TaskScheduler.Default);
        }
    }

    private async Task ClearSearch()
    {
        _currentInput = string.Empty;
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = null;
        await SearchTermChanged.InvokeAsync(string.Empty);
    }

    private void OpenCustomerSelector() => _showCustomerSelector = true;
    private void CloseCustomerSelector() => _showCustomerSelector = false;

    private async Task OnCustomerSelected(BusinessPartyDto? customer)
    {
        _showCustomerSelector = false;
        await CustomerChanged.InvokeAsync(customer);
    }

    private async Task ClearCustomer()
    {
        await CustomerChanged.InvokeAsync(null);
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : name[..Math.Min(2, name.Length)].ToUpperInvariant();
    }

    private static string GetShortName(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "";
        return name.Length > 14 ? name[..12] + "…" : name;
    }

    public void FocusInput() => _ = _inputRef.FocusAsync();

    public void Dispose()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _barcodeTimerCts?.Cancel();
        _barcodeTimerCts?.Dispose();
    }
}
