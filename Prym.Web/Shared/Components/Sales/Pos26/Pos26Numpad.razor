@* Pos26Numpad — ridotto alle sole azioni di pagamento (Task 7).
   Lo sconto è migrato in Pos26DiscountZone (Task 6); qui restano solo
   Paga (CTA grande), Annulla (link testuale) e Stampa ricevuta non fiscale.
   Nome componente mantenuto invariato per minimizzare il diff (non è più
   un "numpad" in senso stretto, ma rinominare il file comporterebbe
   aggiornare ogni riferimento senza benefici funzionali). *@

<div class="pos26-numpad">
    <button class="pos26-pay-cta"
            @onclick="OnPayClick"
            disabled="@(!CanPay)"
            title="Apri dialog pagamento (F2)">
        <span>Paga</span>
        <span class="pos26-pay-cta-shortcut">F2</span>
    </button>

    <button class="pos26-cancel-link" @onclick="OnCancel" title="Annulla sessione (ESC)">
        Annulla vendita (ESC)
    </button>

    @if (!HasFiscalPrinter && OnPrintReceipt.HasDelegate)
    {
        <button class="pos26-numpad-print-btn"
                @onclick="OnPrintReceipt"
                title="Stampa ricevuta non fiscale (browser)">
            <MudIcon Icon="@Icons.Material.Outlined.Print" Size="Size.Small" Class="mr-1" />
            Stampa ricevuta
        </button>
    }
</div>

@code {
    [Parameter] public EventCallback OnPay { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool CanPay { get; set; }
    /// <summary>Indica se è configurata una stampante fiscale. Se false, viene mostrato il pulsante "Stampa ricevuta".</summary>
    [Parameter] public bool HasFiscalPrinter { get; set; }
    /// <summary>Invocato quando il cassiere richiede la stampa non-fiscale (browser print).</summary>
    [Parameter] public EventCallback OnPrintReceipt { get; set; }

    private async Task OnPayClick()
    {
        if (CanPay)
            await OnPay.InvokeAsync();
    }
}
