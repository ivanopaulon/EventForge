@* Pos26Numpad — tastierino numerico scuro con sconto (% e €) e tasto PAGA *@

<div class="pos26-numpad">
    @* Display *@
    <div class="pos26-numpad-display">
        <span class="pos26-numpad-mode">@_modeLabel</span>
        <span class="pos26-numpad-value">@(_input.Length > 0 ? _input : "0")</span>
    </div>

    @* Griglia tasti *@
    <div class="pos26-numpad-grid">
        @foreach (var key in _keys)
        {
            <button class="pos26-numpad-key @key.Css"
                    style="@key.Style"
                    @onclick="() => HandleKey(key.Value)"
                    title="@key.Title"
                    disabled="@key.Disabled">
                @if (!string.IsNullOrEmpty(key.Icon))
                {
                    <MudIcon Icon="@key.Icon" Size="Size.Small" />
                }
                else
                {
                    @key.Label
                }
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public decimal Value { get; set; }
    [Parameter] public EventCallback<decimal> ValueChanged { get; set; }
    [Parameter] public EventCallback OnPay { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    /// <summary>Invocato per sconto percentuale (0-100).</summary>
    [Parameter] public EventCallback<decimal> OnApplyDiscount { get; set; }
    /// <summary>Invocato per sconto a valore fisso in €.</summary>
    [Parameter] public EventCallback<decimal> OnApplyFixedDiscount { get; set; }
    [Parameter] public bool CanPay { get; set; }

    private enum NumpadMode { Normal, DiscountPercent, DiscountFixed }

    private string _input = string.Empty;
    private NumpadMode _mode = NumpadMode.Normal;

    private string _modeLabel => _mode switch
    {
        NumpadMode.DiscountPercent => "Sconto %",
        NumpadMode.DiscountFixed   => "Sconto €",
        _                          => "Qtà / Importo"
    };

    private record KeyDef(string Value, string Label, string Icon = "", string Css = "", string Style = "", bool Disabled = false, string Title = "");

    private List<KeyDef> _keys = [];
    private NumpadMode _lastBuiltMode;
    private bool _lastCanPay;

    protected override void OnInitialized() => _keys = BuildKeys();

    protected override void OnParametersSet()
    {
        // Rebuild only when CanPay changes (affects the PAGA button style/disabled state).
        // Mode changes are handled inside HandleKey() below.
        if (_lastCanPay != CanPay)
        {
            _lastCanPay = CanPay;
            _keys = BuildKeys();
        }
    }

    private List<KeyDef> BuildKeys()
    {
        return new List<KeyDef>
        {
            new("7", "7"), new("8", "8"), new("9", "9"),
            new("4", "4"), new("5", "5"), new("6", "6"),
            new("1", "1"), new("2", "2"), new("3", "3"),
            new(",", ","), new("0", "0"),
            new("back", "", Icons.Material.Outlined.Backspace, "pos26-numpad-key--back",
                "background:var(--pos-red-key); color:#fff;", Title: "Cancella"),
            // Tasto sconto % — cicla tra normale → % → applica
            new("%sc", "%sc", "", "pos26-numpad-key--discount",
                $"background:{(_mode == NumpadMode.DiscountPercent ? "var(--pos-accent)" : "var(--pos-dark-border)")}; color:#fff;",
                Title: "Sconto percentuale"),
            // Tasto sconto € fisso — cicla tra normale → € → applica
            new("€sc", "€sc", "", "pos26-numpad-key--discount",
                $"background:{(_mode == NumpadMode.DiscountFixed ? "var(--pos-accent)" : "var(--pos-dark-border)")}; color:#fff;",
                Title: "Sconto a valore fisso"),
            // PAGA
            new("PAGA", "PAGA", "", "pos26-numpad-key--pay",
                $"background:var(--pos-green); color:#fff; opacity:{(CanPay ? "1" : ".4")};",
                !CanPay, Title: "Apri dialog pagamento (F2)"),
            // Annulla
            new("ANNULLA", "Annulla", "", "pos26-numpad-key--cancel",
                "background:var(--pos-dark-border); color:var(--pos-dark-text);",
                Title: "Annulla sessione (ESC)")
        };
    }

    private async Task HandleKey(string key)
    {
        switch (key)
        {
            case "back":
                if (_input.Length > 0)
                    _input = _input[..^1];
                break;

            case "%sc":
                if (_mode != NumpadMode.DiscountPercent)
                {
                    _mode = NumpadMode.DiscountPercent;
                    _input = string.Empty;
                }
                else
                {
                    if (decimal.TryParse(_input.Replace(',', '.'),
                            System.Globalization.NumberStyles.Any,
                            System.Globalization.CultureInfo.InvariantCulture, out var pct))
                        await OnApplyDiscount.InvokeAsync(pct);
                    _mode = NumpadMode.Normal;
                    _input = string.Empty;
                }
                break;

            case "€sc":
                if (_mode != NumpadMode.DiscountFixed)
                {
                    _mode = NumpadMode.DiscountFixed;
                    _input = string.Empty;
                }
                else
                {
                    if (decimal.TryParse(_input.Replace(',', '.'),
                            System.Globalization.NumberStyles.Any,
                            System.Globalization.CultureInfo.InvariantCulture, out var fixedAmt))
                        await OnApplyFixedDiscount.InvokeAsync(fixedAmt);
                    _mode = NumpadMode.Normal;
                    _input = string.Empty;
                }
                break;

            case "PAGA":
                if (CanPay)
                    await OnPay.InvokeAsync();
                break;

            case "ANNULLA":
                _input = string.Empty;
                _mode = NumpadMode.Normal;
                await OnCancel.InvokeAsync();
                break;

            case ",":
                if (!_input.Contains(',') && !_input.Contains('.'))
                    _input += ",";
                break;

            default:
                if (_input.Length < 10)
                    _input += key;
                break;
        }

        // Rebuild key list when mode changed so button highlights update correctly.
        if (_lastBuiltMode != _mode)
        {
            _lastBuiltMode = _mode;
            _keys = BuildKeys();
        }

        if (decimal.TryParse(_input.Replace(',', '.'),
                System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var val))
            await ValueChanged.InvokeAsync(val);
        else if (_input.Length == 0)
            await ValueChanged.InvokeAsync(0m);
    }
}
