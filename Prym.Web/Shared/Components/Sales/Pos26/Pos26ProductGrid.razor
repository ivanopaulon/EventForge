@* Pos26ProductGrid — griglia articoli responsive con Virtualize se >200 *@
@using Prym.DTOs.Products
@using Prym.Web.Models.Sales

@if (IsLoading)
{
    @* Skeleton cards — occupano esattamente lo stesso spazio delle card reali per evitare layout shift *@
    <div class="pos26-product-grid">
        @for (var i = 0; i < SkeletonCount; i++)
        {
            <div class="pos26-product-card pos26-product-card--skeleton">
                <div class="pos26-skeleton-img"></div>
                <div class="pos26-skeleton-line pos26-skeleton-line--name"></div>
                <div class="pos26-skeleton-line pos26-skeleton-line--price"></div>
            </div>
        }
    </div>
}
else if (Products.Count == 0)
{
    <div class="pos26-grid-empty">
        <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Size="Size.Large" Class="opacity-30" />
        <span>Nessun articolo trovato</span>
    </div>
}
else
{
    <div class="pos26-product-grid">
        @* Virtualize.Items richiede ICollection<TItem>; Products è materializzato come List<ProductDto>
           in RebuildFilteredProducts() (POS2026.razor.cs), quindi il cast è solo un'annotazione di tipo
           a costo zero — non alloca una nuova collezione come faceva il precedente .ToList(). *@
        <Virtualize Items="@((ICollection<ProductDto>)Products)" Context="product" OverscanCount="10">
            <Pos26ProductCard @key="product.Id"
                              Product="@product"
                              CartQuantity="@GetCartQty(product.Id)"
                              IsLastPurchase="@IsLastPurchaseProduct(product.Id)"
                              IsBestSeller="@IsBestSellerProduct(product.Id)"
                              StockAvailable="@GetStockAvailable(product.Id)"
                              OnAddToCart="@OnAddToCart"
                              OnLongPress="@OnLongPress" />
        </Virtualize>
    </div>
}

@code {
    [Parameter] public IReadOnlyList<ProductDto> Products { get; set; } = [];
    [Parameter] public Dictionary<Guid, int> CartQuantities { get; set; } = new();
    [Parameter] public HashSet<Guid> LastPurchaseIds { get; set; } = new();
    [Parameter] public HashSet<Guid> BestSellerIds { get; set; } = new();
    /// <summary>Disponibilità stock per prodotto (AvailableQuantity aggregata su tutte le location).</summary>
    [Parameter] public Dictionary<Guid, decimal> StockAvailability { get; set; } = new();
    [Parameter] public EventCallback<ProductDto> OnAddToCart { get; set; }
    [Parameter] public EventCallback<ProductDto> OnLongPress { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    /// <summary>Numero di card scheletro da mostrare durante il caricamento. Default: 16.</summary>
    [Parameter] public int SkeletonCount { get; set; } = 16;

    private int GetCartQty(Guid id) => CartQuantities.TryGetValue(id, out var q) ? q : 0;
    private bool IsLastPurchaseProduct(Guid id) => LastPurchaseIds.Contains(id);
    private bool IsBestSellerProduct(Guid id) => BestSellerIds.Contains(id);
    private decimal? GetStockAvailable(Guid id) => StockAvailability.TryGetValue(id, out var s) ? s : null;

    // ShouldRender guard state — tutte le collezioni osservate vengono ricreate dal padre
    // solo quando il loro contenuto cambia davvero (vedi RebuildFilteredProducts/RebuildCartQuantities
    // in POS2026.razor.cs), quindi un confronto per riferimento è sufficiente ed evita render inutili
    // quando il padre chiama StateHasChanged() per motivi non correlati alla griglia (es. numpad sconto).
    private IReadOnlyList<ProductDto>? _prevProducts;
    private Dictionary<Guid, int>? _prevCartQuantities;
    private HashSet<Guid>? _prevLastPurchaseIds;
    private HashSet<Guid>? _prevBestSellerIds;
    private Dictionary<Guid, decimal>? _prevStockAvailability;
    private bool _prevIsLoading;
    private bool _firstRender = true;

    protected override bool ShouldRender()
    {
        if (_firstRender)
        {
            _firstRender = false;
            CaptureShouldRenderState();
            return true;
        }

        var changed = !ReferenceEquals(_prevProducts, Products)
            || !ReferenceEquals(_prevCartQuantities, CartQuantities)
            || !ReferenceEquals(_prevLastPurchaseIds, LastPurchaseIds)
            || !ReferenceEquals(_prevBestSellerIds, BestSellerIds)
            || !ReferenceEquals(_prevStockAvailability, StockAvailability)
            || _prevIsLoading != IsLoading;

        if (changed)
        {
            CaptureShouldRenderState();
        }

        return changed;
    }

    private void CaptureShouldRenderState()
    {
        _prevProducts = Products;
        _prevCartQuantities = CartQuantities;
        _prevLastPurchaseIds = LastPurchaseIds;
        _prevBestSellerIds = BestSellerIds;
        _prevStockAvailability = StockAvailability;
        _prevIsLoading = IsLoading;
    }
}
