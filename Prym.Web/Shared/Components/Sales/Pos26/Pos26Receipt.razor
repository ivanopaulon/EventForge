@* Pos26Receipt — pannello scontrino scuro (colonna destra POS 2026) *@
@using Prym.DTOs.Business
@using Prym.DTOs.Business.Fidelity
@using Prym.DTOs.Promotions
@using Prym.Web.Shared.Components.Dialogs.Sales.Pos26
@using System.Linq
@inject IDialogService DialogService
@inject ITranslationService TranslationService

<div class="pos26-receipt">
    @* Header *@
    <div class="pos26-receipt-header">
        <div class="pos26-receipt-meta">
            <span class="pos26-receipt-label">Ordine</span>
            <span class="pos26-receipt-value">
                @if (Session != null)
                {
                    @($"#{Session.Id.ToString("N")[..8]}")
                }
                else
                {
                    <span class="pos26-receipt-muted">–</span>
                }
            </span>
        </div>
        @if (Customer != null)
        {
            <div class="pos26-receipt-customer">
                <MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Small" />
                @Customer.Name
            </div>
        }
        @if (FidelityCard != null)
        {
            <div class="pos26-receipt-fidelity d-flex align-center gap-2 mt-1">
                <MudIcon Icon="@Icons.Material.Outlined.Stars" Size="Size.Small" />
                <span>@FidelityCard.CardNumber</span>
                <span class="pos26-receipt-fidelity-pts">@FidelityCard.CurrentPoints pt</span>
            </div>
        }
        @if (Session?.TableId != null)
        {
            <div class="pos26-receipt-table">
                <MudIcon Icon="@Icons.Material.Outlined.TableRestaurant" Size="Size.Small" />
                Tavolo @Session.TableNumber
            </div>
        }
        <button class="pos26-receipt-clear"
                @onclick="OnClearCart"
                title="Svuota carrello"
                disabled="@(!(Items?.Any() == true))">
            <MudIcon Icon="@Icons.Material.Outlined.DeleteSweep" Size="Size.Small" />
        </button>
    </div>

    @* Lista righe *@
    <div class="pos26-receipt-items">
        @if (Items?.Any() == true)
        {
            @foreach (var item in Items)
            {
                <div class="pos26-receipt-row">
                    <div class="pos26-receipt-row-info">
                        <span class="pos26-receipt-row-name">@TruncateName(item.ProductName ?? item.ProductCode ?? "Articolo")</span>
                        @if (!string.IsNullOrEmpty(item.Notes))
                        {
                            <button class="pos26-receipt-note-icon"
                                    @onclick="() => OnEditItemNotes.InvokeAsync(item)"
                                    title="@item.Notes">
                                <MudIcon Icon="@Icons.Material.Outlined.Note" Size="Size.Small" />
                            </button>
                        }
                        <span class="pos26-receipt-row-detail">
                            @item.Quantity.ToString("G") × €@item.UnitPrice.ToString("F2")
                            @if (item.DiscountPercent > 0)
                            {
                                <span class="pos26-receipt-row-discount"> −@item.DiscountPercent.ToString("F1")%</span>
                            }
                        </span>
                        @if (!string.IsNullOrEmpty(item.PriceListName))
                        {
                            <span class="pos26-receipt-row-pricelist" title="Prezzo da listino: @item.PriceListName">
                                <MudIcon Icon="@Icons.Material.Outlined.Sell" Size="Size.Small" />
                            </span>
                        }
                    </div>
                    <div class="pos26-receipt-row-actions">
                        <button class="pos26-receipt-qty-btn" @onclick="() => OnDecrease.InvokeAsync(item)">−</button>
                        <span class="pos26-receipt-qty">@item.Quantity.ToString("G")</span>
                        <button class="pos26-receipt-qty-btn" @onclick="() => OnIncrease.InvokeAsync(item)">+</button>
                        <span class="pos26-receipt-row-total">€@item.TotalAmount.ToString("F2")</span>
                        @if (OnEditItem.HasDelegate)
                        {
                            <button class="pos26-receipt-edit-btn"
                                    @onclick="() => OnEditItem.InvokeAsync(item)"
                                    title="Modifica quantità, prezzo e sconto">
                                <MudIcon Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" />
                            </button>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="pos26-receipt-empty">
                <MudIcon Icon="@Icons.Material.Outlined.ShoppingCart" Size="Size.Medium" Class="opacity-30" />
                <span>Carrello vuoto</span>
            </div>
        }
    </div>

    @* Zona sconto dedicata (Task 6) — interposta tra righe e totali senza estrarre i totali da questo componente. *@
    @if (ExtraContent is not null)
    {
        @ExtraContent
    }

    @* Footer totali *@
    <div class="pos26-receipt-footer">
        <div class="pos26-receipt-total-row">
            <span>Subtotale</span>
            <span>€@Subtotal.ToString("F2")</span>
        </div>
        @if (TotalDiscount > 0)
        {
            var promotionBreakdown = GetPromotionBreakdown();
            var otherDiscount = GetOtherDiscountAmount(promotionBreakdown);
            @if (HasAppliedPromotions())
            {
                <div class="pos26-receipt-total-row">
                    <button class="pos26-receipt-promotions-link" @onclick="OpenPromotionTransparencyDialogAsync">
                        <MudIcon Icon="@Icons.Material.Outlined.Sell" Size="Size.Small" Class="mr-1" />
                        @TranslationService.GetTranslation("pos.promotions.viewDetails", "Dettaglio promozioni")
                    </button>
                </div>
            }
            @foreach (var promo in promotionBreakdown)
            {
                <div class="pos26-receipt-total-row pos26-receipt-total-row--discount">
                    <span class="pos26-receipt-discount-label">
                        <MudIcon Icon="@Icons.Material.Outlined.LocalOffer" Size="Size.Small" Class="mr-1" />
                        @promo.PromotionName
                    </span>
                    <span>−€@promo.Amount.ToString("F2")</span>
                </div>
            }
            @if (otherDiscount > 0)
            {
                <div class="pos26-receipt-total-row pos26-receipt-total-row--discount">
                    <span>Altri sconti</span>
                    <span>−€@otherDiscount.ToString("F2")</span>
                </div>
            }
            @if (!promotionBreakdown.Any() && otherDiscount == 0)
            {
                @* Caso limite: TotalDiscount > 0 ma nessuna riga ha AppliedPromotionsJSON valorizzato
                     (es. dati di sessioni create prima di PROMPT D) — fallback alla riga generica di prima. *@
                <div class="pos26-receipt-total-row pos26-receipt-total-row--discount">
                    <span>Sconto</span>
                    <span>−€@TotalDiscount.ToString("F2")</span>
                </div>
            }
        }
        @if (NearestNearMiss != null)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Outlined.TrendingUp" Class="my-1">
                @TranslationService.GetTranslationFormatted("pos.promotions.nearMiss",
                    "Mancano €{0} per sbloccare \"{1}\"", NearestNearMiss.MissingAmount.ToString("F2"), NearestNearMiss.PromotionName)
            </MudAlert>
        }
        @if (TotalVat > 0)
        {
            <div class="pos26-receipt-total-row pos26-receipt-total-row--vat">
                <span>IVA</span>
                <span>€@TotalVat.ToString("F2")</span>
            </div>
        }
        <div class="pos26-receipt-total-row pos26-receipt-total-row--grand">
            <span>Totale</span>
            <span class="pos26-receipt-grand-total">€@GrandTotal.ToString("F2")</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public SaleSessionDto? Session { get; set; }
    [Parameter] public BusinessPartyDto? Customer { get; set; }
    [Parameter] public FidelityCardDto? FidelityCard { get; set; }
    [Parameter] public List<SaleItemDto>? Items { get; set; }
    [Parameter] public decimal Subtotal { get; set; }
    [Parameter] public decimal TotalDiscount { get; set; }
    [Parameter] public decimal TotalVat { get; set; }
    [Parameter] public decimal GrandTotal { get; set; }
    [Parameter] public EventCallback OnClearCart { get; set; }
    [Parameter] public EventCallback<SaleItemDto> OnIncrease { get; set; }
    [Parameter] public EventCallback<SaleItemDto> OnDecrease { get; set; }
    [Parameter] public EventCallback<SaleItemDto> OnEditItemNotes { get; set; }
    /// <summary>
    /// Invocato quando il cassiere tocca il pulsante modifica riga.
    /// Il parent apre <see cref="POSTouchLineEditDialog"/> e salva le modifiche.
    /// </summary>
    [Parameter] public EventCallback<SaleItemDto> OnEditItem { get; set; }

    /// <summary>Contenuto aggiuntivo renderizzato tra le righe scontrino e i totali (Task 6 — Pos26DiscountZone).</summary>
    [Parameter] public RenderFragment? ExtraContent { get; set; }

    private const int MaxReceiptNameLength = 24;
    private const int ReceiptTruncateAt = 22;

    /// <summary>Promozione con soglia minima non ancora raggiunta più vicina allo sblocco (dato calcolato lato server).</summary>
    private PromotionNearMissDto? NearestNearMiss =>
        Session?.NearMissPromotions?.OrderBy(n => n.MissingAmount).FirstOrDefault();

    private bool HasAppliedPromotions() =>
        Items?.Any(i => !string.IsNullOrEmpty(i.AppliedPromotionsJSON)) == true;

    private async Task OpenPromotionTransparencyDialogAsync()
    {
        var parameters = new DialogParameters
        {
            { "Items", Items ?? new List<SaleItemDto>() }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<PromotionTransparencyDialog>(
            TranslationService.GetTranslation("pos.promotions.title", "Promozioni Attive"), parameters, options);
    }

    private static string TruncateName(string name) =>
        name.Length > MaxReceiptNameLength ? name[..ReceiptTruncateAt] + "…" : name;

    private List<(string PromotionName, decimal Amount)> GetPromotionBreakdown()
    {
        if (Items == null || Items.Count == 0)
            return new();

        var all = new List<Prym.DTOs.Promotions.AppliedPromotionSnapshot>();
        foreach (var item in Items)
        {
            if (string.IsNullOrEmpty(item.AppliedPromotionsJSON))
                continue;
            try
            {
                var snapshots = System.Text.Json.JsonSerializer.Deserialize<List<Prym.DTOs.Promotions.AppliedPromotionSnapshot>>(item.AppliedPromotionsJSON);
                if (snapshots != null)
                    all.AddRange(snapshots);
            }
            catch (System.Text.Json.JsonException)
            {
                // Riga con JSON malformato (non dovrebbe accadere, ma non deve rompere lo scontrino) — ignora.
            }
        }

        return all
            .GroupBy(s => s.PromotionName)
            .Select(g => (PromotionName: g.Key, Amount: g.Sum(s => s.DiscountAmount)))
            .OrderByDescending(x => x.Amount)
            .ToList();
    }

    private decimal GetOtherDiscountAmount(List<(string PromotionName, decimal Amount)> promotionBreakdown)
    {
        var promotionTotal = promotionBreakdown.Sum(p => p.Amount);
        var other = TotalDiscount - promotionTotal;
        return other > 0.01m ? other : 0m; // tolleranza di arrotondamento
    }
}
