@typeparam TItem

@if (Filters != null && Filters.Any())
{
    <div class="@($"quick-filters-wrapper{(IsInToolbar ? " in-toolbar" : "")}")">
        @foreach (var filter in Filters)
        {
            var isActive = _activeFilterId == filter.Id;
            <MudToggleIconButton Toggled="@isActive"
                                 ToggledChanged="@((v) => OnToggleFilter(filter, v))"
                                 Icon="@(filter.Icon ?? Icons.Material.Outlined.FilterList)"
                                 ToggledIcon="@(filter.Icon ?? Icons.Material.Outlined.FilterList)"
                                 Color="@Color.Default"
                                 ToggledColor="Color.Primary"
                                 Size="Size.Small"
                                 Title="@(filter.Description ?? filter.Label)" />
            @if (!string.IsNullOrEmpty(filter.Label))
            {
                <MudText Typo="Typo.caption"
                         Class="@($"quick-filter-label{(isActive ? " active" : "")}")"
                         @onclick="@(() => OnToggleFilter(filter, !isActive))">
                    @filter.Label@if (ShowCount) { <text>&nbsp;(@GetFilterCount(filter))</text> }
                </MudText>
            }
        }
    </div>
}

@code {
    /// <summary>
    /// Gli elementi su cui calcolare i conteggi dei filtri.
    /// </summary>
    [Parameter] public IEnumerable<TItem>? Items { get; set; }
    
    /// <summary>
    /// Lista dei filtri rapidi da visualizzare.
    /// </summary>
    [Parameter] public List<QuickFilter<TItem>>? Filters { get; set; }
    
    /// <summary>
    /// Callback invocato quando viene selezionato un filtro.
    /// </summary>
    [Parameter] public EventCallback<QuickFilter<TItem>?> OnFilterSelected { get; set; }
    
    /// <summary>
    /// Indica se mostrare il conteggio degli elementi per ogni filtro.
    /// </summary>
    [Parameter] public bool ShowCount { get; set; } = true;

    /// <summary>
    /// Quando true, il componente si adatta per l'uso dentro una toolbar (layout compatto, nessun wrapper MudPaper).
    /// </summary>
    [Parameter] public bool IsInToolbar { get; set; } = false;
    
    private string? _activeFilterId;
    
    private int GetFilterCount(QuickFilter<TItem> filter)
    {
        if (Items == null || filter.Predicate == null)
            return 0;
        
        return Items.Count(filter.Predicate);
    }
    
    private async Task OnToggleFilter(QuickFilter<TItem> filter, bool toggled)
    {
        if (toggled)
        {
            _activeFilterId = filter.Id;
            await OnFilterSelected.InvokeAsync(filter);
        }
        else
        {
            _activeFilterId = null;
            await OnFilterSelected.InvokeAsync(null);
        }
    }
}
