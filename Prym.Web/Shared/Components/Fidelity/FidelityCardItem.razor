@using Prym.DTOs.Business.Fidelity

<MudPaper Elevation="2" Class="pa-4" Style="@GetCardStyle()">
    <MudStack Spacing="3">
        
        <!-- Header: Tipo Card + Badge Status -->
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Class="text-white-full" Icon="@GetCardIcon()" Size="Size.Medium" />
                <MudText Typo="Typo.h6" Class="fw-semibold text-white-full">
                    @(Card.TierName ?? "—")
                </MudText>
            </MudStack>
            <MudChip T="string" 
                     Size="Size.Small" 
                     Color="@GetStatusColor()" Class="fw-semibold" 
>
                @GetStatusText()
            </MudChip>
        </MudStack>
        
        <!-- Numero Card -->
        <MudText Typo="Typo.body2" Class="text-card-mono">
            @Card.CardNumber
        </MudText>
        
        <!-- Validità -->
        <MudText Typo="Typo.caption" Class="text-white-80">
            Validità: @Card.ValidFrom.ToString("dd/MM/yyyy") - @Card.ValidTo.ToString("dd/MM/yyyy")
        </MudText>
        
        <MudDivider Class="divider-dark-bg" />
        
        <!-- Contatori Punti -->
        <MudGrid Spacing="2">
            <MudItem xs="4">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Class="text-dark-secondary">Punti Attuali</MudText>
                    <MudText Typo="Typo.h5" Class="fw-bold text-white-full">@Card.CurrentPoints</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="4">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Class="text-dark-secondary">Tot. Guadagnati</MudText>
                    <MudText Typo="Typo.body1" Class="text-white-90">@Card.TotalPointsEarned</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="4">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Class="text-dark-secondary">Tot. Utilizzati</MudText>
                    <MudText Typo="Typo.body1" Class="text-white-90">@Card.TotalPointsRedeemed</MudText>
                </MudStack>
            </MudItem>
        </MudGrid>
        
        <!-- Vantaggi -->
        <MudStack Row="true" Spacing="1" Class="flex-wrap-wrap">
            @if (Card.DiscountPercentage > 0)
            {
                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.Discount" Class="chip-white-alpha"
>
                    Sconto @Card.DiscountPercentage%
                </MudChip>
            }
            @if (Card.HasPriorityAccess)
            {
                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.Star" Class="chip-white-alpha"
>
                    Priority Access
                </MudChip>
            }
            @if (Card.HasBirthdayBonus)
            {
                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.Cake" Class="chip-white-alpha"
>
                    Birthday Bonus
                </MudChip>
            }
        </MudStack>
        
        <!-- Azioni -->
        <MudStack Row="true" Spacing="1" Class="flex-wrap-wrap">
            <MudIconButton Class="text-white-full"
                           Icon="@Icons.Material.Outlined.History"
                           Color="Color.Default"
                           Size="Size.Small"
                           OnClick="@(() => OnViewHistory.InvokeAsync(Card))"
                           title="Storico transazioni" />
            
            @if (Card.Status == FidelityCardStatus.Active)
            {
                <MudIconButton Class="text-white-full"
                               Icon="@Icons.Material.Outlined.AddCircle"
                               Color="Color.Default"
                               Size="Size.Small"
                               OnClick="@(() => OnManagePoints.InvokeAsync(Card))"
                               title="Gestisci punti" />
            }
            
            @if (Card.Status != FidelityCardStatus.Revoked)
            {
                <MudIconButton Class="text-white-full"
                               Icon="@Icons.Material.Outlined.Edit"
                               Color="Color.Default"
                               Size="Size.Small"
                               OnClick="@(() => OnEdit.InvokeAsync(Card))"
                               title="Modifica card" />
            }
            
            @if (Card.Status == FidelityCardStatus.Active)
            {
                <MudIconButton Class="text-white-full"
                               Icon="@Icons.Material.Outlined.Pause"
                               Color="Color.Default"
                               Size="Size.Small"
                               OnClick="@(() => OnSuspend.InvokeAsync(Card))"
                               title="Sospendi card" />
            }
            
            @if (Card.Status == FidelityCardStatus.Suspended)
            {
                <MudIconButton Class="text-white-full"
                               Icon="@Icons.Material.Outlined.PlayArrow"
                               Color="Color.Default"
                               Size="Size.Small"
                               OnClick="@(() => OnActivate.InvokeAsync(Card))"
                               title="Riattiva card" />
            }
            
            @if (Card.Status != FidelityCardStatus.Revoked)
            {
                <MudIconButton Class="text-white-full"
                               Icon="@Icons.Material.Outlined.Block"
                               Color="Color.Default"
                               Size="Size.Small"
                               OnClick="@(() => OnRevoke.InvokeAsync(Card))"
                               title="Revoca card" />
            }
        </MudStack>
        
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public FidelityCardDto Card { get; set; } = null!;
    
    [Parameter]
    public EventCallback<FidelityCardDto> OnViewHistory { get; set; }
    
    [Parameter]
    public EventCallback<FidelityCardDto> OnManagePoints { get; set; }
    
    [Parameter]
    public EventCallback<FidelityCardDto> OnEdit { get; set; }
    
    [Parameter]
    public EventCallback<FidelityCardDto> OnSuspend { get; set; }
    
    [Parameter]
    public EventCallback<FidelityCardDto> OnActivate { get; set; }
    
    [Parameter]
    public EventCallback<FidelityCardDto> OnRevoke { get; set; }
    
    private string GetCardStyle()
    {
        // The tier's configured color (hex) drives the card background; fall back to a neutral gradient.
        var safeColor = Prym.Web.Shared.Utils.CssColorSanitizer.SanitizeOrNull(Card.TierColor);
        var background = safeColor is null
            ? "linear-gradient(135deg, #667eea 0%, #764ba2 100%)"
            : safeColor;

        return $"background: {background}; border-radius: 12px; min-height: 200px;";
    }
    
    private string GetCardIcon()
    {
        return string.IsNullOrWhiteSpace(Card.TierIcon)
            ? Icons.Material.Outlined.CardMembership
            : Card.TierIcon;
    }
    
    private Color GetStatusColor()
    {
        return Card.Status switch
        {
            FidelityCardStatus.Active => Color.Success,
            FidelityCardStatus.Suspended => Color.Warning,
            FidelityCardStatus.Expired => Color.Default,
            FidelityCardStatus.Revoked => Color.Error,
            _ => Color.Default
        };
    }
    
    private string GetStatusText()
    {
        return Card.Status switch
        {
            FidelityCardStatus.Active => "Attiva",
            FidelityCardStatus.Suspended => "Sospesa",
            FidelityCardStatus.Expired => "Scaduta",
            FidelityCardStatus.Revoked => "Revocata",
            _ => "Sconosciuto"
        };
    }
}
