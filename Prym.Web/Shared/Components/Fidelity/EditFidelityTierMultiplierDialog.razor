@using Prym.DTOs.Business.Fidelity
@using Prym.Web.Services
@inject IFidelityTierMultiplierService TierMultiplierService
@inject IFidelityTierService FidelityTierService
@inject ITranslationService TranslationService
@inject IAppNotificationService AppNotification
@inject ILogger<EditFidelityTierMultiplierDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.Star"
          Title="@(IsEditMode
              ? TranslationService.GetTranslation("fidelityPoints.tierMultipliers.editTitle", "Modifica Moltiplicatore Livello")
              : TranslationService.GetTranslation("fidelityPoints.tierMultipliers.createTitle", "Nuovo Moltiplicatore Livello"))"
          IsProcessing="@_isProcessing"
          OnClose="Cancel"
          MinWidth="@Prym.Web.Shared.Components.Dialogs.EFDialogDefaults.MinWidthSimple">
    <ChildContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudGrid>
                <MudItem xs="12" md="6">
                    @if (IsEditMode)
                    {
                        <MudTextField Value="@GetTierLabel(_tierId)"
                                      Label="@TranslationService.GetTranslation("fidelityPoints.tierMultipliers.cardType", "Livello Carta")"
                                      Variant="Variant.Outlined"
                                      ReadOnly="true"
                                      Disabled="true"
                                      Margin="Margin.Dense" />
                    }
                    else
                    {
                        <MudSelect T="Guid"
                                   @bind-Value="_tierId"
                                   Label="@($"{TranslationService.GetTranslation("fidelityPoints.tierMultipliers.cardType", "Livello Carta")} *")"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   Margin="Margin.Dense">
                            @foreach (var tier in AvailableTiers)
                            {
                                <MudSelectItem Value="@tier.Id">@tier.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal"
                                     @bind-Value="_multiplier"
                                     Label="@($"{TranslationService.GetTranslation("fidelityPoints.tierMultipliers.multiplier", "Moltiplicatore")} *")"
                                     Variant="Variant.Outlined"
                                     Required="true"
                                     Min="0.01m"
                                     Max="100m"
                                     Immediate="true"
                                     Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </ChildContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Color="Color.Default">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="SubmitAsync"
                   Disabled="@(!_isValid || _isProcessing)">
            @if (_isProcessing)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <text>@TranslationService.GetTranslation("common.save", "Salva")</text>
            }
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>Campaign this multiplier belongs to — required, tier multipliers are always per-campaign.</summary>
    [Parameter, EditorRequired]
    public Guid CampaignId { get; set; }

    /// <summary>Existing multiplier to edit; null when creating a new one.</summary>
    [Parameter]
    public FidelityTierMultiplierDto? TierMultiplier { get; set; }

    /// <summary>Tier ids already configured for this campaign, excluded from the create picker.</summary>
    [Parameter]
    public IReadOnlyCollection<Guid> ExistingTierIds { get; set; } = [];

    private bool IsEditMode => TierMultiplier is not null;

    private MudForm _form = null!;
    private bool _isValid;
    private bool _isProcessing;
    private Guid _tierId;
    private decimal _multiplier = 1.0m;
    private IReadOnlyList<FidelityTierDto> _tiers = [];

    private IEnumerable<FidelityTierDto> AvailableTiers =>
        _tiers.Where(t => !ExistingTierIds.Contains(t.Id));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _tiers = (await FidelityTierService.GetAllAsync())
                .Where(t => t.IsActive)
                .OrderBy(t => t.SortOrder)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading fidelity tiers");
        }
    }

    protected override void OnParametersSet()
    {
        if (IsEditMode)
        {
            _tierId = TierMultiplier!.TierId;
            _multiplier = TierMultiplier.Multiplier;
        }
        else if (_tierId == default && AvailableTiers.Any())
        {
            _tierId = AvailableTiers.First().Id;
        }
    }

    private async Task SubmitAsync()
    {
        if (_form == null)
            return;

        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            AppNotification.ShowError(TranslationService.GetTranslation("validation.fixErrors", "Correggi gli errori prima di salvare"));
            return;
        }

        try
        {
            _isProcessing = true;

            if (IsEditMode)
            {
                var dto = new UpdateFidelityTierMultiplierDto
                {
                    TierId = _tierId,
                    Multiplier = _multiplier
                };

                await TierMultiplierService.UpdateAsync(TierMultiplier!.Id, dto);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("fidelityPoints.tierMultipliers.updated", "Moltiplicatore livello aggiornato con successo."));
            }
            else
            {
                var dto = new CreateFidelityTierMultiplierDto
                {
                    CampaignId = CampaignId,
                    TierId = _tierId,
                    Multiplier = _multiplier
                };

                await TierMultiplierService.CreateAsync(dto);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("fidelityPoints.tierMultipliers.created", "Moltiplicatore livello creato con successo."));
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving fidelity tier multiplier for campaign {CampaignId}", CampaignId);
            AppNotification.ShowError(ex.Message);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private string GetTierLabel(Guid tierId)
        => _tiers.FirstOrDefault(t => t.Id == tierId)?.Name
           ?? TierMultiplier?.TierName
           ?? tierId.ToString();
}
