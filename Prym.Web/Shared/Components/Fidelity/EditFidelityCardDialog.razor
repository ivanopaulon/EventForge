@using Prym.DTOs.Business.Fidelity
@using Prym.Web.Services
@inject ILogger<EditFidelityCardDialog> Logger
@inject IAppNotificationService AppNotification
@inject IFidelityTierService FidelityTierService

<EFDialog Icon="@Icons.Material.Outlined.CardMembership"
          Title="Modifica Card Fedeltà"
          IsProcessing="@_isProcessing"
          OnClose="Cancel">
    <ChildContent>
        
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudGrid>
                
                <MudItem xs="12">
                    <MudTextField Value="@Card.CardNumber"
                                 Label="Numero Card"
                                 Variant="Variant.Outlined"
                                 ReadOnly="true"
                                 Disabled="true"
                    Margin="Margin.Dense"/>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudSelect T="Guid?" @bind-Value="_tierId"
                              Label="Livello *"
                              Variant="Variant.Outlined"
                              Required="true">
                        @foreach (var tier in _tiers)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)tier.Id)">@tier.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="_status"
                              Label="Status"
                              Variant="Variant.Outlined"
                              Disabled="true">
                        <MudSelectItem Value="@FidelityCardStatus.Active">Attiva</MudSelectItem>
                        <MudSelectItem Value="@FidelityCardStatus.Suspended">Sospesa</MudSelectItem>
                        <MudSelectItem Value="@FidelityCardStatus.Expired">Scaduta</MudSelectItem>
                        <MudSelectItem Value="@FidelityCardStatus.Revoked">Revocata</MudSelectItem>
                    </MudSelect>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudDatePicker @bind-Date="_validFrom"
                                   Label="Valida da *"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   Editable="true"
                    Margin="Margin.Dense"/>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudDatePicker @bind-Date="_validTo"
                                   Label="Valida fino a *"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   Editable="true"
                    Margin="Margin.Dense"/>
                </MudItem>
                
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="_discountPercentage"
                                     Label="Sconto %"
                                     Variant="Variant.Outlined"
                                     Min="0"
                                     Max="100"
                    Margin="Margin.Dense"/>
                </MudItem>
                
                <MudItem xs="12" md="4">
                    <MudSwitch @bind-Value="_hasPriorityAccess"
                              Label="Priority Access"
                              Color="Color.Primary" />
                </MudItem>
                
                <MudItem xs="12" md="4">
                    <MudSwitch @bind-Value="_hasBirthdayBonus"
                              Label="Birthday Bonus"
                              Color="Color.Primary" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudTextField @bind-Value="_notes"
                                 Label="Note"
                                 Variant="Variant.Outlined"
                                 Lines="3"
                                 MaxLength="500"
                    Margin="Margin.Dense"/>
                </MudItem>
                
            </MudGrid>
        </MudForm>
    </ChildContent>
    <DialogActions>
        <MudButton OnClick="Cancel"
                               Variant="Variant.Text" Color="Color.Default">Annulla</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   OnClick="Submit" 
                   Disabled="@(!_isValid || _isProcessing)">
            @if (_isProcessing)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <text>Salva Modifiche</text>
            }
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter, EditorRequired]
    public FidelityCardDto Card { get; set; } = null!;
    
    private MudForm _form = null!;
    private bool _isValid;
    private bool _isProcessing;
    
    private Guid? _tierId;
    private IReadOnlyList<FidelityTierDto> _tiers = [];
    private FidelityCardStatus _status;
    private DateTime? _validFrom;
    private DateTime? _validTo;
    private decimal _discountPercentage;
    private bool _hasPriorityAccess;
    private bool _hasBirthdayBonus;
    private string? _notes;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _tiers = (await FidelityTierService.GetAllAsync())
                .Where(t => t.IsActive)
                .OrderBy(t => t.SortOrder)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore durante il caricamento dei livelli fedeltà");
        }
    }

    protected override void OnParametersSet()
    {
        _tierId = Card.TierId;
        _status = Card.Status;
        _validFrom = Card.ValidFrom;
        _validTo = Card.ValidTo;
        _discountPercentage = Card.DiscountPercentage;
        _hasPriorityAccess = Card.HasPriorityAccess;
        _hasBirthdayBonus = Card.HasBirthdayBonus;
        _notes = Card.Notes;
    }
    
    private async Task Submit()
    {
        if (!_isValid) return;
        
        try
        {
            _isProcessing = true;
            
            var updateCard = new UpdateFidelityCardDto
            {
                TierId = _tierId,
                ValidFrom = _validFrom ?? Card.ValidFrom,
                ValidTo = _validTo ?? Card.ValidTo,
                DiscountPercentage = _discountPercentage,
                HasPriorityAccess = _hasPriorityAccess,
                HasBirthdayBonus = _hasBirthdayBonus,
                Notes = _notes
            };

            MudDialog.Close(DialogResult.Ok(updateCard));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore durante la modifica della card fedeltà {CardNumber}", Card.CardNumber);
            AppNotification.ShowError("Errore durante la modifica della card.");
        }
        finally
        {
            _isProcessing = false;
        }
    }
    
    private void Cancel() => MudDialog.Cancel();
}
