@using Prym.DTOs.Business.Fidelity
@using Prym.Web.Services
@inject ILogger<CreateFidelityCardDialog> Logger
@inject IAppNotificationService AppNotification
@inject IFidelityTierService FidelityTierService

<EFDialog Icon="@Icons.Material.Outlined.CardMembership"
          Title="Nuova Card Fedeltà"
          IsProcessing="@_isProcessing"
          OnClose="Cancel">
    <ChildContent>
        
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudGrid>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_cardNumber"
                                  Label="Numero Card *"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  MaxLength="50"
                    Margin="Margin.Dense"/>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSelect T="Guid?" @bind-Value="_tierId"
                              Label="Livello *"
                              Variant="Variant.Outlined"
                              Required="true">
                        @foreach (var tier in _tiers)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)tier.Id)">@tier.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudDatePicker @bind-Date="_validFrom"
                                   Label="Valida da *"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   Editable="true"
                    Margin="Margin.Dense"/>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudDatePicker @bind-Date="_validTo"
                                   Label="Valida fino a *"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   Editable="true"
                    Margin="Margin.Dense"/>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="_discountPercentage"
                                     Label="Sconto %"
                                     Variant="Variant.Outlined"
                                     Min="0"
                                     Max="100"
                    Margin="Margin.Dense"/>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Value="_hasPriorityAccess"
                              Label="Priority Access"
                              Color="Color.Primary" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Value="_hasBirthdayBonus"
                              Label="Birthday Bonus"
                              Color="Color.Primary" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_notes"
                                 Label="Note"
                                 Variant="Variant.Outlined"
                                 Lines="3"
                                 MaxLength="500"
                    Margin="Margin.Dense"/>
                </MudItem>
                
            </MudGrid>
        </MudForm>
    </ChildContent>
    <DialogActions>
        <MudButton OnClick="Cancel"
                               Variant="Variant.Text" Color="Color.Default">Annulla</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   OnClick="Submit" 
                   Disabled="@(!_isValid || _isProcessing)">
            @if (_isProcessing)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <text>Crea Card</text>
            }
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;
    private MudForm _form = null!;
    private bool _isValid;
    private bool _isProcessing;
    
    private string _cardNumber = string.Empty;
    private Guid? _tierId;
    private IReadOnlyList<FidelityTierDto> _tiers = [];
    private DateTime? _validFrom = DateTime.Now;
    private DateTime? _validTo = DateTime.Now.AddYears(1);
    private decimal _discountPercentage = 0;
    private bool _hasPriorityAccess = false;
    private bool _hasBirthdayBonus = false;
    private string? _notes;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _tiers = (await FidelityTierService.GetAllAsync())
                .Where(t => t.IsActive)
                .OrderBy(t => t.SortOrder)
                .ToList();
            _tierId = _tiers.FirstOrDefault()?.Id;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore durante il caricamento dei livelli fedeltà");
        }
    }
    
    private async Task Submit()
    {
        if (!_isValid) return;
        
        try
        {
            _isProcessing = true;
            
            var newCard = new CreateFidelityCardDto
            {
                CardNumber = _cardNumber,
                TierId = _tierId,
                ValidFrom = _validFrom ?? DateTime.Now,
                ValidTo = _validTo ?? DateTime.Now.AddYears(1),
                DiscountPercentage = _discountPercentage,
                HasPriorityAccess = _hasPriorityAccess,
                HasBirthdayBonus = _hasBirthdayBonus,
                Notes = _notes
            };
            
            MudDialog.Close(DialogResult.Ok(newCard));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore durante la creazione della card fedeltà");
            AppNotification.ShowError("Errore durante la creazione della card.");
        }
        finally
        {
            _isProcessing = false;
        }
    }
    
    private void Cancel() => MudDialog.Cancel();
}
