@using Prym.DTOs.Business.Fidelity

<EFDialog Icon="@Icons.Material.Outlined.History"
          Title="@($"Storico Punti - Card {Card.TierName}")"
          IsProcessing="false"
          OnClose="Close">
    <ChildContent>
        
        <!-- Informazioni Card -->
        <MudPaper Outlined="true" Class="pa-3 mb-4">
            <MudStack Spacing="2">
                <MudText Typo="Typo.subtitle1" Class="fw-semibold">
                    Storico Transazioni - Card @Card.TierName
                </MudText>
                <MudText Typo="Typo.body2">
                    Numero: @Card.CardNumber
                </MudText>
            </MudStack>
        </MudPaper>
        
        @if (Transactions != null && Transactions.Any())
        {
            <EFTable TItem="FidelityPointsTransactionDto"
                     Items="@_orderedTransactions"
                     Dense="true"
                     Hover="true"
                     Striped="true"
                     ShowSearch="false"
                     ShowFilters="false"
                     ShowRefresh="false"
                     ShowCreate="false"
                     ShowExport="false"
                     ShowColumnConfiguration="false"
                     AllowDragDropGrouping="false"
                     ComponentKey="fidelity-points-history-dialog"
                     InitialColumnConfigurations="@_transactionColumns">
                <HeaderContent Context="columns">
                    <MudTh>Data</MudTh>
                    <MudTh>Tipo</MudTh>
                    <MudTh >Punti</MudTh>
                    <MudTh >Saldo Dopo</MudTh>
                    <MudTh>Descrizione</MudTh>
                </HeaderContent>
                <RowTemplate Context="t">
                    <MudTd DataLabel="Data">@t.TransactionDate.ToString("dd/MM/yyyy HH:mm")</MudTd>
                    <MudTd DataLabel="Tipo">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@GetTransactionTypeColor(t.TransactionType)"
                                 Icon="@GetTransactionTypeIcon(t.TransactionType)">
                            @GetTransactionTypeText(t.TransactionType)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Punti" >
                        <MudText Typo="Typo.body2"
                                 Color="@(GetSignedPoints(t) > 0 ? Color.Success : Color.Warning)"
                                  Class="fw-semibold">
                            @(GetSignedPoints(t) > 0 ? "+" : "")@GetSignedPoints(t)
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Saldo Dopo" >
                        <MudText Typo="Typo.body2" Class="fw-medium">@GetBalanceAfter(t)</MudText>
                    </MudTd>
                    <MudTd DataLabel="Descrizione">
                        <MudText Typo="Typo.body2">@t.Description</MudText>
                    </MudTd>
                </RowTemplate>
            </EFTable>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                Nessuna transazione presente per questa card
            </MudAlert>
        }
        
    </ChildContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Close">
            Chiudi
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter, EditorRequired]
    public FidelityCardDto Card { get; set; } = null!;
    
    [Parameter]
    public IEnumerable<FidelityPointsTransactionDto>? Transactions { get; set; }

    private readonly List<EFTableColumnConfiguration> _transactionColumns = new()
    {
        new() { PropertyName = "TransactionDate", DisplayName = "Data",        Order = 0 },
        new() { PropertyName = "TransactionType", DisplayName = "Tipo",        Order = 1 },
        new() { PropertyName = "Points",          DisplayName = "Punti",       Order = 2 },
        new() { PropertyName = "Description",     DisplayName = "Descrizione", Order = 4 },
    };

    private List<FidelityPointsTransactionDto> _orderedTransactions = [];
    private readonly Dictionary<Guid, int> _balanceAfter = [];
    
    protected override void OnParametersSet()
    {
        _orderedTransactions = (Transactions ?? [])
            .OrderByDescending(t => t.TransactionDate)
            .ThenByDescending(t => t.CreatedAt)
            .ToList();

        _balanceAfter.Clear();
        var runningBalance = Card.CurrentPoints;

        foreach (var transaction in _orderedTransactions)
        {
            _balanceAfter[transaction.Id] = runningBalance;
            runningBalance -= GetSignedPoints(transaction);
        }
    }

    private Color GetTransactionTypeColor(FidelityTransactionType type)
    {
        return type switch
        {
            FidelityTransactionType.Earned => Color.Success,
            FidelityTransactionType.Redeemed => Color.Warning,
            FidelityTransactionType.Adjustment => Color.Info,
            _ => Color.Default
        };
    }
    
    private string GetTransactionTypeIcon(FidelityTransactionType type)
    {
        return type switch
        {
            FidelityTransactionType.Earned => Icons.Material.Outlined.Add,
            FidelityTransactionType.Redeemed => Icons.Material.Outlined.Remove,
            FidelityTransactionType.Adjustment => Icons.Material.Outlined.Edit,
            _ => Icons.Material.Outlined.Circle
        };
    }
    
    private string GetTransactionTypeText(FidelityTransactionType type)
    {
        return type switch
        {
            FidelityTransactionType.Earned => "Guadagnati",
            FidelityTransactionType.Redeemed => "Riscattati",
            FidelityTransactionType.Adjustment => "Aggiustati",
            _ => "Sconosciuto"
        };
    }

    private int GetSignedPoints(FidelityPointsTransactionDto transaction) =>
        transaction.TransactionType switch
        {
            FidelityTransactionType.Redeemed => -transaction.Points,
            _ => transaction.Points
        };

    private int GetBalanceAfter(FidelityPointsTransactionDto transaction) =>
        _balanceAfter.TryGetValue(transaction.Id, out var balance) ? balance : 0;
    
    private void Close() => MudDialog.Close();
}
