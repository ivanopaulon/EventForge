@using Prym.DTOs.Store
@using Prym.Web.Services.Store
@inject IFiscalDrawerService FiscalDrawerService
@inject ITranslationService TranslationService
@inject IAppNotificationService AppNotification
@inject ILogger<FiscalDrawerHistoryDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.History"
          Title="@($"Storico cassetto — {DrawerName}")"
          IsProcessing="@_isLoading"
          OnClose="Close"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <ChildContent>
        <MudTabs Elevation="0" ApplyEffectsToContainer="true" PanelClass="pa-4">
            <MudTabPanel Text="Sessione corrente" Icon="@Icons.Material.Outlined.LockOpen">
                @if (_currentSession is null)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Nessuna sessione aperta per questo cassetto.</MudText>
                }
                else
                {
                    <MudGrid>
                        <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Aperta il</MudText><MudText>@_currentSession.OpenedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText></MudItem>
                        <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Operatore</MudText><MudText>@(_currentSession.OpenedByOperatorName ?? "-")</MudText></MudItem>
                        <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Fondo apertura</MudText><MudText>@_currentSession.OpeningBalance.ToString("C2", _it)</MudText></MudItem>
                        <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Totale vendite</MudText><MudText>@_currentSession.TotalSales.ToString("C2", _it)</MudText></MudItem>
                        <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Versamenti</MudText><MudText>@_currentSession.TotalDeposits.ToString("C2", _it)</MudText></MudItem>
                        <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Prelievi</MudText><MudText>@_currentSession.TotalWithdrawals.ToString("C2", _it)</MudText></MudItem>
                        <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Movimenti</MudText><MudText>@_currentSession.TransactionCount</MudText></MudItem>
                    </MudGrid>
                    <MudButton Variant="Variant.Text" Class="mt-2" StartIcon="@Icons.Material.Outlined.Receipt"
                               OnClick="@(() => LoadTransactionsAsync(_currentSession.Id))">
                        Vedi movimenti di questa sessione
                    </MudButton>
                }
            </MudTabPanel>
            <MudTabPanel Text="Sessioni passate" Icon="@Icons.Material.Outlined.History">
                @if (!_sessions.Any())
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Nessuna sessione storica trovata.</MudText>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true">
                        <thead>
                            <tr><th>Data</th><th>Apertura</th><th>Chiusura</th><th>Fondo apertura</th><th>Fondo chiusura</th><th>Movimenti</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _sessions)
                            {
                                <tr>
                                    <td>@s.SessionDate.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                    <td>@s.OpenedAt.ToLocalTime().ToString("HH:mm")</td>
                                    <td>@(s.ClosedAt?.ToLocalTime().ToString("HH:mm") ?? "-")</td>
                                    <td>@s.OpeningBalance.ToString("C2", _it)</td>
                                    <td>@s.ClosingBalance.ToString("C2", _it)</td>
                                    <td>@s.TransactionCount</td>
                                    <td>
                                        <MudTooltip Text="Vedi movimenti">
                                            <PrymIconButton Icon="@Icons.Material.Outlined.Receipt" Size="Size.Small"
                                                            OnClick="@(() => LoadTransactionsAsync(s.Id))" />
                                        </MudTooltip>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                    @if (_sessionsTotalCount > _sessions.Count)
                    {
                        <MudButton Variant="Variant.Text" Class="mt-2" OnClick="LoadMoreSessionsAsync">Carica altre</MudButton>
                    }
                }
            </MudTabPanel>
            <MudTabPanel Text="Movimenti" Icon="@Icons.Material.Outlined.Receipt">
                @if (!_transactions.Any())
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Seleziona una sessione per vederne i movimenti, oppure vengono mostrati tutti i movimenti del cassetto.
                    </MudText>
                }
                <MudSimpleTable Dense="true" Hover="true">
                    <thead>
                        <tr><th>Data/Ora</th><th>Tipo</th><th>Pagamento</th><th>Importo</th><th>Operatore</th><th>Descrizione</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _transactions)
                        {
                            <tr>
                                <td>@t.TransactionAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@t.TransactionType</td>
                                <td>@t.PaymentType</td>
                                <td>@t.Amount.ToString("C2", _it)</td>
                                <td>@(t.OperatorName ?? "-")</td>
                                <td>@(t.Description ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
                @if (_transactionsTotalCount > _transactions.Count)
                {
                    <MudButton Variant="Variant.Text" Class="mt-2" OnClick="LoadMoreTransactionsAsync">Carica altri</MudButton>
                }
            </MudTabPanel>
        </MudTabs>
    </ChildContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Text">Chiudi</MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public Guid FiscalDrawerId { get; set; }
    [Parameter] public string DrawerName { get; set; } = string.Empty;

    private readonly System.Globalization.CultureInfo _it = new("it-IT");
    private bool _isLoading;

    private FiscalDrawerSessionDto? _currentSession;

    private readonly List<FiscalDrawerSessionDto> _sessions = new();
    private int _sessionsPage = 1;
    private long _sessionsTotalCount;

    private readonly List<FiscalDrawerTransactionDto> _transactions = new();
    private Guid? _selectedSessionId;
    private int _transactionsPage = 1;
    private long _transactionsTotalCount;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            _currentSession = await FiscalDrawerService.GetCurrentSessionAsync(FiscalDrawerId);
            await LoadSessionsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading fiscal drawer history for {DrawerId}.", FiscalDrawerId);
            AppNotification.ShowWarning("Si è verificato un errore nel caricamento dello storico cassetto.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadSessionsAsync()
    {
        var result = await FiscalDrawerService.GetSessionsAsync(FiscalDrawerId, _sessionsPage, 20);
        if (result is null) return;
        _sessions.AddRange(result.Items);
        _sessionsTotalCount = result.TotalCount;
    }

    private async Task LoadMoreSessionsAsync()
    {
        _sessionsPage++;
        await LoadSessionsAsync();
    }

    private async Task LoadTransactionsAsync(Guid sessionId)
    {
        _selectedSessionId = sessionId;
        _transactions.Clear();
        _transactionsPage = 1;
        await LoadMoreTransactionsAsync();
    }

    private async Task LoadMoreTransactionsAsync()
    {
        try
        {
            var result = await FiscalDrawerService.GetTransactionsAsync(FiscalDrawerId, _selectedSessionId, _transactionsPage, 50);
            if (result is null) return;
            _transactions.AddRange(result.Items);
            _transactionsTotalCount = result.TotalCount;
            _transactionsPage++;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading fiscal drawer transactions for {DrawerId}.", FiscalDrawerId);
            AppNotification.ShowWarning("Si è verificato un errore nel caricamento dei movimenti.");
        }
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
}
