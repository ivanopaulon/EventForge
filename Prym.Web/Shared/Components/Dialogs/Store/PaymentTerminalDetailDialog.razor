@using Prym.DTOs.PaymentTerminal
@using Prym.Web.ViewModels
@attribute [Authorize]
@inject PaymentTerminalDetailViewModel ViewModel
@inject ITranslationService TranslationService
@inject IAppNotificationService AppNotification
@inject ILogger<PaymentTerminalDetailDialog> Logger
@implements IDisposable

<EFDialog Icon="@Icons.Material.Outlined.CreditCard"
          Title="@(ViewModel.IsNewEntity ? "Nuovo Terminale POS" : (ViewModel.Entity?.Name ?? "Terminale POS"))"
          IsProcessing="@(ViewModel.IsLoading || ViewModel.IsSaving)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <ChildContent>
        @if (ViewModel.IsLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (!ViewModel.IsNewEntity && ViewModel.Entity == null)
        {
            <MudAlert Severity="Severity.Error">Terminale POS non trovato.</MudAlert>
        }
        else if (ViewModel.Entity != null)
        {
            <MudTabs Elevation="0" Rounded="false" PanelClass="pa-4" Class="ef-tabs" ApplyEffectsToContainer="true">

                @* ─── Tab 1: Generale ─────────────────────────────────────── *@
                <MudTabPanel Text="Generale" Icon="@Icons.Material.Outlined.Info">
                    @if (!ViewModel.IsNewEntity)
                    {
                        <div class="d-flex align-center gap-4 flex-wrap mb-3">
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Color="Color.Primary" Size="Size.Medium">
                                    <MudIcon Icon="@Icons.Material.Outlined.CreditCard" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.body1" Class="fw-semibold">@ViewModel.Entity.Name</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        ID: @ViewModel.Entity.Id.ToString()[..8]...
                                    </MudText>
                                </div>
                            </div>
                            <MudChip T="string" Size="Size.Medium"
                                     Color="@(ViewModel.Entity.IsEnabled ? Color.Success : Color.Default)">
                                @(ViewModel.Entity.IsEnabled ? "Abilitato" : "Disabilitato")
                            </MudChip>
                        </div>
                        <MudDivider Class="mb-3" />
                    }

                    <MudForm @ref="_form" Model="@ViewModel.Entity">
                        <MudGrid>
                            <MudItem xs="12">
                                <PrymTextField @bind-Value="ViewModel.Entity.Name"
                                               Label="@TranslationService.GetTranslation("field.name", "Nome")"
                                               Required="true"
                                               MaxLength="100"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>
                            <MudItem xs="12">
                                <PrymTextField @bind-Value="ViewModel.Entity.Description"
                                               Label="Descrizione"
                                               MaxLength="200"
                                               Lines="2"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSwitch @bind-Value="ViewModel.Entity.IsEnabled"
                                           Label="Terminale abilitato"
                                           Color="Color.Primary"
                                           @bind-Value:after="HandleEntityChanged" />
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                </MudTabPanel>

                @* ─── Tab 2: Connessione ──────────────────────────────────── *@
                <MudTabPanel Text="Connessione" Icon="@Icons.Material.Outlined.Cable">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <PrymSelect @bind-Value="ViewModel.Entity.ConnectionType"
                                        Label="Tipo di connessione"
                                        @bind-Value:after="HandleEntityChanged">
                                <MudSelectItem Value="@("Tcp")">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Outlined.Cable" Size="Size.Small" />
                                        <MudText>TCP Diretto (Server → Terminale)</MudText>
                                    </MudStack>
                                </MudSelectItem>
                                <MudSelectItem Value="@("TcpViaAgent")">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Outlined.Hub" Size="Size.Small" />
                                        <MudText>TCP via Agente</MudText>
                                    </MudStack>
                                </MudSelectItem>
                            </PrymSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <PrymNumericField @bind-Value="ViewModel.Entity.TimeoutMs"
                                              Label="Timeout (ms)"
                                              Min="1000"
                                              Max="120000"
                                              Step="1000"
                                              @bind-Value:after="HandleEntityChanged" />
                        </MudItem>
                        <MudItem xs="12" sm="8">
                            <PrymTextField @bind-Value="ViewModel.Entity.IpAddress"
                                           Label="Indirizzo IP del terminale"
                                           MaxLength="45"
                                           Placeholder="es. 192.168.1.100"
                                           HelperText="Indirizzo IPv4 o IPv6 del terminale POS"
                                           @bind-Value:after="HandleEntityChanged" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <PrymNumericField @bind-Value="ViewModel.Entity.Port"
                                              Label="Porta TCP"
                                              Min="1"
                                              Max="65535"
                                              HelperText="Default: 60000"
                                              @bind-Value:after="HandleEntityChanged" />
                        </MudItem>

                        @if (ViewModel.Entity.ConnectionType == "TcpViaAgent")
                        {
                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Info" Class="mb-2">
                                    Connessione tramite agente: il server contatta l'agente che si connette localmente al terminale.
                                </MudAlert>
                                <PrymTextField @bind-Value="_agentIdText"
                                               Label="ID Agente (GUID)"
                                               Placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                                               HelperText="GUID dell'agente EventForge configurato nel server"
                                               @bind-Value:after="OnAgentIdChanged" />
                            </MudItem>
                        }

                        @* Test connessione *@
                        <MudItem xs="12">
                            <MudDivider Class="my-2" />
                            <div class="d-flex align-center gap-3 flex-wrap">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Info"
                                           StartIcon="@Icons.Material.Outlined.NetworkCheck"
                                           Disabled="@(_isTesting || string.IsNullOrWhiteSpace(ViewModel.Entity.IpAddress))"
                                           OnClick="TestConnectionAsync">
                                    @(_isTesting ? "Test in corso..." : "Test Connessione")
                                </MudButton>
                                @if (_testResult is not null)
                                {
                                    <MudChip T="string" Color="@(_testSuccess ? Color.Success : Color.Error)"
                                             Icon="@(_testSuccess ? Icons.Material.Outlined.CheckCircle : Icons.Material.Outlined.Error)">
                                        @_testResult
                                    </MudChip>
                                }
                            </div>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                @* ─── Tab 3: Protocollo 17 ────────────────────────────────── *@
                <MudTabPanel Text="Protocollo 17" Icon="@Icons.Material.Outlined.Settings">
                    <MudGrid>
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info" Class="mb-3">
                                <strong>ECR17 / Protocollo 17</strong> — Standard italiano per la comunicazione automatica
                                dell'importo tra registratore di cassa e terminale di pagamento POS via TCP/IP.
                            </MudAlert>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <PrymTextField @bind-Value="ViewModel.Entity.TerminalId"
                                           Label="ID Terminale (max 8 caratteri)"
                                           MaxLength="8"
                                           HelperText="Identificativo del terminale (se richiesto dal provider POS)"
                                           @bind-Value:after="HandleEntityChanged" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudSwitch @bind-Value="ViewModel.Entity.AmountConfirmationRequired"
                                       Label="Richiedi conferma importo sul terminale prima dell'addebito"
                                       Color="Color.Primary"
                                       @bind-Value:after="HandleEntityChanged" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudPaper Elevation="0" Class="pa-3 bg-grey-r8">
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Riepilogo configurazione protocollo</MudText>
                                <MudGrid Spacing="1">
                                    <MudItem xs="6">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Tipo frame</MudText>
                                        <MudText Typo="Typo.body2">STX | CMD | Importo (10 cifre) | ETX | BCC</MudText>
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Codici operazione</MudText>
                                        <MudText Typo="Typo.body2">01=Pagamento, 02=Storno, 04=Rimborso</MudText>
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Codici risposta</MudText>
                                        <MudText Typo="Typo.body2">00=Approvato, 01=Rifiutato, 05=Annullato</MudText>
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Checksum</MudText>
                                        <MudText Typo="Typo.body2">XOR di tutti i byte tra STX ed ETX incluso</MudText>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                @* ─── Tab 4: Audit ────────────────────────────────────────── *@
                @if (!ViewModel.IsNewEntity)
                {
                    <MudTabPanel Text="Audit" Icon="@Icons.Material.Outlined.History">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <PrymTextField Value="@ViewModel.Entity.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                               Label="@TranslationService.GetTranslation("field.createdAt", "Creato il")"
                                               ReadOnly="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <PrymTextField Value="@(ViewModel.Entity.CreatedBy ?? "-")"
                                               Label="@TranslationService.GetTranslation("field.createdBy", "Creato da")"
                                               ReadOnly="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <PrymTextField Value="@(ViewModel.Entity.ModifiedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")"
                                               Label="@TranslationService.GetTranslation("field.modifiedAt", "Modificato il")"
                                               ReadOnly="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <PrymTextField Value="@(ViewModel.Entity.ModifiedBy ?? "-")"
                                               Label="@TranslationService.GetTranslation("field.modifiedBy", "Modificato da")"
                                               ReadOnly="true" />
                            </MudItem>
                        </MudGrid>
                    </MudTabPanel>
                }

            </MudTabs>
        }
    </ChildContent>
    <DialogActions>
        <PrymButton Intent="PrymButton.ButtonIntent.Ghost" OnClick="Cancel" Disabled="@ViewModel.IsSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </PrymButton>
        <PrymButton OnClick="SaveAsync"
                    Disabled="@(ViewModel.IsLoading || ViewModel.IsSaving || ViewModel.Entity == null)">
            @TranslationService.GetTranslation("common.save", "Salva")
        </PrymButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? TerminalId { get; set; }

    private MudForm? _form;
    private string _agentIdText = string.Empty;
    private bool _isTesting;
    private string? _testResult;
    private bool _testSuccess;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ViewModel.StateChanged += OnViewModelStateChanged;
            await ViewModel.LoadEntityAsync(TerminalId ?? Guid.Empty);

            // Sync agent ID text field
            if (ViewModel.Entity?.AgentId.HasValue == true)
                _agentIdText = ViewModel.Entity.AgentId.Value.ToString();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing PaymentTerminalDetailDialog.");
        }
    }

    private void HandleEntityChanged() => ViewModel.NotifyEntityChanged();

    private void OnAgentIdChanged()
    {
        if (ViewModel.Entity is null) return;
        ViewModel.Entity.AgentId = Guid.TryParse(_agentIdText, out var g) ? g : null;
        HandleEntityChanged();
    }

    private async Task TestConnectionAsync()
    {
        if (ViewModel.Entity is null || string.IsNullOrWhiteSpace(ViewModel.Entity.IpAddress)) return;
        _isTesting = true;
        _testResult = null;
        StateHasChanged();
        try
        {
            if (ViewModel.Entity.Id != Guid.Empty)
            {
                await ViewModel.TestConnectionAsync(ViewModel.Entity.Id);
            }
            else
            {
                _testResult = "Salva il terminale prima di testare la connessione.";
                _testSuccess = false;
                return;
            }
            _testResult = "Connessione riuscita";
            _testSuccess = true;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Connection test failed for terminal {Id}", ViewModel.Entity.Id);
            _testResult = $"Errore: {ex.Message}";
            _testSuccess = false;
        }
        finally
        {
            _isTesting = false;
        }
    }

    private async Task SaveAsync()
    {
        if (_form != null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid) return;
        }

        try
        {
            var isNew = ViewModel.IsNewEntity;
            var success = await ViewModel.SaveEntityAsync();
            if (success)
            {
                AppNotification.ShowSuccess(isNew
                    ? "Terminale POS creato con successo."
                    : "Terminale POS aggiornato con successo.");
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                AppNotification.ShowError("Errore nel salvataggio del terminale POS.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore nel salvataggio del terminale POS.");
            AppNotification.ShowError("Errore imprevisto nel salvataggio del terminale POS.");
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void OnViewModelStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ViewModel.StateChanged -= OnViewModelStateChanged;
    }
}
