@using Prym.DTOs.Store
@using Microsoft.AspNetCore.Components.Forms
@using Prym.Web.Services.Store
@using Prym.Web.ViewModels
@attribute [Authorize]
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject IStoreUserGroupService StoreUserGroupService
@inject OperatorGroupDetailViewModel ViewModel
@inject ILogger<OperatorGroupDetailDialog> Logger
@inject IAppNotificationService AppNotification
@implements IDisposable

<EFDialog Icon="@Icons.Material.Outlined.Groups"
          Title="@(ViewModel.IsNewEntity ? TranslationService.GetTranslation("store.newOperatorGroup", "Nuovo Gruppo Operatori") : ViewModel.Entity?.Name ?? string.Empty)"
          IsProcessing="@(ViewModel.IsLoading || ViewModel.IsSaving)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <ChildContent>
        @if (ViewModel.IsLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (ViewModel.Entity == null)
        {
            <MudAlert Severity="Severity.Error">
                @TranslationService.GetTranslation("store.operatorGroupNotFound", "Gruppo operatori non trovato")
            </MudAlert>
        }
        else
        {
            <MudTabs Position="Position.Left" Rounded="true" Border="true" MinimumTabWidth="160px" PanelClass="pa-4">
                <MudTabPanel Text="Generale" Icon="@Icons.Material.Outlined.Info">
                    @if (ViewModel.Entity.IsSystemGroup && !ViewModel.IsNewEntity)
                    {
                        <MudAlert Severity="Severity.Info" Class="mb-4">
                            @TranslationService.GetTranslation("store.systemGroupReadOnly", "Questo è un gruppo di sistema e non può essere modificato.")
                        </MudAlert>
                    }

                    @if (!ViewModel.IsNewEntity)
                    {
                        <div class="d-flex align-center gap-4 flex-wrap mb-4">
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Color="Color.Primary" Size="Size.Medium">
                                    <MudIcon Icon="@Icons.Material.Outlined.Groups" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.body1" Class="fw-semibold">@ViewModel.Entity.Name</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        Code: @ViewModel.Entity.Code - ID: @ViewModel.Entity.Id.ToString()[..8]...
                                    </MudText>
                                </div>
                            </div>
                            <MudChip T="string" Size="Size.Medium" Color="GetStatusColor(ViewModel.Entity.Status)">
                                @GetStatusText(ViewModel.Entity.Status)
                            </MudChip>
                            @if (ViewModel.Entity.IsSystemGroup)
                            {
                                <MudChip T="string" Size="Size.Medium" Color="Color.Default" Icon="@Icons.Material.Outlined.Lock">
                                    @TranslationService.GetTranslation("status.systemGroup", "Gruppo di Sistema")
                                </MudChip>
                            }
                            @if (ViewModel.Entity.IsDefault)
                            {
                                <MudChip T="string" Size="Size.Medium" Color="Color.Warning" Icon="@Icons.Material.Outlined.Star">
                                    @TranslationService.GetTranslation("status.default", "Default")
                                </MudChip>
                            }
                        </div>
                    }

                    @if (!ViewModel.IsNewEntity)
                    {
                        <MudPaper Elevation="0" Class="pa-4 mb-4">
                            <MudText Typo="Typo.subtitle1" Class="mb-3">
                                <MudIcon Icon="@Icons.Material.Outlined.Image" Class="mr-2" />
                                @TranslationService.GetTranslation("store.groupImage", "Logo")
                            </MudText>

                            @if (!string.IsNullOrWhiteSpace(ViewModel.Entity.ImageThumbnailUrl ?? ViewModel.Entity.ImageUrl ?? ViewModel.Entity.LogoUrl))
                            {
                                <MudImage Src="@(ViewModel.Entity.ImageThumbnailUrl ?? ViewModel.Entity.ImageUrl ?? ViewModel.Entity.LogoUrl)"
                                          Alt="@ViewModel.Entity.Name"
                                          Class="mb-3"
                                          Style="height:160px; width:160px; object-fit:cover; border-radius:8px;" />
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                                    @TranslationService.GetTranslation("store.noGroupImage", "Nessun logo caricato")
                                </MudAlert>
                            }

                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="flex-wrap">
                                <MudFileUpload T="IBrowserFile" Accept="image/*" @bind-Files="_selectedImage" MaximumFileCount="1">
                                    <CustomContent Context="fileUpload">
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                                   Disabled="_isUploadingImage"
                                                   OnClick="@fileUpload.OpenFilePickerAsync">
                                            @TranslationService.GetTranslation("common.select", "Seleziona")
                                        </MudButton>
                                    </CustomContent>
                                </MudFileUpload>

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.Upload"
                                           Disabled="_isUploadingImage || _selectedImage == null"
                                           OnClick="UploadImageAsync">
                                    @TranslationService.GetTranslation("common.upload", "Carica")
                                </MudButton>

                                @if (ViewModel.Entity.ImageDocumentId.HasValue || ViewModel.Entity.LogoDocumentId.HasValue)
                                {
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Error"
                                               StartIcon="@Icons.Material.Filled.Delete"
                                               Disabled="_isUploadingImage"
                                               OnClick="RemoveImageAsync">
                                        @TranslationService.GetTranslation("common.remove", "Rimuovi")
                                    </MudButton>
                                }
                            </MudStack>
                        </MudPaper>
                    }

                    <MudForm @ref="_form" Model="@ViewModel.Entity">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.Code"
                                               Label="@TranslationService.GetTranslation("field.code", "Codice")"
                                               Required="true"
                                               MaxLength="50"
                                               Disabled="@(ViewModel.Entity.IsSystemGroup && !ViewModel.IsNewEntity)"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.Name"
                                               Label="@TranslationService.GetTranslation("field.name", "Nome")"
                                               Required="true"
                                               MaxLength="50"
                                               Disabled="@(ViewModel.Entity.IsSystemGroup && !ViewModel.IsNewEntity)"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <PrymSelect @bind-Value="ViewModel.Entity.Status"
                                            Label="@TranslationService.GetTranslation("field.status", "Status")"
                                            Disabled="@(ViewModel.Entity.IsSystemGroup && !ViewModel.IsNewEntity)"
                                            @bind-Value:after="HandleEntityChanged">
                                    @foreach (CashierGroupStatus status in Enum.GetValues(typeof(CashierGroupStatus)))
                                    {
                                        <MudSelectItem Value="@status">@GetStatusText(status)</MudSelectItem>
                                    }
                                </PrymSelect>
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.ColorHex"
                                               Label="@TranslationService.GetTranslation("field.colorHex", "Colore (Hex)")"
                                               MaxLength="7"
                                               Placeholder="#FF5733"
                                               Disabled="@(ViewModel.Entity.IsSystemGroup && !ViewModel.IsNewEntity)"
                                               Pattern="^#([A-Fa-f0-9]{6})$"
                                               @bind-Value:after="HandleEntityChanged"
                                               Adornment="Adornment.Start"
                                               AdornmentIcon="@Icons.Material.Outlined.Palette"
                                               AdornmentColor="@(string.IsNullOrEmpty(ViewModel.Entity.ColorHex) ? Color.Default : Color.Primary)"
                                               HelperText="@TranslationService.GetTranslation("field.colorHexHelper", "Formato: #RRGGBB")" />
                            </MudItem>

                            @if (ViewModel.IsNewEntity)
                            {
                                <MudItem xs="12" sm="6">
                                    <MudField Label="@TranslationService.GetTranslation("field.isSystemGroup", "Gruppo di Sistema")" Variant="Variant.Outlined">
                                        <MudSwitch @bind-Value="ViewModel.Entity.IsSystemGroup"
                                                   Label="@TranslationService.GetTranslation("field.isSystemGroupHelp", "Gruppo di sistema (non modificabile)")"
                                                   Color="Color.Primary"
                                                   @bind-Value:after="HandleEntityChanged" />
                                    </MudField>
                                </MudItem>

                                <MudItem xs="12" sm="6">
                                    <MudField Label="@TranslationService.GetTranslation("field.isDefault", "Gruppo Default")" Variant="Variant.Outlined">
                                        <MudSwitch @bind-Value="ViewModel.Entity.IsDefault"
                                                   Label="@TranslationService.GetTranslation("field.isDefaultHelp", "Assegnato automaticamente ai nuovi operatori")"
                                                   Color="Color.Primary"
                                                   @bind-Value:after="HandleEntityChanged" />
                                    </MudField>
                                </MudItem>
                            }

                            <MudItem xs="12">
                                <PrymTextField @bind-Value="ViewModel.Entity.Description"
                                               Label="@TranslationService.GetTranslation("field.description", "Descrizione")"
                                               Lines="3"
                                               MaxLength="200"
                                               Disabled="@(ViewModel.Entity.IsSystemGroup && !ViewModel.IsNewEntity)"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            @if (!ViewModel.IsNewEntity)
                            {
                                <MudItem xs="12">
                                    <MudDivider Class="my-4" />
                                    <MudText Typo="Typo.h6" Class="mb-2">
                                        @TranslationService.GetTranslation("store.groupStatistics", "Statistiche Gruppo")
                                    </MudText>
                                    <MudGrid>
                                        <MudItem xs="12" sm="6" md="4">
                                            <MudPaper Elevation="1" Class="pa-4">
                                                <div class="d-flex align-center gap-2">
                                                    <MudIcon Icon="@Icons.Material.Outlined.People" Color="Color.Primary" />
                                                    <div>
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                            @TranslationService.GetTranslation("field.operatorsCount", "Operatori")
                                                        </MudText>
                                                        <MudText Typo="Typo.h6">@ViewModel.Entity.CashierCount</MudText>
                                                    </div>
                                                </div>
                                            </MudPaper>
                                        </MudItem>
                                        <MudItem xs="12" sm="6" md="4">
                                            <MudPaper Elevation="1" Class="pa-4">
                                                <div class="d-flex align-center gap-2">
                                                    <MudIcon Icon="@Icons.Material.Outlined.Security" Color="Color.Primary" />
                                                    <div>
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                            @TranslationService.GetTranslation("field.privilegesCount", "Privilegi")
                                                        </MudText>
                                                        <MudText Typo="Typo.h6">@ViewModel.Entity.PrivilegeCount</MudText>
                                                    </div>
                                                </div>
                                            </MudPaper>
                                        </MudItem>
                                    </MudGrid>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudForm>
                </MudTabPanel>
                <MudTabPanel Text="Audit" Icon="@Icons.Material.Outlined.History" Disabled="@ViewModel.IsNewEntity">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <PrymTextField Value="@(ViewModel.Entity.Id.ToString())"
                                           Label="@TranslationService.GetTranslation("field.id", "ID")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <PrymTextField Value="@(ViewModel.Entity.CreatedAt.ToString("dd/MM/yyyy HH:mm"))"
                                           Label="@TranslationService.GetTranslation("field.createdAt", "Creato il")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <PrymTextField Value="@(ViewModel.Entity.CreatedBy ?? string.Empty)"
                                           Label="@TranslationService.GetTranslation("field.createdBy", "Creato da")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <PrymTextField Value="@(ViewModel.Entity.ModifiedAt?.ToString("dd/MM/yyyy HH:mm") ?? string.Empty)"
                                           Label="@TranslationService.GetTranslation("field.modifiedAt", "Modificato il")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <PrymTextField Value="@(ViewModel.Entity.ModifiedBy ?? string.Empty)"
                                           Label="@TranslationService.GetTranslation("field.modifiedBy", "Modificato da")"
                                           ReadOnly="true" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
            </MudTabs>
        }
    </ChildContent>
    <DialogActions>
        <PrymButton Intent="PrymButton.ButtonIntent.Ghost" OnClick="Cancel" Disabled="ViewModel.IsSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </PrymButton>
        <PrymButton StartIcon="@Icons.Material.Filled.Save"
                    OnClick="SaveAsync"
                    Disabled="ViewModel.IsSaving || ViewModel.IsLoading || (ViewModel.Entity?.IsSystemGroup == true && !ViewModel.IsNewEntity)">
            @TranslationService.GetTranslation("common.save", "Salva")
        </PrymButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? EntityId { get; set; }

    private MudForm _form = null!;
    private IBrowserFile? _selectedImage;
    private bool _isUploadingImage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ViewModel.StateChanged += OnViewModelStateChanged;
            await ViewModel.LoadEntityAsync(EntityId ?? Guid.Empty);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing OperatorGroupDetailDialog.");
        }
    }

    private async Task Cancel()
    {
        if (ViewModel.HasUnsavedChanges())
        {
            var result = await DialogService.ShowMessageBoxAsync(
                TranslationService.GetTranslation("common.confirm", "Conferma"),
                TranslationService.GetTranslation("common.unsavedChangesConfirm", "Ci sono modifiche non salvate. Vuoi salvare prima di uscire?"),
                yesText: TranslationService.GetTranslation("common.save", "Salva"),
                noText: TranslationService.GetTranslation("common.discard", "Non salvare"),
                cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
            if (result == null) return;
            if (result == true) { await SaveAsync(); return; }
        }
        MudDialog.Close();
    }

    private async Task SaveAsync()
    {
        if (ViewModel.Entity == null) return;

        try
        {
            if (ViewModel.Entity.IsSystemGroup && !ViewModel.IsNewEntity)
            {
                AppNotification.ShowWarning(TranslationService.GetTranslation("store.cannotModifySystemGroup", "Non è possibile modificare un gruppo di sistema"));
                return;
            }

            await _form.ValidateAsync();
            if (!_form.IsValid)
            {
                AppNotification.ShowWarning(TranslationService.GetTranslation("common.validationErrors", "Correggere gli errori di validazione"));
                return;
            }

            var success = await ViewModel.SaveEntityAsync();
            if (success)
            {
                var message = ViewModel.IsNewEntity
                    ? TranslationService.GetTranslation("store.operatorGroupCreated", "Gruppo creato con successo")
                    : TranslationService.GetTranslation("store.operatorGroupSaved", "Gruppo salvato con successo");
                AppNotification.ShowSuccess(message);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                var message = ViewModel.IsNewEntity
                    ? TranslationService.GetTranslation("store.createError", "Errore nella creazione")
                    : TranslationService.GetTranslation("store.saveError", "Errore nel salvataggio");
                AppNotification.ShowError(message);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving operator group");
            AppNotification.ShowError(ex.Message, exception: ex);
        }
    }

    private async Task UploadImageAsync()
    {
        if (ViewModel.Entity == null || ViewModel.Entity.Id == Guid.Empty || _selectedImage == null)
        {
            return;
        }

        _isUploadingImage = true;
        try
        {
            var updated = await StoreUserGroupService.UploadImageAsync(ViewModel.Entity.Id, _selectedImage);
            if (updated != null)
            {
                await ViewModel.ReloadEntityAsync();
                _selectedImage = null;
                AppNotification.ShowSuccess(TranslationService.GetTranslation("store.groupImageUploaded", "Logo caricato con successo"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error uploading operator group image");
            AppNotification.ShowError(ex.Message);
        }
        finally
        {
            _isUploadingImage = false;
        }
    }

    private async Task RemoveImageAsync()
    {
        if (ViewModel.Entity == null || ViewModel.Entity.Id == Guid.Empty)
        {
            return;
        }

        _isUploadingImage = true;
        try
        {
            if (await StoreUserGroupService.DeleteImageAsync(ViewModel.Entity.Id))
            {
                await ViewModel.ReloadEntityAsync();
                AppNotification.ShowSuccess(TranslationService.GetTranslation("store.groupImageRemoved", "Logo rimosso con successo"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error removing operator group image");
            AppNotification.ShowError(ex.Message);
        }
        finally
        {
            _isUploadingImage = false;
        }
    }

    private void HandleEntityChanged() => ViewModel.NotifyEntityChanged();
    private void OnViewModelStateChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => ViewModel.StateChanged -= OnViewModelStateChanged;

    private Color GetStatusColor(CashierGroupStatus status) => status switch
    {
        CashierGroupStatus.Active => Color.Success,
        CashierGroupStatus.Suspended => Color.Warning,
        CashierGroupStatus.Deleted => Color.Error,
        _ => Color.Default
    };

    private string GetStatusText(CashierGroupStatus status) => status switch
    {
        CashierGroupStatus.Active => TranslationService.GetTranslation("status.active", "Attivo"),
        CashierGroupStatus.Suspended => TranslationService.GetTranslation("status.suspended", "Sospeso"),
        CashierGroupStatus.Deleted => TranslationService.GetTranslation("status.deleted", "Eliminato"),
        _ => status.ToString()
    };
}
