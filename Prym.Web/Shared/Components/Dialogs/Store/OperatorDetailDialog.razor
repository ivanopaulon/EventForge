@using Prym.DTOs.Store
@using Microsoft.AspNetCore.Components.Forms
@using Prym.Web.Services.Store
@using Prym.Web.ViewModels
@attribute [Authorize]
@inject OperatorDetailViewModel ViewModel
@inject IDialogService DialogService
@inject IStoreUserService StoreUserService
@inject ITranslationService TranslationService
@inject ILogger<OperatorDetailDialog> Logger
@inject IAppNotificationService AppNotification
@implements IDisposable

<EFDialog Icon="@Icons.Material.Outlined.Person"
          Title="@(ViewModel.IsNewEntity ? TranslationService.GetTranslation("store.newOperator", "Nuovo Operatore") : (ViewModel.Entity?.Name ?? string.Empty))"
          IsProcessing="@(ViewModel.IsLoading || ViewModel.IsSaving)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <ChildContent>
        @if (ViewModel.IsLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (!ViewModel.IsNewEntity && ViewModel.Entity == null)
        {
            <MudAlert Severity="Severity.Error">
                @TranslationService.GetTranslation("store.operatorNotFound", "Operatore non trovato")
            </MudAlert>
        }
        else if (ViewModel.Entity != null)
        {
            <MudTabs Position="Position.Left" Rounded="true" Border="true" MinimumTabWidth="160px" PanelClass="pa-4">
                <MudTabPanel Text="Generale" Icon="@Icons.Material.Outlined.Info">
                    @if (!ViewModel.IsNewEntity)
                    {
                        <div class="d-flex align-center gap-4 flex-wrap mb-3">
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Color="Color.Primary" Size="Size.Medium">
                                    <MudIcon Icon="@Icons.Material.Outlined.Person" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.body1" Class="fw-semibold">@ViewModel.Entity.Name</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @@@ViewModel.Entity.Username - ID: @ViewModel.Entity.Id.ToString()[..8]...
                                    </MudText>
                                </div>
                            </div>
                            <MudChip T="string" Size="Size.Medium" Color="GetStatusColor(ViewModel.Entity.Status)">
                                @GetStatusText(ViewModel.Entity.Status)
                            </MudChip>
                            @if (ViewModel.Entity.IsOnShift)
                            {
                                <MudChip T="string" Size="Size.Medium" Color="Color.Success" Icon="@Icons.Material.Outlined.CheckCircle">
                                    @TranslationService.GetTranslation("status.onShift", "In Turno")
                                </MudChip>
                            }
                        </div>
                        <MudDivider Class="mb-3" />
                    }

                    @if (!ViewModel.IsNewEntity)
                    {
                       <MudPaper Elevation="0" Class="pa-4 mb-4">
                           <MudText Typo="Typo.subtitle1" Class="mb-3">
                               <MudIcon Icon="@Icons.Material.Outlined.Image" Class="mr-2" />
                               @TranslationService.GetTranslation("store.operatorImage", "Immagine")
                           </MudText>

                           @if (!string.IsNullOrWhiteSpace(ViewModel.Entity.ImageThumbnailUrl ?? ViewModel.Entity.ImageUrl ?? ViewModel.Entity.PhotoUrl))
                           {
                               <MudImage Src="@(ViewModel.Entity.ImageThumbnailUrl ?? ViewModel.Entity.ImageUrl ?? ViewModel.Entity.PhotoUrl)"
                                         Alt="@ViewModel.Entity.Name"
                                         Class="mb-3"
                                         Style="height:160px; width:160px; object-fit:cover; border-radius:8px;" />
                           }
                           else
                           {
                               <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                                   @TranslationService.GetTranslation("store.noOperatorImage", "Nessuna immagine caricata")
                               </MudAlert>
                           }

                           <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="flex-wrap">
                               <MudFileUpload T="IBrowserFile" Accept="image/*" @bind-Files="_selectedImage" MaximumFileCount="1">
                                   <CustomContent Context="fileUpload">
                                       <MudButton Variant="Variant.Filled"
                                                  Color="Color.Primary"
                                                  StartIcon="@Icons.Material.Filled.CloudUpload"
                                                  Disabled="_isUploadingImage"
                                                  OnClick="@fileUpload.OpenFilePickerAsync">
                                           @TranslationService.GetTranslation("common.select", "Seleziona")
                                       </MudButton>
                                   </CustomContent>
                               </MudFileUpload>

                               <MudButton Variant="Variant.Filled"
                                          Color="Color.Success"
                                          StartIcon="@Icons.Material.Filled.Upload"
                                          Disabled="_isUploadingImage || _selectedImage == null"
                                          OnClick="UploadImageAsync">
                                   @TranslationService.GetTranslation("common.upload", "Carica")
                               </MudButton>

                               @if (ViewModel.Entity.ImageDocumentId.HasValue || ViewModel.Entity.PhotoDocumentId.HasValue)
                               {
                                   <MudButton Variant="Variant.Filled"
                                              Color="Color.Error"
                                              StartIcon="@Icons.Material.Filled.Delete"
                                              Disabled="_isUploadingImage"
                                              OnClick="RemoveImageAsync">
                                       @TranslationService.GetTranslation("common.remove", "Rimuovi")
                                   </MudButton>
                               }
                           </MudStack>
                       </MudPaper>

                       <MudPaper Elevation="0" Class="pa-4 mb-4">
                           <MudText Typo="Typo.subtitle1" Class="mb-3">
                               <MudIcon Icon="@Icons.Material.Outlined.Pin" Class="mr-2" />
                               PIN rapido POS
                           </MudText>
                           <MudGrid>
                               <MudItem xs="12" md="8">
                                   <MudTextField @bind-Value="_quickPin"
                                                 Label="Nuovo PIN rapido"
                                                 InputType="InputType.Password"
                                                 HelperText="PIN numerico da 4 a 6 cifre"
                                                 MaxLength="6"
                                                 Immediate="true" />
                               </MudItem>
                               <MudItem xs="12" md="4" Class="d-flex align-end">
                                   <MudButton Variant="Variant.Filled"
                                              Color="Color.Primary"
                                              StartIcon="@Icons.Material.Filled.Save"
                                              Disabled="@(_isSavingQuickPin || string.IsNullOrWhiteSpace(_quickPin))"
                                              OnClick="SaveQuickPinAsync">
                                       Salva PIN
                                   </MudButton>
                               </MudItem>
                           </MudGrid>
                       </MudPaper>
                    }

                    <MudForm @ref="_form" Model="@ViewModel.Entity">
                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.Name"
                                               Label="@TranslationService.GetTranslation("field.name", "Nome")"
                                               Required="true"
                                               MaxLength="100"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <PrymTextField @bind-Value="ViewModel.Username"
                                               Label="@TranslationService.GetTranslation("field.username", "Username")"
                                               Required="@ViewModel.IsNewEntity"
                                               MaxLength="50"
                                               Disabled="@(!ViewModel.IsNewEntity)"
                                               HelperText="@(ViewModel.IsNewEntity ? TranslationService.GetTranslation("field.usernameRequired", "Username obbligatorio") : TranslationService.GetTranslation("field.usernameImmutable", "Username non può essere modificato dopo la creazione"))"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            @if (ViewModel.IsNewEntity)
                            {
                                <MudItem xs="12" md="6">
                                    <PrymTextField @bind-Value="ViewModel.Password"
                                                   Label="@TranslationService.GetTranslation("field.password", "Password")"
                                                   InputType="InputType.Password"
                                                   Required="true"
                                                   HelperText="@TranslationService.GetTranslation("field.passwordHelper", "Lascia vuoto per generare automaticamente")"
                                                   @bind-Value:after="HandleEntityChanged" />
                                </MudItem>
                            }

                            <MudItem xs="12" md="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.Email"
                                               Label="@TranslationService.GetTranslation("field.email", "Email")"
                                               MaxLength="100"
                                               InputType="InputType.Email"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.Role"
                                               Label="@TranslationService.GetTranslation("field.role", "Ruolo")"
                                               MaxLength="50"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <PrymSelect @bind-Value="ViewModel.Entity.Status"
                                            Label="@TranslationService.GetTranslation("field.status", "Status")"
                                            @bind-Value:after="HandleEntityChanged">
                                    @foreach (CashierStatus status in Enum.GetValues(typeof(CashierStatus)))
                                    {
                                        <MudSelectItem Value="@status">@GetStatusText(status)</MudSelectItem>
                                    }
                                </PrymSelect>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <PrymSelect @bind-Value="ViewModel.Entity.CashierGroupId"
                                            Label="@TranslationService.GetTranslation("field.cashierGroup", "Gruppo Cassieri")"
                                            T="Guid?"
                                            Clearable="true"
                                            @bind-Value:after="HandleEntityChanged">
                                    <MudSelectItem Value="@((Guid?)null)">
                                        @TranslationService.GetTranslation("common.none", "None")
                                    </MudSelectItem>
                                    @foreach (var group in ViewModel.AvailableGroups)
                                    {
                                        <MudSelectItem Value="@((Guid?)group.Id)">@group.Name</MudSelectItem>
                                    }
                                </PrymSelect>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.PhoneNumber"
                                               Label="@TranslationService.GetTranslation("field.phoneNumber", "Numero di Telefono")"
                                               MaxLength="20"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <PrymDatePicker @bind-Date="ViewModel.DateOfBirth"
                                                Label="@TranslationService.GetTranslation("field.dateOfBirth", "Data di Nascita")"
                                                DateFormat="dd/MM/yyyy"
                                                @bind-Date:after="HandleEntityChanged" />
                            </MudItem>

                            @if (ViewModel.IsNewEntity)
                            {
                                <MudItem xs="12" md="6">
                                    <MudSwitch @bind-Value="ViewModel.PhotoConsent"
                                               Label="@TranslationService.GetTranslation("field.photoConsent", "Consenso per la Foto (GDPR)")"
                                               Color="Color.Primary"
                                               @bind-Value:after="HandleEntityChanged" />
                                </MudItem>
                            }

                            <MudItem xs="12">
                                <PrymTextField @bind-Value="ViewModel.Entity.Notes"
                                               Label="@TranslationService.GetTranslation("field.notes", "Note")"
                                               Lines="3"
                                               MaxLength="200"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                </MudTabPanel>
            </MudTabs>
        }
    </ChildContent>
    <DialogActions>
        <PrymButton Intent="PrymButton.ButtonIntent.Ghost" OnClick="Cancel" Disabled="ViewModel.IsSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </PrymButton>
        <PrymButton StartIcon="@Icons.Material.Filled.Save"
                    OnClick="SaveAsync" Disabled="ViewModel.IsSaving || ViewModel.IsLoading || ViewModel.Entity == null">
            @TranslationService.GetTranslation("common.save", "Salva")
        </PrymButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? EntityId { get; set; }

    private MudForm? _form;
    private IBrowserFile? _selectedImage;
    private bool _isUploadingImage;
    private string _quickPin = string.Empty;
    private bool _isSavingQuickPin;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ViewModel.StateChanged += OnViewModelStateChanged;
            await ViewModel.LoadEntityAsync(EntityId ?? Guid.Empty);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing OperatorDetailDialog.");
        }
    }

    private void HandleEntityChanged()
    {
        ViewModel.NotifyEntityChanged();
    }

    private async Task UploadImageAsync()
    {
        if (ViewModel.Entity == null || ViewModel.Entity.Id == Guid.Empty || _selectedImage == null)
        {
            return;
        }

        if (!ViewModel.Entity.PhotoConsent)
        {
            AppNotification.ShowWarning(TranslationService.GetTranslation("store.photoConsentRequired", "Serve il consenso foto per caricare un'immagine."));
            return;
        }

        _isUploadingImage = true;
        try
        {
            var updated = await StoreUserService.UploadImageAsync(ViewModel.Entity.Id, _selectedImage);
            if (updated != null)
            {
                await ViewModel.ReloadEntityAsync();
                _selectedImage = null;
                AppNotification.ShowSuccess(TranslationService.GetTranslation("store.operatorImageUploaded", "Immagine caricata con successo"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error uploading operator image.");
            AppNotification.ShowError(ex.Message);
        }
        finally
        {
            _isUploadingImage = false;
        }
    }

    private async Task RemoveImageAsync()
    {
        if (ViewModel.Entity == null || ViewModel.Entity.Id == Guid.Empty)
        {
            return;
        }

        _isUploadingImage = true;
        try
        {
            if (await StoreUserService.DeleteImageAsync(ViewModel.Entity.Id))
            {
                await ViewModel.ReloadEntityAsync();
                AppNotification.ShowSuccess(TranslationService.GetTranslation("store.operatorImageRemoved", "Immagine rimossa con successo"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error removing operator image.");
            AppNotification.ShowError(ex.Message);
        }
        finally
        {
            _isUploadingImage = false;
        }
    }

    private async Task SaveAsync()
    {
        if (_form != null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid)
            {
                AppNotification.ShowError(TranslationService.GetTranslation("validation.fixErrors", "Correggi gli errori prima di salvare"));
                return;
            }
        }

        try
        {
            var success = await ViewModel.SaveEntityAsync();
            if (success)
            {
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving operator.");
            AppNotification.ShowWarning("Si è verificato un errore nel salvataggio.");
        }
    }

    private async Task SaveQuickPinAsync()
    {
        if (ViewModel.Entity == null || ViewModel.Entity.Id == Guid.Empty)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_quickPin) || !System.Text.RegularExpressions.Regex.IsMatch(_quickPin, Prym.DTOs.Store.StoreUserPinDto.PinPattern))
        {
            AppNotification.ShowWarning("Il PIN rapido deve contenere da 4 a 6 cifre.");
            return;
        }

        _isSavingQuickPin = true;
        try
        {
            await StoreUserService.SetPinAsync(ViewModel.Entity.Id, _quickPin);
            _quickPin = string.Empty;
            AppNotification.ShowSuccess("PIN rapido salvato con successo.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving quick PIN for operator {OperatorId}.", ViewModel.Entity.Id);
            AppNotification.ShowError(ex.Message);
        }
        finally
        {
            _isSavingQuickPin = false;
        }
    }

    private async Task Cancel()
    {
        if (ViewModel.HasUnsavedChanges())
        {
            var result = await DialogService.ShowMessageBoxAsync(
                TranslationService.GetTranslation("common.confirm", "Conferma"),
                TranslationService.GetTranslation("common.unsavedChangesConfirm", "Ci sono modifiche non salvate. Vuoi salvare prima di uscire?"),
                yesText: TranslationService.GetTranslation("common.save", "Salva"),
                noText: TranslationService.GetTranslation("common.discard", "Non salvare"),
                cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
            if (result == null) return;
            if (result == true) { await SaveAsync(); return; }
        }
        MudDialog.Close();
    }

    private void OnViewModelStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private Color GetStatusColor(CashierStatus status) => status switch
    {
        CashierStatus.Active => Color.Success,
        CashierStatus.Suspended => Color.Warning,
        CashierStatus.Deleted => Color.Error,
        _ => Color.Default
    };

    private string GetStatusText(CashierStatus status) => status switch
    {
        CashierStatus.Active => TranslationService.GetTranslation("status.active", "Attivo"),
        CashierStatus.Suspended => TranslationService.GetTranslation("status.suspended", "Sospeso"),
        CashierStatus.Deleted => TranslationService.GetTranslation("status.deleted", "Eliminato"),
        _ => status.ToString()
    };

    public void Dispose()
    {
        ViewModel.StateChanged -= OnViewModelStateChanged;
    }
}
