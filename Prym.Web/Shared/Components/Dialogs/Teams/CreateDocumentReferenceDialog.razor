@using Prym.DTOs.Common
@using Prym.DTOs.Teams
@using Prym.Web.Services.Teams
@using Microsoft.AspNetCore.Components.Forms
@attribute [Authorize]
@inject ITeamService TeamService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject ILogger<CreateDocumentReferenceDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.UploadFile"
          Title="@TranslationService.GetTranslation("documents.create", "Nuovo Documento")"
          IsProcessing="@_isSaving"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthSimple"
          MinHeight="@EFDialogDefaults.MinHeightSimple">
    <ChildContent>
        <MudForm @ref="_form">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <PrymSelect T="DocumentReferenceType" @bind-Value="_type"
                                Label="@TranslationService.GetTranslation("documents.type", "Tipo")">
                        @foreach (var t in Enum.GetValues<DocumentReferenceType>())
                        {
                            <MudSelectItem T="DocumentReferenceType" Value="@t">@t</MudSelectItem>
                        }
                    </PrymSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <PrymSelect T="DocumentReferenceSubType" @bind-Value="_subType"
                                Label="@TranslationService.GetTranslation("documents.subtype", "Sottotipo")">
                        @foreach (var st in Enum.GetValues<DocumentReferenceSubType>())
                        {
                            <MudSelectItem T="DocumentReferenceSubType" Value="@st">@st</MudSelectItem>
                        }
                    </PrymSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" @bind-Value="_title"
                                  Label="@TranslationService.GetTranslation("documents.docTitle", "Titolo")"
                                  MaxLength="200" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="_expiry"
                                   Label="@TranslationService.GetTranslation("documents.expiry", "Scadenza")"
                                   DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="12">
                    <MudFileUpload T="IBrowserFile"
                                   Accept="*/*"
                                   @bind-Files="_selectedFile"
                                   MaximumFileCount="1">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.CloudUpload"
                                       FullWidth="true">
                                @TranslationService.GetTranslation("documents.selectFile", "Seleziona File")
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                    @if (_selectedFile is not null)
                    {
                        <MudChip T="string" Color="Color.Info" Icon="@Icons.Material.Filled.InsertDriveFile" Class="mt-2">
                            @_selectedFile.Name (@FormatFileSize(_selectedFile.Size))
                        </MudChip>
                    }
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" @bind-Value="_notes"
                                  Label="@TranslationService.GetTranslation("documents.notes", "Note")"
                                  Lines="2" MaxLength="500" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </ChildContent>
    <DialogActions>
        <PrymButton Variant="Variant.Text" OnClick="Cancel">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </PrymButton>
        <PrymButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@(_isSaving || _selectedFile is null)">
            @TranslationService.GetTranslation("common.save", "Salva")
        </PrymButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired] public Guid OwnerId { get; set; }
    [Parameter, EditorRequired] public string OwnerType { get; set; } = string.Empty;

    private MudForm _form = null!;
    private bool _isSaving;
    private IBrowserFile? _selectedFile;

    private DocumentReferenceType _type = DocumentReferenceType.Other;
    private DocumentReferenceSubType _subType = DocumentReferenceSubType.None;
    private string? _title;
    private DateTime? _expiry;
    private string? _notes;

    private async Task SaveAsync()
    {
        if (_selectedFile is null) return;

        await _form.Validate();
        if (!_form.IsValid) return;

        _isSaving = true;
        try
        {
            var result = await TeamService.UploadDocumentAsync(
                _selectedFile,
                OwnerId,
                OwnerType,
                _type,
                _subType,
                _expiry,
                _title,
                _notes);

            if (result is not null)
            {
                AppNotification.ShowSuccess(TranslationService.GetTranslation("documents.created", "Documento creato con successo."));
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslation("documents.createError", "Errore nella creazione del documento."));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating document reference");
            AppNotification.ShowError(TranslationService.GetTranslation("documents.createError", "Errore nella creazione del documento."));
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private static string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}
