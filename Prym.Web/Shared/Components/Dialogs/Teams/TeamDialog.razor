@using Prym.DTOs.Common
@using Prym.DTOs.Teams
@using Prym.Web.Services.Teams
@using Prym.Web.Services
@using Prym.Web.Shared.Components.Dialogs.Events
@attribute [Authorize]
@inject ITeamService TeamService
@inject IEventService EventService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject ILogger<TeamDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.Groups"
          Title="@(_isEdit ? TranslationService.GetTranslation("teams.editTeam", "Modifica Squadra") : TranslationService.GetTranslation("teams.createTeam", "Nuova Squadra"))"
          IsProcessing="@_isSaving"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthSimple"
          MinHeight="@EFDialogDefaults.MinHeightSimple">
    <ChildContent>
        @if (!_isEdit && _events.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="mb-3">
                @TranslationService.GetTranslation("teams.noEventsAvailable", "Nessun evento disponibile. Crea prima un evento per poter associare una squadra.")
            </MudAlert>
        }
        <MudForm @ref="_form">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" @bind-Value="_name"
                                  Label="@TranslationService.GetTranslation("field.name", "Nome")"
                                  Required="true" RequiredError="Il nome è obbligatorio"
                                  MaxLength="100" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" @bind-Value="_email"
                                  Label="@TranslationService.GetTranslation("teams.email", "Email")"
                                  InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <div class="d-flex align-center gap-2">
                        <PrymSelect T="Guid" @bind-Value="_eventId"
                                    Label="@TranslationService.GetTranslation("teams.event", "Evento Collegato")"
                                    Placeholder="@TranslationService.GetTranslation("teams.selectEvent", "Seleziona un evento...")"
                                    Required="true" RequiredError="L'evento è obbligatorio"
                                    Disabled="_isEdit"
                                    Class="flex-grow-1">
                            @foreach (var e in _events)
                            {
                                <MudSelectItem T="Guid" Value="@e.Id">@e.Name</MudSelectItem>
                            }
                        </PrymSelect>
                        @if (!_isEdit)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Add"
                                           Color="Color.Primary"
                                           Title="@TranslationService.GetTranslation("teams.createEvent", "Crea nuovo evento")"
                                           OnClick="OpenCreateEventDialogAsync" />
                        }
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" @bind-Value="_category"
                                  Label="@TranslationService.GetTranslation("teams.category", "Categoria")"
                                  MaxLength="50" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <PrymSelect T="TeamStatus" @bind-Value="_status"
                                Label="@TranslationService.GetTranslation("field.status", "Stato")">
                        @foreach (var s in Enum.GetValues<TeamStatus>())
                        {
                            <MudSelectItem T="TeamStatus" Value="@s">@s</MudSelectItem>
                        }
                    </PrymSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" @bind-Value="_clubCode"
                                  Label="@TranslationService.GetTranslation("teams.clubCode", "Codice Club")"
                                  MaxLength="50" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" @bind-Value="_federationCode"
                                  Label="@TranslationService.GetTranslation("teams.federationCode", "Codice Federazione")"
                                  MaxLength="50" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" @bind-Value="_shortDescription"
                                  Label="@TranslationService.GetTranslation("field.shortDescription", "Descrizione Breve")"
                                  MaxLength="200" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" @bind-Value="_longDescription"
                                  Label="@TranslationService.GetTranslation("field.description", "Descrizione")"
                                  Lines="3" MaxLength="2000" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </ChildContent>
    <DialogActions>
        <PrymButton Variant="Variant.Text" OnClick="Cancel">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </PrymButton>
        <PrymButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_isSaving">
            @TranslationService.GetTranslation("common.save", "Salva")
        </PrymButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public TeamDto? Team { get; set; }

    private MudForm _form = null!;
    private bool _isEdit;
    private bool _isSaving;

    private string _name = string.Empty;
    private string _shortDescription = string.Empty;
    private string _longDescription = string.Empty;
    private string? _email;
    private TeamStatus _status = TeamStatus.Active;
    private string? _clubCode;
    private string? _federationCode;
    private string? _category;
    private Guid _eventId;
    private List<Prym.DTOs.Events.EventDto> _events = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadEventsAsync();

        if (Team is not null)
        {
            _isEdit = true;
            _name = Team.Name;
            _shortDescription = Team.ShortDescription;
            _longDescription = Team.LongDescription;
            _email = Team.Email;
            _status = Team.Status;
            _clubCode = Team.ClubCode;
            _federationCode = Team.FederationCode;
            _category = Team.Category;
            _eventId = Team.EventId;
        }
    }

    private async Task SaveAsync()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _isSaving = true;
        try
        {
            if (_isEdit && Team is not null)
            {
                var dto = new UpdateTeamDto
                {
                    Name = _name,
                    ShortDescription = _shortDescription,
                    LongDescription = _longDescription,
                    Email = _email,
                    Status = _status,
                    ClubCode = _clubCode,
                    FederationCode = _federationCode,
                    Category = _category
                };
                var result = await TeamService.UpdateTeamAsync(Team.Id, dto);
                if (result is null)
                {
                    AppNotification.ShowError(TranslationService.GetTranslation("teams.saveError", "Errore nel salvataggio della squadra."));
                    return;
                }
                AppNotification.ShowSuccess(TranslationService.GetTranslation("teams.updated", "Squadra aggiornata con successo."));
            }
            else
            {
                var dto = new CreateTeamDto
                {
                    Name = _name,
                    ShortDescription = _shortDescription,
                    LongDescription = _longDescription,
                    Email = _email,
                    Status = _status,
                    ClubCode = _clubCode,
                    FederationCode = _federationCode,
                    Category = _category,
                    EventId = _eventId
                };
                var result = await TeamService.CreateTeamAsync(dto);
                if (result is null)
                {
                    AppNotification.ShowError(TranslationService.GetTranslation("teams.createError", "Errore nella creazione della squadra."));
                    return;
                }
                AppNotification.ShowSuccess(TranslationService.GetTranslation("teams.created", "Squadra creata con successo."));
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving team");
            AppNotification.ShowError(TranslationService.GetTranslation("teams.saveError", "Errore nel salvataggio della squadra."));
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task LoadEventsAsync()
    {
        try
        {
            var events = await EventService.GetEventsAsync(1, 200);
            _events = events?.Items?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading events for team dialog");
        }
    }

    private async Task OpenCreateEventDialogAsync()
    {
        try
        {
            var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<CreateEventDialog>("", new DialogParameters(), options);
            var result = await dialog.Result;

            if (result is { Canceled: false } && result.Data is Prym.DTOs.Events.EventDto created)
            {
                await LoadEventsAsync();
                _eventId = created.Id;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating event from team dialog");
            AppNotification.ShowError(TranslationService.GetTranslation("teams.createEventError", "Errore nella creazione dell'evento."));
        }
    }
}
