@using Prym.DTOs.Documents
@using Prym.DTOs.Warehouse
@attribute [Authorize]
@inject IDocumentTypeService DocumentTypeService
@inject IWarehouseService WarehouseService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<DocumentTypeDetailDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.Category"
          Title="@(_isCreateMode ? TranslationService.GetTranslation("documentType.createNew", "Crea Nuovo Tipo Documento") : (_documentType?.Name ?? string.Empty))"
          IsProcessing="@(_isLoading || _isSaving)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthSimple">
    <ChildContent>
        @if (_isLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (!_isCreateMode && _documentType == null)
        {
            <MudAlert Severity="Severity.Error">
                @TranslationService.GetTranslation("documentType.notFound", "Tipo documento non trovato")
            </MudAlert>
        }
        else
        {
            <MudForm @ref="_form" Class="pa-4">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <PrymTextField @bind-Value="DocumentTypeName"
                                       Label="@($"{TranslationService.GetTranslation("field.name", "Nome")} *")"
                                       Required="true"
                                       RequiredError="@TranslationService.GetTranslation("documentType.error.nameRequired", "Il nome è obbligatorio")"
                                       MaxLength="50"
                                       Immediate="true"
                                       OnBlur="@(() => MarkChanged())"
                                       HelperText="@TranslationService.GetTranslation("documentType.helperText.name", "Inserisci il nome del tipo documento")" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <PrymTextField @bind-Value="DocumentTypeCode"
                                       Label="@($"{TranslationService.GetTranslation("field.code", "Codice")} *")"
                                       Required="true"
                                       RequiredError="@TranslationService.GetTranslation("documentType.error.codeRequired", "Il codice è obbligatorio")"
                                       MaxLength="10"
                                       Immediate="true"
                                       OnBlur="@(() => MarkChanged())"
                                       HelperText="@TranslationService.GetTranslation("documentType.helperText.code", "Codice univoco per il tipo documento (es: DDT, FT, NC)")" />
                    </MudItem>

                    <MudItem xs="12">
                        <PrymTextField @bind-Value="DocumentTypeNotes"
                                       Label="@TranslationService.GetTranslation("field.notes", "Note")"
                                       Lines="3"
                                       MaxLength="200"
                                       OnBlur="@(() => MarkChanged())"
                                       HelperText="@TranslationService.GetTranslation("documentType.helperText.notes", "Note o descrizione aggiuntiva")" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <PrymSelect T="BusinessPartyType"
                                    @bind-Value="DocumentTypeRequiredPartyType"
                                    Label="@TranslationService.GetTranslation("field.requiredPartyType", "Tipo Controparte Richiesto")"
                                    @bind-Value:after="@MarkChanged"
                                    HelperText="@TranslationService.GetTranslation("documentType.helperText.partyType", "Tipo di controparte richiesto per questo documento")">
                            <MudSelectItem T="BusinessPartyType" Value="BusinessPartyType.Customer">
                                @TranslationService.GetTranslation("businessPartyType.customer", "Cliente")
                            </MudSelectItem>
                            <MudSelectItem T="BusinessPartyType" Value="BusinessPartyType.Supplier">
                                @TranslationService.GetTranslation("businessPartyType.supplier", "Fornitore")
                            </MudSelectItem>
                            <MudSelectItem T="BusinessPartyType" Value="BusinessPartyType.Both">
                                @TranslationService.GetTranslation("businessPartyType.both", "Entrambi")
                            </MudSelectItem>
                        </PrymSelect>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <PrymSelect T="Guid?"
                                    @bind-Value="DocumentTypeDefaultWarehouseId"
                                    Label="@TranslationService.GetTranslation("field.defaultWarehouse", "Magazzino Predefinito")"
                                    Clearable="true"
                                    @bind-Value:after="@MarkChanged"
                                    HelperText="@TranslationService.GetTranslation("documentType.helperText.warehouse", "Magazzino predefinito per i documenti di questo tipo")">
                            @if (_warehouses != null)
                            {
                                @foreach (var warehouse in _warehouses)
                                {
                                    <MudSelectItem T="Guid?" Value="@warehouse.Id">@warehouse.Name</MudSelectItem>
                                }
                            }
                        </PrymSelect>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudSwitch @bind-Value="DocumentTypeIsFiscal"
                                   @bind-Value:after="@(() => MarkChanged())"
                                   Label="@TranslationService.GetTranslation("field.isFiscal", "Documento Fiscale")"
                                   Color="Color.Primary"
                                   ThumbIcon="@(DocumentTypeIsFiscal ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" />
                        <MudText Typo="Typo.caption" Class="mud-input-helper-text">
                            @TranslationService.GetTranslation("documentType.helperText.isFiscal", "Indica se il documento ha valore fiscale")
                        </MudText>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudSwitch @bind-Value="DocumentTypeIsStockIncrease"
                                   @bind-Value:after="@(() => MarkChanged())"
                                   Label="@TranslationService.GetTranslation("field.isStockIncrease", "Aumento Stock")"
                                   Color="Color.Success"
                                   ThumbIcon="@(DocumentTypeIsStockIncrease ? Icons.Material.Filled.TrendingUp : Icons.Material.Filled.TrendingDown)" />
                        <MudText Typo="Typo.caption" Class="mud-input-helper-text">
                            @TranslationService.GetTranslation("documentType.helperText.isStockIncrease", "Indica se il documento aumenta lo stock di magazzino")
                        </MudText>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudSwitch @bind-Value="DocumentTypeIsInventoryDocument"
                                   @bind-Value:after="@(() => MarkChanged())"
                                   Label="@TranslationService.GetTranslation("field.isInventoryDocument", "Documento di Inventario")"
                                   Color="Color.Warning"
                                   ThumbIcon="@(DocumentTypeIsInventoryDocument ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" />
                        <MudText Typo="Typo.caption" Class="mud-input-helper-text">
                            @TranslationService.GetTranslation("documentType.helperText.isInventoryDocument", "Indica se il documento rappresenta un inventario fisico. Disabilita automaticamente i movimenti di magazzino.")
                        </MudText>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudSwitch @bind-Value="DocumentTypeIsTransferDocument"
                                   @bind-Value:after="@(() => MarkChanged())"
                                   Label="@TranslationService.GetTranslation("field.isTransferDocument", "Documento di Trasferimento")"
                                   Color="Color.Info"
                                   ThumbIcon="@(DocumentTypeIsTransferDocument ? Icons.Material.Filled.SwapHoriz : Icons.Material.Filled.Cancel)" />
                        <MudText Typo="Typo.caption" Class="mud-input-helper-text">
                            @TranslationService.GetTranslation("documentType.helperText.isTransferDocument", "Se attivo, la ricostruzione movimenti genera un movimento di tipo Trasferimento invece di Entrata/Uscita.")
                        </MudText>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudSelect @bind-Value="DocumentTypeDefaultMovementReason"
                                   @bind-Value:after="@(() => MarkChanged())"
                                   Label="@TranslationService.GetTranslation("field.defaultMovementReason", "Causale Movimento Default")"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Clearable="true">
                            <MudSelectItem T="string?" Value="@("Purchase")">@TranslationService.GetTranslation("movementReason.purchase", "Acquisto")</MudSelectItem>
                            <MudSelectItem T="string?" Value="@("Sale")">@TranslationService.GetTranslation("movementReason.sale", "Vendita")</MudSelectItem>
                            <MudSelectItem T="string?" Value="@("Return")">@TranslationService.GetTranslation("movementReason.return", "Reso")</MudSelectItem>
                            <MudSelectItem T="string?" Value="@("Transfer")">@TranslationService.GetTranslation("movementReason.transfer", "Trasferimento")</MudSelectItem>
                            <MudSelectItem T="string?" Value="@("Adjustment")">@TranslationService.GetTranslation("movementReason.adjustment", "Rettifica")</MudSelectItem>
                        </MudSelect>
                        <MudText Typo="Typo.caption" Class="mud-input-helper-text">
                            @TranslationService.GetTranslation("documentType.helperText.defaultMovementReason", "Causale usata durante la ricostruzione movimenti. Se non impostata, viene derivata da Entrata/Uscita.")
                        </MudText>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudSwitch @bind-Value="DocumentTypeCreatesStockMovements"
                                   @bind-Value:after="@(() => MarkChanged())"
                                   Disabled="@(DocumentTypeIsInventoryDocument || DocumentTypeMovesStockOnRowChange)"
                                   Label="@TranslationService.GetTranslation("field.createsStockMovements", "Crea Movimenti di Magazzino")"
                                   Color="Color.Primary"
                                   ThumbIcon="@(DocumentTypeCreatesStockMovements ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" />
                        <MudText Typo="Typo.caption" Class="mud-input-helper-text">
                            @if (DocumentTypeIsInventoryDocument)
                            {
                                @TranslationService.GetTranslation("documentType.helperText.createsStockMovementsDisabled", "Disabilitato per i documenti di inventario")
                            }
                            else if (DocumentTypeMovesStockOnRowChange)
                            {
                                @TranslationService.GetTranslation("documentType.helperText.createsStockMovementsDisabledLive", "Disabilitato: i movimenti vengono gestiti riga per riga")
                            }
                            else
                            {
                                @TranslationService.GetTranslation("documentType.helperText.createsStockMovements", "Indica se la chiusura del documento genera movimenti di magazzino")
                            }
                        </MudText>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudSwitch @bind-Value="DocumentTypeMovesStockOnRowChange"
                                   @bind-Value:after="@(() => MarkChanged())"
                                   Disabled="@DocumentTypeIsInventoryDocument"
                                   Label="@TranslationService.GetTranslation("field.movesStockOnRowChange", "Muovi Magazzino su Modifica Riga")"
                                   Color="Color.Secondary"
                                   ThumbIcon="@(DocumentTypeMovesStockOnRowChange ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" />
                        <MudText Typo="Typo.caption" Class="mud-input-helper-text">
                            @if (DocumentTypeIsInventoryDocument)
                            {
                                @TranslationService.GetTranslation("documentType.helperText.movesStockOnRowChangeDisabled", "Disabilitato per i documenti di inventario")
                            }
                            else
                            {
                                @TranslationService.GetTranslation("documentType.helperText.movesStockOnRowChange", "Se attivo, il movimento di magazzino viene creato/aggiornato/eliminato ad ogni modifica della riga (modalità live, es. C3). Disabilita automaticamente 'Crea Movimenti di Magazzino'.")
                            }
                        </MudText>
                    </MudItem>

                    @if (!_isCreateMode && _documentType != null)
                    {
                        <MudItem xs="12" md="4">
                            <PrymTextField T="string" Value="@_documentType.Id.ToString()"
                                           Label="@TranslationService.GetTranslation("field.id", "ID")"
                                           ReadOnly="true"
                                           aria-label="@TranslationService.GetTranslation("documentType.aria.uniqueId", "Identificativo unico")" />
                        </MudItem>
                    }
                </MudGrid>
            </MudForm>

            @if (!_isCreateMode && _documentType != null)
            {
                <MudDivider Class="my-4" />
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Outlined.Pin" Class="mr-2" />
                        @TranslationService.GetTranslation("documentType.counters", "Contatori Numerazione")
                    </MudText>
                    <MudLink Href="/documents/counters">@TranslationService.GetTranslation("documentType.manageCounters", "Gestisci Contatori")</MudLink>
                </div>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    @TranslationService.GetTranslation("documentType.countersDescription", "I contatori gestiscono la numerazione automatica dei documenti. Vai alla pagina di gestione contatori per configurarli.")
                </MudText>
            }
        }
    </ChildContent>
    <DialogActions>
        <PrymButton Intent="PrymButton.ButtonIntent.Ghost" OnClick="Cancel" Disabled="_isSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </PrymButton>
        <PrymButton StartIcon="@Icons.Material.Filled.Save"
                    OnClick="SaveDocumentTypeAsync" Disabled="_isSaving || _isLoading || _documentType == null">
            @TranslationService.GetTranslation("common.save", "Salva")
        </PrymButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? EntityId { get; set; }

    private DocumentTypeDto? _documentType;
    private IEnumerable<StorageFacilityDto>? _warehouses;
    private bool _isLoading = true;
    private bool _isCreateMode => EntityId == null || EntityId == Guid.Empty;
    private bool _isSaving = false;
    private MudForm? _form;

    private string _originalDocumentTypeSnapshot = string.Empty;
    private bool _hasLocalChanges = false;

    private string DocumentTypeName
    {
        get => _documentType?.Name ?? string.Empty;
        set { if (_documentType != null) _documentType.Name = value; }
    }

    private string DocumentTypeCode
    {
        get => _documentType?.Code ?? string.Empty;
        set { if (_documentType != null) _documentType.Code = value; }
    }

    private string? DocumentTypeNotes
    {
        get => _documentType?.Notes;
        set { if (_documentType != null) _documentType.Notes = value; }
    }

    private bool DocumentTypeIsFiscal
    {
        get => _documentType?.IsFiscal ?? false;
        set { if (_documentType != null) _documentType.IsFiscal = value; }
    }

    private bool DocumentTypeIsStockIncrease
    {
        get => _documentType?.IsStockIncrease ?? false;
        set { if (_documentType != null) _documentType.IsStockIncrease = value; }
    }

    private bool DocumentTypeIsInventoryDocument
    {
        get => _documentType?.IsInventoryDocument ?? false;
        set
        {
            if (_documentType != null)
            {
                _documentType.IsInventoryDocument = value;
                // Inventory documents must never create stock movements or use live mode.
                if (value)
                {
                    _documentType.CreatesStockMovements = false;
                    _documentType.MovesStockOnRowChange = false;
                }
            }
        }
    }

    private bool DocumentTypeCreatesStockMovements
    {
        get => _documentType?.CreatesStockMovements ?? true;
        set { if (_documentType != null) _documentType.CreatesStockMovements = value; }
    }

    private bool DocumentTypeMovesStockOnRowChange
    {
        get => _documentType?.MovesStockOnRowChange ?? true;
        set
        {
            if (_documentType != null)
            {
                _documentType.MovesStockOnRowChange = value;
                // Live per-row mode is incompatible with bulk-on-archive generation.
                if (value)
                    _documentType.CreatesStockMovements = false;
            }
        }
    }

    private bool DocumentTypeIsTransferDocument
    {
        get => _documentType?.IsTransferDocument ?? false;
        set { if (_documentType != null) _documentType.IsTransferDocument = value; }
    }

    private string? DocumentTypeDefaultMovementReason
    {
        get => _documentType?.DefaultMovementReason;
        set { if (_documentType != null) _documentType.DefaultMovementReason = value; }
    }

    private BusinessPartyType DocumentTypeRequiredPartyType
    {
        get => _documentType?.RequiredPartyType ?? BusinessPartyType.Both;
        set { if (_documentType != null) _documentType.RequiredPartyType = value; }
    }

    private Guid? DocumentTypeDefaultWarehouseId
    {
        get => _documentType?.DefaultWarehouseId;
        set { if (_documentType != null) _documentType.DefaultWarehouseId = value; }
    }

    private static readonly System.Text.Json.JsonSerializerOptions _jsonOptions = new()
    {
        PropertyNameCaseInsensitive = true,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Task.WhenAll(LoadDocumentTypeAsync(), LoadWarehousesAsync());
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing DocumentTypeDetailDialog.");
        }
    }

    private async Task LoadDocumentTypeAsync()
    {
        _isLoading = true;
        try
        {
            if (_isCreateMode)
            {
                _documentType = new DocumentTypeDto
                {
                    Name = string.Empty,
                    Code = string.Empty,
                    RequiredPartyType = BusinessPartyType.Both,
                    MovesStockOnRowChange = true,
                    CreatesStockMovements = false
                };
                _originalDocumentTypeSnapshot = SerializeDocumentType(_documentType);
            }
            else if (EntityId.HasValue)
            {
                var documentType = await DocumentTypeService.GetDocumentTypeByIdAsync(EntityId.Value);
                _documentType = documentType;

                if (_documentType != null)
                {
                    _originalDocumentTypeSnapshot = SerializeDocumentType(_documentType);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading document type {EntityId}", EntityId);
            AppNotification.ShowError(TranslationService.GetTranslation("documentType.loadError", "Errore nel caricamento del tipo documento"));
        }
        finally
        {
            _isLoading = false;
            _hasLocalChanges = false;
        }
    }

    private async Task LoadWarehousesAsync()
    {
        try
        {
            var result = await WarehouseService.GetStorageFacilitiesAsync(page: 1, pageSize: 100);
            _warehouses = result?.Items?.ToList() ?? new List<StorageFacilityDto>();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading warehouses");
            AppNotification.ShowWarning(TranslationService.GetTranslation("warehouse.loadError", "Errore nel caricamento dei magazzini"));
        }
    }

    private async Task SaveDocumentTypeAsync()
    {
        if (_documentType == null || _form == null) return;

        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            AppNotification.ShowError(TranslationService.GetTranslation("validation.fixErrors", "Correggi gli errori prima di salvare"));
            return;
        }

        _isSaving = true;
        try
        {
            if (_isCreateMode)
            {
                var createDto = new CreateDocumentTypeDto
                {
                    Name = _documentType.Name,
                    Code = _documentType.Code,
                    Notes = _documentType.Notes,
                    IsFiscal = _documentType.IsFiscal,
                    IsStockIncrease = _documentType.IsStockIncrease,
                    IsInventoryDocument = _documentType.IsInventoryDocument,
                    IsTransferDocument = _documentType.IsTransferDocument,
                    CreatesStockMovements = _documentType.CreatesStockMovements,
                    MovesStockOnRowChange = _documentType.MovesStockOnRowChange,
                    RequiredPartyType = _documentType.RequiredPartyType,
                    DefaultWarehouseId = _documentType.DefaultWarehouseId,
                    DefaultMovementReason = _documentType.DefaultMovementReason
                };

                await DocumentTypeService.CreateDocumentTypeAsync(createDto);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("documentType.createSuccess", "Tipo documento creato con successo"));
            }
            else if (EntityId.HasValue)
            {
                var updateDto = new UpdateDocumentTypeDto
                {
                    Name = _documentType.Name,
                    Code = _documentType.Code,
                    Notes = _documentType.Notes,
                    IsFiscal = _documentType.IsFiscal,
                    IsStockIncrease = _documentType.IsStockIncrease,
                    IsInventoryDocument = _documentType.IsInventoryDocument,
                    IsTransferDocument = _documentType.IsTransferDocument,
                    CreatesStockMovements = _documentType.CreatesStockMovements,
                    MovesStockOnRowChange = _documentType.MovesStockOnRowChange,
                    RequiredPartyType = _documentType.RequiredPartyType,
                    DefaultWarehouseId = _documentType.DefaultWarehouseId,
                    DefaultMovementReason = _documentType.DefaultMovementReason
                };

                await DocumentTypeService.UpdateDocumentTypeAsync(EntityId.Value, updateDto);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("documentType.updateSuccess", "Tipo documento aggiornato con successo"));
            }

            _hasLocalChanges = false;
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving document type");
            AppNotification.ShowError(TranslationService.GetTranslation("documentType.saveError", "Errore nel salvataggio del tipo documento"));
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void MarkChanged()
    {
        _hasLocalChanges = true;
        StateHasChanged();
    }

    private string SerializeDocumentType(DocumentTypeDto? dt)
    {
        if (dt == null) return string.Empty;
        return System.Text.Json.JsonSerializer.Serialize(dt, _jsonOptions);
    }

    private bool HasUnsavedChanges()
    {
        if (_documentType == null) return false;
        if (_hasLocalChanges) return true;
        var current = SerializeDocumentType(_documentType);
        return !string.Equals(current, _originalDocumentTypeSnapshot, StringComparison.Ordinal);
    }

    private async Task Cancel()
    {
        if (HasUnsavedChanges())
        {
            var result = await DialogService.ShowMessageBoxAsync(
                TranslationService.GetTranslation("common.confirm", "Conferma"),
                TranslationService.GetTranslation("documentType.unsavedChangesConfirm", "Ci sono modifiche non salvate. Vuoi salvare prima di uscire?"),
                yesText: TranslationService.GetTranslation("common.save", "Salva"),
                noText: TranslationService.GetTranslation("common.discard", "Non salvare"),
                cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
            if (result == null) return;
            if (result == true) { await SaveDocumentTypeAsync(); return; }
        }
        MudDialog.Close();
    }
}
