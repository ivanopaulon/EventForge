@inject ITranslationService TranslationService

<MudStack Spacing="0" Class="h-full">
    <MudText Typo="Typo.subtitle2" Class="mb-2 fw-semibold">
        <MudIcon Icon="@Icons.Material.Outlined.Summarize" Class="mr-1" Size="Size.Small" />
        @TranslationService.GetTranslation("documents.rowSummary", "Riepilogo Riga")
    </MudText>
    <MudDivider Class="mb-3" />
    <MudStack Spacing="2">
        <MudStack Spacing="0">
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @TranslationService.GetTranslation("documents.netSubtotal", "Subtotale Netto")
            </MudText>
            <MudText Typo="Typo.body1" Class="fw-semibold">
                @NetSubtotal.ToString("C2")
            </MudText>
        </MudStack>
        <MudStack Spacing="0">
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @TranslationService.GetTranslation("documents.vatTax", "Imposta IVA")
            </MudText>
            <MudText Typo="Typo.body1" Class="fw-semibold">
                @VatAmount.ToString("C2")
            </MudText>
        </MudStack>
        @if (TotalDiscount > 0)
        {
            <MudStack Spacing="0">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @TranslationService.GetTranslation("documents.totalDiscount", "Sconto Totale")
                </MudText>
                <MudText Typo="Typo.body1" Class="fw-semibold" Color="Color.Success">
                    -@TotalDiscount.ToString("C2")
                </MudText>
            </MudStack>
        }
        <MudDivider />
        <MudStack Spacing="0">
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @TranslationService.GetTranslation("documents.lineTotal", "TOTALE RIGA")
            </MudText>
            <MudText Typo="Typo.h5" Class="fw-bold" Color="Color.Primary">
                @LineTotal.ToString("C2")
            </MudText>
        </MudStack>
    </MudStack>
</MudStack>

@code {
    [Parameter] public decimal NetSubtotal { get; set; } = 0m;
    [Parameter] public decimal VatAmount { get; set; } = 0m;
    [Parameter] public decimal TotalDiscount { get; set; } = 0m;
    [Parameter] public decimal LineTotal { get; set; } = 0m;
}
