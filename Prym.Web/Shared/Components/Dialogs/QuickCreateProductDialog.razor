@using Prym.DTOs.Products
@using Prym.DTOs.VatRates
@using Prym.DTOs.UnitOfMeasures
@inject ITranslationService TranslationService
@inject IProductService ProductService
@inject IFinancialService FinancialService
@inject IAppNotificationService AppNotification
@inject ILogger<QuickCreateProductDialog> Logger
@implements IDisposable

<EFDialog Icon="@Icons.Material.Outlined.AddShoppingCart"
          Title="@(IsEditMode 
              ? TranslationService.GetTranslation("warehouse.quickEditProduct", "Modifica Rapida Prodotto")
              : TranslationService.GetTranslation("warehouse.quickCreateProduct", "Nuovo Prodotto"))"
          IsProcessing="@_isLoading"
          OnClose="Cancel"
          MinWidth="min(750px, 95vw)">
    <ChildContent>
        @if (_isLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else
        {
            @if (AutoAssignCode && !string.IsNullOrWhiteSpace(PrefilledCode))
            {
                <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3" Variant="Variant.Filled">
                    <MudText Typo="Typo.body2">
                        <MudIcon Icon="@Icons.Material.Outlined.QrCode" Size="Size.Small" Class="mr-1" />
                        Il codice <strong>@PrefilledCode</strong> sarà assegnato automaticamente
                    </MudText>
                </MudAlert>
            }

            <MudForm @ref="_form" @bind-IsValid="@_isFormValid">
                <MudGrid Spacing="3">
                    <!-- Codice -->
                    <MudItem xs="12" sm="6">
                        <PrymTextField @bind-Value="_model.Code"
                                       Label="@($"{TranslationService.GetTranslation("field.code", "Codice")} *")"
                                       Required="true"
                                       RequiredError="@TranslationService.GetTranslation("validation.codeRequired", "Il codice è obbligatorio")"
                                       MaxLength="100"
                                       ReadOnly="@(!string.IsNullOrWhiteSpace(PrefilledCode))"
                                       HelperText="@(!string.IsNullOrWhiteSpace(PrefilledCode) ? TranslationService.GetTranslation("products.codeFromScanner", "Codice letto da scanner — non modificabile") : null)" />
                    </MudItem>

                    <!-- Nome -->
                    <MudItem xs="12" sm="6">
                        <PrymTextField T="string"
                                       Value="_model.Name"
                                       ValueChanged="@((string v) => OnNameChangedAsync(v))"
                                       Label="@($"{TranslationService.GetTranslation("field.name", "Nome")} *")"
                                       Required="true"
                                       RequiredError="@TranslationService.GetTranslation("validation.nameRequired", "Il nome è obbligatorio")"
                                       MaxLength="100"
                                       Immediate="true"
                                       DebounceInterval="600"
                                       HelperText="@TranslationService.GetTranslation("products.nameHelper", "Nome commerciale breve del prodotto, usato per la ricerca")" />
                    </MudItem>

                    <!-- Descrizione -->
                    <MudItem xs="12">
                        <PrymTextField @bind-Value="_model.Description"
                                       Label="@TranslationService.GetTranslation("field.description", "Descrizione")"
                                       Lines="3"
                                       MaxLength="500"
                                       HelperText="@TranslationService.GetTranslation("products.descriptionHelper", "Descrizione estesa opzionale (es. caratteristiche, note)")" />
                    </MudItem>

                    <!-- Avviso prodotti simili -->
                    @if (_isDuplicateChecking)
                    {
                        <MudItem xs="12">
                            <MudProgressLinear Indeterminate="true" Color="Color.Warning" />
                        </MudItem>
                    }
                    else if (_similarProducts.Any())
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Warning" Class="mt-1" Dense="true">
                                <MudText Typo="Typo.body2" Class="mb-2">
                                    <strong>@TranslationService.GetTranslation("products.similarProductsFound", "Attenzione: esistono già prodotti con nome simile.")</strong>
                                    @TranslationService.GetTranslation("products.similarProductsHint", " Verificare prima di creare un duplicato.")
                                </MudText>
                                @foreach (var similar in _similarProducts)
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-1">
                                        <div>
                                            <MudText Typo="Typo.body2"><strong>@similar.Name</strong></MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                @TranslationService.GetTranslation("products.code", "Codice"): @similar.Code
                                                @if (similar.DefaultPrice.HasValue)
                                                {
                                                    <span> — @similar.DefaultPrice.Value.ToString("C2")</span>
                                                }
                                            </MudText>
                                        </div>
                                        <MudButton Size="Size.Small"
                                                   Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Outlined.CheckCircle"
                                                   OnClick="@(() => UseExistingProductAsync(similar))">
                                            @TranslationService.GetTranslation("products.useExisting", "Usa questo")
                                        </MudButton>
                                    </MudStack>
                                }
                            </MudAlert>
                        </MudItem>
                    }

                    <!-- Dati Commerciali -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">
                            @TranslationService.GetTranslation("products.commercialData", "Dati Commerciali")
                        </MudText>
                    </MudItem>

                    <!-- Unità di Misura -->
                    <MudItem xs="12" sm="4">
                        <PrymSelect @bind-Value="_model.UnitOfMeasureId"
                                    Label="@($"{TranslationService.GetTranslation("products.unitOfMeasure", "Unità di Misura")} *")"
                                    Required="true">
                            @if (_availableUnits != null && _availableUnits.Any())
                            {
                                @foreach (var unit in _availableUnits)
                                {
                                    <MudSelectItem Value="@((Guid?)unit.Id)">@unit.Symbol - @unit.Name</MudSelectItem>
                                }
                            }
                        </PrymSelect>
                    </MudItem>

                    <!-- Prezzo -->
                    <MudItem xs="12" sm="4">
                        <PrymNullableNumericField T="decimal"
                                                  @bind-Value="_model.DefaultPrice"
                                                  Label="@($"{TranslationService.GetTranslation("field.salePrice", "Prezzo")} *")"
                                                  Required="true"
                                                  Min="0"
                                                  Format="F2" />
                    </MudItem>

                    <!-- Aliquota IVA -->
                    <MudItem xs="12" sm="4">
                        <PrymSelect @bind-Value="_model.VatRateId"
                                    Label="@($"{TranslationService.GetTranslation("products.vatRate", "Aliquota IVA")} *")"
                                    Required="true">
                            @if (_vatRates != null && _vatRates.Any())
                            {
                                @foreach (var vat in _vatRates)
                                {
                                    <MudSelectItem Value="@((Guid?)vat.Id)">@vat.Name (@vat.Percentage %)</MudSelectItem>
                                }
                            }
                        </PrymSelect>
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </ChildContent>
    <DialogActions>
        <PrymButton Intent="PrymButton.ButtonIntent.Ghost"
                    OnClick="Cancel"
                    Disabled="@_isLoading">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </PrymButton>
        <PrymButton Intent="PrymButton.ButtonIntent.Primary"
                    StartIcon="@Icons.Material.Outlined.Save"
                    OnClick="CreateProduct"
                    Disabled="@(!_isFormValid || _isLoading)">
            @TranslationService.GetTranslation("common.save", "Salva")
        </PrymButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] 
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string PrefilledCode { get; set; } = string.Empty;

    [Parameter]
    public bool AutoAssignCode { get; set; } = false;

    [Parameter]
    public bool IsEditMode { get; set; } = false;

    [Parameter]
    public Guid? ProductId { get; set; }

    [Parameter]
    public ProductDto? ExistingProduct { get; set; }

    private bool _isLoading = false;
    private bool _isFormValid = false;
    private MudForm? _form;
    private ProductDto _model = new();
    private IEnumerable<VatRateDto>? _vatRates;
    private IEnumerable<UMDto>? _availableUnits;
    private ProductDto? _cachedExistingProduct = null; // Cache for complete product data

    // Duplicate detection state
    private List<ProductDto> _similarProducts = new();
    private bool _isDuplicateChecking = false;
    private CancellationTokenSource? _duplicateCheckCts;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadVatRates(),
            LoadAvailableUnitsAsync()
        );
        
        if (IsEditMode && ExistingProduct != null)
        {
            // OPTIMIZATION: Load and cache the complete product data once at initialization
            Logger.LogInformation("Loading complete product data for ProductId {ProductId}", ProductId);
            try
            {
                _cachedExistingProduct = await ProductService.GetProductByIdAsync(ProductId!.Value);
                if (_cachedExistingProduct == null)
                {
                    Logger.LogError("Product {ProductId} not found during initialization", ProductId);
                    AppNotification.ShowError(TranslationService.GetTranslation("products.notFound", "Prodotto non trovato"));
                    return;
                }
                Logger.LogInformation("Cached complete product data for {ProductCode}", _cachedExistingProduct.Code);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error loading product {ProductId} during initialization", ProductId);
            }
            
            // Load existing product data for display
            _model = new ProductDto
            {
                Id = ExistingProduct.Id,
                Code = ExistingProduct.Code,
                Name = ExistingProduct.Name,
                Description = ExistingProduct.Description,
                DefaultPrice = ExistingProduct.DefaultPrice,
                VatRateId = ExistingProduct.VatRateId,
                UnitOfMeasureId = ExistingProduct.UnitOfMeasureId,
                IsVatIncluded = ExistingProduct.IsVatIncluded,
                Status = ExistingProduct.Status
            };
        }
        else
        {
            // Pre-fill the code if provided
            if (!string.IsNullOrWhiteSpace(PrefilledCode))
            {
                _model.Code = PrefilledCode;
            }

            // Set defaults
            _model.Status = ProductStatus.Active;
            _model.IsVatIncluded = true; // Always VAT included as per requirements
        }
    }

    private async Task LoadVatRates()
    {
        _isLoading = true;
        try
        {
            var result = await FinancialService.GetVatRatesAsync(1, 100);
            _vatRates = result?.Items ?? Enumerable.Empty<VatRateDto>();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading VAT rates");
            AppNotification.ShowError(TranslationService.GetTranslation("products.vatRatesLoadError", "Errore nel caricamento delle aliquote IVA"));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadAvailableUnitsAsync()
    {
        try
        {
            var units = await ProductService.GetUnitsOfMeasureAsync();
            _availableUnits = units ?? Enumerable.Empty<UMDto>();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading units of measure");
            AppNotification.ShowError(TranslationService.GetTranslation("products.unitsLoadError", "Errore nel caricamento delle unità di misura"));
            _availableUnits = Enumerable.Empty<UMDto>();
        }
    }

    private async Task CreateProduct()
    {
        if (IsEditMode)
        {
            await UpdateProduct();
        }
        else
        {
            await CreateNewProduct();
        }
    }

    private async Task UpdateProduct()
    {
        _isLoading = true;
        
        try
        {
            // Validate form
            if (_form != null)
            {
                await _form.ValidateAsync();
                if (!_isFormValid)
                {
                    AppNotification.ShowError(TranslationService.GetTranslation("validation.fixErrors", "Correggi gli errori prima di salvare"));
                    return;
                }
            }

            Logger.LogInformation("Starting product update for ProductId {ProductId}", ProductId);
            ProductDto? existingProduct = _cachedExistingProduct;
            if (existingProduct == null)
            {
                Logger.LogInformation("Cached product not available, loading from server");
                existingProduct = await ProductService.GetProductByIdAsync(ProductId!.Value);
                if (existingProduct == null)
                {
                    Logger.LogError("Product {ProductId} not found when attempting to update", ProductId);
                    AppNotification.ShowError(TranslationService.GetTranslation("products.notFound", "Prodotto non trovato"));
                    return;
                }
            }
            else
            {
                Logger.LogInformation("Using cached product data for update");
            }

            Logger.LogInformation("Loaded existing product {ProductCode} - {ProductName}", existingProduct.Code, existingProduct.Name);

            // CRITICAL FIX: Create UpdateProductDto with ALL fields from existing product
            // This preserves all values that are not modified in this quick edit dialog
            var updateDto = new UpdateProductDto
            {
                // Fields modified in this dialog
                Name = _model.Name,
                Description = _model.Description ?? string.Empty,
                DefaultPrice = _model.DefaultPrice,
                VatRateId = _model.VatRateId,
                UnitOfMeasureId = _model.UnitOfMeasureId,
                IsVatIncluded = true, // Always true as per requirements
                Status = _model.Status,
                
                // FIXED: Preserve all other fields from existing product
                ShortDescription = existingProduct.ShortDescription,
                ImageUrl = existingProduct.ImageUrl,
                ImageDocumentId = existingProduct.ImageDocumentId,
                CategoryNodeId = existingProduct.CategoryNodeId,
                FamilyNodeId = existingProduct.FamilyNodeId,
                GroupNodeId = existingProduct.GroupNodeId,
                StationId = existingProduct.StationId,
                BrandId = existingProduct.BrandId,
                ModelId = existingProduct.ModelId,
                PreferredSupplierId = existingProduct.PreferredSupplierId,
                ReorderPoint = existingProduct.ReorderPoint,
                SafetyStock = existingProduct.SafetyStock,
                TargetStockLevel = existingProduct.TargetStockLevel,
                AverageDailyDemand = existingProduct.AverageDailyDemand
            };

            Logger.LogInformation("Updating product {ProductId} with DTO - Name: {Name}, Description: {Description}, Price: {Price}, VatRateId: {VatRateId}",
                ProductId, updateDto.Name, updateDto.Description, updateDto.DefaultPrice, updateDto.VatRateId);

            var updatedProduct = await ProductService.UpdateProductAsync(ProductId!.Value, updateDto);
            
            if (updatedProduct != null)
            {
                Logger.LogInformation("Product {ProductId} updated successfully - Name: {Name}, Description: {Description}",
                    updatedProduct.Id, updatedProduct.Name, updatedProduct.Description);
                
                AppNotification.ShowSuccess(TranslationService.GetTranslation("products.updateSuccess", "Prodotto aggiornato con successo"));
                
                // Close dialog and return the updated product
                MudDialog.Close(DialogResult.Ok(updatedProduct));
            }
            else
            {
                Logger.LogError("Product update returned null for ProductId {ProductId}", ProductId);
                AppNotification.ShowError(TranslationService.GetTranslation("products.updateError", "Errore nell'aggiornamento del prodotto"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating product {ProductId}: {Message}", ProductId, ex.Message);
            AppNotification.ShowError(TranslationService.GetTranslation("products.updateError", "Errore nell'aggiornamento del prodotto: {0}", ex.Message));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CreateNewProduct()
    {
        _isLoading = true;
        
        try
        {
            // Validate form
            if (_form != null)
            {
                await _form.ValidateAsync();
                if (!_isFormValid)
                {
                    AppNotification.ShowError(TranslationService.GetTranslation("validation.fixErrors", "Correggi gli errori prima di salvare"));
                    return;
                }
            }

            // Create the product via API
            var createDto = new CreateProductDto
            {
                Code = _model.Code,
                Name = _model.Name,
                Description = _model.Description ?? string.Empty,
                DefaultPrice = _model.DefaultPrice,
                VatRateId = _model.VatRateId,
                UnitOfMeasureId = _model.UnitOfMeasureId,
                IsVatIncluded = true, // Always true as per requirements
                Status = ProductStatus.Active
            };

            var createdProduct = await ProductService.CreateProductAsync(createDto);
            
            if (createdProduct != null)
            {
                // If AutoAssignCode is enabled, also create the product code
                if (AutoAssignCode && !string.IsNullOrWhiteSpace(PrefilledCode))
                {
                    try
                    {
                        var codeDto = new CreateProductCodeDto
                        {
                            ProductId = createdProduct.Id,
                            Code = PrefilledCode,
                            CodeType = "Barcode", // Default to Barcode for scanned codes
                            Status = ProductCodeStatus.Active
                        };
                        
                        await ProductService.CreateProductCodeAsync(codeDto);
                        
                        Logger.LogInformation("Auto-assigned code {Code} to product {ProductId}", PrefilledCode, createdProduct.Id);
                    }
                    catch (Exception codeEx)
                    {
                        Logger.LogError(codeEx, "Error auto-assigning code to product");
                        // Don't fail the whole operation if code assignment fails
                        AppNotification.ShowWarning(TranslationService.GetTranslation("products.codeAssignmentWarning", "Prodotto creato ma codice non assegnato automaticamente"));
                    }
                }
                
                AppNotification.ShowSuccess(TranslationService.GetTranslation("products.createSuccess", "Prodotto creato con successo"));
                
                // Close dialog and return the created product
                MudDialog.Close(DialogResult.Ok(createdProduct));
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslation("products.createError", "Errore nella creazione del prodotto"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating product");
            AppNotification.ShowError(TranslationService.GetTranslation("products.createError", "Errore nella creazione del prodotto: {0}", ex.Message));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Cancel()
    {
        _duplicateCheckCts?.Cancel();
        _duplicateCheckCts?.Dispose();
        MudDialog.Cancel();
    }

    // ── Duplicate detection ──────────────────────────────────────────────────

    private async Task OnNameChangedAsync(string value)
    {
        _model.Name = value;

        // Cancel and dispose the previous in-flight check before starting a new one
        _duplicateCheckCts?.Cancel();
        _duplicateCheckCts?.Dispose();
        _duplicateCheckCts = new CancellationTokenSource();
        var cts = _duplicateCheckCts;

        if (IsEditMode || string.IsNullOrWhiteSpace(value) || value.Trim().Length < 3)
        {
            _similarProducts = new List<ProductDto>();
            _isDuplicateChecking = false;
            StateHasChanged();
            return;
        }

        _isDuplicateChecking = true;
        StateHasChanged();

        try
        {
            var result = await ProductService.SearchProductsAsync(value.Trim(), 5, cts.Token);
            if (!cts.IsCancellationRequested)
            {
                _similarProducts = result?.SearchResults ?? new List<ProductDto>();
                // Exclude exact code match from duplicate suggestions (it's already a different product)
                if (result?.IsExactCodeMatch == true && result.ExactMatch?.Product != null)
                {
                    _similarProducts = _similarProducts
                        .Where(p => p.Id != result.ExactMatch.Product.Id)
                        .ToList();
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Debounce cancelled — ignore
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error during duplicate name check for '{Name}'", value);
            _similarProducts = new List<ProductDto>();
        }
        finally
        {
            if (!cts.IsCancellationRequested)
            {
                _isDuplicateChecking = false;
                StateHasChanged();
            }
        }
    }

    private async Task UseExistingProductAsync(ProductDto existingProduct)
    {
        if (AutoAssignCode && !string.IsNullOrWhiteSpace(PrefilledCode))
        {
            _isLoading = true;
            try
            {
                var codeDto = new CreateProductCodeDto
                {
                    ProductId = existingProduct.Id,
                    Code = PrefilledCode,
                    CodeType = "Barcode",
                    Status = ProductCodeStatus.Active
                };
                await ProductService.CreateProductCodeAsync(codeDto);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("products.codeAssignedToExisting",
                    "Codice assegnato al prodotto esistente: {0}", existingProduct.Name));
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error assigning code {Code} to existing product {ProductId}", PrefilledCode, existingProduct.Id);
                AppNotification.ShowWarning(TranslationService.GetTranslation("products.codeAssignmentWarning",
                    "Prodotto selezionato ma codice non assegnato automaticamente"));
            }
            finally
            {
                _isLoading = false;
            }
        }

        MudDialog.Close(DialogResult.Ok(existingProduct));
    }

    public void Dispose()
    {
        _duplicateCheckCts?.Cancel();
        _duplicateCheckCts?.Dispose();
    }
}
