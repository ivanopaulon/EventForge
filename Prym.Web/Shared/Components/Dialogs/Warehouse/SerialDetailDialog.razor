@using Prym.DTOs.Warehouse
@using Prym.DTOs.Products
@using Prym.Web.Shared.Components.Warehouse
@using Prym.Web.ViewModels
@attribute [Authorize]
@inject SerialDetailViewModel ViewModel
@inject ISerialService SerialService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<SerialDetailDialog> Logger
@implements IDisposable

<EFDialog Icon="@Icons.Material.Outlined.Numbers"
          Title="@(ViewModel.IsNewEntity ? TranslationService.GetTranslation("serial.newSerial", "Nuova Matricola") : TranslationService.GetTranslation("serial.detail", "Dettaglio Matricola"))"
          IsProcessing="@(ViewModel.IsLoading || ViewModel.IsSaving)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <TitleActions>
        @if (!ViewModel.IsNewEntity && ViewModel.Entity != null)
        {
            @if (ViewModel.Entity.Status is "Available" or "Maintenance" or "Recalled")
            {
                <MudTooltip Text="@TranslationService.GetTranslation("serial.markDefective", "Segna come difettosa")">
                    <MudIconButton Icon="@Icons.Material.Outlined.BugReport"
                                   Color="Color.Warning"
                                   Size="Size.Small"
                                   Disabled="@(ViewModel.IsLoading || ViewModel.IsSaving)"
                                    OnClick="MarkDefectiveAsync" />
                </MudTooltip>
            }
            @if (ViewModel.Entity.Status == "Available")
            {
                <MudTooltip Text="@TranslationService.GetTranslation("serial.sell", "Vendi matricola")">
                    <MudIconButton Icon="@Icons.Material.Outlined.ShoppingCart"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Disabled="@(ViewModel.IsLoading || ViewModel.IsSaving)"
                                   OnClick="SellSerialAsync" />
                </MudTooltip>
            }
            @if (ViewModel.Entity.Status == "Sold")
            {
                <MudTooltip Text="@TranslationService.GetTranslation("serial.return", "Registra rientro")">
                    <MudIconButton Icon="@Icons.Material.Outlined.AssignmentReturn"
                                   Color="Color.Success"
                                   Size="Size.Small"
                                   Disabled="@(ViewModel.IsLoading || ViewModel.IsSaving)"
                                   OnClick="ReturnSerialAsync" />
                </MudTooltip>
            }
            @if (ViewModel.Entity.Status is "Available" or "Maintenance" or "Defective" or "Recalled")
            {
                <MudTooltip Text="@TranslationService.GetTranslation("serial.markScrapped", "Rottama matricola")">
                    <MudIconButton Icon="@Icons.Material.Outlined.Archive"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   Disabled="@(ViewModel.IsLoading || ViewModel.IsSaving)"
                                   OnClick="MarkScrappedAsync" />
                </MudTooltip>
            }
        }
    </TitleActions>
    <ChildContent>
        @if (ViewModel.IsLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (ViewModel.Entity == null)
        {
            <MudAlert Severity="Severity.Error">
                @TranslationService.GetTranslation("serial.notFound", "Matricola non trovata")
            </MudAlert>
        }
        else
        {
            @if (!ViewModel.IsNewEntity)
            {
                <div class="d-flex align-center gap-4 flex-wrap mb-3">
                    <div class="d-flex align-center gap-2">
                        <MudAvatar Color="Color.Primary" Size="Size.Medium">
                            <MudIcon Icon="@Icons.Material.Outlined.Numbers" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body1" Class="fw-semibold">@ViewModel.Entity.SerialNumber</MudText>
                            @if (!string.IsNullOrEmpty(ViewModel.Entity.ProductName))
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @TranslationService.GetTranslation("field.product", "Prodotto"): @ViewModel.Entity.ProductName
                                </MudText>
                            }
                        </div>
                    </div>
                    <SerialStatusBadge Status="@ViewModel.Entity.Status" Size="Size.Medium" />
                    @if (!string.IsNullOrEmpty(ViewModel.Entity.LotCode))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Outlined.QrCode">
                            @TranslationService.GetTranslation("warehouse.lot", "Lotto"): @ViewModel.Entity.LotCode
                        </MudChip>
                    }
                </div>
                <MudDivider Class="mb-3" />
            }

            <MudTabs Position="Position.Left" Rounded="true" Border="true" MinimumTabWidth="160px" PanelClass="pa-4" @bind-ActivePanelIndex="_activeTab">

                <MudTabPanel Text="@TranslationService.GetTranslation("serial.generalInfo", "Informazioni Generali")" Icon="@Icons.Material.Filled.Info">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <PrymTextField @bind-Value="ViewModel.Entity.SerialNumber"
                                           Label="@($"{TranslationService.GetTranslation("serial.number", "Numero Matricola")} *")"
                                           MaxLength="100"
                                           Required="true"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.Numbers"
                                           @bind-Value:after="ViewModel.NotifyEntityChanged"
                                           HelperText="@TranslationService.GetTranslation("serial.numberHelper", "Numero seriale univoco")" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudAutocomplete T="ProductDto"
                                             Value="_selectedProduct"
                                             ValueChanged="OnProductSelectedAsync"
                                             Label="@($"{TranslationService.GetTranslation("field.product", "Prodotto")} *")"
                                             SearchFunc="ViewModel.SearchProductsAsync"
                                             ToStringFunc="@(p => p != null ? $"{p.Name} ({p.Code})" : string.Empty)"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             ShowProgressIndicator="true"
                                             MinCharacters="1"
                                             DebounceInterval="250"
                                             Clearable="true"
                                             CoerceText="false"
                                             CoerceValue="false"
                                             Disabled="@(!ViewModel.IsNewEntity)" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudSelect T="Guid?"
                                       @bind-Value="ViewModel.Entity.LotId"
                                       Label="@TranslationService.GetTranslation("warehouse.lot", "Lotto")"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Clearable="true"
                                       @bind-Value:after="ViewModel.NotifyEntityChanged">
                                @foreach (var lot in ViewModel.Lots ?? Enumerable.Empty<LotDto>())
                                {
                                    <MudSelectItem Value="@((Guid?)lot.Id)">@lot.Code @(lot.ProductName != null ? $"({lot.ProductName})" : string.Empty)</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudDatePicker Date="@ViewModel.Entity.ManufacturingDate"
                                           Label="@TranslationService.GetTranslation("serial.manufacturingDate", "Data Produzione")"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           DateChanged="@(d => { ViewModel.Entity.ManufacturingDate = d; ViewModel.NotifyEntityChanged(); })"
                                           Clearable="true" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudDatePicker Date="@ViewModel.Entity.WarrantyExpiry"
                                           Label="@TranslationService.GetTranslation("serial.warrantyExpiry", "Scadenza Garanzia")"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           DateChanged="@(d => { ViewModel.Entity.WarrantyExpiry = d; ViewModel.NotifyEntityChanged(); })"
                                           Clearable="true" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <PrymTextField @bind-Value="ViewModel.Entity.Barcode"
                                           Label="@TranslationService.GetTranslation("field.barcode", "Barcode")"
                                           MaxLength="50"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.QrCodeScanner"
                                           @bind-Value:after="ViewModel.NotifyEntityChanged" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <PrymTextField @bind-Value="ViewModel.Entity.RfidTag"
                                           Label="@TranslationService.GetTranslation("serial.rfidTag", "RFID Tag")"
                                           MaxLength="50"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.Wifi"
                                           @bind-Value:after="ViewModel.NotifyEntityChanged" />
                        </MudItem>

                        <MudItem xs="12">
                            <PrymTextField @bind-Value="ViewModel.Entity.Notes"
                                           Label="@TranslationService.GetTranslation("field.notes", "Note")"
                                           Lines="3"
                                           MaxLength="500"
                                           @bind-Value:after="ViewModel.NotifyEntityChanged" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <MudTabPanel Text="@TranslationService.GetTranslation("serial.statusPosition", "Stato e Posizione")" Icon="@Icons.Material.Filled.LocationOn">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudSelect T="string"
                                       @bind-Value="ViewModel.Entity.Status"
                                       Label="@TranslationService.GetTranslation("warehouse.status", "Stato")"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       @bind-Value:after="ViewModel.NotifyEntityChanged">
                                <MudSelectItem Value="@("Available")">@TranslationService.GetTranslation("serial.available", "Disponibile")</MudSelectItem>
                                <MudSelectItem Value="@("Sold")" Disabled="true">@TranslationService.GetTranslation("serial.sold", "Venduto")</MudSelectItem>
                                <MudSelectItem Value="@("InUse")">@TranslationService.GetTranslation("serial.inUse", "In uso")</MudSelectItem>
                                <MudSelectItem Value="@("Maintenance")">@TranslationService.GetTranslation("serial.inMaintenance", "In Manutenzione")</MudSelectItem>
                                <MudSelectItem Value="@("Defective")">@TranslationService.GetTranslation("serial.defective", "Difettoso")</MudSelectItem>
                                <MudSelectItem Value="@("Recalled")">@TranslationService.GetTranslation("serial.recalled", "Richiamata")</MudSelectItem>
                                <MudSelectItem Value="@("Scrapped")">@TranslationService.GetTranslation("serial.scrapped", "Rottamata")</MudSelectItem>
                            </MudSelect>
                        </MudItem>

                        @if (!ViewModel.IsNewEntity)
                        {
                            <MudItem xs="12" md="6">
                                <MudTextField Value="@(ViewModel.Entity.CurrentLocationCode ?? "-")"
                                              Label="@TranslationService.GetTranslation("serial.currentLocation", "Ubicazione Corrente")"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="true" />
                            </MudItem>

                            @if (ViewModel.Entity.Status == "Sold")
                            {
                                <MudItem xs="12" md="6">
                                    <MudTextField Value="@(ViewModel.Entity.OwnerName ?? "-")"
                                                  Label="@TranslationService.GetTranslation("serial.owner", "Proprietario")"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  ReadOnly="true" />
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudTextField Value="@(ViewModel.Entity.SaleDate?.ToString("dd/MM/yyyy") ?? "-")"
                                                  Label="@TranslationService.GetTranslation("serial.saleDate", "Data Vendita")"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  ReadOnly="true" />
                                </MudItem>
                            }

                            <MudItem xs="12" md="6">
                                <MudTextField Value="@ViewModel.Entity.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                              Label="@TranslationService.GetTranslation("common.createdAt", "Creato il")"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="true" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudTextField Value="@(ViewModel.Entity.ModifiedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")"
                                              Label="@TranslationService.GetTranslation("common.modifiedAt", "Modificato il")"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="true" />
                            </MudItem>
                        }
                    </MudGrid>
                </MudTabPanel>

                @if (!ViewModel.IsNewEntity)
                {
                    <MudTabPanel Text="@TranslationService.GetTranslation("common.history", "Storico")" Icon="@Icons.Material.Filled.History">
                        <StockMovementHistoryTable Items="_history"
                                                  IsLoading="_isLoadingHistory"
                                                  EmptyMessage="@TranslationService.GetTranslation("serial.noHistory", "Nessun movimento registrato per questa matricola")" />
                    </MudTabPanel>
                }

            </MudTabs>
        }
    </ChildContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="ViewModel.IsSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveAsync" Disabled="ViewModel.IsSaving || ViewModel.IsLoading || ViewModel.Entity == null">
            @TranslationService.GetTranslation("common.save", "Salva")
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? EntityId { get; set; }
    [Parameter] public Guid? InitialProductId { get; set; }

    private int _activeTab = 0;
    private string? _originalStatus;
    private bool _isLoadingHistory;
    private IEnumerable<StockMovementDto> _history = Enumerable.Empty<StockMovementDto>();
    private ProductDto? _selectedProduct;

    private static readonly HashSet<string> _terminalStatuses = new(StringComparer.Ordinal)
    {
        "Defective", "Scrapped"
    };

    protected override async Task OnInitializedAsync()
    {
        ViewModel.StateChanged += OnViewModelStateChanged;
        try
        {
            if (InitialProductId.HasValue && (EntityId == null || EntityId == Guid.Empty))
            {
                ViewModel.InitialProductId = InitialProductId;
            }
            await ViewModel.LoadEntityAsync(EntityId ?? Guid.Empty);
            _selectedProduct = ViewModel.SelectedProduct;
            _originalStatus = ViewModel.Entity?.Status;
            if (!ViewModel.IsNewEntity)
                await LoadHistoryAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading serial {SerialId}.", EntityId);
            AppNotification.ShowWarning("Si è verificato un errore nel caricamento della matricola.");
        }
    }

    private void OnViewModelStateChanged()
    {
        _selectedProduct = ViewModel.SelectedProduct;
        InvokeAsync(StateHasChanged);
    }

    private async Task OnProductSelectedAsync(ProductDto? product)
    {
        _selectedProduct = product;
        await ViewModel.SetSelectedProductAsync(product);
    }

    private async Task SaveAsync()
    {
        try
        {
            // Warn when moving to a terminal status that is not reversible
            var newStatus = ViewModel.Entity?.Status ?? string.Empty;
            if (!string.IsNullOrEmpty(_originalStatus) &&
                _originalStatus != newStatus &&
                _terminalStatuses.Contains(newStatus))
            {
                var terminalLabel = newStatus switch
                {
                    "Defective" => TranslationService.GetTranslation("serial.defective", "Difettoso"),
                    "Scrapped"  => TranslationService.GetTranslation("serial.scrapped", "Rottamata"),
                    _           => newStatus
                };
                var confirmed = await DialogService.ShowMessageBoxAsync(
                    TranslationService.GetTranslation("common.confirm", "Conferma"),
                    TranslationService.GetTranslation("serial.confirmTerminalStatus",
                        "Stai impostando lo stato su '{0}'. Questa operazione potrebbe essere irreversibile. Continuare?",
                        terminalLabel),
                    yesText: TranslationService.GetTranslation("common.confirm", "Conferma"),
                    cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
                if (confirmed != true) return;
            }

            var success = await ViewModel.SaveEntityAsync();
            if (success)
                MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving serial {SerialId}.", EntityId);
            AppNotification.ShowWarning("Si è verificato un errore nel salvataggio della matricola.");
        }
    }

    private async Task Cancel()
    {
        if (ViewModel.HasUnsavedChanges())
        {
            var result = await DialogService.ShowMessageBoxAsync(
                TranslationService.GetTranslation("common.confirm", "Conferma"),
                TranslationService.GetTranslation("serial.unsavedChanges", "Ci sono modifiche non salvate. Vuoi salvare prima di uscire?"),
                yesText: TranslationService.GetTranslation("common.save", "Salva"),
                noText: TranslationService.GetTranslation("common.discard", "Non salvare"),
                cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
            if (result == null) return;
            if (result == true) { await SaveAsync(); return; }
        }
        MudDialog.Close();
    }

    public void Dispose()
    {
        ViewModel.StateChanged -= OnViewModelStateChanged;
    }

    private async Task MarkDefectiveAsync()
    {
        if (ViewModel.Entity == null) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            TranslationService.GetTranslation("common.confirm", "Conferma"),
            TranslationService.GetTranslation("serial.confirmDefective", "Segnare la matricola '{0}' come difettosa?", ViewModel.Entity.SerialNumber),
            yesText: TranslationService.GetTranslation("serial.markDefective", "Segna difettosa"),
            cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
        if (confirmed != true) return;
        try
        {
            var result = await SerialService.UpdateSerialStatusAsync(ViewModel.Entity.Id, "Defective");
            if (result)
            {
                AppNotification.ShowSuccess(TranslationService.GetTranslation("serial.markedDefective", "Matricola segnata come difettosa"));
                await ViewModel.ReloadEntityAsync();
                await LoadHistoryAsync();
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslation("common.error", "Errore"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error marking serial {SerialId} as defective.", ViewModel.Entity.Id);
            AppNotification.ShowWarning("Si è verificato un errore nell'aggiornamento dello stato.");
        }
    }

    private async Task MarkScrappedAsync()
    {
        if (ViewModel.Entity == null) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            TranslationService.GetTranslation("common.confirm", "Conferma"),
            TranslationService.GetTranslation("serial.confirmScrapped", "Rottamare la matricola '{0}'?", ViewModel.Entity.SerialNumber),
            yesText: TranslationService.GetTranslation("serial.markScrapped", "Rottama"),
            cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
        if (confirmed != true) return;
        try
        {
            var result = await SerialService.UpdateSerialStatusAsync(ViewModel.Entity.Id, "Scrapped");
            if (result)
            {
                AppNotification.ShowSuccess(TranslationService.GetTranslation("serial.markedScrapped", "Matricola rottamata"));
                await ViewModel.ReloadEntityAsync();
                await LoadHistoryAsync();
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslation("common.error", "Errore"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error scrapping serial {SerialId}.", ViewModel.Entity.Id);
            AppNotification.ShowWarning("Si è verificato un errore nella rottamazione della matricola.");
        }
    }

    private async Task SellSerialAsync()
    {
        if (ViewModel.Entity == null) return;

        var dialog = await DialogService.ShowAsync<SerialSellDialog>(string.Empty, new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = false
        });
        var result = await dialog.Result;
        if (result is not { Canceled: false, Data: SellSerialRequestDto request })
            return;

        try
        {
            if (await SerialService.SellSerialAsync(ViewModel.Entity.Id, request.CustomerId, request.SaleDate))
            {
                AppNotification.ShowSuccess(TranslationService.GetTranslation("serial.soldSuccess", "Matricola venduta"));
                await ViewModel.ReloadEntityAsync();
                await LoadHistoryAsync();
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslation("common.error", "Errore"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error selling serial {SerialId}.", ViewModel.Entity.Id);
            AppNotification.ShowWarning("Si è verificato un errore durante la vendita della matricola.");
        }
    }

    private async Task ReturnSerialAsync()
    {
        if (ViewModel.Entity == null) return;

        var dialog = await DialogService.ShowAsync<SerialReturnDialog>(string.Empty, new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = false
        });
        var result = await dialog.Result;
        if (result is not { Canceled: false, Data: ReturnSerialRequestDto request })
            return;

        try
        {
            if (await SerialService.ReturnSerialAsync(ViewModel.Entity.Id, request.NewLocationId, request.Reason))
            {
                AppNotification.ShowSuccess(TranslationService.GetTranslation("serial.returnedSuccess", "Rientro registrato"));
                await ViewModel.ReloadEntityAsync();
                await LoadHistoryAsync();
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslation("common.error", "Errore"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error returning serial {SerialId}.", ViewModel.Entity.Id);
            AppNotification.ShowWarning("Si è verificato un errore durante il rientro della matricola.");
        }
    }

    private async Task LoadHistoryAsync()
    {
        if (ViewModel.Entity == null || ViewModel.IsNewEntity)
        {
            _history = Enumerable.Empty<StockMovementDto>();
            return;
        }

        _isLoadingHistory = true;
        try
        {
            _history = await SerialService.GetSerialHistoryAsync(ViewModel.Entity.Id) ?? Enumerable.Empty<StockMovementDto>();
        }
        finally
        {
            _isLoadingHistory = false;
        }
    }
}
