@* Eccezione documentata (Categoria D — WizardDialog):
   questo dialog è una procedura specializzata di merge inventariale.
   Usa MudTable embedded in un wizard a step con due tabelle contestuali
   (inventari source e destinazione). Non è una lista CRUD.
   EntityManagementPage non è adatto per questo layout procedurale.
   TODO: valutare EFTable per le due tabelle embedded se il wizard
   viene rifattorizzato con un archetipo WizardPage. *@
@using Prym.DTOs.Warehouse
@inject IInventoryService InventoryService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ILogger<InventoryMergeDialog> Logger

<PageLoadingOverlay Visible="@_loading" Message="Caricamento inventari..." />

@if (!_loading)
{
    <EFStepperDialog Icon="@Icons.Material.Filled.MergeType"
                      Title="Accorpamento Inventari"
                      ActiveIndex="@_activeStep"
                      ActiveIndexChanged="@OnActiveStepChanged"
                      StepCount="3"
                      CanGoNext="@(_activeStep == 0 ? _selectedDocuments.Count >= 2 : true)"
                      BeforeNextAsync="@HandleMergeStepAdvance"
                      Busy="@(_previewLoading || _merging)"
                      NextText="@(_activeStep == 0 ? "Mostra anteprima" : "Conferma e Accorpa")"
                      ShowStepperActions="@(_activeStep < 2)"
                      ShowPrevious="@(_activeStep < 2)"
                      ShowCancel="@(_activeStep == 0)"
                      ExtraActions="@(_activeStep == 2 ? ResultActionsFragment : null)">
        <PrymStep Title="Selezione" Icon="@Icons.Material.Filled.Checklist">
            <MudPaper Class="pa-4 mb-4" Elevation="1">
                <MudText Typo="Typo.subtitle1" Class="mb-3">
                    Seleziona almeno 2 inventari aperti da accorpare
                </MudText>

                @if (_loading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
                }
                else if (_openDocumentHeaders == null || !_openDocumentHeaders.Any())
                {
                    <MudAlert Severity="Severity.Info" Class="mb-3">
                        Nessun inventario aperto disponibile per l'accorpamento.
                    </MudAlert>
                }
                else
                {
                    <MudTable T="InventoryDocumentHeaderDto"
                              Items="_openDocumentHeaders"
                              MultiSelection="true"
                              @bind-SelectedItems="_selectedDocuments"
                              Dense="true"
                              Hover="true"
                              Striped="true"
                              Class="mb-3">
                        <HeaderContent>
                            <MudTh>Numero</MudTh>
                            <MudTh>Data Inventario</MudTh>
                            <MudTh>Magazzino</MudTh>
                            <MudTh>Stato</MudTh>
                            <MudTh >N° Righe</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Numero">
                                <MudText Typo="Typo.body2"><b>@context.Number</b></MudText>
                            </MudTd>
                            <MudTd DataLabel="Data Inventario">
                                @context.InventoryDate.ToString("dd/MM/yyyy")
                            </MudTd>
                            <MudTd DataLabel="Magazzino">
                                @(context.WarehouseName ?? "—")
                            </MudTd>
                            <MudTd DataLabel="Stato">
                                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                                    @context.Status
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="N° Righe" >
                                @context.RowCount
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText>Nessun inventario disponibile.</MudText>
                        </NoRecordsContent>
                    </MudTable>

                    @if (_selectedDocuments.Count > 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            @_selectedDocuments.Count inventari selezionati —
                            totale righe: <b>@_selectedDocuments.Sum(d => d.RowCount)</b>
                        </MudAlert>
                    }
                }
            </MudPaper>

            @* Selezione documento target *@
            @if (_selectedDocuments.Count >= 2)
            {
                <MudPaper Class="pa-4 mb-4" Elevation="1">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">Documento di destinazione</MudText>
                    <MudText Typo="Typo.body2" Class="mb-2" Color="Color.Secondary">
                        Il documento scelto come destinazione riceverà tutte le righe accorpate.
                        Gli altri verranno soft-eliminati.
                    </MudText>
                    <MudSelect T="Guid?"
                               @bind-Value="_targetDocumentId"
                               Label="Documento target (opzionale — default: primo selezionato)"
                               Variant="Variant.Outlined"
                               Clearable="true"
                               Dense="true">
                        @foreach (var doc in _selectedDocuments)
                        {
                            <MudSelectItem Value="@((Guid?)doc.Id)">
                                @doc.Number — @doc.InventoryDate.ToString("dd/MM/yyyy")
                                (@(doc.RowCount) righe)
                            </MudSelectItem>
                        }
                    </MudSelect>

                    <MudTextField @bind-Value="_mergeNotes"
                                  Label="Note accorpamento (opzionale)"
                                  Variant="Variant.Outlined"
                                  Lines="2"
                                  Class="mt-3"
                                  MaxLength="500"
                            Margin="Margin.Dense"/>
                </MudPaper>
            }
        </PrymStep>

        <PrymStep Title="Anteprima" Icon="@Icons.Material.Filled.Preview">
            @if (_preview != null)
            {
                <MudGrid Spacing="3" Class="mb-4">
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="pa-3 text-center" Elevation="1">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.h4" Class="mt-1"><b>@_preview.SourceDocuments.Count</b></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Documenti sorgente</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="pa-3 text-center" Elevation="1">
                            <MudIcon Icon="@Icons.Material.Filled.TableRows" Color="Color.Info" Size="Size.Large" />
                            <MudText Typo="Typo.h4" Class="mt-1"><b>@_preview.TotalInputRows</b></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe totali in ingresso</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="pa-3 text-center" Elevation="1">
                            <MudIcon Icon="@Icons.Material.Filled.MergeType" Color="Color.Warning" Size="Size.Large" />
                            <MudText Typo="Typo.h4" Class="mt-1"><b>@_preview.RowsToMerge</b></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe da accorpare (somma qty)</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="pa-3 text-center" Elevation="1">
                            <MudIcon Icon="@Icons.Material.Filled.Output" Color="Color.Success" Size="Size.Large" />
                            <MudText Typo="Typo.h4" Class="mt-1"><b>@_preview.EstimatedOutputRows</b></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe stimate nel risultato</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                @if (_preview.Warnings != null && _preview.Warnings.Any())
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-4" ShowCloseIcon="false">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Attenzione</MudText>
                        <ul Class="pl-4 mb-0">
                            @foreach (var w in _preview.Warnings)
                            {
                                <li><MudText Typo="Typo.body2">@w</MudText></li>
                            }
                        </ul>
                    </MudAlert>
                }

                <MudPaper Class="pa-4 mb-4" Elevation="1">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">Documenti selezionati</MudText>
                    <MudTable T="MergeSourceDocumentSummaryDto"
                              Items="_preview.SourceDocuments"
                              Dense="true"
                              Hover="true"
                              Striped="true">
                        <HeaderContent>
                            <MudTh>Numero</MudTh>
                            <MudTh>Data</MudTh>
                            <MudTh>Magazzino</MudTh>
                            <MudTh>Stato</MudTh>
                            <MudTh >Righe</MudTh>
                            <MudTh>Ruolo</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Numero"><b>@context.Number</b></MudTd>
                            <MudTd DataLabel="Data">@context.InventoryDate.ToString("dd/MM/yyyy")</MudTd>
                            <MudTd DataLabel="Magazzino">@(context.WarehouseName ?? "—")</MudTd>
                            <MudTd DataLabel="Stato">
                                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                                    @context.Status
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Righe" >@context.RowCount</MudTd>
                            <MudTd DataLabel="Ruolo">
                                @if (context.Id == (_targetDocumentId ?? _selectedDocuments.FirstOrDefault()?.Id))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                             Icon="@Icons.Material.Filled.Star">
                                        Destinazione
                                    </MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                        Sorgente → eliminato
                                    </MudChip>
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            }
        </PrymStep>

        <PrymStep Title="Risultato" Icon="@Icons.Material.Filled.CheckCircle">
            @if (_result != null)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4" Icon="@Icons.Material.Filled.CheckCircle">
                    <MudText Typo="Typo.subtitle1">Accorpamento completato con successo!</MudText>
                    <MudText Typo="Typo.body2">
                        Documento risultante: <b>@_result.MergedDocumentNumber</b>
                        — @_result.TotalRows righe totali
                        (@_result.MergedRows accorpate, @_result.CopiedRows copiate).
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mt-1">
                        Documenti eliminati (soft): @_result.SoftDeletedDocumentIds.Count
                    </MudText>
                </MudAlert>

                @if (_result.Warnings != null && _result.Warnings.Any())
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-4">
                        @foreach (var w in _result.Warnings)
                        {
                            <MudText Typo="Typo.body2">⚠️ @w</MudText>
                        }
                    </MudAlert>
                }

                <MudGrid Spacing="3" Class="mb-4">
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3 text-center" Elevation="1">
                            <MudIcon Icon="@Icons.Material.Filled.Done" Color="Color.Success" Size="Size.Large" />
                            <MudText Typo="Typo.h4"><b>@_result.TotalRows</b></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe nel documento finale</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3 text-center" Elevation="1">
                            <MudIcon Icon="@Icons.Material.Filled.MergeType" Color="Color.Warning" Size="Size.Large" />
                            <MudText Typo="Typo.h4"><b>@_result.MergedRows</b></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe accorpate (qty sommate)</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3 text-center" Elevation="1">
                            <MudIcon Icon="@Icons.Material.Filled.ContentCopy" Color="Color.Info" Size="Size.Large" />
                            <MudText Typo="Typo.h4"><b>@_result.CopiedRows</b></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe copiate (nessun duplicato)</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }
        </PrymStep>
    </EFStepperDialog>
}

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private int _activeStep = 0;

    private bool _loading = true;
    private bool _previewLoading = false;
    private bool _merging = false;

    private List<InventoryDocumentHeaderDto> _openDocumentHeaders = new();
    private HashSet<InventoryDocumentHeaderDto> _selectedDocuments = new();
    private Guid? _targetDocumentId = null;
    private string? _mergeNotes;

    private MergeInventoryDocumentsPreviewDto? _preview;
    private MergeInventoryDocumentsResultDto? _result;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadOpenDocumentsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OnInitializedAsync.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task LoadOpenDocumentsAsync()
    {
        _loading = true;
        try
        {
            _openDocumentHeaders = await InventoryService.GetOpenInventoryDocumentHeadersAsync()
                             ?? new List<InventoryDocumentHeaderDto>();
        }
        catch (Exception ex)
        {
            AppNotification.ShowError($"Errore nel caricamento degli inventari: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnActiveStepChanged(int newIndex)
    {
        if (newIndex == 0)
        {
            // Coerente con il precedente GoBackToSelection: tornando alla selezione,
            // l'anteprima va ricalcolata da zero.
            _preview = null;
        }
        _activeStep = newIndex;
    }

    private async Task<bool> HandleMergeStepAdvance(int currentIndex) => currentIndex switch
    {
        0 => await LoadPreviewAsync(),
        1 => await ConfirmAndMergeAsync(),
        _ => true
    };

    private async Task<bool> LoadPreviewAsync()
    {
        _previewLoading = true;
        try
        {
            var ids = _selectedDocuments.Select(d => d.Id).ToList();
            _preview = await InventoryService.PreviewMergeInventoryDocumentsAsync(ids);

            if (_preview == null)
            {
                AppNotification.ShowError("Impossibile generare l'anteprima.");
                return false;
            }
            return true;
        }
        catch (Exception ex)
        {
            AppNotification.ShowError($"Errore anteprima: {ex.Message}");
            return false;
        }
        finally
        {
            _previewLoading = false;
        }
    }

    private async Task<bool> ConfirmAndMergeAsync()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Conferma accorpamento",
            $"Stai per accorpare {_selectedDocuments.Count} inventari in uno solo. " +
            "Gli altri verranno soft-eliminati. Continuare?",
            yesText: "Accorpa",
            cancelText: "Annulla");

        if (confirmed != true) return false;

        _merging = true;
        try
        {
            var dto = new MergeInventoryDocumentsDto
            {
                SourceDocumentIds = _selectedDocuments.Select(d => d.Id).ToList(),
                TargetDocumentId  = _targetDocumentId,
                Notes             = _mergeNotes,
            };

            _result = await InventoryService.MergeInventoryDocumentsExtendedAsync(dto);

            if (_result == null)
            {
                AppNotification.ShowError("Errore durante l'accorpamento.");
                return false;
            }

            AppNotification.ShowSuccess($"Accorpamento completato! Documento: {_result.MergedDocumentNumber}");
            return true;
        }
        catch (Exception ex)
        {
            AppNotification.ShowError($"Errore accorpamento: {ex.Message}");
            return false;
        }
        finally
        {
            _merging = false;
        }
    }

    private async Task ResetWizard()
    {
        try
        {
            _preview           = null;
            _result            = null;
            _selectedDocuments = new();
            _targetDocumentId  = null;
            _mergeNotes        = null;
            _activeStep        = 0;
            await LoadOpenDocumentsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in ResetWizard.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private RenderFragment ResultActionsFragment => builder =>
    {
        builder.OpenComponent<MudButton>(0);
        builder.AddAttribute(1, "Variant", Variant.Outlined);
        builder.AddAttribute(2, "Color", Color.Default);
        builder.AddAttribute(3, "StartIcon", Icons.Material.Filled.Refresh);
        builder.AddAttribute(4, "OnClick", EventCallback.Factory.Create(this, ResetWizard));
        builder.AddAttribute(5, "ChildContent", (RenderFragment)(b => b.AddContent(0, "Nuovo accorpamento")));
        builder.CloseComponent();

        builder.OpenComponent<MudButton>(6);
        builder.AddAttribute(7, "Variant", Variant.Filled);
        builder.AddAttribute(8, "Color", Color.Primary);
        builder.AddAttribute(9, "StartIcon", Icons.Material.Filled.Check);
        builder.AddAttribute(10, "OnClick", EventCallback.Factory.Create(this, () => MudDialog.Close(DialogResult.Ok(true))));
        builder.AddAttribute(11, "ChildContent", (RenderFragment)(b => b.AddContent(0, "Chiudi")));
        builder.CloseComponent();
    };

    private static Color GetStatusColor(string? status) => status switch
    {
        "Open"      => Color.Warning,
        "Closed"    => Color.Success,
        "Cancelled" => Color.Error,
        _           => Color.Default,
    };
}
