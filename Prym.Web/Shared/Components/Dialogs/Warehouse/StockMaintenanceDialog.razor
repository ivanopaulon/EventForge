@using Prym.DTOs.Warehouse
@using Prym.DTOs.Documents
@inject IStockReconciliationService StockReconciliationService
@inject IStockService StockService
@inject IWarehouseService WarehouseService
@inject IDocumentTypeService DocumentTypeService
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject IAppNotificationService AppNotification
@inject IHttpClientService HttpClientService
@inject IJSRuntime JSRuntime
@inject ILogger<StockMaintenanceDialog> Logger
@implements IDisposable

<EFDialog Icon="@Icons.Material.Outlined.Tune"
          Title='@TranslationService.GetTranslation("stock.maintenance.title", "Strumenti Magazzino")'
          IsProcessing="@_isProcessing"
          MinWidth="min(960px, 95vw)"
          Height="calc(100dvh - 96px)"
          OnClose="Close">
    <ChildContent>
        <MudTabs Position="Position.Left" Rounded="true" Border="true"
                 MinimumTabWidth="160px" PanelClass="pa-4"
                 ActivePanelIndex="@_activeTab"
                 ActivePanelIndexChanged="OnTabChanged">

            @* ══════════════════════════════════════════════════════
               Tab 0 – Riconciliazione
               ══════════════════════════════════════════════════════ *@
            <MudTabPanel Icon="@Icons.Material.Outlined.Balance"
                         Text='@TranslationService.GetTranslation("stock.maintenance.tab.reconciliation", "Riconciliazione")'>

                <MudGrid Spacing="2" Class="mb-4">
                    <MudItem xs="12" sm="6" md="5">
                        <MudSelect @bind-Value="_recon_warehouseId"
                                   Label='@TranslationService.GetTranslation("stock.warehouse", "Magazzino")'
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Clearable="true">
                            @foreach (var w in _warehouses)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)w.Id)">@w.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3" Class="d-flex align-center">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Outlined.Calculate"
                                   OnClick="CalculateReconciliationInDialogAsync"
                                   Disabled="@_recon_isLoading">
                            @TranslationService.GetTranslation("stock.reconciliation.calculate", "Calcola")
                        </MudButton>
                    </MudItem>
                </MudGrid>

                @if (_recon_isLoading)
                {
                    <div class="d-flex flex-column align-center justify-center pa-8 gap-3">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                        <MudText Typo="Typo.body1">
                            @TranslationService.GetTranslation("stock.reconciliation.calculating", "Calcolo in corso...")
                        </MudText>
                    </div>
                }
                else if (_recon_calculated)
                {
                    @* Summary row *@
                    <div class="d-flex flex-wrap align-center gap-2 mb-4">
                        <MudChip T="string" Icon="@Icons.Material.Outlined.CheckCircle" Color="Color.Success" Size="Size.Small">
                            @TranslationService.GetTranslationFormatted("stock.reconciliation.correct",
                                "{0} correct{1}", _recon_correctCount, _recon_correctCount == 1 ? "a" : "e")
                        </MudChip>
                        @if (ReconDiscrepancyCount > 0)
                        {
                            <MudChip T="string" Icon="@Icons.Material.Outlined.Warning" Color="Color.Warning" Size="Size.Small">
                                @TranslationService.GetTranslationFormatted("stock.reconciliation.discrepancies",
                                    "{0} discrepanz{1}", ReconDiscrepancyCount, ReconDiscrepancyCount == 1 ? "a" : "e")
                            </MudChip>
                            <MudSpacer />
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Warning"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Outlined.PlaylistAddCheck"
                                       OnClick="BulkApplyReconciledInDialogAsync"
                                       Disabled="@(_recon_isBulkApplying || _recon_isLoading)">
                                @if (_recon_isBulkApplying)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                }
                                @TranslationService.GetTranslationFormatted("stock.bulkApplyReconciled.button",
                                    "Applica tutte ({0})", ReconDiscrepancyCount)
                            </MudButton>
                        }
                    </div>

                    @if (ReconDiscrepancyCount == 0)
                    {
                        <MudAlert Severity="Severity.Success" Icon="@Icons.Material.Outlined.CheckCircle">
                            @TranslationService.GetTranslation("stock.reconciliationOk",
                                "Riconciliazione completata: nessuna discrepanza trovata.")
                        </MudAlert>
                    }
                    else
                    {
                        <div style="max-height:380px; overflow-y:auto;">
                            <MudTable Items="@ReconDiscrepancies"
                                      Dense="true" Striped="true" Hover="true" Elevation="0"
                                      FixedHeader="true">
                                <HeaderContent>
                                    <MudTh>@TranslationService.GetTranslation("field.productCode", "Codice")</MudTh>
                                    <MudTh>@TranslationService.GetTranslation("field.productName", "Prodotto")</MudTh>
                                    <MudTh>@TranslationService.GetTranslation("field.warehouse", "Magazzino")</MudTh>
                                    <MudTh>@TranslationService.GetTranslation("field.location", "Ubicazione")</MudTh>
                                    <MudTh Class="text-right">@TranslationService.GetTranslation("field.quantity", "Attuale")</MudTh>
                                    <MudTh Class="text-right">@TranslationService.GetTranslation("stock.reconciliation.calculated", "Calcolata")</MudTh>
                                    <MudTh Class="text-right">Δ</MudTh>
                                    <MudTh>@TranslationService.GetTranslation("field.severity", "Severità")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.ProductCode</MudChip>
                                    </MudTd>
                                    <MudTd>
                                        <MudText Typo="Typo.body2" Class="text-truncate ef-max-200">@context.ProductName</MudText>
                                    </MudTd>
                                    <MudTd>
                                        <MudText Typo="Typo.body2">@context.WarehouseName</MudText>
                                    </MudTd>
                                    <MudTd>
                                        <MudText Typo="Typo.body2">@context.LocationCode</MudText>
                                    </MudTd>
                                    <MudTd Class="text-right">
                                        <MudText Typo="Typo.body2">@context.CurrentQuantity.ToString("N2")</MudText>
                                    </MudTd>
                                    <MudTd Class="text-right">
                                        <MudText Typo="Typo.body2" Class="fw-semibold">@context.CalculatedQuantity.ToString("N2")</MudText>
                                    </MudTd>
                                    <MudTd Class="text-right">
                                        <MudText Typo="Typo.body2"
                                                 Color="@(context.Difference > 0 ? Color.Success : Color.Error)"
                                                 Class="fw-semibold">
                                            @(context.Difference > 0 ? "+" : "")@context.Difference.ToString("N2")
                                        </MudText>
                                    </MudTd>
                                    <MudTd>
                                        <MudChip T="string" Size="Size.Small" Color="@GetSeverityColor(context.Severity)">
                                            @GetSeverityLabel(context.Severity)
                                        </MudChip>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        </div>
                    }
                }
                else
                {
                    <div class="d-flex flex-column align-center justify-center pa-8 gap-3">
                        <MudIcon Icon="@Icons.Material.Outlined.Balance" Size="Size.Large" Class="mud-text-secondary" />
                        <MudText Typo="Typo.body1" Class="mud-text-secondary">
                            @TranslationService.GetTranslation("stock.reconciliation.hint",
                                "Seleziona il magazzino (opzionale) e premi Calcola per verificare le discrepanze.")
                        </MudText>
                    </div>
                }
            </MudTabPanel>

            @* ══════════════════════════════════════════════════════
               Tab 1 – Ricostruzione movimenti
               ══════════════════════════════════════════════════════ *@
            <MudTabPanel Icon="@Icons.Material.Outlined.BuildCircle"
                         Text='@TranslationService.GetTranslation("stock.maintenance.tab.rebuild", "Ricostruzione")'>
                @if (!_tab1Initialized)
                {
                    <div class="d-flex justify-center pa-8">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    </div>
                }
                else
                {
                    <MudStepper Class="min-h-0" @ref="_rebuild_stepper"
                                ActiveIndex="@_rebuild_step"
                                ActiveIndexChanged="@(i => _rebuild_step = i)"
                                NonLinear="false"
                                Color="Color.Primary"
                                Variant="Variant.Filled"
                                DisableAnimation="false">
                        <MudStep Title="Filtri" Icon="@Icons.Material.Outlined.Settings">
                            <MudGrid Spacing="2">
                                <MudItem xs="12" sm="6">
                                    <MudDatePicker @bind-Date="_rebuild_fromDate"
                                                   Label="@TranslationService.GetTranslation("common.dateFrom", "Data Da")"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Clearable="true"
                                                   DateFormat="dd/MM/yyyy" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudDatePicker @bind-Date="_rebuild_toDate"
                                                   Label="@TranslationService.GetTranslation("common.dateTo", "Data A")"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Clearable="true"
                                                   DateFormat="dd/MM/yyyy" />
                                </MudItem>

                                <MudItem xs="12" sm="6">
                                    <MudSelect @bind-Value="_rebuild_warehouseId"
                                               Label="@TranslationService.GetTranslation("stock.warehouse", "Magazzino")"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Clearable="true">
                                        @foreach (var w in _warehouses)
                                        {
                                            <MudSelectItem T="Guid?" Value="@((Guid?)w.Id)">@w.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudSelect @bind-Value="_rebuild_documentTypeId"
                                               Label="@TranslationService.GetTranslation("rebuildMovements.documentType", "Tipo Documento")"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Clearable="true">
                                        @foreach (var dt in _documentTypes)
                                        {
                                            <MudSelectItem T="Guid?" Value="@((Guid?)dt.Id)">@dt.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1">
                                        @TranslationService.GetTranslation("rebuildMovements.approvalStatus", "Stato Approvazione")
                                    </MudText>
                                    <div class="d-flex flex-column gap-0">
                                        <MudCheckBox @bind-Value="_rebuild_includeApproved" Dense="true" Color="Color.Success"
                                                     Label="@TranslationService.GetTranslation("rebuildMovements.approved", "Approvato")" />
                                        <MudCheckBox @bind-Value="_rebuild_includePending" Dense="true" Color="Color.Warning"
                                                     Label="@TranslationService.GetTranslation("rebuildMovements.pending", "In Attesa")" />
                                        <MudCheckBox @bind-Value="_rebuild_includeRejected" Dense="true" Color="Color.Error"
                                                     Label="@TranslationService.GetTranslation("rebuildMovements.rejected", "Rifiutato")" />
                                        <MudCheckBox @bind-Value="_rebuild_includeNoneApproval" Dense="true" Color="Color.Default"
                                                     Label="@TranslationService.GetTranslation("rebuildMovements.approvalNone", "Nessuna")" />
                                    </div>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.subtitle2" Class="mb-1">
                                        @TranslationService.GetTranslation("rebuildMovements.documentStatus", "Stato Documento")
                                    </MudText>
                                    <div class="d-flex flex-column gap-0">
                                        <MudCheckBox @bind-Value="_rebuild_includeClosed" Dense="true" Color="Color.Primary"
                                                     Label="@TranslationService.GetTranslation("rebuildMovements.closed", "Chiuso")" />
                                        <MudCheckBox @bind-Value="_rebuild_includeOpen" Dense="true" Color="Color.Info"
                                                     Label="@TranslationService.GetTranslation("rebuildMovements.open", "Aperto")" />
                                        <MudCheckBox @bind-Value="_rebuild_includeDraft" Dense="true" Color="Color.Default"
                                                     Label="@TranslationService.GetTranslation("rebuildMovements.draft", "Bozza")" />
                                        <MudCheckBox @bind-Value="_rebuild_includeCancelled" Dense="true" Color="Color.Error"
                                                     Label="@TranslationService.GetTranslation("rebuildMovements.cancelled", "Annullato")" />
                                    </div>
                                </MudItem>

                                <MudItem xs="12">
                                    <MudDivider Class="my-1" />
                                    <MudCheckBox @bind-Value="_rebuild_updateExisting" Dense="true" Color="Color.Warning"
                                                 Label="@TranslationService.GetTranslation("rebuildMovements.updateExisting", "Aggiorna movimenti esistenti (data, quantità, tipo)")"
                                                 Class="mt-1" />
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary ml-8">
                                        @TranslationService.GetTranslation("rebuildMovements.updateExistingHint", "Se attivo, i movimenti già collegati ai documenti vengono riallineati con i dati del documento.")
                                    </MudText>
                                    <MudDivider Class="my-2" />
                                    <MudCheckBox @bind-Value="_rebuild_forceRecalculate" Dense="true" Color="Color.Error"
                                                 Label="@TranslationService.GetTranslation("rebuildMovements.forceRecalculate", "Forza ricalcolo giacenze dai movimenti")"
                                                 Class="mt-1" />
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary ml-8">
                                        @TranslationService.GetTranslation("rebuildMovements.forceRecalculateHint", "Se attivo, sovrascrive la quantità di ogni giacenza con il netto calcolato dai movimenti storici (Entrate − Uscite). Usa questa opzione per correggere saldi negativi dovuti a movimenti mancanti o errati.")
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudStep>

                        <MudStep Title="Anteprima" Icon="@Icons.Material.Outlined.Preview">
                            @if (_rebuild_isLoading)
                            {
                                <div class="d-flex flex-column align-center justify-center pa-8 gap-3">
                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                                    <MudText Typo="Typo.body1">
                                        @TranslationService.GetTranslation("rebuildMovements.calculatingPreview", "Calcolo anteprima in corso...")
                                    </MudText>
                                </div>
                            }
                            else if (_rebuild_previewResult != null)
                            {
                                <MudGrid Spacing="2" Class="mb-4">
                                    <MudItem xs="6" sm="3">
                                        <MudPaper Class="pa-3 text-center" Elevation="2">
                                            <MudText Typo="Typo.h5">@_rebuild_previewResult.DocumentsScanned</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                @TranslationService.GetTranslation("rebuildMovements.documents", "Documenti")
                                            </MudText>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="6" sm="3">
                                        <MudPaper Class="pa-3 text-center border-success-l-3" Elevation="2">
                                            <MudText Typo="Typo.h5" Color="Color.Success">@_rebuild_previewResult.MovementsCreated</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                @TranslationService.GetTranslation("rebuildMovements.toCreate", "Da creare")
                                            </MudText>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="6" sm="3">
                                        <MudPaper Class="pa-3 text-center border-warning-l-3" Elevation="2">
                                            <MudText Typo="Typo.h5" Color="Color.Warning">@_rebuild_previewResult.MovementsUpdated</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                @TranslationService.GetTranslation("rebuildMovements.toUpdate", "Da aggiornare")
                                            </MudText>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="6" sm="3">
                                        <MudPaper Class="pa-3 text-center border-info-l-3" Elevation="2">
                                            <MudText Typo="Typo.h5" Color="Color.Info">@_rebuild_previewResult.RowsAlreadyHadMovement</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                @TranslationService.GetTranslation("rebuildMovements.alreadyPresent", "Già presenti")
                                            </MudText>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="6" sm="3">
                                        <MudPaper Class="pa-3 text-center" Elevation="2"
                                                  Style="@(_rebuild_previewResult.RowsSkippedNoLocation + _rebuild_previewResult.Errors > 0 ? "border-left: 3px solid var(--mud-palette-warning);" : "")">
                                            <MudText Typo="Typo.h5"
                                                     Color="@(_rebuild_previewResult.RowsSkippedNoLocation + _rebuild_previewResult.Errors > 0 ? Color.Warning : Color.Default)">
                                                @(_rebuild_previewResult.RowsSkippedNoLocation + _rebuild_previewResult.Errors)
                                            </MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                @TranslationService.GetTranslation("rebuildMovements.skippedOrErrors", "Saltati / Errori")
                                            </MudText>
                                        </MudPaper>
                                    </MudItem>
                                </MudGrid>

                                @if (_rebuild_previewResult.MovementsCreated == 0)
                                {
                                    <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Outlined.CheckCircle">
                                        @TranslationService.GetTranslation("rebuildMovements.nothingToCreate",
                                            "Nessun movimento mancante trovato. Tutti i documenti filtrati hanno già un movimento di magazzino associato.")
                                    </MudAlert>
                                }
                                else
                                {
                                    <MudText Typo="Typo.subtitle2" Class="mb-2">
                                        @TranslationService.GetTranslation("rebuildMovements.previewDetail", "Dettaglio movimenti da creare")
                                        @if (PreviewCreatedCount > _previewMaxRows)
                                        {
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary ml-2 d-inline">
                                                (mostrati @_previewMaxRows di @PreviewCreatedCount)
                                            </MudText>
                                        }
                                    </MudText>
                                    <div class="mh-280-scroll">
                                        <MudTable Items="@PreviewCreatedItems"
                                                  Dense="true" Striped="true" Hover="true" Elevation="0">
                                            <HeaderContent>
                                                <MudTh>@TranslationService.GetTranslation("field.document", "Documento")</MudTh>
                                                <MudTh>@TranslationService.GetTranslation("field.productName", "Prodotto")</MudTh>
                                                <MudTh>@TranslationService.GetTranslation("field.type", "Tipo")</MudTh>
                                                <MudTh>@TranslationService.GetTranslation("field.quantity", "Qtà")</MudTh>
                                            </HeaderContent>
                                            <RowTemplate>
                                                <MudTd>
                                                    <MudText Typo="Typo.body2">@context.DocumentNumber</MudText>
                                                </MudTd>
                                                <MudTd>
                                                    <MudText Typo="Typo.body2" Class="text-truncate ef-max-200">@context.ProductName</MudText>
                                                </MudTd>
                                                <MudTd>
                                                    <MudChip T="string" Size="Size.Small"
                                                             Color="@(context.MovementType == "Inbound" ? Color.Success : Color.Warning)"
                                                             Variant="Variant.Outlined">
                                                        @(context.MovementType == "Inbound"
                                                            ? TranslationService.GetTranslation("rebuildMovements.inbound", "↑ Entrata")
                                                            : TranslationService.GetTranslation("rebuildMovements.outbound", "↓ Uscita"))
                                                    </MudChip>
                                                </MudTd>
                                                <MudTd>
                                                    <MudText Typo="Typo.body2" Class="fw-semibold">@context.Quantity.ToString("N2")</MudText>
                                                </MudTd>
                                            </RowTemplate>
                                        </MudTable>
                                    </div>
                                }
                            }
                        </MudStep>

                        <MudStep Title="Applicazione" Icon="@Icons.Material.Outlined.PlayArrow">
                            @if (_rebuild_isLoading)
                            {
                                <div class="d-flex flex-column align-center pa-4 gap-4">
                                    <div class="d-flex align-center gap-3">
                                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                                        <div>
                                            <MudText Typo="Typo.body1">
                                                @TranslationService.GetTranslation("rebuildMovements.applying", "Creazione movimenti in corso...")
                                            </MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                @TranslationService.GetTranslationFormatted("rebuildMovements.elapsed", "{0}s trascorsi",
                                                    (int)(DateTimeOffset.UtcNow - _applyStartTime).TotalSeconds)
                                            </MudText>
                                        </div>
                                    </div>
                                    @if (_progressLog.Count > 0)
                                    {
                                        <MudPaper Outlined="true" Class="pa-3" Style="width:100%; min-height:90px;">
                                            <div class="d-flex flex-column gap-2">
                                                @for (var i = 0; i < _progressLog.Count; i++)
                                                {
                                                    var logMsg = _progressLog[i];
                                                    var logOpacity = i == 0 ? "1" : i == 1 ? "0.65" : "0.35";
                                                    var isFirst = i == 0;
                                                    <div class="d-flex align-center gap-2" style="opacity:@logOpacity">
                                                        @if (isFirst)
                                                        {
                                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                                                        }
                                                        else
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircleOutline" Size="Size.Small" Color="Color.Success" />
                                                        }
                                                        <MudText Typo="Typo.body2"
                                                                 Color="@(isFirst ? Color.Primary : Color.Default)"
                                                                 Style="@(isFirst ? "font-weight:600" : "")">
                                                            @logMsg
                                                        </MudText>
                                                    </div>
                                                }
                                            </div>
                                        </MudPaper>
                                    }
                                </div>
                            }
                            else if (_rebuild_applyResult != null)
                            {
                                <MudAlert Severity="@(_rebuild_applyResult.Errors == 0 ? Severity.Success : Severity.Warning)" Class="mb-4">
                                    @if (_rebuild_applyResult.Errors == 0)
                                    {
                                        @TranslationService.GetTranslation("rebuildMovements.applySuccess", "Operazione completata con successo!")
                                    }
                                    else
                                    {
                                        @TranslationService.GetTranslationFormatted("rebuildMovements.applyPartial",
                                            "Operazione completata con {0} errore/i.", _rebuild_applyResult.Errors)
                                    }
                                </MudAlert>

                                <MudGrid Spacing="2">
                                    <MudItem xs="6" sm="3">
                                        <MudPaper Class="pa-3 text-center border-success-l-3" Elevation="2">
                                            <MudText Typo="Typo.h5" Color="Color.Success">@_rebuild_applyResult.MovementsCreated</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                @TranslationService.GetTranslation("rebuildMovements.movementsCreated", "Movimenti creati")
                                            </MudText>
                                        </MudPaper>
                                    </MudItem>
                                    @if (_rebuild_applyResult.MovementsUpdated > 0)
                                    {
                                        <MudItem xs="6" sm="3">
                                            <MudPaper Class="pa-3 text-center border-warning-l-3" Elevation="2">
                                                <MudText Typo="Typo.h5" Color="Color.Warning">@_rebuild_applyResult.MovementsUpdated</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                    @TranslationService.GetTranslation("rebuildMovements.movementsUpdated", "Movimenti aggiornati")
                                                </MudText>
                                            </MudPaper>
                                        </MudItem>
                                    }
                                    @if (_rebuild_applyResult.StocksForceRecalculated > 0)
                                    {
                                        <MudItem xs="6" sm="3">
                                            <MudPaper Class="pa-3 text-center border-error-l-3" Elevation="2">
                                                <MudText Typo="Typo.h5" Color="Color.Error">@_rebuild_applyResult.StocksForceRecalculated</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                    @TranslationService.GetTranslation("rebuildMovements.stocksRecalculated", "Giacenze ricalcolate")
                                                </MudText>
                                            </MudPaper>
                                        </MudItem>
                                    }
                                    @if (_rebuild_applyResult.Errors > 0)
                                    {
                                        <MudItem xs="6" sm="3">
                                            <MudPaper Class="pa-3 text-center border-error-l-3" Elevation="2">
                                                <MudText Typo="Typo.h5" Color="Color.Error">@_rebuild_applyResult.Errors</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                    @TranslationService.GetTranslation("common.errors", "Errori")
                                                </MudText>
                                            </MudPaper>
                                        </MudItem>
                                    }
                                    <MudItem xs="6" sm="3">
                                        <MudPaper Class="pa-3 text-center" Elevation="2">
                                            <MudText Typo="Typo.h5">@_rebuild_applyResult.DocumentsScanned</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                @TranslationService.GetTranslation("rebuildMovements.documents", "Documenti")
                                            </MudText>
                                        </MudPaper>
                                    </MudItem>
                                </MudGrid>

                                @if (_rebuild_applyResult.Items.Any(i => i.Status == StatusError))
                                {
                                    <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">
                                        @TranslationService.GetTranslation("rebuildMovements.errorDetail", "Dettaglio errori")
                                    </MudText>
                                    <div class="mh-200-scroll">
                                        <MudTable Items="@ApplyErrorItems"
                                                  Dense="true" Elevation="0">
                                            <HeaderContent>
                                                <MudTh>@TranslationService.GetTranslation("field.document", "Documento")</MudTh>
                                                <MudTh>@TranslationService.GetTranslation("field.productName", "Prodotto")</MudTh>
                                                <MudTh>@TranslationService.GetTranslation("common.error", "Errore")</MudTh>
                                            </HeaderContent>
                                            <RowTemplate>
                                                <MudTd><MudText Typo="Typo.body2">@context.DocumentNumber</MudText></MudTd>
                                                <MudTd><MudText Typo="Typo.body2">@context.ProductName</MudText></MudTd>
                                                <MudTd><MudText Typo="Typo.caption" Color="Color.Error">@context.ErrorMessage</MudText></MudTd>
                                            </RowTemplate>
                                        </MudTable>
                                    </div>
                                }
                            }
                        </MudStep>
                    </MudStepper>

                    @* Step-level action buttons (inline since actions differ per step) *@
                    <div class="d-flex justify-end gap-2 mt-3">
                        @if (_rebuild_step == 0)
                        {
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       OnClick="RebuildGoToPreviewAsync"
                                       Disabled="_rebuild_isLoading"
                                       StartIcon="@Icons.Material.Outlined.Preview">
                                @TranslationService.GetTranslation("rebuildMovements.preview", "Anteprima")
                            </MudButton>
                        }
                        else if (_rebuild_step == 1 && !_rebuild_isLoading)
                        {
                            <MudButton Variant="Variant.Text"
                                       OnClick="@(() => _rebuild_step = 0)"
                                       StartIcon="@Icons.Material.Outlined.NavigateBefore">
                                @TranslationService.GetTranslation("common.back", "Indietro")
                            </MudButton>
                            @if (_rebuild_previewResult?.MovementsCreated > 0 || _rebuild_previewResult?.MovementsUpdated > 0)
                            {
                                var totalOps = (_rebuild_previewResult?.MovementsCreated ?? 0) + (_rebuild_previewResult?.MovementsUpdated ?? 0);
                                <MudButton Color="Color.Primary"
                                           Variant="Variant.Filled"
                                           OnClick="RebuildApplyAsync"
                                           StartIcon="@Icons.Material.Outlined.PlayArrow">
                                    @TranslationService.GetTranslationFormatted("rebuildMovements.apply",
                                        "Applica ({0} operazioni)", totalOps)
                                </MudButton>
                            }
                        }
                        else if (_rebuild_step == 2 && !_rebuild_isLoading)
                        {
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       OnClick="RebuildReset"
                                       StartIcon="@Icons.Material.Outlined.Refresh">
                                @TranslationService.GetTranslation("rebuildMovements.newSearch", "Nuova ricerca")
                            </MudButton>
                        }
                    </div>
                }
            </MudTabPanel>

            @* ══════════════════════════════════════════════════════
               Tab 2 – Snapshot storico
               ══════════════════════════════════════════════════════ *@
            <MudTabPanel Icon="@Icons.Material.Outlined.EventNote"
                         Text='@TranslationService.GetTranslation("stock.maintenance.tab.snapshot", "Snapshot")'>
                @if (!_tab2Initialized)
                {
                    <div class="d-flex justify-center pa-8">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    </div>
                }
                else
                {
                    @* Quick-select: last 3 inventory dates *@
                    @if (_snapshot_recentInventoryDates.Any())
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">
                            @TranslationService.GetTranslation("stock.snapshot.recentInventories", "Ultimi inventari:")
                        </MudText>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            @foreach (var inv in _snapshot_recentInventoryDates)
                            {
                                var isSelected = _snapshot_selectedInventoryDate?.DocumentHeaderId == inv.DocumentHeaderId;
                                <MudChip T="string"
                                         Color="@(isSelected ? Color.Primary : Color.Default)"
                                         Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                                         Size="Size.Small"
                                         Icon="@Icons.Material.Outlined.Inventory2"
                                         OnClick="@(() => SnapshotSelectInventoryDate(inv))"
                                         Style="cursor:pointer">
                                    @inv.Date.ToString("dd/MM/yyyy") — @inv.DocumentNumber
                                </MudChip>
                            }
                        </div>

                        @if (_snapshot_selectedInventoryDate is not null)
                        {
                            <div class="d-flex align-center gap-2 mb-3">
                                <MudSwitch @bind-Value="_snapshot_useInventoryQuantities"
                                           Label="@TranslationService.GetTranslation("stock.snapshot.useInventoryQuantities", "Estrai quantità inventariate")"
                                           Color="Color.Secondary" />
                                @if (_snapshot_useInventoryQuantities)
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @TranslationService.GetTranslation("stock.snapshot.useInventoryQuantitiesHint",
                                            "Le quantità mostrate sono quelle fisicamente conteggiate nell'inventario, senza ricalcolo dai movimenti.")
                                    </MudText>
                                }
                            </div>
                        }
                    }

                    @* Parameters row *@
                    <MudGrid Spacing="2" Class="mb-4">
                        <MudItem xs="12" sm="6" md="4">
                            <MudDatePicker @bind-Date="_snapshot_referenceDate"
                                           Label="@TranslationService.GetTranslation("stock.snapshot.referenceDate", "Data di riferimento")"
                                           Variant="Variant.Outlined"
                                           DateFormat="dd/MM/yyyy"
                                           MaxDate="@DateTime.Today"
                                           Editable="true"
                                           Class="mb-0" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <MudSelect @bind-Value="_snapshot_warehouseId"
                                       Label="@TranslationService.GetTranslation("stock.warehouse", "Magazzino")"
                                       Variant="Variant.Outlined"
                                       Clearable="true"
                                       Class="mb-0">
                                @foreach (var wh in _warehouses)
                                {
                                    <MudSelectItem T="Guid?" Value="@wh.Id">@wh.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4" Class="d-flex align-center">
                            <MudSwitch @bind-Value="_snapshot_includePrices"
                                       Label="@TranslationService.GetTranslation("stock.snapshot.includePrices", "Includi prezzi")"
                                       Color="Color.Primary" />
                        </MudItem>
                    </MudGrid>

                    @* Action buttons *@
                    <div class="d-flex align-center gap-2 mb-4">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Outlined.Search"
                                   OnClick="SnapshotExtractAsync"
                                   Disabled="@(_snapshot_isLoading || !_snapshot_referenceDate.HasValue)">
                            @TranslationService.GetTranslation("stock.snapshot.extract", "Estrai")
                        </MudButton>

                        @if (_snapshot_results.Any())
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Success"
                                       StartIcon="@Icons.Material.Outlined.FileDownload"
                                       OnClick="SnapshotExportToExcelAsync"
                                       Disabled="@_snapshot_isExporting">
                                @if (_snapshot_isExporting)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                }
                                @TranslationService.GetTranslation("stock.snapshot.exportExcel", "Esporta Excel")
                            </MudButton>

                            <MudSpacer />
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @TranslationService.GetTranslationFormatted("stock.snapshot.rowsFound", "{0} righe trovate", _snapshot_results.Count)
                            </MudText>
                        }
                    </div>

                    @* Note on sale price *@
                    @if (_snapshot_results.Any() && _snapshot_includePrices)
                    {
                        var hasListPrices = _snapshot_results.Any(r => r.IsPriceFromList);
                        <MudAlert Severity="@(hasListPrices ? Severity.Success : Severity.Info)" Dense="true" Class="mb-3">
                            <MudText Typo="Typo.caption">
                                @if (hasListPrices)
                                {
                                    @TranslationService.GetTranslation("stock.snapshot.salePriceFromList",
                                        "Il prezzo di vendita è stato risolto dal listino prezzi attivo alla data di riferimento.")
                                }
                                else
                                {
                                    @TranslationService.GetTranslation("stock.snapshot.salePriceFallback",
                                        "Nessun listino attivo trovato per la data selezionata: viene mostrato il prezzo di vendita predefinito del prodotto.")
                                }
                            </MudText>
                        </MudAlert>
                    }

                    @* Results table *@
                    @if (_snapshot_isLoading)
                    {
                        <div class="d-flex justify-center pa-4">
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                        </div>
                    }
                    else if (_snapshot_extracted && !_snapshot_results.Any())
                    {
                        <div class="text-center pa-4">
                            <MudIcon Icon="@Icons.Material.Outlined.Inventory" Size="Size.Large" Class="mud-text-secondary mb-2" />
                            <MudText Typo="Typo.body1" Class="mud-text-secondary">
                                @TranslationService.GetTranslation("stock.snapshot.noResults", "Nessuna giacenza trovata per la data selezionata")
                            </MudText>
                        </div>
                    }
                    else if (_snapshot_results.Any())
                    {
                        <div style="overflow-x: auto;">
                            <MudTable Items="_snapshot_results"
                                      Dense="true"
                                      Hover="true"
                                      Striped="true"
                                      FixedHeader="true"
                                      Height="350px"
                                      Breakpoint="Breakpoint.None">
                                <HeaderContent>
                                    <MudTh>@TranslationService.GetTranslation("field.productCode", "Codice")</MudTh>
                                    <MudTh>@TranslationService.GetTranslation("field.productName", "Nome Prodotto")</MudTh>
                                    <MudTh>@TranslationService.GetTranslation("field.warehouse", "Magazzino")</MudTh>
                                    <MudTh>@TranslationService.GetTranslation("field.location", "Ubicazione")</MudTh>
                                    <MudTh>@TranslationService.GetTranslation("field.lotCode", "Lotto")</MudTh>
                                    <MudTh Class="text-right">@TranslationService.GetTranslation("field.quantity", "Quantità")</MudTh>
                                    @if (_snapshot_includePrices)
                                    {
                                        <MudTh Class="text-right">@TranslationService.GetTranslation("stock.snapshot.unitCost", "Prezzo Acquisto")</MudTh>
                                        <MudTh Class="text-right">@TranslationService.GetTranslation("stock.snapshot.totalCostValue", "Valore Acquisto")</MudTh>
                                        <MudTh Class="text-right">@TranslationService.GetTranslation("stock.snapshot.salePrice", "Prezzo Vendita")</MudTh>
                                        <MudTh Class="text-right">@TranslationService.GetTranslation("stock.snapshot.totalSaleValue", "Valore Vendita")</MudTh>
                                    }
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Codice">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.ProductCode</MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Nome Prodotto">
                                        <MudText Typo="Typo.body2">@context.ProductName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="Magazzino">
                                        <MudText Typo="Typo.body2">@context.WarehouseName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="Ubicazione">
                                        <div>
                                            <MudText Typo="Typo.body2">@context.LocationCode</MudText>
                                            @if (!string.IsNullOrWhiteSpace(context.LocationDescription))
                                            {
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.LocationDescription</MudText>
                                            }
                                        </div>
                                    </MudTd>
                                    <MudTd DataLabel="Lotto">
                                        @if (!string.IsNullOrWhiteSpace(context.LotCode))
                                        {
                                            <div>
                                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary">@context.LotCode</MudChip>
                                                @if (context.LotExpiry.HasValue)
                                                {
                                                    var isExpired = context.LotExpiry.Value <= _snapshot_referenceDate!.Value;
                                                    <MudText Typo="Typo.caption" Color="@(isExpired ? Color.Error : Color.Default)">
                                                        @context.LotExpiry.Value.ToString("dd/MM/yyyy")
                                                    </MudText>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body2">-</MudText>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Quantità" Class="text-right">
                                        <MudText Typo="Typo.body2"
                                                 Color="@(context.Quantity > 0 ? Color.Default : Color.Error)"
                                                 Class="fw-semibold">
                                            @context.Quantity.ToString("N2")
                                        </MudText>
                                    </MudTd>
                                    @if (_snapshot_includePrices)
                                    {
                                        <MudTd DataLabel="Prezzo Acquisto" Class="text-right">
                                            <MudText Typo="Typo.body2">@(context.UnitCost?.ToString("N2") ?? "-")</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="Valore Acquisto" Class="text-right">
                                            <MudText Typo="Typo.body2">@(context.TotalCostValue?.ToString("N2") ?? "-")</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="Prezzo Vendita" Class="text-right">
                                            <div>
                                                <MudText Typo="Typo.body2">@(context.SalePrice?.ToString("N2") ?? "-")</MudText>
                                                @if (context.IsPriceFromList && !string.IsNullOrWhiteSpace(context.PriceListName))
                                                {
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.PriceListName</MudText>
                                                }
                                            </div>
                                        </MudTd>
                                        <MudTd DataLabel="Valore Vendita" Class="text-right">
                                            <MudText Typo="Typo.body2">@(context.TotalSaleValue?.ToString("N2") ?? "-")</MudText>
                                        </MudTd>
                                    }
                                </RowTemplate>
                            </MudTable>
                        </div>
                    }
                }
            </MudTabPanel>

        </MudTabs>
    </ChildContent>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>Pre-selects a warehouse when opening the dialog from the stock overview page.</summary>
    [Parameter] public Guid? InitialWarehouseId { get; set; }

    /// <summary>Which tab to show on open: 0 = Riconciliazione, 1 = Ricostruzione, 2 = Snapshot.</summary>
    [Parameter] public int InitialTab { get; set; } = 0;

    // ── General ──────────────────────────────────────────────
    private bool _isProcessing => _recon_isLoading || _recon_isBulkApplying || _rebuild_isLoading || _snapshot_isLoading;
    private int _activeTab = 0;
    private bool _shouldReload = false;
    private bool _tab1Initialized = false;
    private bool _tab2Initialized = false;

    // ── Shared reference data ─────────────────────────────────
    private List<StorageFacilityDto> _warehouses = new();

    // ══════════════════════════════════════════════════════════
    // TAB 0 – Riconciliazione
    // ══════════════════════════════════════════════════════════
    private Guid? _recon_warehouseId;
    private bool _recon_isLoading = false;
    private bool _recon_isBulkApplying = false;
    private bool _recon_calculated = false;
    private Dictionary<Guid, StockReconciliationItemDto> _recon_data = new();
    private int _recon_correctCount = 0;

    private IEnumerable<StockReconciliationItemDto> ReconDiscrepancies =>
        _recon_data.Values.Where(r => r.Severity != ReconciliationSeverity.Correct);
    private int ReconDiscrepancyCount => ReconDiscrepancies.Count();

    private async Task CalculateReconciliationInDialogAsync()
    {
        try
        {
            _recon_isLoading = true;
            _recon_calculated = false;
            StateHasChanged();

            var request = new StockReconciliationRequestDto
            {
                WarehouseId = _recon_warehouseId,
                IncludeDocuments = true,
                IncludeInventories = true,
                IncludeStockMovements = true,
                OnlyWithDiscrepancies = false
            };

            var result = await StockReconciliationService.CalculateReconciliationAsync(request);
            if (result?.Items != null)
            {
                _recon_data = result.Items.ToDictionary(i => i.StockId);
                _recon_correctCount = result.Items.Count(i => i.Severity == ReconciliationSeverity.Correct);
                _recon_calculated = true;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error calculating reconciliation in StockMaintenanceDialog");
            AppNotification.ShowError(TranslationService.GetTranslation("stock.reconciliationError", "Errore nel calcolo della riconciliazione"));
        }
        finally
        {
            _recon_isLoading = false;
            StateHasChanged();
        }
    }

    private async Task BulkApplyReconciledInDialogAsync()
    {
        var itemsToApply = ReconDiscrepancies.Select(r => r.StockId).ToList();
        if (itemsToApply.Count == 0)
        {
            AppNotification.ShowInfo(TranslationService.GetTranslation("stock.bulkApplyReconciled.nothingToApply", "Nessuna discrepanza da correggere."));
            return;
        }

        var confirm = await DialogService.ShowMessageBoxAsync(
            TranslationService.GetTranslation("stock.bulkApplyReconciled.confirmTitle", "Applica quantità riconciliate"),
            TranslationService.GetTranslationFormatted(
                "stock.bulkApplyReconciled.confirmMessage",
                "Verranno aggiornate {0} giacenze con le quantità calcolate dai movimenti. Per ogni modifica sarà creato un movimento di rettifica. Continuare?",
                itemsToApply.Count),
            yesText: TranslationService.GetTranslation("common.confirm", "Conferma"),
            cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));

        if (confirm != true)
            return;

        try
        {
            _recon_isBulkApplying = true;
            StateHasChanged();

            var applyRequest = new StockReconciliationApplyRequestDto
            {
                ItemsToApply = itemsToApply,
                Reason = TranslationService.GetTranslation("stock.bulkApplyReconciled.reason", "Applicazione massiva quantità riconciliate da movimenti"),
                CreateAdjustmentMovements = true,
                ReconciliationFilters = new StockReconciliationRequestDto
                {
                    WarehouseId = _recon_warehouseId,
                    IncludeDocuments = true,
                    IncludeInventories = true,
                    IncludeStockMovements = true,
                    OnlyWithDiscrepancies = false
                }
            };

            var applyResult = await StockReconciliationService.ApplyReconciliationAsync(applyRequest);

            if (applyResult?.Success == true)
            {
                AppNotification.ShowSuccess(TranslationService.GetTranslationFormatted(
                    "stock.bulkApplyReconciled.success",
                    "Giacenze aggiornate: {0}. Movimenti di rettifica creati: {1}.",
                    applyResult.UpdatedCount, applyResult.MovementsCreated));
                _shouldReload = true;
                // Refresh reconciliation data to reflect the applied changes
                await CalculateReconciliationInDialogAsync();
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslationFormatted(
                    "stock.bulkApplyReconciled.error",
                    "Errore durante l'applicazione: {0}",
                    applyResult?.ErrorMessage ?? "Errore sconosciuto"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in BulkApplyReconciledInDialogAsync");
            AppNotification.ShowError(TranslationService.GetTranslation("stock.bulkApplyReconciled.exception", "Errore imprevisto durante l'applicazione massiva."));
        }
        finally
        {
            _recon_isBulkApplying = false;
            StateHasChanged();
        }
    }

    private static Color GetSeverityColor(ReconciliationSeverity severity) => severity switch
    {
        ReconciliationSeverity.Correct => Color.Success,
        ReconciliationSeverity.Minor   => Color.Warning,
        ReconciliationSeverity.Major   => Color.Error,
        ReconciliationSeverity.Missing => Color.Dark,
        _                              => Color.Default
    };

    private string GetSeverityLabel(ReconciliationSeverity severity) => severity switch
    {
        ReconciliationSeverity.Correct => TranslationService.GetTranslation("reconciliation.severity.correct", "OK"),
        ReconciliationSeverity.Minor   => TranslationService.GetTranslation("reconciliation.severity.minor", "Minore"),
        ReconciliationSeverity.Major   => TranslationService.GetTranslation("reconciliation.severity.major", "Maggiore"),
        ReconciliationSeverity.Missing => TranslationService.GetTranslation("reconciliation.severity.missing", "Mancante"),
        _                              => severity.ToString()
    };

    // ══════════════════════════════════════════════════════════
    // TAB 1 – Ricostruzione movimenti
    // ══════════════════════════════════════════════════════════
    private const int _previewMaxRows = 200;
    private int _rebuild_step = 0;
    private bool _rebuild_isLoading = false;
    private MudStepper? _rebuild_stepper;

    // Filter state
    private DateTime? _rebuild_fromDate;
    private DateTime? _rebuild_toDate;
    private Guid? _rebuild_warehouseId;
    private Guid? _rebuild_documentTypeId;
    private bool _rebuild_includeApproved = true;
    private bool _rebuild_includePending = false;
    private bool _rebuild_includeRejected = false;
    private bool _rebuild_includeNoneApproval = false;
    private bool _rebuild_includeClosed = true;
    private bool _rebuild_includeOpen = false;
    private bool _rebuild_includeDraft = false;
    private bool _rebuild_includeCancelled = false;
    private bool _rebuild_updateExisting = true;
    private bool _rebuild_forceRecalculate = false;

    // Reference data (document types only — warehouses shared)
    private List<DocumentTypeDto> _documentTypes = new();

    // Results
    private RebuildMovementsResultDto? _rebuild_previewResult;
    private RebuildMovementsResultDto? _rebuild_applyResult;

    // Progress tracker
    private readonly List<string> _progressLog = new();
    private DateTimeOffset _applyStartTime;
    private CancellationTokenSource? _progressCts;

    private static readonly string[] _progressMessages =
    [
        "Caricamento intestazioni documento...",
        "Verifica movimenti già esistenti...",
        "Ricerca ubicazioni di magazzino...",
        "Pianificazione movimenti da creare/aggiornare...",
        "Aggiornamento movimenti esistenti...",
        "Creazione nuovi movimenti di magazzino...",
        "Salvataggio modifiche su database...",
        "Aggiornamento giacenze prodotti...",
        "Verifica coerenza dati...",
        "Completamento operazione batch..."
    ];

    private const string StatusCreated = "Created";
    private const string StatusError = "Error";

    private IEnumerable<RebuildMovementsRowResultDto> PreviewCreatedItems =>
        _rebuild_previewResult?.Items.Where(i => i.Status == StatusCreated).Take(_previewMaxRows)
        ?? Enumerable.Empty<RebuildMovementsRowResultDto>();

    private int PreviewCreatedCount => _rebuild_previewResult?.Items.Count(i => i.Status == StatusCreated) ?? 0;

    private IEnumerable<RebuildMovementsRowResultDto> ApplyErrorItems =>
        _rebuild_applyResult?.Items.Where(i => i.Status == StatusError)
        ?? Enumerable.Empty<RebuildMovementsRowResultDto>();

    private async Task InitTab1Async()
    {
        _rebuild_warehouseId = InitialWarehouseId;
        try
        {
            _documentTypes = (await DocumentTypeService.GetAllDocumentTypesAsync())?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading document types in StockMaintenanceDialog tab 1");
        }
    }

    private async Task RebuildGoToPreviewAsync()
    {
        _rebuild_step = 1;
        _rebuild_isLoading = true;
        _rebuild_previewResult = null;
        StateHasChanged();
        try
        {
            var request = BuildRebuildRequest(dryRun: true);
            _rebuild_previewResult = await StockReconciliationService.RebuildMovementsPreviewAsync(request);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error previewing rebuild movements");
            AppNotification.ShowError(TranslationService.GetTranslation("rebuildMovements.previewError", "Errore durante il calcolo dell'anteprima."));
        }
        finally
        {
            _rebuild_isLoading = false;
        }
    }

    private async Task RebuildApplyAsync()
    {
        _rebuild_step = 2;
        _rebuild_isLoading = true;
        _rebuild_applyResult = null;
        _progressLog.Clear();
        _applyStartTime = DateTimeOffset.UtcNow;
        _ = StartProgressTrackerAsync().ContinueWith(
            t => Logger.LogError(t.Exception, "Unexpected error in progress tracker"),
            TaskContinuationOptions.OnlyOnFaulted);
        StateHasChanged();
        try
        {
            var request = BuildRebuildRequest(dryRun: false);
            _rebuild_applyResult = await StockReconciliationService.RebuildMovementsExecuteAsync(request);
            if (_rebuild_applyResult != null && (_rebuild_applyResult.MovementsCreated > 0 || _rebuild_applyResult.MovementsUpdated > 0))
                _shouldReload = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error executing rebuild movements");
            AppNotification.ShowError(TranslationService.GetTranslation("rebuildMovements.applyError", "Errore durante l'applicazione dei movimenti."));
        }
        finally
        {
            StopProgressTracker();
            _rebuild_isLoading = false;
        }
    }

    private void RebuildReset()
    {
        _rebuild_step = 0;
        _rebuild_previewResult = null;
        _rebuild_applyResult = null;
        _progressLog.Clear();
    }

    private RebuildMovementsRequestDto BuildRebuildRequest(bool dryRun)
    {
        var approvalStatuses = new List<int>();
        if (_rebuild_includeApproved) approvalStatuses.Add(2);
        if (_rebuild_includePending) approvalStatuses.Add(1);
        if (_rebuild_includeRejected) approvalStatuses.Add(3);
        if (_rebuild_includeNoneApproval) approvalStatuses.Add(0);

        var documentStatuses = new List<int>();
        if (_rebuild_includeClosed) documentStatuses.Add(2);
        if (_rebuild_includeOpen) documentStatuses.Add(1);
        if (_rebuild_includeDraft) documentStatuses.Add(0);
        if (_rebuild_includeCancelled) documentStatuses.Add(3);

        return new RebuildMovementsRequestDto
        {
            DryRun = dryRun,
            FromDate = _rebuild_fromDate.HasValue ? DateTime.SpecifyKind(_rebuild_fromDate.Value, DateTimeKind.Utc) : null,
            ToDate = _rebuild_toDate.HasValue ? DateTime.SpecifyKind(_rebuild_toDate.Value, DateTimeKind.Utc) : null,
            WarehouseId = _rebuild_warehouseId,
            DocumentTypeId = _rebuild_documentTypeId,
            ApprovalStatuses = approvalStatuses.Count > 0 ? approvalStatuses : null,
            DocumentStatuses = documentStatuses.Count > 0 ? documentStatuses : null,
            UpdateExisting = _rebuild_updateExisting,
            ForceRecalculateFromMovements = _rebuild_forceRecalculate
        };
    }

    private async Task StartProgressTrackerAsync()
    {
        _progressCts = new CancellationTokenSource();
        var msgIndex = 0;
        try
        {
            while (!_progressCts.Token.IsCancellationRequested)
            {
                await Task.Delay(2500, _progressCts.Token);
                var msg = _progressMessages[msgIndex % _progressMessages.Length];
                _progressLog.Insert(0, msg);
                if (_progressLog.Count > 3)
                    _progressLog.RemoveAt(3);
                msgIndex++;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException) { /* expected */ }
    }

    private void StopProgressTracker()
    {
        _progressCts?.Cancel();
        _progressCts?.Dispose();
        _progressCts = null;
    }

    public void Dispose() => StopProgressTracker();

    // ══════════════════════════════════════════════════════════
    // TAB 2 – Snapshot storico
    // ══════════════════════════════════════════════════════════
    private DateTime? _snapshot_referenceDate = DateTime.Today.AddDays(-1);
    private Guid? _snapshot_warehouseId;
    private bool _snapshot_includePrices = true;
    private bool _snapshot_isLoading = false;
    private bool _snapshot_isExporting = false;
    private bool _snapshot_extracted = false;
    private InventorySnapshotDateDto? _snapshot_selectedInventoryDate;
    private bool _snapshot_useInventoryQuantities = false;
    private List<StockSnapshotDto> _snapshot_results = new();
    private List<InventorySnapshotDateDto> _snapshot_recentInventoryDates = new();

    private async Task InitTab2Async()
    {
        _snapshot_warehouseId = InitialWarehouseId;
        try
        {
            var inv = await StockService.GetRecentInventoryDatesAsync(3);
            if (inv != null)
                _snapshot_recentInventoryDates = inv.ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading inventory dates in StockMaintenanceDialog tab 2");
        }
    }

    private void SnapshotSelectInventoryDate(InventorySnapshotDateDto inv)
    {
        if (_snapshot_selectedInventoryDate?.DocumentHeaderId == inv.DocumentHeaderId)
        {
            _snapshot_selectedInventoryDate = null;
            _snapshot_useInventoryQuantities = false;
        }
        else
        {
            _snapshot_selectedInventoryDate = inv;
            _snapshot_referenceDate = inv.Date;
        }
    }

    private async Task SnapshotExtractAsync()
    {
        if (!_snapshot_referenceDate.HasValue)
            return;

        try
        {
            _snapshot_isLoading = true;
            _snapshot_extracted = false;
            _snapshot_results.Clear();

            IEnumerable<StockSnapshotDto>? data;

            if (_snapshot_useInventoryQuantities && _snapshot_selectedInventoryDate is not null)
            {
                data = await StockService.GetInventoryDocumentQuantitiesAsync(
                    _snapshot_selectedInventoryDate.DocumentHeaderId,
                    searchTerm: null,
                    warehouseId: _snapshot_warehouseId,
                    locationId: null);
            }
            else
            {
                data = await StockService.GetStockSnapshotAsync(
                    _snapshot_referenceDate.Value,
                    searchTerm: null,
                    warehouseId: _snapshot_warehouseId,
                    locationId: null);
            }

            _snapshot_results = data?.ToList() ?? new List<StockSnapshotDto>();
            _snapshot_extracted = true;

            if (!_snapshot_results.Any())
                AppNotification.ShowInfo(TranslationService.GetTranslation(
                    "stock.snapshot.noResults", "Nessuna giacenza trovata per la data selezionata"));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error extracting stock snapshot for {Date}", _snapshot_referenceDate);
            AppNotification.ShowError(TranslationService.GetTranslation(
                "stock.snapshot.extractError", "Errore durante l'estrazione delle giacenze"));
        }
        finally
        {
            _snapshot_isLoading = false;
        }
    }

    private async Task SnapshotExportToExcelAsync()
    {
        if (!_snapshot_results.Any()) return;

        try
        {
            _snapshot_isExporting = true;

            var columns = new List<object>
            {
                new { propertyName = "productCode",      displayName = "Codice",          isVisible = true },
                new { propertyName = "productName",      displayName = "Nome Prodotto",    isVisible = true },
                new { propertyName = "warehouseName",    displayName = "Magazzino",        isVisible = true },
                new { propertyName = "locationCode",     displayName = "Ubicazione",       isVisible = true },
                new { propertyName = "lotCode",          displayName = "Lotto",            isVisible = true },
                new { propertyName = "quantity",         displayName = "Quantità",         isVisible = true }
            };

            if (_snapshot_includePrices)
            {
                columns.Add(new { propertyName = "unitCost",        displayName = "Prezzo Acquisto",  isVisible = true });
                columns.Add(new { propertyName = "totalCostValue",  displayName = "Valore Acquisto",  isVisible = true });
                columns.Add(new { propertyName = "salePrice",       displayName = "Prezzo Vendita",   isVisible = true });
                columns.Add(new { propertyName = "totalSaleValue",  displayName = "Valore Vendita",   isVisible = true });
                columns.Add(new { propertyName = "priceListName",   displayName = "Listino",          isVisible = true });
            }

            var dateStr = _snapshot_referenceDate!.Value.ToString("dd/MM/yyyy");
            var payload = new
            {
                data = _snapshot_results,
                options = new
                {
                    fileName = $"StockSnapshot_{_snapshot_referenceDate:yyyyMMdd}",
                    sheetName = $"Giacenze al {dateStr}",
                    columns,
                    formatting = new
                    {
                        headerBackgroundColor = "#1565C0",
                        headerFontColor = "#FFFFFF",
                        headerBold = true,
                        headerBorders = true,
                        alternateRowColors = true,
                        alternateRowColor = "#F5F5F5",
                        dataBorders = true
                    },
                    autoFitColumns = true,
                    freezeHeader = true,
                    addAutoFilter = true
                }
            };

            var stream = await HttpClientService.PostStreamAsync("api/v1/export/excel", payload);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            var fileName = $"StockSnapshot_{_snapshot_referenceDate!.Value:yyyyMMdd}_{DateTime.Now:HHmmss}.xlsx";
            await JSRuntime.InvokeVoidAsync("downloadFileFromBytes", fileName, bytes);
            AppNotification.ShowSuccess(TranslationService.GetTranslation("stock.snapshot.exportSuccess", "Esportazione completata"));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error exporting stock snapshot");
            AppNotification.ShowError(TranslationService.GetTranslation("stock.snapshot.exportError", "Errore durante l'esportazione"));
        }
        finally
        {
            _snapshot_isExporting = false;
        }
    }

    // ══════════════════════════════════════════════════════════
    // Lifecycle / navigation
    // ══════════════════════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        _activeTab = InitialTab;
        _recon_warehouseId = InitialWarehouseId;

        // Load shared warehouses
        try
        {
            var whResult = await WarehouseService.GetStorageFacilitiesAsync();
            _warehouses = whResult?.Items?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading warehouses in StockMaintenanceDialog");
        }

        // Tab 0 always loads on open (reconciliation is fast enough for background load)
        _ = CalculateReconciliationInDialogAsync();

        // Tabs 1 and 2 are lazy-init
        if (_activeTab == 1) await EnsureTab1InitializedAsync();
        else if (_activeTab == 2) await EnsureTab2InitializedAsync();
    }

    private async Task OnTabChanged(int tab)
    {
        _activeTab = tab;
        if (tab == 1) await EnsureTab1InitializedAsync();
        else if (tab == 2) await EnsureTab2InitializedAsync();
    }

    private async Task EnsureTab1InitializedAsync()
    {
        if (_tab1Initialized) return;
        await InitTab1Async();
        _tab1Initialized = true;
    }

    private async Task EnsureTab2InitializedAsync()
    {
        if (_tab2Initialized) return;
        await InitTab2Async();
        _tab2Initialized = true;
    }

    private void Close()
    {
        if (_isProcessing) return;
        MudDialog.Close(DialogResult.Ok(_shouldReload));
    }
}
