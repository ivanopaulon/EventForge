@using Prym.DTOs.Warehouse
@using Prym.DTOs.Products
@using Prym.Web.ViewModels
@attribute [Authorize]
@inject LotDetailViewModel ViewModel
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<LotDetailDialog> Logger
@implements IDisposable

<EFDialog Icon="@Icons.Material.Outlined.QrCode"
          Title="@(ViewModel.IsNewEntity ? TranslationService.GetTranslation("lot.newLot", "Nuovo Lotto") : TranslationService.GetTranslation("lot.detail", "Dettaglio Lotto"))"
          IsProcessing="@(ViewModel.IsLoading || ViewModel.IsSaving)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <ChildContent>
        @if (ViewModel.IsLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (ViewModel.Entity == null)
        {
            <MudAlert Severity="Severity.Error">
                @TranslationService.GetTranslation("lot.notFound", "Lotto non trovato")
            </MudAlert>
        }
        else
        {
            @if (!ViewModel.IsNewEntity)
            {
                <div class="d-flex align-center gap-4 flex-wrap mb-3">
                    <div class="d-flex align-center gap-2">
                        <MudAvatar Color="Color.Primary" Size="Size.Medium">
                            <MudIcon Icon="@Icons.Material.Outlined.QrCode" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body1" Class="fw-semibold">@ViewModel.Entity.Code</MudText>
                            @if (!string.IsNullOrEmpty(ViewModel.Entity.ProductName))
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @TranslationService.GetTranslation("field.product", "Prodotto"): @ViewModel.Entity.ProductName
                                </MudText>
                            }
                        </div>
                    </div>
                    <MudChip T="string" Size="Size.Medium" Color="@GetStatusColor(ViewModel.Entity.Status)" Icon="@GetStatusIcon(ViewModel.Entity.Status)">
                        @GetStatusText(ViewModel.Entity.Status)
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Color="@GetQualityColor(ViewModel.Entity.QualityStatus)">
                        @GetQualityText(ViewModel.Entity.QualityStatus)
                    </MudChip>
                </div>
                <MudDivider Class="mb-3" />
            }

            <MudTabs Position="Position.Left" Rounded="true" Border="true" MinimumTabWidth="160px" PanelClass="pa-4" @bind-ActivePanelIndex="_activeTab">

                <MudTabPanel Text="@TranslationService.GetTranslation("lot.generalInfo", "Informazioni Generali")" Icon="@Icons.Material.Filled.Info">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <PrymTextField @bind-Value="ViewModel.Entity.Code"
                                           Label="@($"{TranslationService.GetTranslation("warehouse.lotCode", "Codice Lotto")} *")"
                                           MaxLength="50"
                                           Required="true"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.QrCode"
                                           ReadOnly="@(!ViewModel.IsNewEntity)"
                                           @bind-Value:after="ViewModel.NotifyEntityChanged"
                                           HelperText="@TranslationService.GetTranslation("lot.codeHelper", "Codice identificativo del lotto")" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudSelect T="Guid"
                                       @bind-Value="ViewModel.Entity.ProductId"
                                       Label="@($"{TranslationService.GetTranslation("field.product", "Prodotto")} *")"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Disabled="@(!ViewModel.IsNewEntity)"
                                       @bind-Value:after="ViewModel.NotifyEntityChanged">
                                @foreach (var product in ViewModel.Products ?? Enumerable.Empty<ProductDto>())
                                {
                                    <MudSelectItem Value="@product.Id">@product.Name (@product.Code)</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudDatePicker @bind-Date="_productionDateLocal"
                                           @bind-Date:after="@OnProductionDateChanged"
                                           Label="@TranslationService.GetTranslation("warehouse.productionDate", "Data Produzione")"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Clearable="true" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudDatePicker @bind-Date="_expiryDateLocal"
                                           @bind-Date:after="@OnExpiryDateChanged"
                                           Label="@TranslationService.GetTranslation("warehouse.expiryDate", "Data Scadenza")"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Clearable="true" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <PrymNumericField T="decimal"
                                              @bind-Value="ViewModel.Entity.OriginalQuantity"
                                              Label="@($"{TranslationService.GetTranslation("warehouse.originalQuantity", "Quantità Originale")} *")"
                                              Min="0"
                                              Format="N4"
                                              ReadOnly="@(!ViewModel.IsNewEntity)"
                                              @bind-Value:after="ViewModel.NotifyEntityChanged" />
                        </MudItem>

                        @if (!ViewModel.IsNewEntity)
                        {
                            <MudItem xs="12" md="6">
                                <PrymNumericField T="decimal"
                                                  @bind-Value="ViewModel.Entity.AvailableQuantity"
                                                  Label="@TranslationService.GetTranslation("warehouse.availableQuantity", "Quantità Disponibile")"
                                                  Min="0"
                                                  Format="N4"
                                                  @bind-Value:after="ViewModel.NotifyEntityChanged" />
                            </MudItem>
                        }

                        <MudItem xs="12" md="6">
                            <PrymTextField @bind-Value="ViewModel.Entity.Barcode"
                                           Label="@TranslationService.GetTranslation("field.barcode", "Barcode")"
                                           MaxLength="50"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.QrCodeScanner"
                                           @bind-Value:after="ViewModel.NotifyEntityChanged" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <PrymTextField @bind-Value="ViewModel.Entity.CountryOfOrigin"
                                           Label="@TranslationService.GetTranslation("warehouse.countryOfOrigin", "Paese di Origine")"
                                           MaxLength="50"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.Public"
                                           @bind-Value:after="ViewModel.NotifyEntityChanged" />
                        </MudItem>

                        <MudItem xs="12">
                            <PrymTextField @bind-Value="ViewModel.Entity.Notes"
                                           Label="@TranslationService.GetTranslation("field.notes", "Note")"
                                           Lines="3"
                                           MaxLength="500"
                                           @bind-Value:after="ViewModel.NotifyEntityChanged" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                @if (!ViewModel.IsNewEntity)
                {
                    <MudTabPanel Text="@TranslationService.GetTranslation("lot.statusQuality", "Stato e Qualità")" Icon="@Icons.Material.Filled.VerifiedUser">
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField Value="@GetStatusText(ViewModel.Entity.Status)"
                                              Label="@TranslationService.GetTranslation("warehouse.status", "Stato")"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="true"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@GetStatusIcon(ViewModel.Entity.Status)" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudTextField Value="@GetQualityText(ViewModel.Entity.QualityStatus)"
                                              Label="@TranslationService.GetTranslation("warehouse.qualityStatus", "Stato Qualità")"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="true" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudTextField Value="@ViewModel.Entity.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                              Label="@TranslationService.GetTranslation("common.createdAt", "Creato il")"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="true" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudTextField Value="@(ViewModel.Entity.ModifiedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")"
                                              Label="@TranslationService.GetTranslation("common.modifiedAt", "Modificato il")"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="true" />
                            </MudItem>
                        </MudGrid>
                    </MudTabPanel>
                }

            </MudTabs>
        }
    </ChildContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="ViewModel.IsSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveAsync" Disabled="ViewModel.IsSaving || ViewModel.IsLoading || ViewModel.Entity == null">
            @TranslationService.GetTranslation("common.save", "Salva")
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? EntityId { get; set; }
    [Parameter] public Guid? InitialProductId { get; set; }

    private int _activeTab = 0;
    private DateTime? _productionDateLocal;
    private DateTime? _expiryDateLocal;

    protected override async Task OnInitializedAsync()
    {
        ViewModel.StateChanged += OnViewModelStateChanged;
        try
        {
            if (InitialProductId.HasValue && (EntityId == null || EntityId == Guid.Empty))
            {
                ViewModel.InitialProductId = InitialProductId;
            }
            await ViewModel.LoadEntityAsync(EntityId ?? Guid.Empty);
            _productionDateLocal = ViewModel.Entity?.ProductionDate;
            _expiryDateLocal = ViewModel.Entity?.ExpiryDate;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading lot {LotId}.", EntityId);
            AppNotification.ShowWarning("Si è verificato un errore nel caricamento del lotto.");
        }
    }

    private void OnViewModelStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnProductionDateChanged()
    {
        if (ViewModel.Entity != null)
        {
            ViewModel.Entity.ProductionDate = _productionDateLocal;
            ViewModel.NotifyEntityChanged();
        }
    }

    private void OnExpiryDateChanged()
    {
        if (ViewModel.Entity != null)
        {
            ViewModel.Entity.ExpiryDate = _expiryDateLocal;
            ViewModel.NotifyEntityChanged();
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            var success = await ViewModel.SaveEntityAsync();
            if (success)
                MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving lot {LotId}.", EntityId);
            AppNotification.ShowWarning("Si è verificato un errore nel salvataggio del lotto.");
        }
    }

    private async Task Cancel()
    {
        if (ViewModel.HasUnsavedChanges())
        {
            var result = await DialogService.ShowMessageBoxAsync(
                TranslationService.GetTranslation("common.confirm", "Conferma"),
                TranslationService.GetTranslation("lot.unsavedChanges", "Ci sono modifiche non salvate. Vuoi salvare prima di uscire?"),
                yesText: TranslationService.GetTranslation("common.save", "Salva"),
                noText: TranslationService.GetTranslation("common.discard", "Non salvare"),
                cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
            if (result == null) return;
            if (result == true) { await SaveAsync(); return; }
        }
        MudDialog.Close();
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Blocked" => Color.Error,
        "Expired" => Color.Warning,
        "Recalled" => Color.Error,
        _ => Color.Default
    };

    private string GetStatusIcon(string status) => status switch
    {
        "Active" => Icons.Material.Outlined.CheckCircle,
        "Blocked" => Icons.Material.Outlined.Block,
        "Expired" => Icons.Material.Outlined.EventBusy,
        _ => Icons.Material.Outlined.Circle
    };

    private string GetStatusText(string status) => status switch
    {
        "Active" => TranslationService.GetTranslation("warehouse.active", "Attivo"),
        "Blocked" => TranslationService.GetTranslation("warehouse.blocked", "Bloccato"),
        "Expired" => TranslationService.GetTranslation("warehouse.expired", "Scaduto"),
        "Recalled" => TranslationService.GetTranslation("warehouse.recalled", "Richiamato"),
        "Consumed" => TranslationService.GetTranslation("warehouse.consumed", "Consumato"),
        _ => status
    };

    private Color GetQualityColor(string qualityStatus) => qualityStatus switch
    {
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        "Pending" => Color.Warning,
        "OnHold" => Color.Info,
        _ => Color.Default
    };

    private string GetQualityText(string qualityStatus) => qualityStatus switch
    {
        "Approved" => TranslationService.GetTranslation("warehouse.approved", "Approvato"),
        "Rejected" => TranslationService.GetTranslation("warehouse.rejected", "Rifiutato"),
        "Pending" => TranslationService.GetTranslation("warehouse.pending", "In Attesa"),
        "OnHold" => TranslationService.GetTranslation("warehouse.onHold", "In Sospeso"),
        _ => qualityStatus
    };

    public void Dispose()
    {
        ViewModel.StateChanged -= OnViewModelStateChanged;
    }
}
