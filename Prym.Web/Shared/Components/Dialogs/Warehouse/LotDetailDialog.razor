@using Prym.DTOs.Warehouse
@using Prym.DTOs.Products
@using Prym.Web.Shared.Components.Warehouse
@using Prym.Web.ViewModels
@attribute [Authorize]
@inject LotDetailViewModel ViewModel
@inject ILotService LotService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<LotDetailDialog> Logger
@implements IDisposable

<EFDialog Icon="@Icons.Material.Outlined.QrCode"
          Title="@(ViewModel.IsNewEntity ? TranslationService.GetTranslation("lot.newLot", "Nuovo Lotto") : TranslationService.GetTranslation("lot.detail", "Dettaglio Lotto"))"
          IsProcessing="@(ViewModel.IsLoading || ViewModel.IsSaving)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <TitleActions>
        @if (!ViewModel.IsNewEntity && ViewModel.Entity != null)
        {
            @if (ViewModel.Entity.Status != "Blocked")
            {
                <MudTooltip Text="@TranslationService.GetTranslation("warehouse.block", "Blocca lotto")">
                    <MudIconButton Icon="@Icons.Material.Outlined.Lock"
                                   Color="Color.Warning"
                                   Size="Size.Small"
                                   Disabled="@(ViewModel.IsLoading || ViewModel.IsSaving)"
                                   OnClick="BlockLotAsync" />
                </MudTooltip>
            }
            else
            {
                <MudTooltip Text="@TranslationService.GetTranslation("warehouse.unblock", "Sblocca lotto")">
                    <MudIconButton Icon="@Icons.Material.Outlined.LockOpen"
                                   Color="Color.Success"
                                   Size="Size.Small"
                                   Disabled="@(ViewModel.IsLoading || ViewModel.IsSaving)"
                                   OnClick="UnblockLotAsync" />
                </MudTooltip>
            }
        }
    </TitleActions>
    <ChildContent>
        @if (ViewModel.IsLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (ViewModel.Entity == null)
        {
            <MudAlert Severity="Severity.Error">
                @TranslationService.GetTranslation("lot.notFound", "Lotto non trovato")
            </MudAlert>
        }
        else
        {
            @if (!ViewModel.IsNewEntity)
            {
                <div class="d-flex align-center gap-4 flex-wrap mb-3">
                    <div class="d-flex align-center gap-2">
                        <MudAvatar Color="Color.Primary" Size="Size.Medium">
                            <MudIcon Icon="@Icons.Material.Outlined.QrCode" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body1" Class="fw-semibold">@ViewModel.Entity.Code</MudText>
                            @if (!string.IsNullOrEmpty(ViewModel.Entity.ProductName))
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @TranslationService.GetTranslation("field.product", "Prodotto"): @ViewModel.Entity.ProductName
                                </MudText>
                            }
                        </div>
                    </div>
                    <LotStatusBadge Status="@ViewModel.Entity.Status" Size="Size.Medium" ShowIcon="true" />
                    <QualityStatusBadge Status="@ViewModel.Entity.QualityStatus" Size="Size.Medium" ShowIcon="true" />
                </div>
                <MudDivider Class="mb-3" />
            }

            <MudTabs Position="Position.Left" Rounded="true" Border="true" MinimumTabWidth="160px" PanelClass="pa-4" @bind-ActivePanelIndex="_activeTab">

                <MudTabPanel Text="@TranslationService.GetTranslation("lot.generalInfo", "Informazioni Generali")" Icon="@Icons.Material.Filled.Info">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <PrymTextField @bind-Value="ViewModel.Entity.Code"
                                           Label="@($"{TranslationService.GetTranslation("warehouse.lotCode", "Codice Lotto")} *")"
                                           MaxLength="50"
                                           Required="true"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.QrCode"
                                           ReadOnly="@(!ViewModel.IsNewEntity)"
                                           @bind-Value:after="ViewModel.NotifyEntityChanged"
                                           HelperText="@TranslationService.GetTranslation("lot.codeHelper", "Codice identificativo del lotto")" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudSelect T="Guid"
                                       @bind-Value="ViewModel.Entity.ProductId"
                                       Label="@($"{TranslationService.GetTranslation("field.product", "Prodotto")} *")"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Disabled="@(!ViewModel.IsNewEntity)"
                                       @bind-Value:after="ViewModel.NotifyEntityChanged">
                                @foreach (var product in ViewModel.Products ?? Enumerable.Empty<ProductDto>())
                                {
                                    <MudSelectItem Value="@product.Id">@product.Name (@product.Code)</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudDatePicker @bind-Date="_productionDateLocal"
                                           @bind-Date:after="@OnProductionDateChanged"
                                           Label="@TranslationService.GetTranslation("warehouse.productionDate", "Data Produzione")"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Clearable="true" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudDatePicker @bind-Date="_expiryDateLocal"
                                           @bind-Date:after="@OnExpiryDateChanged"
                                           Label="@TranslationService.GetTranslation("warehouse.expiryDate", "Data Scadenza")"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Clearable="true" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <PrymNumericField T="decimal"
                                              @bind-Value="ViewModel.Entity.OriginalQuantity"
                                              Label="@($"{TranslationService.GetTranslation("warehouse.originalQuantity", "Quantità Originale")} *")"
                                              Min="0"
                                              Format="N4"
                                              ReadOnly="@(!ViewModel.IsNewEntity)"
                                              @bind-Value:after="ViewModel.NotifyEntityChanged" />
                        </MudItem>

                        @if (!ViewModel.IsNewEntity)
                        {
                            <MudItem xs="12" md="6">
                                <PrymNumericField T="decimal"
                                                  @bind-Value="ViewModel.Entity.AvailableQuantity"
                                                  Label="@TranslationService.GetTranslation("warehouse.availableQuantity", "Quantità Disponibile")"
                                                  Min="0"
                                                  Format="N4"
                                                  @bind-Value:after="ViewModel.NotifyEntityChanged" />
                            </MudItem>
                        }

                        <MudItem xs="12" md="6">
                            <PrymTextField @bind-Value="ViewModel.Entity.Barcode"
                                           Label="@TranslationService.GetTranslation("field.barcode", "Barcode")"
                                           MaxLength="50"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.QrCodeScanner"
                                           @bind-Value:after="ViewModel.NotifyEntityChanged" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <PrymTextField @bind-Value="ViewModel.Entity.CountryOfOrigin"
                                           Label="@TranslationService.GetTranslation("warehouse.countryOfOrigin", "Paese di Origine")"
                                           MaxLength="50"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.Public"
                                           @bind-Value:after="ViewModel.NotifyEntityChanged" />
                        </MudItem>

                        <MudItem xs="12">
                            <PrymTextField @bind-Value="ViewModel.Entity.Notes"
                                           Label="@TranslationService.GetTranslation("field.notes", "Note")"
                                           Lines="3"
                                           MaxLength="500"
                                           @bind-Value:after="ViewModel.NotifyEntityChanged" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                @if (!ViewModel.IsNewEntity)
                {
                    <MudTabPanel Text="@TranslationService.GetTranslation("lot.statusQuality", "Stato e Qualità")" Icon="@Icons.Material.Filled.VerifiedUser">
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">
                                    @TranslationService.GetTranslation("warehouse.status", "Stato")
                                </MudText>
                                <LotStatusBadge Status="@ViewModel.Entity.Status" Size="Size.Medium" ShowIcon="true" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">
                                    @TranslationService.GetTranslation("warehouse.qualityStatus", "Stato Qualità")
                                </MudText>
                                <QualityStatusBadge Status="@ViewModel.Entity.QualityStatus" Size="Size.Medium" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudTextField Value="@ViewModel.Entity.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                              Label="@TranslationService.GetTranslation("common.createdAt", "Creato il")"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="true" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudTextField Value="@(ViewModel.Entity.ModifiedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")"
                                              Label="@TranslationService.GetTranslation("common.modifiedAt", "Modificato il")"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="true" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudDivider Class="my-2" />
                                <MudText Typo="Typo.subtitle2" Class="mb-3">
                                    @TranslationService.GetTranslation("lot.changeQuality", "Modifica Stato Qualità")
                                </MudText>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudSelect T="string"
                                           @bind-Value="_pendingQualityStatus"
                                           Label="@TranslationService.GetTranslation("warehouse.newQualityStatus", "Nuovo Stato Qualità")"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Disabled="@(ViewModel.IsLoading || ViewModel.IsSaving)">
                                    <MudSelectItem Value="@("Approved")">@TranslationService.GetTranslation("warehouse.approved", "Approvato")</MudSelectItem>
                                    <MudSelectItem Value="@("Rejected")">@TranslationService.GetTranslation("warehouse.rejected", "Rifiutato")</MudSelectItem>
                                    <MudSelectItem Value="@("Pending")">@TranslationService.GetTranslation("warehouse.pending", "In Attesa")</MudSelectItem>
                                    <MudSelectItem Value="@("OnHold")">@TranslationService.GetTranslation("warehouse.onHold", "In Sospeso")</MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <PrymTextField @bind-Value="_qualityChangeNotes"
                                               Label="@TranslationService.GetTranslation("lot.qualityChangeNotes", "Note (opzionali)")"
                                               MaxLength="500"
                                               Disabled="@(ViewModel.IsLoading || ViewModel.IsSaving)" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.CheckCircle"
                                           Disabled="@(string.IsNullOrEmpty(_pendingQualityStatus) || _pendingQualityStatus == ViewModel.Entity.QualityStatus || ViewModel.IsLoading || ViewModel.IsSaving)"
                                           OnClick="ApplyQualityStatusAsync">
                                    @TranslationService.GetTranslation("lot.applyQuality", "Applica")
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                    </MudTabPanel>

                    <MudTabPanel Text="@TranslationService.GetTranslation("common.history", "Storico")" Icon="@Icons.Material.Filled.History">
                        <StockMovementHistoryTable Items="_history"
                                                  IsLoading="_isLoadingHistory"
                                                  EmptyMessage="@TranslationService.GetTranslation("lot.noHistory", "Nessun movimento registrato per questo lotto")" />
                    </MudTabPanel>
                }

            </MudTabs>
        }
    </ChildContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="ViewModel.IsSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveAsync" Disabled="ViewModel.IsSaving || ViewModel.IsLoading || ViewModel.Entity == null">
            @TranslationService.GetTranslation("common.save", "Salva")
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? EntityId { get; set; }
    [Parameter] public Guid? InitialProductId { get; set; }

    private int _activeTab = 0;
    private DateTime? _productionDateLocal;
    private DateTime? _expiryDateLocal;
    private string _pendingQualityStatus = string.Empty;
    private string? _qualityChangeNotes;
    private bool _isLoadingHistory;
    private IEnumerable<StockMovementDto> _history = Enumerable.Empty<StockMovementDto>();

    protected override async Task OnInitializedAsync()
    {
        ViewModel.StateChanged += OnViewModelStateChanged;
        try
        {
            if (InitialProductId.HasValue && (EntityId == null || EntityId == Guid.Empty))
            {
                ViewModel.InitialProductId = InitialProductId;
            }
            await ViewModel.LoadEntityAsync(EntityId ?? Guid.Empty);
            _productionDateLocal = ViewModel.Entity?.ProductionDate;
            _expiryDateLocal = ViewModel.Entity?.ExpiryDate;
            _pendingQualityStatus = ViewModel.Entity?.QualityStatus ?? string.Empty;
            if (!ViewModel.IsNewEntity)
                await LoadHistoryAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading lot {LotId}.", EntityId);
            AppNotification.ShowWarning("Si è verificato un errore nel caricamento del lotto.");
        }
    }

    private void OnViewModelStateChanged()
    {
        // Re-sync local date pickers whenever the entity is reloaded (e.g. after Block/Unblock)
        if (ViewModel.Entity != null)
        {
            _productionDateLocal = ViewModel.Entity.ProductionDate;
            _expiryDateLocal = ViewModel.Entity.ExpiryDate;
            _pendingQualityStatus = ViewModel.Entity.QualityStatus;
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnProductionDateChanged()
    {
        if (ViewModel.Entity != null)
        {
            ViewModel.Entity.ProductionDate = _productionDateLocal;
            ViewModel.NotifyEntityChanged();
        }
    }

    private void OnExpiryDateChanged()
    {
        if (ViewModel.Entity != null)
        {
            ViewModel.Entity.ExpiryDate = _expiryDateLocal;
            ViewModel.NotifyEntityChanged();
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            var success = await ViewModel.SaveEntityAsync();
            if (success)
                MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving lot {LotId}.", EntityId);
            AppNotification.ShowWarning("Si è verificato un errore nel salvataggio del lotto.");
        }
    }

    private async Task Cancel()
    {
        if (ViewModel.HasUnsavedChanges())
        {
            var result = await DialogService.ShowMessageBoxAsync(
                TranslationService.GetTranslation("common.confirm", "Conferma"),
                TranslationService.GetTranslation("lot.unsavedChanges", "Ci sono modifiche non salvate. Vuoi salvare prima di uscire?"),
                yesText: TranslationService.GetTranslation("common.save", "Salva"),
                noText: TranslationService.GetTranslation("common.discard", "Non salvare"),
                cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
            if (result == null) return;
            if (result == true) { await SaveAsync(); return; }
        }
        MudDialog.Close();
    }

    public void Dispose()
    {
        ViewModel.StateChanged -= OnViewModelStateChanged;
    }

    private async Task ApplyQualityStatusAsync()
    {
        if (ViewModel.Entity == null || string.IsNullOrEmpty(_pendingQualityStatus)) return;
        try
        {
            var result = await LotService.UpdateQualityStatusAsync(ViewModel.Entity.Id, _pendingQualityStatus, _qualityChangeNotes);
            if (result)
            {
                _qualityChangeNotes = null;
                AppNotification.ShowSuccess(TranslationService.GetTranslation("lot.qualityUpdated", "Stato qualità aggiornato"));
                await ViewModel.ReloadEntityAsync();
                await LoadHistoryAsync();
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslation("common.error", "Errore"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating quality status for lot {LotId}.", ViewModel.Entity.Id);
            AppNotification.ShowWarning("Si è verificato un errore nell'aggiornamento dello stato qualità.");
        }
    }

    private async Task BlockLotAsync()
    {
        if (ViewModel.Entity == null) return;
        var parameters = new DialogParameters
        {
            [nameof(LotBlockDialog.LotCode)] = ViewModel.Entity.Code
        };
        var dialog = await DialogService.ShowAsync<LotBlockDialog>(string.Empty, parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = false
        });
        var dialogResult = await dialog.Result;
        if (dialogResult is not { Canceled: false }) return;

        var reason = dialogResult.Data as string;
        if (string.IsNullOrWhiteSpace(reason))
            reason = TranslationService.GetTranslation("warehouse.defaultBlockReason", "Blocco manuale da operatore");

        try
        {
            var result = await LotService.BlockLotAsync(ViewModel.Entity.Id, reason);
            if (result)
            {
                AppNotification.ShowSuccess(TranslationService.GetTranslation("warehouse.lotBlocked", "Lotto bloccato"));
                await ViewModel.ReloadEntityAsync();
                await LoadHistoryAsync();
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslation("common.error", "Errore"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error blocking lot {LotId}.", ViewModel.Entity.Id);
            AppNotification.ShowWarning("Si è verificato un errore nel blocco del lotto.");
        }
    }

    private async Task UnblockLotAsync()
    {
        if (ViewModel.Entity == null) return;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            TranslationService.GetTranslation("common.confirm", "Conferma"),
            TranslationService.GetTranslation("warehouse.confirmUnblock", "Sbloccare il lotto '{0}'?", ViewModel.Entity.Code),
            yesText: TranslationService.GetTranslation("warehouse.unblock", "Sblocca"),
            cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
        if (confirmed != true) return;
        try
        {
            var result = await LotService.UnblockLotAsync(ViewModel.Entity.Id);
            if (result)
            {
                AppNotification.ShowSuccess(TranslationService.GetTranslation("warehouse.lotUnblocked", "Lotto sbloccato"));
                await ViewModel.ReloadEntityAsync();
                await LoadHistoryAsync();
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslation("common.error", "Errore"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error unblocking lot {LotId}.", ViewModel.Entity.Id);
            AppNotification.ShowWarning("Si è verificato un errore nello sblocco del lotto.");
        }
    }

    private async Task LoadHistoryAsync()
    {
        if (ViewModel.Entity == null || ViewModel.IsNewEntity)
        {
            _history = Enumerable.Empty<StockMovementDto>();
            return;
        }

        _isLoadingHistory = true;
        try
        {
            _history = await LotService.GetLotHistoryAsync(ViewModel.Entity.Id) ?? Enumerable.Empty<StockMovementDto>();
        }
        finally
        {
            _isLoadingHistory = false;
        }
    }
}
