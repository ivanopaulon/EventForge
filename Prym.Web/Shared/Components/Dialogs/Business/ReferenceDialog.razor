@inject IEntityManagementService EntityManagementService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject ILogger<ReferenceDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.Person"
          Title="@(_isEditMode
              ? TranslationService.GetTranslation("reference.editTitle", "Modifica Riferimento")
              : TranslationService.GetTranslation("reference.addTitle", "Nuovo Riferimento"))"
          IsProcessing="_isProcessing"
          OnClose="Cancel">
    <ChildContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_firstName"
                                 Label="@($"{TranslationService.GetTranslation("field.firstName", "Nome")} *")"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Required="true"
                                 MaxLength="50" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_lastName"
                                 Label="@($"{TranslationService.GetTranslation("field.lastName", "Cognome")} *")"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Required="true"
                                 MaxLength="50" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_department"
                                 Label="@TranslationService.GetTranslation("field.department", "Dipartimento/Ruolo")"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 MaxLength="50" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_notes"
                                 Label="@TranslationService.GetTranslation("field.notes", "Note")"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Lines="3"
                                 MaxLength="100" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </ChildContent>
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Variant="Variant.Text"
                   Disabled="@_isProcessing">
            @TranslationService.GetTranslation("button.cancel", "Annulla")
        </MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Outlined.Save"
                   OnClick="Submit"
                   Disabled="@(!_isValid || _isProcessing)">
            @if (_isProcessing)
            {
                <MudProgressCircular Class="spinner-18-mr" Size="Size.Small" Indeterminate="true" />
            }
            @TranslationService.GetTranslation("button.save", "Salva")
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] 
    private IMudDialogInstance MudDialog { get; set; } = null!;

    // For Add mode
    [Parameter] 
    public Guid? OwnerId { get; set; }

    [Parameter] 
    public string? OwnerType { get; set; }

    // For Edit mode
    [Parameter] 
    public ReferenceDto? Reference { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _isProcessing;
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private string? _department;
    private string? _notes;
    private bool _isEditMode;

    protected override void OnParametersSet()
    {
        if (Reference != null)
        {
            // Edit mode
            _isEditMode = true;
            _firstName = Reference.FirstName;
            _lastName = Reference.LastName;
            _department = Reference.Department;
            _notes = Reference.Notes;
        }
        else
        {
            // Add mode
            _isEditMode = false;
        }
    }

    private async Task Submit()
    {
        if (!_isValid) return;

        try
        {
            _isProcessing = true;

            if (_isEditMode && Reference != null)
            {
                // Edit mode
                var updateDto = new UpdateReferenceDto
                {
                    FirstName = _firstName,
                    LastName = _lastName,
                    Department = _department,
                    Notes = _notes
                };

                await EntityManagementService.UpdateReferenceAsync(Reference.Id, updateDto);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("messages.updateSuccessful", "Aggiornamento completato con successo"));
            }
            else if (OwnerId.HasValue && !string.IsNullOrEmpty(OwnerType))
            {
                // Add mode
                var createDto = new CreateReferenceDto
                {
                    OwnerId = OwnerId.Value,
                    OwnerType = OwnerType,
                    FirstName = _firstName,
                    LastName = _lastName,
                    Department = _department,
                    Notes = _notes
                };

                await EntityManagementService.CreateReferenceAsync(createDto);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("messages.createSuccessful", "Creazione completata con successo"));
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to {Action} reference", _isEditMode ? "update" : "create");
            var errorMsg = _isEditMode 
                ? TranslationService.GetTranslation("messages.updateFailed", "Errore durante l'aggiornamento")
                : TranslationService.GetTranslation("messages.createFailed", "Errore durante la creazione");
            AppNotification.ShowError(errorMsg);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
