@namespace Prym.Web.Shared.Components
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject ILogger<FloatingProfile> Logger
@implements IDisposable

@if (_isAuthenticated)
{
    @if (!HideFab)
    {
        <!-- Floating Profile Button -->
        <div class="fp-fab">
            <MudFab Color="Color.Secondary"
                    Size="Size.Small"
                    Icon="@Icons.Material.Filled.AccountCircle"
                    OnClick="ToggleDialog"
                    title="@TranslationService.GetTranslation("navigation.profile", "Profilo")"
                    aria-label="@TranslationService.GetTranslation("navigation.profile", "Profilo")" />
        </div>
    }

    @if (_isDialogOpen)
    {
        <MudOverlay Visible="true" DarkBackground="true" OnClick="CloseDialog" ZIndex="1299" />
        <div class="fp-dialog mud-elevation-8">
            <MudList T="string" Clickable="true">
                <MudListItem Class="fp-dialog-header" Clickable="false">
                    <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">
                        @(_currentUser?.FirstName is { Length: > 0 } fn
                            ? fn
                            : _currentUser?.Username ?? TranslationService.GetTranslation("navigation.profile", "Profilo"))
                    </MudText>
                </MudListItem>
                <MudDivider />
                <MudListItem Icon="@Icons.Material.Filled.Person" OnClick="NavigateToProfile">
                    @TranslationService.GetTranslation("navigation.profile", "Profilo")
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.FontDownload" OnClick="OpenFontPreferences">
                    @TranslationService.GetTranslation("fontPreferences.title", "Preferenze Font")
                </MudListItem>
                @if (_currentUser?.Roles?.Contains("SuperAdmin") == true)
                {
                    <MudListItem Icon="@Icons.Material.Outlined.AdminPanelSettings" OnClick="OpenAdminDashboard">
                        @TranslationService.GetTranslation("menu.adminDashboard", "Admin Dashboard")
                    </MudListItem>
                }
                <MudDivider />
                <MudListItem Icon="@Icons.Material.Filled.Logout" OnClick="HandleLogout">
                    @TranslationService.GetTranslation("auth.logout", "Logout")
                </MudListItem>
            </MudList>
        </div>
    }
}

@code {
    [Parameter] public bool HideFab { get; set; }

    public bool IsSuperAdmin => _currentUser?.Roles?.Contains("SuperAdmin") == true;

    private bool _isAuthenticated = false;
    private bool _isDialogOpen = false;
    private UserDto? _currentUser;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            AuthService.OnAuthenticationStateChanged += OnAuthenticationStateChanged;
            await CheckAuthenticationState();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in {MethodName}.", nameof(OnInitializedAsync));
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task CheckAuthenticationState()
    {
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        _currentUser = _isAuthenticated ? await AuthService.GetCurrentUserAsync() : null;
        await InvokeAsync(StateHasChanged);
    }

    private void OnAuthenticationStateChanged()
        => _ = InvokeAsync(CheckAuthenticationState);

    public void ToggleDialog()
    {
        _isDialogOpen = !_isDialogOpen;
    }

    private void CloseDialog()
    {
        _isDialogOpen = false;
    }

    public async Task NavigateToProfile()
    {
        try
        {
            CloseDialog();
            await DialogService.ShowAsync<ProfileDialog>(
                string.Empty,
                EFDialogDefaults.Options);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in {MethodName}.", nameof(NavigateToProfile));
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    public async Task OpenFontPreferences()
    {
        try
        {
            CloseDialog();
            var options = new DialogOptions
            {
                CloseOnEscapeKey = true,
                MaxWidth = MaxWidth.Small,
                FullWidth = true
            };
            await DialogService.ShowAsync<FontPreferencesDialog>(
                TranslationService.GetTranslation("fontPreferences.title", "Preferenze Font"),
                options);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in {MethodName}.", nameof(OpenFontPreferences));
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    public void OpenAdminDashboard()
    {
        CloseDialog();
        NavigationManager.NavigateTo("/Dashboard/Index");
    }

    public async Task HandleLogout()
    {
        CloseDialog();
        try
        {
            await AuthService.LogoutAsync();
            AppNotification.ShowSuccess(TranslationService.GetTranslation("auth.logoutSuccess", "Successfully logged out"));
            // Do not show login overlay after logout — user must request login explicitly
        }
        catch (Exception ex)
        {
            AppNotification.ShowError(TranslationService.GetTranslation("auth.logoutError", "Logout error: {0}", ex.Message));
        }
    }

    private string GetUserInitials()
    {
        if (_currentUser == null) return "?";

        var first = string.IsNullOrWhiteSpace(_currentUser.FirstName) ? null : _currentUser.FirstName!.Trim();
        var last = string.IsNullOrWhiteSpace(_currentUser.LastName) ? null : _currentUser.LastName!.Trim();

        if (string.IsNullOrEmpty(first) && string.IsNullOrEmpty(last))
        {
            var uname = _currentUser.Username ?? string.Empty;
            return !string.IsNullOrEmpty(uname) ? char.ToUpperInvariant(uname[0]).ToString() : "?";
        }

        var fi = !string.IsNullOrEmpty(first) ? char.ToUpperInvariant(first[0]).ToString() : "";
        var li = !string.IsNullOrEmpty(last) ? char.ToUpperInvariant(last[0]).ToString() : "";

        return $"{fi}{li}";
    }

    private string GetAvatarColor()
    {
        var name = _currentUser?.FirstName ?? _currentUser?.Username ?? "U";
        var colors = new[]
        {
            "#1976D2", "#388E3C", "#F57C00", "#7B1FA2",
            "#C62828", "#00838F", "#558B2F", "#6D4C41"
        };
        var idx = Math.Abs(name.GetHashCode()) % colors.Length;
        return colors[idx];
    }

    public void Dispose()
    {
        AuthService.OnAuthenticationStateChanged -= OnAuthenticationStateChanged;
    }
}

<style>
    .fp-fab {
        position: fixed;
        bottom: 64px;
        right: 16px;
        z-index: 1300;
    }

    .fp-dialog {
        position: fixed;
        bottom: 112px;
        right: 16px;
        width: 240px;
        z-index: 1300;
        border-radius: 12px;
        background: var(--mud-palette-surface);
        overflow: hidden;
    }

    .fp-dialog-header {
        pointer-events: none;
    }

    @@media (max-width: 420px) {
        .fp-fab {
            bottom: 64px;
            right: 16px;
        }

        .fp-dialog {
            bottom: 112px;
            right: 16px;
            width: calc(100vw - 32px);
        }
    }
</style>
