@implements IDisposable
@inject IUpdateNotificationService UpdateNotification

@{
    var progress = UpdateNotification.CurrentProgress;
    var visible = UpdateNotification.IsServerMaintenance || progress != null;
}

@if (visible)
{
    @if (!_isHidden)
    {
        <div class="ef-dl-snackbar">
            <div class="ef-dl-snackbar-header">
                <MudIcon Icon="@Icons.Material.Filled.SystemUpdate" Color="Color.Primary" Size="Size.Small" Class="me-1" />
                <MudText Typo="Typo.subtitle2" Class="flex-grow-1 text-truncate">
                    @if (progress?.Component != null)
                    {
                        @($"Aggiornamento: {progress.Component}{(progress.Version != null ? $" v{progress.Version}" : "")}")
                    }
                    else
                    {
                        @("Aggiornamento in corso")
                    }
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small"
                               OnClick="@(() => _isHidden = true)" Title="Nascondi" Class="ms-1" />
            </div>
            <div class="ef-dl-snackbar-body">
                <MudProgressLinear Color="Color.Primary"
                                   Value="@(progress?.PercentComplete ?? 0)"
                                   Max="100"
                                   Indeterminate="@(progress?.PercentComplete == null)"
                                   Rounded="true" Size="Size.Small" Class="mb-1" />
                @if (progress != null)
                {
                    var statParts = new System.Collections.Generic.List<string>();
                    if (progress.FormattedTotal != null)
                        statParts.Add($"{progress.FormattedDownloaded} / {progress.FormattedTotal}");
                    else if (progress.FormattedDownloaded != null)
                        statParts.Add(progress.FormattedDownloaded);
                    if (progress.FormattedSpeed != null) statParts.Add(progress.FormattedSpeed);
                    if (progress.Eta != null) statParts.Add($"ETA {progress.Eta}");
                    if (progress.PercentComplete != null) statParts.Add($"{progress.PercentComplete}%");

                    if (statParts.Count > 0)
                    {
                        <MudText Typo="Typo.caption" Class="ef-dl-snackbar-stats">
                            <span>@TranslatePhase(progress.Phase)</span>
                            <span class="ef-dl-snackbar-sep"> · </span>
                            <span>@string.Join(" · ", statParts)</span>
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Class="ef-dl-snackbar-stats">@TranslatePhase(progress.Phase)</MudText>
                    }
                }
            </div>
        </div>
    }
    else
    {
        <div class="ef-dl-restore-btn">
            <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.SystemUpdate"
                    Size="Size.Small" OnClick="@(() => _isHidden = false)"
                    Title="Mostra progresso aggiornamento" />
        </div>
    }
}

@code {
    private bool _isHidden;

    protected override void OnInitialized()
    {
        UpdateNotification.StateChanged += OnStateChanged;
    }

    private void OnStateChanged()
    {
        // Auto-show when new progress arrives
        if (UpdateNotification.CurrentProgress != null)
            _isHidden = false;
        InvokeAsync(StateHasChanged);
    }

    private static string TranslatePhase(string? phase) => phase switch
    {
        "Downloading"              => "Download in corso",
        "VerifyingChecksum"        => "Verifica integrità",
        "BackingUp"                => "Backup in corso",
        "RunningPreMigrations"     => "Migrazioni pre-deploy",
        "StoppingService"          => "Arresto servizio",
        "DeployingBinaries"        => "Deploy file",
        "StartingService"          => "Avvio servizio",
        "RunningPostMigrations"    => "Migrazioni post-deploy",
        "VerifyingHealth"          => "Verifica salute",
        "Completed"                => "Completato",
        "Rollback"                 => "Ripristino backup",
        "AwaitingMaintenanceWindow"=> "In attesa finestra manutenzione",
        _                          => "Operazione in corso"
    };

    public void Dispose()
    {
        UpdateNotification.StateChanged -= OnStateChanged;
    }
}
