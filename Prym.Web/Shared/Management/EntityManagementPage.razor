@typeparam TEntity where TEntity : class
@using Prym.Web.Extensions
@implements IDisposable
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject IAuthenticationDialogService AuthenticationDialogService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<EntityManagementPage<TEntity>> Logger

<PageLoadingOverlay Visible="@(_isLoading || _isLoadingEntities)"
                     Message="@_loadingMessage"
                     ShowProgressLog="@_showLoadingProgressLog"
                     ProgressMessages="@_loadingProgressMessages"
                     ShowElapsedTime="@_showLoadingElapsed"
                     ProgressValue="@_loadingProgressValue"
                     ProgressIntervalMs="1800" />

@if (!_isLoading)
{
    <div class="@Config.PageRootCssClass ef-flex-col-fill">
        <!-- Page Header -->
        @if (PageHeader != null)
        {
            @PageHeader
        }
        else
        {
            <ManagementPageHeader Title="@TranslationService.GetTranslation(Config.PageTitleKey, Config.PageTitleDefault)"
                                  Icon="@Config.EntityIcon"
                                  BreadcrumbItems="@(BreadcrumbItems ?? Config.BreadcrumbItems)" />
        }

        <div class="eftable-wrapper ef-flex-child-fill">
            <EFTable @ref="_efTable"
                 TItem="TEntity"
                 Items="_filteredEntities"
                 MultiSelection="true"
                 SelectedItems="_selectedEntities"
                 SelectedItemsChanged="_selectedItemsChangedCallback"
                 IsLoading="_isLoadingEntities"
                 ComponentKey="@Config.ComponentKey"
                 InitialColumnConfigurations="Config.Columns"
                 AllowDragDropGrouping="true"
                 ShowExport="@Config.ShowExport"
                 ShowExportDialog="@Config.ShowExport"
                 ExportFormats="@(new List<string> { "Excel" })"
                 ExcelFileName="@Config.ExcelFileName"
                 IsDataFiltered="@HasActiveFilters()"
                 TotalItemsCount="@_entities.Count"
                 Title="@TranslationService.GetTranslation(Config.PageTitleKey, Config.PageTitleDefault)"
                 ShowSearch="true"
                 SearchPlaceholder="@TranslationService.GetTranslation(Config.SearchPlaceholderKey, Config.SearchPlaceholderDefault)"
                 OnSearch="@OnSearchChanged"
                 ShowSelectionBadge="true"
                 ShowRefresh="true"
                 OnRefresh="@LoadEntitiesAsync"
                 ShowCreate="true"
                 OnCreate="@CreateEntity"
                 CreateTooltip="@Config.CreateTooltip"
                 ShowBulkDelete="true"
                 OnBulkDelete="@DeleteSelectedEntities"
                 IsToolbarDisabled="@_isLoadingEntities"
                 FixedHeader="true"
                 Height="100%">
            <AdditionalToolbarContent>
                @if (Config.QuickFilters != null && Config.QuickFilters.Any())
                {
                    <QuickFilters TItem="TEntity"
                                  Items="_entities"
                                  Filters="Config.QuickFilters"
                                  OnFilterSelected="@(async (f) => await HandleQuickFilter(f))"
                                  ShowCount="true"
                                  IsInToolbar="true" />
                }
                @if (AdditionalToolbarContent != null)
                {
                    @AdditionalToolbarContent
                }
            </AdditionalToolbarContent>
            <HeaderContent Context="columnConfigurations">
                @if (HeaderContent != null)
                {
                    @HeaderContent(columnConfigurations)
                }
            </HeaderContent>

            <RowTemplate Context="item">
                @{
                    var visibleCols = _efTable?.ColumnConfigurations?.Where(c => c.IsVisible).OrderBy(c => c.Order).ToList()
                        ?? Config.Columns.Where(c => c.IsVisible).OrderBy(c => c.Order).ToList();
                }
                @if (RowTemplate != null)
                {
                    @RowTemplate((Item: item, Cols: visibleCols))
                }
                <MudTd DataLabel="@TranslationService.GetTranslation("common.actions", "Azioni")" Class="text-center">
                    <ActionButtonGroup EntityName="@Config.GetDisplayName(item)"
                                       ItemDisplayName="@Config.GetDisplayName(item)"
                                       ShowView="@(Config.ShowView && OnViewEntity != null)"
                                       ShowEdit="@Config.ShowEdit"
                                       ShowAuditLog="@Config.ShowAuditLog"
                                       ShowToggleStatus="@Config.ShowToggleStatus"
                                       ShowDelete="@Config.ShowDelete"
                                       IsActive="@(Config.GetIsActive?.Invoke(item) ?? true)"
                                       CanEdit="@(Config.CanEdit == null || Config.CanEdit(item))"
                                       CanDelete="@(Config.CanDelete == null || Config.CanDelete(item))"
                                       OnView="@(async () => { if (OnViewEntity != null) await OnViewEntity(Config.GetId(item)); })"
                                       OnEdit="@(async () => await EditEntity(Config.GetId(item)))"
                                       OnAuditLog="@(() => ViewAuditLog(item))"
                                       OnToggleStatus="@(() => ToggleEntityStatus(item))"
                                       OnDelete="@(() => DeleteEntity(item))" />
                    @if (AdditionalRowActions != null)
                    {
                        @AdditionalRowActions(item)
                    }
                </MudTd>
            </RowTemplate>

            <NoRecordsContent>
                <div class="text-center pa-2 pa-sm-3 pa-md-4">
                    <MudIcon Icon="@Config.EntityIcon" Size="Size.Medium" Class="mb-4 mud-text-secondary" />
                    <MudText Typo="Typo.h6" Class="mb-2">
                        @(_entities.Any() ?
                            TranslationService.GetTranslation("common.noRecordsMatchFilters", "Nessun elemento corrisponde ai filtri applicati") :
                            TranslationService.GetTranslation("common.noRecordsFound", "Nessun elemento trovato"))
                    </MudText>
                    @if (_entities.Any())
                    {
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Outlined.Clear"
                                   OnClick="@(async () => await ClearFilters())">
                            @TranslationService.GetTranslation("common.clearFilters", "Cancella filtri")
                        </MudButton>
                    }
                </div>
            </NoRecordsContent>
            </EFTable>

            @BelowTableContent
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public EntityManagementConfig<TEntity> Config { get; set; } = null!;
    [Parameter, EditorRequired] public IEntityManagementService<TEntity> Service { get; set; } = null!;
    [Parameter] public RenderFragment? PageHeader { get; set; }
    [Parameter] public List<BreadcrumbItem>? BreadcrumbItems { get; set; }
    [Parameter] public RenderFragment<List<EFTableColumnConfiguration>>? HeaderContent { get; set; }
    [Parameter] public RenderFragment<(TEntity Item, List<EFTableColumnConfiguration> Cols)>? RowTemplate { get; set; }
    [Parameter] public RenderFragment? BelowTableContent { get; set; }
    [Parameter] public RenderFragment<TEntity>? AdditionalRowActions { get; set; }
    [Parameter] public RenderFragment? AdditionalToolbarContent { get; set; }

    /// <summary>
    /// Optional extra filter applied on top of quick-filter and search.
    /// Set by consumer pages to filter by additional fields (e.g. document type, status from a select).
    /// The filter is re-evaluated on every render so binding to a parent field works correctly.
    /// </summary>
    [Parameter] public Func<TEntity, bool>? AdditionalFilter { get; set; }

    /// <summary>
    /// When set, replaces the default "navigate to {BaseRoute}/new" behaviour of the Create button.
    /// Use this when the create action should open a dialog instead of navigating to a new page.
    /// </summary>
    [Parameter] public Func<Task>? OnCreateOverride { get; set; }

    /// <summary>
    /// When set, replaces the default "navigate to {BaseRoute}/{id}" behaviour of the Edit button.
    /// Use this when the edit action should open a dialog instead of navigating to a detail page.
    /// </summary>
    [Parameter] public Func<Guid, Task>? OnEditOverride { get; set; }

    /// <summary>
    /// Optional async callback invoked instead of the standard Service.GetPagedAsync call.
    /// Use this for pages that load data from multiple services (e.g. StockOverview).
    /// When provided, the component calls this delegate and expects it to populate data externally.
    /// </summary>
    [Parameter] public Func<Task>? OnCustomLoad { get; set; }

    /// <summary>
    /// Optional async callback invoked after OnInitializedAsync completes successfully.
    /// Use this for post-init logic (e.g. reconciliation calculations in StockOverview).
    /// </summary>
    [Parameter] public Func<Task>? OnAfterInitialized { get; set; }

    /// <summary>
    /// Optional async callback invoked when a QuickFilter is selected.
    /// When provided, it replaces the default client-side filter behavior (useful for server-side filtering).
    /// </summary>
    [Parameter] public Func<QuickFilter<TEntity>?, Task>? OnQuickFilterChanged { get; set; }

    /// <summary>
    /// Optional async callback invoked when filters are cleared.
    /// When provided, it replaces the default ClearFilters behavior.
    /// </summary>
    [Parameter] public Func<Task>? OnClearFilters { get; set; }

    /// <summary>
    /// When true, OnInitializedAsync redirects to EmbeddedRedirectUrl if the page is not embedded.
    /// </summary>
    [Parameter] public bool IsEmbedded { get; set; } = true;

    /// <summary>
    /// URL to redirect to when IsEmbedded is false. Used by pages like StockOverview.
    /// </summary>
    [Parameter] public string? EmbeddedRedirectUrl { get; set; }

    /// <summary>
    /// Exposes the internal EFTable reference for advanced column manipulation from the parent page.
    /// </summary>
    public EFTable<TEntity>? EFTableRef => _efTable;

    // Dialog options for fullscreen audit dialog
    private readonly DialogOptions _auditDialogOptions = new()
    {
        FullScreen = true,
        CloseButton = true,
        MaxWidth = MaxWidth.False
    };

    // UI State Management
    private bool _isLoading = true;
    private bool _isLoadingEntities = false;

    // Dynamic overlay state — updated via SetLoadingMode() before each operation
    private string _loadingMessage = string.Empty;
    private double? _loadingProgressValue = null;
    private bool _showLoadingElapsed = false;
    private bool _showLoadingProgressLog = false;
    private IReadOnlyList<string>? _loadingProgressMessages = null;

    private static readonly IReadOnlyList<string> _loadProgressMessages = new[]
    {
        "Connessione al server...",
        "Lettura dati...",
        "Elaborazione risultati...",
        "Preparazione visualizzazione..."
    };

    private void SetLoadingMode(string message, bool showLog = false,
        IReadOnlyList<string>? progressMessages = null,
        bool showElapsed = false, double? progressValue = null)
    {
        _loadingMessage = message;
        _showLoadingProgressLog = showLog;
        _loadingProgressMessages = progressMessages;
        _showLoadingElapsed = showElapsed;
        _loadingProgressValue = progressValue;
    }

    // CancellationToken for async operations
    private CancellationTokenSource _cts = new();

    // Debounce timer for search (complements EFTable's own debounce)
    private System.Threading.Timer? _searchDebounceTimer;
    private const int SearchDebounceMs = 300;

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        _searchDebounceTimer?.Dispose();
    }

    // Filter and search state
    private string _searchTerm = string.Empty;
    private QuickFilter<TEntity>? _activeQuickFilter;

    // Data collections
    private List<TEntity> _entities = new();
    private HashSet<TEntity> _selectedEntities = new();

    // EFTable reference
    private EFTable<TEntity> _efTable = null!;

    // Initialized once in OnInitialized to avoid recreating the EventCallback on every render
    private EventCallback<HashSet<TEntity>> _selectedItemsChangedCallback;

    // Memoized filtered list — rebuilt by RefreshFilteredEntities() instead of recomputing on every access
    private List<TEntity> _filteredEntities = new();

    private bool FilterEntity(TEntity entity)
    {
        if (AdditionalFilter != null && !AdditionalFilter(entity))
            return false;

        if (_activeQuickFilter?.Predicate != null)
        {
            if (!_activeQuickFilter.Predicate(entity))
                return false;
        }

        if (!entity.MatchesSearchInColumns(
            _searchTerm,
            Config.Columns.Where(c => c.IsSearchable).Select(c => c.PropertyName)))
            return false;

        return true;
    }

    private void RefreshFilteredEntities()
    {
        _filteredEntities = _entities.Where(FilterEntity).ToList();
    }

    private async Task HandleQuickFilter(QuickFilter<TEntity>? filter)
    {
        try
        {
            _activeQuickFilter = filter;
            if (OnQuickFilterChanged != null)
                await OnQuickFilterChanged(filter);
            else
                RefreshFilteredEntities();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in {MethodName}.", nameof(HandleQuickFilter));
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private void OnSelectedItemsChanged(HashSet<TEntity> items)
    {
        _selectedEntities = items;
        // StateHasChanged not needed: Blazor calls it automatically after EventCallback
    }

    /// <summary>
    /// Optional callback invoked when the user clicks the View button on an entity row.
    /// When null, the View button is hidden. Replaces the TODO ViewEntity stub.
    /// </summary>
    [Parameter] public Func<Guid, Task>? OnViewEntity { get; set; }

    protected override void OnInitialized()
    {
        _selectedItemsChangedCallback = EventCallback.Factory.Create<HashSet<TEntity>>(this, OnSelectedItemsChanged);
        SetLoadingMode(TranslationService.GetTranslation("messages.loadingPage", "Caricamento pagina..."));
    }

    protected override void OnParametersSet()
    {
        // Re-filter whenever a parameter changes (e.g. AdditionalFilter updated by a parent page).
        // Skip during the initial load phase to avoid redundant work before data is loaded.
        if (!_isLoading)
            RefreshFilteredEntities();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (!IsEmbedded && !string.IsNullOrWhiteSpace(EmbeddedRedirectUrl))
            {
                NavigationManager.NavigateTo(EmbeddedRedirectUrl);
                return;
            }

            var isAuthenticated = await AuthService.IsAuthenticatedAsync();
            if (!isAuthenticated)
            {
                await ShowLoginDialogAsync();
                return;
            }
            await LoadEntitiesAsync();

            if (OnAfterInitialized != null)
                await OnAfterInitialized();
        }
        catch (Exception ex)
        {
            var msg = TranslationService.GetTranslation(Config.LoadErrorMessageKey,
                "Errore nel caricamento della pagina: {0}", ex.Message);
            AppNotification.ShowError(msg, exception: ex);
            Logger.LogError(ex, "Error loading {EntityType} page", Config.EntityTypeName);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadEntitiesAsync()
    {
        try
        {
            SetLoadingMode(
                TranslationService.GetTranslation("common.loading", "Caricamento..."),
                showLog: true,
                progressMessages: _loadProgressMessages,
                showElapsed: true
            );
            _isLoadingEntities = true;
            StateHasChanged();

            if (OnCustomLoad != null)
            {
                await OnCustomLoad();
            }
            else if (Config.UseServerSidePaging)
            {
                var result = await Service.GetPagedAsync(
                    1,
                    Config.DefaultPageSize,
                    _searchTerm,
                    null,
                    _cts.Token);
                if (result != null)
                    _entities = result.Items.ToList();
            }
            else
            {
                var result = await Service.GetPagedAsync(1, int.MaxValue, ct: _cts.Token);
                if (result != null)
                    _entities = result.Items.ToList();
            }
        }
        catch (OperationCanceledException) { /* navigation away, ignore */ }
        catch (Exception ex)
        {
            var msg = TranslationService.GetTranslation(Config.LoadErrorMessageKey,
                "Errore nel caricamento: {0}", ex.Message);
            AppNotification.ShowError(msg, exception: ex);
            Logger.LogError(ex, "Error loading {EntityType} list", Config.EntityTypeName);
        }
        finally
        {
            RefreshFilteredEntities();
            _isLoadingEntities = false;
            StateHasChanged();
        }
    }

    private async Task CreateEntity()
    {
        try
        {
            if (OnCreateOverride != null)
            {
                await OnCreateOverride.Invoke();
            }
            else
            {
                NavigationManager.NavigateTo($"{Config.BaseRoute}/new");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in {MethodName}.", nameof(CreateEntity));
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    /// <summary>
    /// Forces a reload of the entity list. Call via <c>@ref</c> after custom row actions
    /// (e.g. Block/Unblock, Ship, Receive) that mutate entity state on the server.
    /// </summary>
    public async Task RefreshAsync() => await LoadEntitiesAsync();

    /// <summary>
    /// Returns a read-only view of the currently selected entities in the table.
    /// Can be used by parent pages to implement bulk actions on selected items.
    /// </summary>
    public IReadOnlyCollection<TEntity> SelectedItems => _selectedEntities;

    private async Task EditEntity(Guid id)
    {
        try
        {
            if (OnEditOverride != null)
                await OnEditOverride(id);
            else
                NavigationManager.NavigateTo($"{Config.BaseRoute}/{id}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in {MethodName}.", nameof(EditEntity));
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task DeleteEntity(TEntity entity)
    {
        if (Config.CanDelete != null && !Config.CanDelete(entity))
        {
            AppNotification.ShowWarning(TranslationService.GetTranslation(Config.CannotDeleteMessageKey,
                "Impossibile eliminare questo elemento"));
            return;
        }

        var displayName = Config.GetDisplayName(entity);
        var confirmTitle = TranslationService.GetTranslation("common.confirm", "Conferma");
        var confirmMessage = TranslationService.GetTranslation(Config.DeleteConfirmMessageKey,
            "Sei sicuro di voler eliminare '{0}'? Questa azione non può essere annullata.", displayName);

        var confirm = await DialogService.ShowMessageBoxAsync(
            confirmTitle,
            confirmMessage,
            yesText: TranslationService.GetTranslation("common.delete", "Elimina"),
            cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));

        if (confirm == true)
        {
            try
            {
                await Service.DeleteAsync(Config.GetId(entity));
                var id = Config.GetId(entity);
                var existing = _entities.FirstOrDefault(e => Config.GetId(e) == id);
                if (existing != null) _entities.Remove(existing);
                RefreshFilteredEntities();
                AppNotification.ShowSuccess(TranslationService.GetTranslation(Config.DeleteSuccessMessageKey,
                    "Elemento eliminato con successo!"));
                StateHasChanged();
            }
            catch (Exception ex)
            {
                var msg = TranslationService.GetTranslation(Config.DeleteErrorMessageKey,
                    "Errore nell'eliminazione: {0}", ex.Message);
                AppNotification.ShowError(msg, exception: ex);
                Logger.LogError(ex, "Error deleting {EntityType} {Id}", Config.EntityTypeName, Config.GetId(entity));
            }
        }
    }

    private async Task DeleteSelectedEntities()
    {
        if (_selectedEntities.Count == 0)
            return;

        var deletableEntities = Config.CanDelete != null
            ? _selectedEntities.Where(e => Config.CanDelete(e)).ToList()
            : _selectedEntities.ToList();

        if (deletableEntities.Count == 0)
        {
            AppNotification.ShowWarning(TranslationService.GetTranslation(Config.CannotDeleteMessageKey,
                "Impossibile eliminare gli elementi selezionati"));
            return;
        }

        var skippedCount = _selectedEntities.Count - deletableEntities.Count;
        var confirmTitle = TranslationService.GetTranslation("common.confirm", "Conferma");
        var confirmMessage = TranslationService.GetTranslationFormatted(Config.BulkDeleteConfirmMessageKey,
            "Sei sicuro di voler eliminare {0} elementi selezionati? Questa azione non può essere annullata.",
            deletableEntities.Count);

        var confirm = await DialogService.ShowMessageBoxAsync(
            confirmTitle,
            confirmMessage,
            yesText: TranslationService.GetTranslation("common.delete", "Elimina"),
            cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));

        if (confirm == true)
        {
            var deletedCount = 0;
            var failedCount = 0;
            var needsFullReload = false;
            var total = deletableEntities.Count;
            var done = 0;

            try
            {
                SetLoadingMode(
                    TranslationService.GetTranslationFormatted("common.deletingItems", "Eliminazione {0} di {1}...", 0, total),
                    showElapsed: true,
                    progressValue: 0
                );
                _isLoadingEntities = true;
                StateHasChanged();

                foreach (var entity in deletableEntities)
                {
                    try
                    {
                        var id = Config.GetId(entity);
                        await Service.DeleteAsync(id, _cts.Token);
                        _entities.RemoveAll(e => Config.GetId(e) == id);
                        deletedCount++;
                        RefreshFilteredEntities();
                    }
                    catch (Exception ex)
                    {
                        failedCount++;
                        needsFullReload = true;
                        Logger.LogError(ex, "Error deleting {EntityType} {Id}", Config.EntityTypeName, Config.GetId(entity));
                    }
                    finally
                    {
                        done++;
                        _loadingProgressValue = total > 0 ? (double)done / total * 100.0 : 0;
                        _loadingMessage = TranslationService.GetTranslationFormatted("common.deletingItems", "Eliminazione {0} di {1}...", done, total);
                        StateHasChanged();
                    }
                }

                if (failedCount == 0 && skippedCount == 0)
                {
                    AppNotification.ShowSuccess(TranslationService.GetTranslationFormatted(Config.BulkDeleteSuccessMessageKey,
                        "{0} elementi eliminati con successo!", deletedCount));
                }
                else if (skippedCount > 0 && failedCount == 0)
                {
                    AppNotification.ShowWarning(TranslationService.GetTranslationFormatted("common.bulkDeletePartialSkipped",
                        "{0} elementi eliminati, {1} non eliminabili ignorati", deletedCount, skippedCount));
                }
                else
                {
                    AppNotification.ShowWarning(TranslationService.GetTranslationFormatted("common.bulkDeletePartial",
                        "{0} elementi eliminati, {1} falliti", deletedCount, failedCount));
                }
            }
            catch (Exception ex)
            {
                var msg = TranslationService.GetTranslationFormatted(Config.DeleteErrorMessageKey,
                    "Errore nell'eliminazione: {0}", ex.Message);
                AppNotification.ShowError(msg, exception: ex);
                Logger.LogError(ex, "Error deleting selected {EntityType} items", Config.EntityTypeName);
                needsFullReload = true;
            }
            finally
            {
                _isLoadingEntities = false;
                _selectedEntities.Clear();

                if (needsFullReload)
                {
                    // Re-align local list with server after partial failures
                    await LoadEntitiesAsync();
                }
                else
                {
                    StateHasChanged();
                }
            }
        }
    }

    private async Task ToggleEntityStatus(TEntity entity)
    {
        var isActive = Config.GetIsActive?.Invoke(entity) ?? true;
        var actionText = isActive
            ? TranslationService.GetTranslation("common.deactivate", "disattivare")
            : TranslationService.GetTranslation("common.activate", "attivare");

        var confirmTitle = TranslationService.GetTranslation("common.confirm", "Conferma");
        var confirmMessage = TranslationService.GetTranslationFormatted("common.confirmStatusChange",
            "Sei sicuro di voler {0} '{1}'?", actionText, Config.GetDisplayName(entity));

        var confirm = await DialogService.ShowMessageBoxAsync(
            confirmTitle,
            confirmMessage,
            yesText: TranslationService.GetTranslation("common.confirm", "Conferma"),
            cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));

        if (confirm == true)
        {
            try
            {
                SetLoadingMode(
                    TranslationService.GetTranslation("common.updatingStatus", "Aggiornamento stato..."),
                    progressValue: null
                );
                _isLoadingEntities = true;
                StateHasChanged();
                await Service.ToggleStatusAsync(Config.GetId(entity), !isActive, _cts.Token);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("common.statusChangeSuccess",
                    "Stato aggiornato con successo"));
                // Reload to reflect the updated status from the server
                await LoadEntitiesAsync();
            }
            catch (Exception ex)
            {
                var msg = TranslationService.GetTranslation("common.statusChangeError",
                    "Errore nel cambio di stato: {0}", ex.Message);
                AppNotification.ShowError(msg, exception: ex);
                Logger.LogError(ex, "Error toggling {EntityType} status {Id}", Config.EntityTypeName, Config.GetId(entity));
                // Force reload to re-align local list with server after error
                await LoadEntitiesAsync();
            }
            finally
            {
                _isLoadingEntities = false;
                StateHasChanged();
            }
        }
    }

    private async Task ViewAuditLog(TEntity entity)
    {
        try
        {
            var parameters = new DialogParameters<AuditHistoryDialog>
            {
                { x => x.EntityType, Config.EntityTypeName },
                { x => x.EntityId, Config.GetId(entity) },
                { x => x.EntityName, Config.GetDisplayName(entity) }
            };

            await DialogService.ShowAsync<AuditHistoryDialog>(
                TranslationService.GetTranslation("audit.historyDialog.title", "Cronologia Modifiche"),
                parameters,
                _auditDialogOptions);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in {MethodName}.", nameof(ViewAuditLog));
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private void OnSearchChanged(string term)
    {
        _searchTerm = term;
        _searchDebounceTimer?.Dispose();
        _searchDebounceTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                RefreshFilteredEntities();
                StateHasChanged();
            });
        }, null, SearchDebounceMs, Timeout.Infinite);
    }

    private async Task ClearFilters()
    {
        try
        {
            _searchTerm = string.Empty;
            _activeQuickFilter = null;
            if (OnClearFilters != null)
                await OnClearFilters();
            else
            {
                RefreshFilteredEntities();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in {MethodName}.", nameof(ClearFilters));
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private bool HasActiveFilters()
    {
        return !string.IsNullOrWhiteSpace(_searchTerm) || _activeQuickFilter != null;
    }

    private async Task ShowLoginDialogAsync()
    {
        var result = await AuthenticationDialogService.ShowLoginDialogAsync();
        if (result)
        {
            await OnInitializedAsync();
        }
    }
}
