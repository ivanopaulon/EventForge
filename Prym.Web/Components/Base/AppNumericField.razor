@typeparam T where T : struct

<MudNumericField T="T"
                 @ref="_numericField"
                 Value="Value"
                 ValueChanged="ValueChanged"
                 For="For"
                 Label="@Label"
                 Placeholder="@Placeholder"
                 Variant="Variant.Outlined"
                 Margin="Margin.Dense"
                 HideSpinButtons="true"
                 Immediate="Immediate"
                 Required="Required"
                 RequiredError="@RequiredError"
                 Format="@Format"
                 ReadOnly="ReadOnly"
                 Disabled="Disabled"
                 HelperText="@HelperText"
                 Class="@Class"
                 Style="@Style"
                 @attributes="AllAttrs" />

@code {
    private MudNumericField<T>? _numericField;

    [Parameter] public T                             Value                { get; set; } = default;
    [Parameter] public EventCallback<T>              ValueChanged         { get; set; }
    [Parameter] public Expression<Func<T>>?          For                  { get; set; }
    [Parameter] public string?                       Label                { get; set; }
    [Parameter] public string?                       Placeholder          { get; set; }
    [Parameter] public T?                            Min                  { get; set; }
    [Parameter] public T?                            Max                  { get; set; }
    [Parameter] public T?                            Step                 { get; set; }
    [Parameter] public string?                       Format               { get; set; }
    [Parameter] public bool                          Immediate            { get; set; } = false;
    [Parameter] public bool                          Required             { get; set; } = false;
    [Parameter] public string?                       RequiredError        { get; set; }
    [Parameter] public bool                          ReadOnly             { get; set; } = false;
    [Parameter] public bool                          Disabled             { get; set; } = false;
    [Parameter] public string?                       HelperText           { get; set; }
    [Parameter] public string?                       Class                { get; set; }
    [Parameter] public string?                       Style                { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>?      AdditionalAttributes { get; set; }

    public ValueTask FocusAsync() => _numericField?.FocusAsync() ?? ValueTask.CompletedTask;

    private Dictionary<string, object?> AllAttrs
    {
        get
        {
            var attributes = new Dictionary<string, object?>();
            if (Min.HasValue) attributes["Min"] = Min.Value;
            if (Max.HasValue) attributes["Max"] = Max.Value;
            if (Step.HasValue) attributes["Step"] = Step.Value;
            if (AdditionalAttributes is not null)
            {
                foreach (var attribute in AdditionalAttributes)
                    attributes[attribute.Key] = attribute.Value;
            }

            return attributes;
        }
    }
}
