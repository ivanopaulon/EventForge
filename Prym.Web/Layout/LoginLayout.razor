@inherits LayoutComponentBase
@using Prym.Web.Constants
@inject IThemeService ThemeService
@inject ITranslationService TranslationService
@inject ILogger<LoginLayout> Logger
@implements IDisposable

<MudLayout Class="align-content-center login-container">
    @Body
</MudLayout>

<HealthFooter />

@code {
    protected override async Task OnInitializedAsync()
    {
        ThemeService.OnThemeChanged += OnThemeChanged;
        TranslationService.LanguageChanged += OnLanguageChanged;
        try
        {
            await ThemeService.InitializeAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing theme in LoginLayout");
        }
    }

    private void OnThemeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLanguageChanged(object? sender, string newLanguage)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeChanged;
        TranslationService.LanguageChanged -= OnLanguageChanged;
    }
}