@using EventForge.DTOs.External.WhatsApp
@using EventForge.Client.Services.WhatsApp
@inject IWhatsAppClientService WhatsAppClientService
@inject IAppNotificationService AppNotification
@inject ILogger<WhatsAppConfigDialog> Logger

<EFDialog Title="Configurazione WhatsApp Business"
          Icon="@Icons.Custom.Brands.WhatsApp"
          MinWidth="min(560px, 95vw)"
          IsProcessing="@_isProcessing"
          OnClose="@HandleClose">
    <ChildContent>
        <div class="pa-4">
            @if (_loadError != null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
            }

            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-3">
                Credenziali Meta Business Cloud API
            </MudText>

            <MudStack Spacing="3">
                <!-- Enable toggle -->
                <MudSwitch @bind-Value="_config.IsEnabled"
                           Label="Integrazione WhatsApp abilitata"
                           Color="Color.Success"
                           Disabled="@_isProcessing" />

                <!-- Phone Number ID -->
                <MudTextField T="string"
                              @bind-Value="_config.PhoneNumberId"
                              Label="Phone Number ID"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Disabled="@_isProcessing"
                              HelperText="ID numerico del numero di telefono Business nella dashboard Meta"
                              Required="true"
                              Counter="30" />

                <!-- Access Token -->
                <MudTextField T="string"
                              @bind-Value="_config.AccessToken"
                              Label="Access Token"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              InputType="@(_showToken ? InputType.Text : InputType.Password)"
                              Disabled="@_isProcessing"
                              HelperText="Token permanente (System User) dell'account WhatsApp Business"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showToken ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                              OnAdornmentClick="@(() => _showToken = !_showToken)" />

                <!-- Verify Token -->
                <MudTextField T="string"
                              @bind-Value="_config.VerifyToken"
                              Label="Verify Token"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Disabled="@_isProcessing"
                              HelperText="Token di verifica webhook configurato nel portale Meta" />

                <!-- API Version -->
                <MudTextField T="string"
                              @bind-Value="_config.ApiVersion"
                              Label="API Version"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Disabled="@_isProcessing"
                              HelperText="Versione Meta Graph API (es. v19.0)" />
            </MudStack>

            <!-- Test result banner -->
            @if (_testResult != null)
            {
                <MudAlert Severity="@(_testSuccess ? Severity.Success : Severity.Warning)"
                          Class="mt-4"
                          Dense="true">
                    @_testResult
                </MudAlert>
            }
        </div>
    </ChildContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.NetworkCheck"
                   OnClick="@TestConnection"
                   Disabled="@_isProcessing"
                   Color="Color.Info">
            Testa connessione
        </MudButton>
        <MudSpacer />
        <MudButton Variant="Variant.Text"
                   OnClick="@HandleClose"
                   Disabled="@_isProcessing">
            Annulla
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="@SaveConfig"
                   Disabled="@_isProcessing">
            Salva
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }

    private WhatsAppConfigDto _config = new();
    private bool _isProcessing;
    private bool _showToken;
    private string? _loadError;
    private string? _testResult;
    private bool _testSuccess;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isProcessing = true;
            var loaded = await WhatsAppClientService.GetConfigAsync();
            if (loaded != null) _config = loaded;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading WhatsApp config");
            _loadError = "Impossibile caricare la configurazione. Riprova.";
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task SaveConfig()
    {
        try
        {
            _isProcessing = true;
            _testResult = null;
            await WhatsAppClientService.SaveConfigAsync(_config);
            AppNotification.ShowSuccess("Configurazione WhatsApp salvata con successo.");
            MudDialog?.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving WhatsApp config");
            AppNotification.ShowError("Errore durante il salvataggio della configurazione.");
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task TestConnection()
    {
        try
        {
            _isProcessing = true;
            _testResult = null;
            var (success, message) = await WhatsAppClientService.TestConnectionAsync();
            _testSuccess = success;
            _testResult = message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error testing WhatsApp connection");
            _testSuccess = false;
            _testResult = $"Errore durante il test: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void HandleClose()
    {
        MudDialog?.Cancel();
    }
}
