    // Messaging
    // ────────────────────────────────────────────────────────────────────────

    private async Task SendMessageAsync(SendMessageDto messageDto)
    {
        if (string.IsNullOrWhiteSpace(messageDto.Content) || _selectedChat == null) return;

        _isSendingMessage = true;
        StateHasChanged();
        try
        {
            messageDto.SenderId = _currentUserId;
            messageDto.ChatId   = _selectedChat.Id;
            var sent = await ChatService.SendMessageAsync(messageDto);
            _messages.Add(sent);
            _messageIds.Add(sent.Id);
            _selectedChat.LastMessage = sent;
            _selectedChat.UpdatedAt   = sent.SentAt;
            _replyToMessage           = null;
            _pendingAttachments.Clear();
            await ScrollToBottomAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error sending message");
            AppNotification.ShowError($"Errore nell'invio: {ex.Message}");
        }
        finally
        {
            _isSendingMessage = false;
            StateHasChanged();
        }
    }

    private async Task HandleAttachFilesAsync(IReadOnlyList<IBrowserFile> files)
    {
        if (_selectedChat == null || files.Count == 0) return;
        _isSendingMessage = true;
        StateHasChanged();
        try
        {
            foreach (var file in files)
            {
                var attachment = await ChatService.UploadFileAsync(_selectedChat.Id, file);
                if (attachment != null)
                    _pendingAttachments.Add(attachment);
                else
                    AppNotification.ShowWarning($"Impossibile caricare il file '{file.Name}'.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error uploading file(s) to chat {ChatId}", _selectedChat.Id);
            AppNotification.ShowError($"Errore nel caricamento del file: {ex.Message}");
        }
        finally
        {
            _isSendingMessage = false;
            StateHasChanged();
        }
    }

    private void SetReplyToMessage(ChatMessageDto m) { _replyToMessage = m; StateHasChanged(); }
    private void CancelReply()                        { _replyToMessage = null; StateHasChanged(); }
    private void RemoveAttachment(MessageAttachmentDto a) { _pendingAttachments.Remove(a); StateHasChanged(); }

    private async Task ToggleMessageReaction(Guid messageId, string emoji)
    {
        try
        {
            await ChatService.ToggleMessageReactionAsync(new MessageReactionActionDto
            {
                MessageId = messageId,
                UserId    = _currentUserId,
                Emoji     = emoji,
                IsAdding  = true
            });
            var msg = _messages.FirstOrDefault(m => m.Id == messageId);
            if (msg?.Reactions is null) return;
            var ex = msg.Reactions.FirstOrDefault(r => r.Emoji == emoji);
            if (ex is not null)
            {
                if (ex.HasCurrentUserReacted) { ex.Count--; ex.UserIds.Remove(_currentUserId); ex.HasCurrentUserReacted = false; if (ex.Count == 0) msg.Reactions.Remove(ex); }
                else                          { ex.Count++; ex.UserIds.Add(_currentUserId);    ex.HasCurrentUserReacted = true; }
            }
            else
            {
                msg.Reactions.Add(new MessageReactionDto { Emoji = emoji, Count = 1, UserIds = [_currentUserId], HasCurrentUserReacted = true });
            }
            StateHasChanged();
        }
        catch (Exception ex) { AppNotification.ShowError($"Errore reazione: {ex.Message}"); }
    }

