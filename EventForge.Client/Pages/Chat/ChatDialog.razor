    private List<ChatResponseDto> GetFilteredChats()
    {
        var list = _chatFilter switch
        {
            "internal" => _chatList.Where(c => c.Type != ChatType.WhatsApp),
            "whatsapp" => _chatList.Where(c => c.Type == ChatType.WhatsApp),
            _          => _chatList.AsEnumerable()
        };
        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var q = _searchText.Trim();
            list = list.Where(c =>
                GetChatName(c).Contains(q, StringComparison.OrdinalIgnoreCase) ||
                (c.ExternalPhoneNumber?.Contains(q, StringComparison.OrdinalIgnoreCase) == true) ||
                (c.BusinessPartyName?.Contains(q, StringComparison.OrdinalIgnoreCase) == true));
        }
        return list.ToList();
    }

    private static string GetChatName(ChatResponseDto? chat, Guid currentUserId = default)
    {
        if (chat is null) return string.Empty;
        if (chat.Type == ChatType.DirectMessage)
        {
            var other = chat.Members?.FirstOrDefault(m => m.UserId != currentUserId);
            return other?.DisplayName ?? chat.Name ?? $"Chat {chat.Id.ToString()[..8]}";
        }
        return chat.Name ?? $"Chat {chat.Id.ToString()[..8]}";
    }

    private string GetChatName(ChatResponseDto? chat) => GetChatName(chat, _currentUserId);

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return (parts.Length >= 2 ? $"{parts[0][0]}{parts[1][0]}" : name[..Math.Min(2, name.Length)]).ToUpper();
    }

    private static readonly string[] _avatarColors =
        ["#f44336","#e91e63","#9c27b0","#673ab7","#3f51b5","#2196f3","#009688","#4caf50"];

    private static string GetAvatarColor(string name)
    {
        if (string.IsNullOrEmpty(name)) return _avatarColors[0];
        unchecked { var h = name.Aggregate(0, (a, c) => a * 31 + c); return _avatarColors[((h % _avatarColors.Length) + _avatarColors.Length) % _avatarColors.Length]; }
    }

