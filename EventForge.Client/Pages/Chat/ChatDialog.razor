@using EventForge.DTOs.Chat
@using EventForge.Client.Services.WhatsApp
@using EventForge.Client.Models.Messaging
@using EventForge.Client.Shared.Helpers
@using Microsoft.AspNetCore.Components.Forms
@inject IAuthService AuthService
@inject IChatService ChatService
@inject IRealtimeService RealtimeService
@inject IWhatsAppClientService WhatsAppClientService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject IJSRuntime JSRuntime
@inject ILogger<ChatDialog> Logger
@implements IDisposable

@* Open with: new DialogOptions { BackdropClick = false, CloseButton = false } *@
<EFDialog Icon="@Icons.Material.Filled.Chat"
          Title="@TranslationService.GetTranslation("chat.title", "Chat")"
          IsProcessing="@_isLoadingChats"
          MinWidth="min(1200px, 96vw)"
          Height="calc(100dvh - 48px)"
          OnClose="@HandleClose">
    <ChildContent>
        <div class="chat-dlg-layout">

            @* ═══════════════ LEFT SIDEBAR ═══════════════ *@
            <div class="chat-dlg-sidebar @(_sidebarVisible ? "" : "chat-dlg-sidebar--hidden")">

                @* Sidebar header: title / unread / WhatsApp config / collapse button *@
                <div class="chat-dlg-sidebar-header">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.subtitle1" Class="chat-dlg-sidebar-title">
                            @TranslationService.GetTranslation("chat.conversations", "Conversazioni")
                        </MudText>
                        @if (_totalUnread > 0)
                        {
                            <MudBadge Content="@_totalUnread.ToString()" Color="Color.Error" />
                        }
                    </div>
                    <div class="d-flex align-center gap-1">
                        <AuthorizeViewRoles Roles="Admin,SuperAdmin">
                            <MudTooltip Text="@TranslationService.GetTranslation("chat.settings", "Impostazioni Chat")" Placement="Placement.Bottom">
                                <MudIconButton Icon="@Icons.Material.Filled.Settings"
                                               Size="Size.Small"
                                               Color="Color.Inherit"
                                               OnClick="@OpenChatSettingsAsync" />
                            </MudTooltip>
                        </AuthorizeViewRoles>
                        <MudTooltip Text="@TranslationService.GetTranslation("chat.hideSidebar", "Nascondi")" Placement="Placement.Bottom">
                            <MudIconButton Icon="@Icons.Material.Filled.MenuOpen"
                                           Size="Size.Small"
                                           Color="Color.Inherit"
                                           OnClick="@(() => _sidebarVisible = false)" />
                        </MudTooltip>
                    </div>
                </div>

                @* Search *@
                <div class="chat-dlg-search-wrap">
                    <MudTextField T="string"
                                  @bind-Value="_searchText"
                                  Label="@TranslationService.GetTranslation("chat.search", "Cerca chat...")"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  FullWidth="true"
                                  Immediate="true"
                                  Class="messaging-search-field" />
                </div>

                @* Filter tabs: All / Internal / WhatsApp *@
                <div class="chat-dlg-filter-row">
                    <MudChip T="string"
                             Variant="@(_chatFilter == "all" ? Variant.Filled : Variant.Outlined)"
                             Color="@(_chatFilter == "all" ? Color.Primary : Color.Default)"
                             Size="Size.Small"
                             OnClick="@(() => SetChatFilter("all"))">
                        @TranslationService.GetTranslation("chat.allChats", "Tutte")
                    </MudChip>
                    <MudChip T="string"
                             Variant="@(_chatFilter == "internal" ? Variant.Filled : Variant.Outlined)"
                             Color="@(_chatFilter == "internal" ? Color.Primary : Color.Default)"
                             Size="Size.Small"
                             Icon="@Icons.Material.Filled.People"
                             OnClick="@(() => SetChatFilter("internal"))">
                        @TranslationService.GetTranslation("chat.internalMessages", "Interni")
                    </MudChip>
                    <MudChip T="string"
                             Variant="@(_chatFilter == "whatsapp" ? Variant.Filled : Variant.Outlined)"
                             Color="@(_chatFilter == "whatsapp" ? Color.Success : Color.Default)"
                             Size="Size.Small"
                             Icon="@Icons.Custom.Brands.WhatsApp"
                             OnClick="@(() => SetChatFilter("whatsapp"))">
                        WhatsApp
                    </MudChip>
                </div>

                <MudDivider />

                @* Conversation list *@
                <div class="chat-dlg-conv-list">
                    @if (_isLoadingChats)
                    {
                        <div class="d-flex justify-center pa-6">
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                        </div>
                    }
                    else
                    {
                        var visibleChats = GetFilteredChats();
                        @if (visibleChats.Count == 0)
                        {
                            <div class="d-flex flex-column align-center justify-center pa-6 gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline"
                                         Size="Size.Large"
                                         Style="opacity:.3;" />
                                <MudText Typo="Typo.body2" Color="Color.Tertiary">
                                    @TranslationService.GetTranslation("chat.noChats", "Nessuna chat disponibile")
                                </MudText>
                            </div>
                        }
                        else
                        {
                            <MudList T="object" Dense="true" Clickable="true" Padding="false">
                                @foreach (var chat in visibleChats)
                                {
                                    var isSelected = chat.Id == _selectedChatId;
                                    var chatName   = GetChatName(chat);
                                    var isWa       = chat.Type == ChatType.WhatsApp;
                                    var otherOnline = chat.Type == ChatType.DirectMessage
                                                      && chat.Members.FirstOrDefault(m => m.UserId != _currentUserId)?.IsOnline == true;

                                    <MudListItem T="object"
                                                 OnClick="@(() => SelectChatAsync(chat))"
                                                 Class="@($"conversation-item{(isSelected ? " conversation-item--active" : "")}")">
                                        <div class="d-flex align-center w-100 gap-3">

                                            @* Avatar + presence dot *@
                                            <div style="position:relative;flex-shrink:0;">
                                                @if (isWa)
                                                {
                                                    <MudAvatar Style="background:#25D366;width:40px;height:40px;">
                                                        <MudIcon Icon="@Icons.Custom.Brands.WhatsApp"
                                                                 Style="color:white;font-size:22px;" />
                                                    </MudAvatar>
                                                }
                                                else
                                                {
                                                    <MudAvatar Style="@($"background:{GetAvatarColor(chatName)};width:40px;height:40px;color:#fff;font-size:.85rem;font-weight:600;")">
                                                        @GetInitials(chatName)
                                                    </MudAvatar>
                                                }
                                                <span class="@GetPresenceDotClass(otherOnline ? PresenceStatus.Online : PresenceStatus.Offline)"></span>
                                            </div>

                                            @* Name + last message *@
                                            <div class="flex-grow-1 overflow-hidden">
                                                <div class="d-flex justify-space-between align-center">
                                                    <MudText Typo="Typo.body2"
                                                             Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                                             Class="@(chat.UnreadCount > 0 ? "font-weight-bold" : "")">
                                                        @(isWa ? (chat.BusinessPartyName ?? chat.ExternalPhoneNumber ?? chatName) : chatName)
                                                    </MudText>
                                                    @if (chat.UnreadCount > 0)
                                                    {
                                                        <MudChip T="string"
                                                                 Label="true"
                                                                 Size="Size.Small"
                                                                 Style="@($"background:{(isWa ? "#25D366" : "var(--mud-palette-primary)")};color:#fff;height:18px;min-width:18px;font-size:0.7rem;padding:0 4px;")">
                                                            @chat.UnreadCount.ToString()
                                                        </MudChip>
                                                    }
                                                </div>
                                                <MudText Typo="Typo.caption"
                                                         Color="Color.Secondary"
                                                         Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:block;">
                                                    @(chat.LastMessage?.Content ?? "")
                                                </MudText>
                                            </div>
                                        </div>
                                    </MudListItem>
                                    <MudDivider />
                                }
                            </MudList>
                        }
                    }
                </div>

                @* New-chat FAB (bottom-right of sidebar) *@
                <MudTooltip Text="@TranslationService.GetTranslation("chat.newChat", "Nuova Chat")" Placement="Placement.Left">
                    <MudFab Color="Color.Primary"
                            StartIcon="@Icons.Material.Filled.Edit"
                            Size="Size.Medium"
                            Class="chat-dlg-new-fab"
                            OnClick="@OpenStartConversationDialogAsync" />
                </MudTooltip>
            </div>

            @* ═══════════════ RIGHT MAIN AREA ═══════════════ *@
            <div class="chat-dlg-main">
                @if (_selectedChat != null)
                {
                    var selIsWa = _selectedChat.Type == ChatType.WhatsApp;

                    @* Chat header *@
                    <div class="chat-dlg-chat-header">
                        @* Show sidebar button when sidebar is hidden *@
                        @if (!_sidebarVisible)
                        {
                            <MudTooltip Text="@TranslationService.GetTranslation("chat.showConversations", "Mostra conversazioni")" Placement="Placement.Bottom">
                                <MudIconButton Icon="@Icons.Material.Filled.Menu"
                                               Color="Color.Inherit"
                                               Size="Size.Small"
                                               Style="margin-right:4px;flex-shrink:0;"
                                               OnClick="@(() => _sidebarVisible = true)" />
                            </MudTooltip>
                        }
                        @* Avatar *@
                        <div style="position:relative;flex-shrink:0;margin-right:12px;">
                            @if (selIsWa)
                            {
                                <MudAvatar Style="background:#25D366;width:36px;height:36px;">
                                    <MudIcon Icon="@Icons.Custom.Brands.WhatsApp" Style="color:white;font-size:20px;" />
                                </MudAvatar>
                            }
                            else
                            {
                                var selName = GetChatName(_selectedChat);
                                <MudAvatar Style="@($"background:{GetAvatarColor(selName)};width:36px;height:36px;color:#fff;font-size:.8rem;font-weight:600;")">
                                    @GetInitials(selName)
                                </MudAvatar>
                            }
                            @{
                                var headerOtherMember = _selectedChat.Type == ChatType.DirectMessage
                                    ? _chatMembers.FirstOrDefault(m => m.UserId != _currentUserId)
                                    : null;
                                var headerOnline = headerOtherMember?.IsOnline == true;
                            }
                            <span class="@GetPresenceDotClass(headerOnline ? PresenceStatus.Online : PresenceStatus.Offline) messaging-header"></span>
                        </div>

                        @* Name + channel chip + presence *@
                        <div class="flex-grow-1 overflow-hidden">
                            <div class="d-flex align-center gap-2 flex-wrap">
                                <MudText Typo="Typo.subtitle1"
                                         Style="font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:rgba(255,255,255,0.87);">
                                    @(selIsWa
                                        ? (_selectedChat.BusinessPartyName ?? _selectedChat.ExternalPhoneNumber ?? GetChatName(_selectedChat))
                                        : GetChatName(_selectedChat))
                                </MudText>
                                @if (selIsWa)
                                {
                                    <MudChip T="string" Label="true" Size="Size.Small"
                                             Style="background:#dcf8c6;color:#1a7a4a;height:20px;font-size:.7rem;padding:0 6px;">
                                        WA
                                    </MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Label="true" Size="Size.Small" Variant="Variant.Outlined"
                                             Color="Color.Primary"
                                             Style="height:20px;font-size:.7rem;padding:0 6px;">
                                        Interno
                                    </MudChip>
                                }
                            </div>
                            @if (_typingUsers.Count > 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("chat.typing", "sta scrivendo...")
                                </MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption"
                                         Style="@($"color:{PresenceColor(headerOnline ? PresenceStatus.Online : PresenceStatus.Offline)};")">
                                    @PresenceLabel(headerOnline ? PresenceStatus.Online : PresenceStatus.Offline)
                                </MudText>
                            }
                        </div>

                        @* Header actions *@
                        @if (_selectedChat.Type != ChatType.WhatsApp)
                        {
                            <MudTooltip Text="@(_showChatInfo ? TranslationService.GetTranslation("chat.hideInfo","Nascondi info") : TranslationService.GetTranslation("chat.chatInfo","Informazioni"))">
                                <MudIconButton Icon="@(_showChatInfo ? Icons.Material.Outlined.Info : Icons.Material.Filled.Info)"
                                               Color="@(_showChatInfo ? Color.Primary : Color.Inherit)"
                                               Size="Size.Small"
                                               OnClick="@(() => { _showChatInfo = !_showChatInfo; })" />
                            </MudTooltip>
                        }
                        <MudTooltip Text="Altro">
                            <MudIconButton Icon="@Icons.Material.Filled.MoreVert"
                                           Color="Color.Inherit"
                                           Size="Size.Small" />
                        </MudTooltip>
                    </div>

                    @* Messages + members panel *@
                    <div class="chat-dlg-content-row">

                        @* Messages *@
                        <div class="chat-dlg-messages" id="messages-container">
                            @if (_isLoadingMessages)
                            {
                                <div class="d-flex justify-center align-center pa-8">
                                    <MudProgressCircular Indeterminate="true" />
                                </div>
                            }
                            else if (_messages.Count > 0)
                            {
                                @foreach (var msg in _messages)
                                {
                                    var isMe = msg.SenderId == _currentUserId;
                                    <div class="@($"d-flex {(isMe ? "justify-end" : "justify-start")} mb-1")">
                                        @if (!isMe)
                                        {
                                            <div style="margin-right:8px;flex-shrink:0;align-self:flex-end;">
                                                <MudAvatar Size="Size.Small"
                                                           Style="@($"background:{GetAvatarColor(msg.SenderName ?? "?")};color:#fff;font-size:.65rem;font-weight:600;width:28px;height:28px;")">
                                                    @GetInitials(msg.SenderName ?? "?")
                                                </MudAvatar>
                                            </div>
                                        }
                                        <div style="max-width:70%;">
                                            @if (!isMe && _selectedChat.Type != ChatType.DirectMessage)
                                            {
                                                <MudText Typo="Typo.caption"
                                                         Style="@($"color:{GetAvatarColor(msg.SenderName ?? "?")};font-weight:600;display:block;margin-bottom:2px;")">
                                                    @msg.SenderName
                                                </MudText>
                                            }
                                            <div class="@($"msg-bubble {(isMe ? "msg-bubble--me" : "msg-bubble--other")}")"
                                                 style="@GetBubbleStyle(isMe, selIsWa)">
                                                <div role="article"
                                                     aria-label="@TranslationService.GetTranslation("chat.message", "Chat message")"
                                                     style="white-space:pre-wrap;word-break:break-word;font-size:0.875rem;">@ChatMarkdownRenderer.Render(msg.Content)</div>
                                                <div class="d-flex justify-end align-center gap-1 mt-1">
                                                    <MudText Typo="Typo.caption"
                                                             Style="@($"opacity:.7;font-size:.65rem;color:{(isMe ? "white" : "var(--mud-palette-text-secondary)")};")">
                                                        @FormatMessageTime(msg.SentAt)
                                                    </MudText>
                                                    @if (isMe)
                                                    {
                                                        <MudIcon Icon="@Icons.Material.Filled.DoneAll"
                                                                 Style="@($"font-size:.8rem;color:{(msg.Status == MessageStatus.Read ? "#90caf9" : "rgba(255,255,255,0.5)")};")"/>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                @if (_typingUsers.Count > 0)
                                {
                                    <div class="d-flex align-center gap-2 pa-1">
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @TranslationService.GetTranslation("chat.typing", "sta scrivendo...")
                                        </MudText>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="d-flex justify-center align-center" style="height:200px;">
                                    <div class="text-center">
                                        <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline"
                                                 Size="Size.Large" Color="Color.Tertiary" Class="mb-2" />
                                        <MudText Typo="Typo.body2" Color="Color.Tertiary">
                                            @TranslationService.GetTranslation("chat.noMessages", "Nessun messaggio")
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                            @TranslationService.GetTranslation("chat.startConversation", "Inizia la conversazione!")
                                        </MudText>
                                    </div>
                                </div>
                            }
                        </div>

                        @* Optional members panel *@
                        @if (_showChatInfo && _selectedChat.Type != ChatType.WhatsApp)
                        {
                            <div class="chat-dlg-members">
                                <MudText Typo="Typo.subtitle2" Class="mb-3">
                                    @TranslationService.GetTranslation("chat.members", "Partecipanti")
                                    (@_chatMembers.Count)
                                </MudText>
                                @foreach (var m in _chatMembers)
                                {
                                    var isSelf = m.UserId == _currentUserId;
                                    <div class="d-flex align-center gap-2 mb-2">
                                        <div style="position:relative;flex-shrink:0;">
                                            <MudAvatar Size="Size.Small"
                                                       Style="@($"background:{GetAvatarColor(m.DisplayName ?? m.Username ?? "?")};color:#fff;font-size:.65rem;font-weight:600;width:28px;height:28px;")">
                                                @GetInitials(m.DisplayName ?? m.Username ?? "?")
                                            </MudAvatar>
                                            <span class="@GetPresenceDotClass(m.IsOnline ? PresenceStatus.Online : PresenceStatus.Offline)"></span>
                                        </div>
                                        <div class="flex-grow-1 overflow-hidden">
                                            <MudText Typo="Typo.body2"
                                                     Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                                @(m.DisplayName ?? m.Username)
                                                @if (isSelf)
                                                {
                                                    <span style="color:var(--mud-palette-primary);font-size:.75rem;"> (tu)</span>
                                                }
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @m.Role.ToString()
                                            </MudText>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @* Message composer *@
                    <div class="chat-dlg-composer">
                        <EnhancedMessageComposer CurrentChat="@_selectedChat"
                                                 ReplyToMessage="@_replyToMessage"
                                                 OnSendMessage="@SendMessageAsync"
                                                 OnAttachFile="@HandleAttachFilesAsync"
                                                 OnCancelReply="@CancelReply"
                                                 OnRemoveAttachment="@RemoveAttachment"
                                                 PendingAttachments="@_pendingAttachments"
                                                 IsSending="@_isSendingMessage" />
                    </div>
                }
                else
                {
                    @* Welcome / empty state *@
                    <div class="d-flex flex-column justify-center align-center" style="height:100%;gap:12px;">
                        <MudIcon Icon="@Icons.Material.Outlined.Forum"
                                 Style="font-size:64px;opacity:.2;" />
                        <MudText Typo="Typo.h6" Color="Color.Tertiary">
                            @TranslationService.GetTranslation("chat.welcomeTitle", "Seleziona una conversazione")
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @TranslationService.GetTranslation("chat.welcomeMessage", "oppure avviane una nuova con il pulsante +")
                        </MudText>
                        @if (!_sidebarVisible)
                        {
                            <MudButton Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.Menu"
                                       Color="Color.Primary"
                                       Class="mt-2"
                                       OnClick="@(() => _sidebarVisible = true)">
                                @TranslationService.GetTranslation("chat.showConversations", "Mostra conversazioni")
                            </MudButton>
                        }
                    </div>
                }
            </div>
        </div>
    </ChildContent>
</EFDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }

    // ── Loading ──────────────────────────────────────────────────────────────
    private bool _isLoadingChats;
    private bool _isLoadingMessages;
    private bool _isSendingMessage;

    // ── Filter / search ──────────────────────────────────────────────────────
    private string _searchText  = string.Empty;
    private string _chatFilter  = "all";

    // ── State ────────────────────────────────────────────────────────────────
    private int            _totalUnread;
    private Guid?          _selectedChatId;
    private ChatResponseDto? _selectedChat;
    private Guid           _currentUserId = Guid.Empty;
    private bool           _showChatInfo;
    private bool           _sidebarVisible = true;

    // ── Data ─────────────────────────────────────────────────────────────────
    private List<ChatResponseDto>  _chatList            = [];
    private List<ChatMessageDto>   _messages            = [];
    private readonly HashSet<Guid> _messageIds          = [];
    private List<ChatMemberDto>    _chatMembers         = [];
    private ChatMessageDto?        _replyToMessage;
    private List<MessageAttachmentDto> _pendingAttachments = [];

    // ── Typing ───────────────────────────────────────────────────────────────
    private readonly HashSet<Guid>                          _typingUsers = [];
    private readonly Dictionary<Guid, CancellationTokenSource> _typingCts = [];

    // ────────────────────────────────────────────────────────────────────────
    // Lifecycle
    // ────────────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var userInfo = await AuthService.GetCurrentUserAsync();
            _currentUserId = userInfo?.Id ?? Guid.Empty;

            if (userInfo is null)
            {
                Logger.LogWarning("ChatDialog: user not authenticated, skipping initialization");
                return;
            }

            if (!RealtimeService.IsChatConnected)
                await RealtimeService.StartChatConnectionAsync();

            ChatService.ChatCreated              += OnChatCreated;
            ChatService.MessageReceived          += OnMessageReceived;
            ChatService.MessageEdited            += OnMessageEdited;
            ChatService.MessageDeleted           += OnMessageDeleted;
            ChatService.MessageRead              += OnMessageRead;
            ChatService.TypingIndicator          += OnTypingIndicator;
            ChatService.UserJoinedChat           += OnUserJoinedChat;
            ChatService.UserLeftChat             += OnUserLeftChat;
            ChatService.UserOnlineStatusChanged  += OnUserOnlineStatusChanged;
            ChatService.AddedToChat              += OnAddedToChat;
            ChatService.RemovedFromChat          += OnRemovedFromChat;

            await LoadChatsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing ChatDialog");
            AppNotification.ShowError($"Errore durante l'inizializzazione: {ex.Message}");
        }
    }

    public void Dispose()
    {
        ChatService.ChatCreated              -= OnChatCreated;
        ChatService.MessageReceived          -= OnMessageReceived;
        ChatService.MessageEdited            -= OnMessageEdited;
        ChatService.MessageDeleted           -= OnMessageDeleted;
        ChatService.MessageRead              -= OnMessageRead;
        ChatService.TypingIndicator          -= OnTypingIndicator;
        ChatService.UserJoinedChat           -= OnUserJoinedChat;
        ChatService.UserLeftChat             -= OnUserLeftChat;
        ChatService.UserOnlineStatusChanged  -= OnUserOnlineStatusChanged;
        ChatService.AddedToChat              -= OnAddedToChat;
        ChatService.RemovedFromChat          -= OnRemovedFromChat;
        CancelAllTypingTimers();
    }

    private void HandleClose() => MudDialog?.Cancel();

    // ────────────────────────────────────────────────────────────────────────
    // Data loading
    // ────────────────────────────────────────────────────────────────────────

    private async Task LoadChatsAsync()
    {
        _isLoadingChats = true;
        StateHasChanged();
        try
        {
            _chatList    = await ChatService.GetChatsAsync(1, 50);
            _totalUnread = _chatList.Sum(c => c.UnreadCount);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading chats");
            AppNotification.ShowError($"Errore nel caricamento delle chat: {ex.Message}");
        }
        finally
        {
            _isLoadingChats = false;
            StateHasChanged();
        }
    }

    private async Task SetChatFilter(string filter)
    {
        _chatFilter = filter;
        await LoadChatsAsync();
    }

    // ────────────────────────────────────────────────────────────────────────
    // Chat selection
    // ────────────────────────────────────────────────────────────────────────

    private async Task SelectChatAsync(ChatResponseDto chat)
    {
        if (_selectedChatId.HasValue && _selectedChatId != chat.Id)
        {
            try { await RealtimeService.LeaveChatAsync(_selectedChatId.Value); } catch { }
        }

        _selectedChatId  = chat.Id;
        _selectedChat    = chat;
        _showChatInfo    = false;
        _isLoadingMessages = true;
        _typingUsers.Clear();
        _messageIds.Clear();
        StateHasChanged();

        try
        {
            _messages = await ChatService.GetMessagesAsync(chat.Id, 1, 50);
            _messageIds.UnionWith(_messages.Select(m => m.Id));
            await ChatService.MarkMessagesAsReadAsync(chat.Id);
            chat.UnreadCount = 0;
            _totalUnread     = _chatList.Sum(c => c.UnreadCount);

            try { await RealtimeService.JoinChatAsync(chat.Id); } catch { }

            _chatMembers = chat.Members.Count > 0
                ? chat.Members
                : await ChatService.GetChatMembersAsync(chat.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading messages for chat {ChatId}", chat.Id);
            AppNotification.ShowError($"Errore nel caricamento dei messaggi: {ex.Message}");
        }
        finally
        {
            _isLoadingMessages = false;
            StateHasChanged();
        }

        await ScrollToBottomAsync();
    }

