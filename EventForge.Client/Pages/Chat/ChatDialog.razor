            TranslationService.GetTranslation("chat.confirmDeleteMessage", "Are you sure you want to delete this message?"),
            TranslationService.GetTranslation("common.delete", "Delete"),
            TranslationService.GetTranslation("common.cancel", "Cancel"));

        if (result == true)
        {
            try
            {
                await ChatService.DeleteMessageAsync(message.Id);
                _messages.Remove(message);
                StateHasChanged();
                AppNotification.ShowSuccess(TranslationService.GetTranslation("chat.messageDeleted", "Message deleted"));
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error deleting message");
                AppNotification.ShowError($"Error deleting message: {ex.Message}");
            }
        }
    }

