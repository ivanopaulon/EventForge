    private void CancelReply() { _replyToMessage = null; StateHasChanged(); }
    private void RemoveAttachment(MessageAttachmentDto attachment) { _pendingAttachments.Remove(attachment); StateHasChanged(); }

    private async Task ToggleMessageReaction(Guid messageId, string emoji)
    {
        try
        {
            var reactionDto = new MessageReactionActionDto
            {
                MessageId = messageId,
                UserId = _currentUserId,
                Emoji = emoji,
                IsAdding = true
            };
            await ChatService.ToggleMessageReactionAsync(reactionDto);

            var message = _messages.FirstOrDefault(m => m.Id == messageId);
            if (message?.Reactions != null)
            {
                var existing = message.Reactions.FirstOrDefault(r => r.Emoji == emoji);
                if (existing != null)
                {
                    if (existing.HasCurrentUserReacted)
                    {
                        existing.Count--;
                        existing.UserIds.Remove(_currentUserId);
                        existing.HasCurrentUserReacted = false;
                        if (existing.Count == 0) message.Reactions.Remove(existing);
                    }
                    else
                    {
                        existing.Count++;
                        existing.UserIds.Add(_currentUserId);
                        existing.HasCurrentUserReacted = true;
                    }
                }
                else
                {
                    message.Reactions.Add(new MessageReactionDto
                    {
                        Emoji = emoji,
                        Count = 1,
                        UserIds = new List<Guid> { _currentUserId },
                        HasCurrentUserReacted = true
                    });
                }
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error toggling reaction");
            AppNotification.ShowError($"Error adding reaction: {ex.Message}");
        }
    }

