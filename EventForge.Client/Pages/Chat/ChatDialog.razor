    private async Task DeleteMessage(ChatMessageDto msg)
    {
        var ok = await DialogService.ShowMessageBoxAsync(
            TranslationService.GetTranslation("chat.confirmDelete", "Elimina messaggio"),
            TranslationService.GetTranslation("chat.confirmDeleteMessage", "Sei sicuro di voler eliminare questo messaggio?"),
            TranslationService.GetTranslation("common.delete", "Elimina"),
            TranslationService.GetTranslation("common.cancel", "Annulla"));
        if (ok != true) return;
        try
        {
            await ChatService.DeleteMessageAsync(msg.Id);
            _messages.Remove(msg);
            _messageIds.Remove(msg.Id);
            StateHasChanged();
            AppNotification.ShowSuccess(TranslationService.GetTranslation("chat.messageDeleted", "Messaggio eliminato"));
        }
        catch (Exception ex) { AppNotification.ShowError($"Errore eliminazione: {ex.Message}"); }
    }

