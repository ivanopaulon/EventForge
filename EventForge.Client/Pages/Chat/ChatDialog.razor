    private void OnChatCreated(ChatResponseDto chat) { _chatList.Insert(0, chat); InvokeAsync(StateHasChanged); }

    private void OnMessageReceived(ChatMessageDto msg)
    {
        if (_selectedChatId == msg.ChatId && _messageIds.Add(msg.Id)) { _messages.Add(msg); }
        var chat = _chatList.FirstOrDefault(c => c.Id == msg.ChatId);
        if (chat is not null) { chat.LastMessage = msg; if (_selectedChatId != msg.ChatId) { chat.UnreadCount++; _totalUnread++; } }
        InvokeAsync(StateHasChanged);
    }

    private void OnMessageEdited(EditMessageDto e)
    {
        var m = _messages.FirstOrDefault(x => x.Id == e.MessageId);
        if (m is not null) { m.Content = e.Content; m.IsEdited = true; InvokeAsync(StateHasChanged); }
    }

    private void OnMessageDeleted(Guid id) { _messages.RemoveAll(m => m.Id == id); _messageIds.Remove(id); InvokeAsync(StateHasChanged); }

    private void OnMessageRead(Guid chatId, Guid msgId)
    {
        if (_selectedChatId != chatId) return;
        var m = _messages.FirstOrDefault(x => x.Id == msgId);
        if (m is not null) { m.Status = MessageStatus.Read; InvokeAsync(StateHasChanged); }
    }

    private void OnTypingIndicator(TypingIndicatorDto t)
    {
        if (_selectedChatId != t.ChatId || t.UserId == _currentUserId) return;
        if (t.IsTyping)
        {
            _typingUsers.Add(t.UserId);
            if (_typingCts.TryGetValue(t.UserId, out var old)) { old.Cancel(); old.Dispose(); }
            var cts = new CancellationTokenSource(); _typingCts[t.UserId] = cts; var uid = t.UserId;
            _ = Task.Run(async () =>
            {
                try
                {
                    await Task.Delay(3000, cts.Token);
                    if (!cts.IsCancellationRequested)
                        await InvokeAsync(() => { _typingUsers.Remove(uid); if (_typingCts.TryGetValue(uid, out var c)) { _typingCts.Remove(uid); c.Dispose(); } StateHasChanged(); });
                }
                catch (TaskCanceledException) { }
            }, cts.Token);
        }
        else
        {
            _typingUsers.Remove(t.UserId);
            if (_typingCts.TryGetValue(t.UserId, out var cts)) { cts.Cancel(); cts.Dispose(); _typingCts.Remove(t.UserId); }
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnUserJoinedChat(Guid chatId, Guid userId)
    {
        if (_selectedChatId != chatId) return;
        _ = InvokeAsync(async () => { _chatMembers = await ChatService.GetChatMembersAsync(chatId); StateHasChanged(); });
    }

    private void OnUserLeftChat(Guid chatId, Guid userId)
    {
        if (_selectedChatId != chatId) return;
        _chatMembers.RemoveAll(m => m.UserId == userId); InvokeAsync(StateHasChanged);
    }

    private void OnUserOnlineStatusChanged(Guid userId, bool online)
    {
        var m = _chatMembers.FirstOrDefault(x => x.UserId == userId);
        if (m is not null) { m.IsOnline = online; InvokeAsync(StateHasChanged); }
    }

    private void OnAddedToChat(ChatResponseDto chat)
    {
        Logger.LogInformation("Added to chat {ChatId}", chat.Id);
        if (!_chatList.Any(c => c.Id == chat.Id))
        {
            _chatList.Insert(0, chat);
            _totalUnread = _chatList.Sum(c => c.UnreadCount);
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnRemovedFromChat(Guid chatId)
    {
        Logger.LogInformation("Removed from chat {ChatId}", chatId);
        _chatList.RemoveAll(c => c.Id == chatId);
        _totalUnread = _chatList.Sum(c => c.UnreadCount);
        if (_selectedChatId == chatId)
        {
            _selectedChatId = null;
            _selectedChat = null;
            _messages.Clear();
            _messageIds.Clear();
        }
        InvokeAsync(StateHasChanged);
    }

