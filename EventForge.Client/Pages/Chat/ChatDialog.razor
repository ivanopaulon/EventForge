        display: flex;
        flex-direction: row;
        flex: 1 1 auto;
        overflow: hidden;
        min-height: 0;
        height: 100%;
    }

    /* ── Sidebar ── */
    .chat-dlg-sidebar {
        width: 300px;
        min-width: 300px;
        display: flex;
        flex-direction: column;
        border-right: 1px solid rgba(255, 255, 255, 0.12);
        overflow: hidden;
    }

    .chat-dlg-search {
        padding: 12px 16px 8px;
        flex-shrink: 0;
    }

    .chat-dlg-list {
        flex: 1 1 auto;
        overflow-y: auto;
        overflow-x: hidden;
        min-height: 0;
    }

    .chat-dlg-new-chat {
        padding: 12px 16px;
        flex-shrink: 0;
    }

    .chat-dlg-selected-item {
        background-color: rgba(100, 160, 255, 0.15) !important;
    }

    /* ── Main messages area ── */
    .chat-dlg-main {
        flex: 1 1 auto;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        min-width: 0;
    }

    .chat-dlg-chat-header {
        display: flex;
        align-items: center;
        padding: 10px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        flex-shrink: 0;
        min-height: 54px;
    }

    .chat-dlg-content-row {
        flex: 1 1 auto;
