        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .chat-dlg .mud-dialog-title {
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        padding: 8px 16px;
    }

    /* Two-panel layout: sidebar + main */
