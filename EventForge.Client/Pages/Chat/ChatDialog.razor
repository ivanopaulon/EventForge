    private async Task OpenStartConversationDialogAsync()
    {
        try
        {
            var parameters = new DialogParameters
            {
                { nameof(StartConversationDialog.CurrentUserId), _currentUserId }
            };
            var options = new DialogOptions
            {
                MaxWidth         = MaxWidth.Medium,
                FullWidth        = true,
                BackdropClick    = false,
                CloseButton      = false,
                CloseOnEscapeKey = true
            };
            var dialog = await DialogService.ShowAsync<StartConversationDialog>(
                string.Empty, parameters, options);
            var result = await dialog.Result;
            if (result is { Canceled: false, Data: ChatResponseDto newChat })
            {
                if (!_chatList.Any(c => c.Id == newChat.Id))
                    _chatList.Insert(0, newChat);
                await SelectChatAsync(newChat);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening StartConversationDialog");
            AppNotification.ShowError("Impossibile aprire la finestra di nuova chat.");
        }
    }

