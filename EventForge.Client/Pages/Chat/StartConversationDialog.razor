@using EventForge.DTOs.Chat
@using EventForge.Client.Models.Messaging
@inject IAuthService AuthService
@inject IChatService ChatService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject ILogger<StartConversationDialog> Logger

@* Open with: new DialogOptions { FullScreen = true, BackdropClick = false, CloseButton = false, CloseOnEscapeKey = true } *@
<EFDialog Icon="@Icons.Material.Filled.EditNote"
          Title="@TranslationService.GetTranslation("chat.newConversation", "Nuova conversazione")"
          IsProcessing="@_isLoading"
          OnClose="@(() => MudDialog?.Cancel())">
    <ChildContent>
        <div class="start-conv-layout">

            @* ─── "To:" search panel ─── *@
            <div class="start-conv-search-panel">

                @* Recipients row *@
                <div class="d-flex align-center flex-wrap gap-1 mb-2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="fw-semibold" Style="flex-shrink:0; margin-right:4px;">
                        A:
                    </MudText>
                    @foreach (var contact in _selectedContacts)
                    {
                        <MudChip T="string"
                                 OnClose="@(() => ToggleContact(contact))"
                                 Size="Size.Small"
                                 Style="@GetChipStyle(contact)">
                            <MudIcon Icon="@(contact.Channel == MessagingChannel.WhatsApp ? Icons.Custom.Brands.WhatsApp : Icons.Material.Filled.Person)"
                                     Style="font-size:12px;margin-right:3px;" />
                            @contact.Name
                        </MudChip>
                    }
                    <MudTextField T="string"
                                  @bind-Value="_searchQuery"
                                  Placeholder="@(_selectedContacts.Count == 0 ? TranslationService.GetTranslation("chat.searchContacts", "Cerca un nome o numero...") : "")"
                                  Variant="Variant.Text"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  Class="to-search-field"
                                  Style="flex:1;min-width:160px;" />
                </div>

                @* Channel filter chips *@
                <div class="d-flex gap-2 flex-wrap">
                    <MudChip T="string"
                             Variant="@(_channelFilter == null ? Variant.Filled : Variant.Outlined)"
                             Color="@(_channelFilter == null ? Color.Primary : Color.Default)"
                             Size="Size.Small"
                             OnClick="@(() => SetChannelFilter(null))">
                        Tutti
                    </MudChip>
                    <MudChip T="string"
                             Variant="@(_channelFilter == MessagingChannel.Internal ? Variant.Filled : Variant.Outlined)"
                             Color="@(_channelFilter == MessagingChannel.Internal ? Color.Primary : Color.Default)"
                             Size="Size.Small"
                             Icon="@Icons.Material.Filled.Business"
                             OnClick="@(() => SetChannelFilter(MessagingChannel.Internal))">
                        Interni
                    </MudChip>
                    <MudChip T="string"
                             Variant="@(_channelFilter == MessagingChannel.WhatsApp ? Variant.Filled : Variant.Outlined)"
                             Color="@(_channelFilter == MessagingChannel.WhatsApp ? Color.Success : Color.Default)"
                             Size="Size.Small"
                             Icon="@Icons.Custom.Brands.WhatsApp"
                             Style="@(_channelFilter == MessagingChannel.WhatsApp ? "background:#25D366;color:white;" : "")"
                             OnClick="@(() => SetChannelFilter(MessagingChannel.WhatsApp))">
                        WhatsApp
                    </MudChip>
                </div>
            </div>

            <MudDivider />

            @* ─── Contact list ─── *@
            <div class="start-conv-contact-list">
                @if (_isLoading)
                {
                    <div class="d-flex justify-center pa-6">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    </div>
                }
                else
                {
                    var filtered = FilteredContacts().ToList();

                    @if (filtered.Count == 0)
                    {
                        <div class="d-flex flex-column align-center justify-center pa-8 gap-2">
                            <MudIcon Icon="@Icons.Material.Outlined.SearchOff"
                                     Style="font-size:48px;opacity:.3;" />
                            <MudText Typo="Typo.body1">
                                @TranslationService.GetTranslation("chat.noContactsFound", "Nessun contatto trovato")
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @TranslationService.GetTranslation("chat.tryDifferentSearch", "Prova con un altro nome o numero")
                            </MudText>
                        </div>
                    }
                    else
                    {
                        var internalContacts = filtered.Where(c => c.Channel == MessagingChannel.Internal).ToList();
                        var whatsAppContacts = filtered.Where(c => c.Channel == MessagingChannel.WhatsApp).ToList();

                        @if (internalContacts.Count > 0 && _channelFilter != MessagingChannel.WhatsApp)
                        {
                            <div class="contact-group-header">
                                <MudIcon Icon="@Icons.Material.Filled.Business" Style="font-size:14px;" />
                                Utenti interni
                            </div>
                            <MudList T="object" Dense="true" Clickable="true" Padding="false">
                                @foreach (var contact in internalContacts)
                                {
                                    var isSelected = _selectedContacts.Any(c => c.Id == contact.Id);
                                    <MudListItem T="object"
                                                 OnClick="@(() => ToggleContact(contact))"
                                                 Class="@($"contact-item{(isSelected ? " contact-item--selected" : "")}")">
                                        <div class="d-flex align-center gap-3">
                                            <div style="position:relative;flex-shrink:0;">
                                                <MudAvatar Style="@($"background:{GetAvatarColor(contact.Name)};color:#fff;font-size:.8rem;font-weight:600;width:44px;height:44px;")">
                                                    @contact.Initials
                                                </MudAvatar>
                                                <span class="@GetPresenceDotClass(contact.Presence)"></span>
                                            </div>
                                            <div class="flex-grow-1 overflow-hidden">
                                                <MudText Typo="Typo.body1" Class="text-truncate-ef fw-medium">
                                                    @contact.Name
                                                </MudText>
                                                @if (!string.IsNullOrWhiteSpace(contact.Role))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        @contact.Role
                                                    </MudText>
                                                }
                                                <MudText Typo="Typo.caption"
                                                         Style="@($"color:{PresenceColor(contact.Presence)};")">
                                                    @PresenceLabel(contact.Presence)
                                                </MudText>
                                            </div>
                                            @if (isSelected)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                                         Color="Color.Primary"
                                                         Style="flex-shrink:0;" />
                                            }
                                        </div>
                                    </MudListItem>
                                    <MudDivider />
                                }
                            </MudList>
                        }

                        @if (whatsAppContacts.Count > 0 && _channelFilter != MessagingChannel.Internal)
                        {
                            <div class="contact-group-header contact-group-header--wa">
                                <MudIcon Icon="@Icons.Custom.Brands.WhatsApp"
                                         Style="font-size:14px;color:#25D366;" />
                                Contatti WhatsApp
                            </div>
                            <MudList T="object" Dense="true" Clickable="true" Padding="false">
                                @foreach (var contact in whatsAppContacts)
                                {
                                    var isSelected = _selectedContacts.Any(c => c.Id == contact.Id);
                                    <MudListItem T="object"
                                                 OnClick="@(() => ToggleContact(contact))"
                                                 Class="@($"contact-item{(isSelected ? " contact-item--selected" : "")}")">
                                        <div class="d-flex align-center gap-3">
                                            <MudAvatar Style="background:#25D366;color:white;width:44px;height:44px;flex-shrink:0;">
                                                <MudIcon Icon="@Icons.Custom.Brands.WhatsApp"
                                                         Style="font-size:22px;" />
                                            </MudAvatar>
                                            <div class="flex-grow-1 overflow-hidden">
                                                <MudText Typo="Typo.body1" Class="text-truncate-ef fw-medium">
                                                    @contact.Name
                                                </MudText>
                                                @if (!string.IsNullOrWhiteSpace(contact.Phone))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        @contact.Phone
                                                    </MudText>
                                                }
                                                <MudChip T="string" Label="true" Size="Size.Small"
                                                         Style="background:#dcf8c6;color:#1a7a4a;height:18px;font-size:.65rem;padding:0 4px;">
                                                    WA
                                                </MudChip>
                                            </div>
                                            @if (isSelected)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                                         Style="color:#25D366;flex-shrink:0;" />
                                            }
                                        </div>
                                    </MudListItem>
                                    <MudDivider />
                                }
                            </MudList>
                        }
                    }
                }
            </div>
        </div>
    </ChildContent>
    <DialogActions>
        @* Left: selection count hint *@
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-auto">
            @if (_selectedContacts.Count == 0)
            {
                @TranslationService.GetTranslation("chat.selectAtLeastOne", "Seleziona almeno un contatto")
            }
            else
            {
                @($"{_selectedContacts.Count} {TranslationService.GetTranslation("chat.contactsSelected", "selezionati")}")
            }
        </MudText>
        <MudButton Variant="Variant.Text"
                   OnClick="@(() => MudDialog?.Cancel())">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Send"
                   Disabled="@(_selectedContacts.Count == 0 || _isCreating)"
                   OnClick="@StartChatAsync">
            @TranslationService.GetTranslation("chat.startChat", "Avvia Chat")
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public Guid CurrentUserId { get; set; }

    private bool _isLoading;
    private bool _isCreating;
    private string _searchQuery = string.Empty;
    private MessagingChannel? _channelFilter;

    private List<ContactItem> _allContacts     = []; // TODO: replace with injected service call
    private List<ContactItem> _selectedContacts = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadContactsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing StartConversationDialog");
            AppNotification.ShowError($"Errore caricamento contatti: {ex.Message}");
        }
    }

    private async Task LoadContactsAsync()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            // TODO: replace with injected service call when WhatsApp contacts endpoint is available
            var users = await ChatService.GetAvailableUsersAsync();
            _allContacts = users
                .Where(u => u.Id != CurrentUserId)
                .Select(u => new ContactItem
                {
                    Id          = u.Id,
                    Name        = u.DisplayName,
                    Initials    = GetInitials(u.DisplayName),
                    AvatarColor = GetAvatarColor(u.DisplayName),
                    Channel     = MessagingChannel.Internal,
                    Presence    = u.IsOnline ? PresenceStatus.Online : PresenceStatus.Offline
                })
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading contacts");
            AppNotification.ShowError($"Errore: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private IEnumerable<ContactItem> FilteredContacts()
    {
        var list = _channelFilter.HasValue
            ? _allContacts.Where(c => c.Channel == _channelFilter)
            : _allContacts.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            var q = _searchQuery.Trim();
            list = list.Where(c =>
                c.Name.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                (c.Phone?.Contains(q, StringComparison.OrdinalIgnoreCase) == true));
        }
        return list;
    }

    private void SetChannelFilter(MessagingChannel? channel)
    {
        _channelFilter = channel;
        StateHasChanged();
    }

    private void ToggleContact(ContactItem contact)
    {
        var existing = _selectedContacts.FirstOrDefault(c => c.Id == contact.Id);
        if (existing is not null)
            _selectedContacts.Remove(existing);
        else
            _selectedContacts.Add(contact);
        StateHasChanged();
    }

    private async Task StartChatAsync()
    {
        if (_selectedContacts.Count == 0) return;
        _isCreating = true;
        StateHasChanged();
        try
        {
            var isGroup    = _selectedContacts.Count > 1;
            var isWa       = _selectedContacts.All(c => c.Channel == MessagingChannel.WhatsApp);
            var chatName   = isGroup
                ? string.Join(", ", _selectedContacts.Select(c => c.Name.Split(' ')[0]))
                : null;

            var createDto = new CreateChatDto
            {
                Type           = isWa ? ChatType.WhatsApp : (isGroup ? ChatType.Group : ChatType.DirectMessage),
                Name           = chatName,
                ParticipantIds = _selectedContacts.Select(c => c.Id).ToList(),
                CreatedBy      = CurrentUserId
            };

            var newChat = await ChatService.CreateChatAsync(createDto);
            MudDialog?.Close(DialogResult.Ok(newChat));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating chat");
            AppNotification.ShowError($"Errore creazione chat: {ex.Message}");
        }
        finally
        {
            _isCreating = false;
            StateHasChanged();
        }
    }

    // ── Helpers ──────────────────────────────────────────────────────────────

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return (parts.Length >= 2 ? $"{parts[0][0]}{parts[1][0]}" : name[..Math.Min(2, name.Length)]).ToUpper();
    }

    private static readonly string[] _avatarColors =
        ["#f44336","#e91e63","#9c27b0","#673ab7","#3f51b5","#2196f3","#009688","#4caf50"];

    private static string GetAvatarColor(string name)
    {
        if (string.IsNullOrEmpty(name)) return _avatarColors[0];
        unchecked { var h = name.Aggregate(0, (a, c) => a * 31 + c); return _avatarColors[((h % _avatarColors.Length) + _avatarColors.Length) % _avatarColors.Length]; }
    }

    private static string GetPresenceDotClass(PresenceStatus p) => p switch
    {
        PresenceStatus.Online  => "status-dot status-dot--online",
        PresenceStatus.Away    => "status-dot status-dot--away",
        PresenceStatus.Busy    => "status-dot status-dot--busy",
        _                      => "status-dot status-dot--offline"
    };

    private static string PresenceColor(PresenceStatus p) => p switch
    {
        PresenceStatus.Online => "#47d16c",
        PresenceStatus.Away   => "#f8a723",
        PresenceStatus.Busy   => "#e8323a",
        _                     => "var(--mud-palette-text-disabled)"
    };

    private static string PresenceLabel(PresenceStatus p) => p switch
    {
        PresenceStatus.Online => "Online",
        PresenceStatus.Away   => "Assente",
        PresenceStatus.Busy   => "Occupato",
        _                     => "Offline"
    };

    private static string GetChipStyle(ContactItem c) => c.Channel == MessagingChannel.WhatsApp
        ? "background:#dcf8c6;color:#1a7a4a;"
        : "background:var(--mud-palette-primary-lighten);color:var(--mud-palette-primary);";
}
