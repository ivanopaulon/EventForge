    };

    #region Real-time Event Handlers

    private void OnChatCreated(ChatResponseDto chat)
    {
        _chatList.Insert(0, chat);
        InvokeAsync(StateHasChanged);
    }

    private void OnMessageReceived(ChatMessageDto message)
    {
        // Add message to current chat if it's selected
        if (_selectedChatId == message.ChatId)
        {
            _messages.Add(message);
            InvokeAsync(StateHasChanged);
        }

        // Update chat list last message
        var chat = _chatList.FirstOrDefault(c => c.Id == message.ChatId);
        if (chat != null)
        {
            chat.LastMessage = message;
            if (_selectedChatId != message.ChatId)
            {
                chat.UnreadCount++;
                _totalUnreadMessages++;
            }
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnMessageEdited(EditMessageDto editMessage)
    {
        var message = _messages.FirstOrDefault(m => m.Id == editMessage.MessageId);
        if (message != null)
        {
            message.Content = editMessage.Content;
            message.IsEdited = true;
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnMessageDeleted(Guid messageId)
    {
        _messages.RemoveAll(m => m.Id == messageId);
        InvokeAsync(StateHasChanged);
    }

    private void OnMessageRead(Guid chatId, Guid messageId)
    {
        if (_selectedChatId == chatId)
        {
            var message = _messages.FirstOrDefault(m => m.Id == messageId);
            if (message != null)
            {
                message.Status = MessageStatus.Read;
                InvokeAsync(StateHasChanged);
            }
        }
    }

    private void OnTypingIndicator(TypingIndicatorDto typingIndicator)
    {
        if (_selectedChatId != typingIndicator.ChatId) return;
        if (typingIndicator.UserId == _currentUserId) return;

        if (typingIndicator.IsTyping)
        {
            _typingUsers.Add(typingIndicator.UserId);

            if (_typingCts.TryGetValue(typingIndicator.UserId, out var existing))
            {
                existing.Cancel();
                existing.Dispose();
            }

            var cts = new CancellationTokenSource();
            _typingCts[typingIndicator.UserId] = cts;
            var userId = typingIndicator.UserId;

            _ = Task.Run(async () =>
            {
                try
                {
                    await Task.Delay(3000, cts.Token);
                    if (!cts.Token.IsCancellationRequested)
                    {
                        await InvokeAsync(() =>
                        {
                            _typingUsers.Remove(userId);
                            if (_typingCts.TryGetValue(userId, out var c))
                            {
                                _typingCts.Remove(userId);
                                c.Dispose();
                            }
                            StateHasChanged();
                        });
                    }
                }
                catch (TaskCanceledException) { }
            }, cts.Token);
        }
        else
        {
            _typingUsers.Remove(typingIndicator.UserId);
            if (_typingCts.TryGetValue(typingIndicator.UserId, out var cts))
            {
                cts.Cancel();
                cts.Dispose();
                _typingCts.Remove(typingIndicator.UserId);
            }
        }

        InvokeAsync(StateHasChanged);
    }

    private void OnUserJoinedChat(Guid chatId, Guid userId)
    {
        // Refresh members if the current chat is affected
        if (_selectedChatId == chatId)
        {
            _ = InvokeAsync(async () =>
            {
                _chatMembers = await ChatService.GetChatMembersAsync(chatId);
                StateHasChanged();
            });
        }
    }

    private void OnUserLeftChat(Guid chatId, Guid userId)
    {
        if (_selectedChatId == chatId)
        {
            _chatMembers.RemoveAll(m => m.UserId == userId);
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnUserOnlineStatusChanged(Guid userId, bool isOnline)
    {
        // Update online status in the members panel for the current chat
        var member = _chatMembers.FirstOrDefault(m => m.UserId == userId);
        if (member != null)
        {
            member.IsOnline = isOnline;
            InvokeAsync(StateHasChanged);
        }
    }

