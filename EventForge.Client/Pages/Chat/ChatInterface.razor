    {
        MessageStatus.Sent => Icons.Material.Filled.Check,
        MessageStatus.Delivered => Icons.Material.Filled.DoneAll,
        MessageStatus.Read => Icons.Material.Filled.DoneAll,
        _ => Icons.Material.Filled.Schedule
    };

