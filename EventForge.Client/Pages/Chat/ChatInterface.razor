@page "/chat"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject NavigationManager NavigationManager

@* Chat is now accessed via the fullscreen ChatDialog opened from FloatingFabMenu.
   If someone navigates here directly, redirect to the home page. *@

@code {
    protected override void OnInitialized()
    {
        NavigationManager.NavigateTo("/", replace: true);
    }
}
