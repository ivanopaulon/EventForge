    /// <summary>
    /// Toggle message reaction
    /// </summary>
    private async Task ToggleMessageReaction(Guid messageId, string emoji)
    {
        try
        {
            var reactionDto = new MessageReactionActionDto
            {
                MessageId = messageId,
                UserId = _currentUserId,
                Emoji = emoji,
                IsAdding = true // Logic to determine add/remove should be in service
            };

            await ChatService.ToggleMessageReactionAsync(reactionDto);
            
            // Update UI optimistically
            var message = _messages.FirstOrDefault(m => m.Id == messageId);
            if (message?.Reactions != null)
            {
                var existingReaction = message.Reactions.FirstOrDefault(r => r.Emoji == emoji);
                if (existingReaction != null)
                {
                    if (existingReaction.HasCurrentUserReacted)
                    {
                        existingReaction.Count--;
                        existingReaction.UserIds.Remove(_currentUserId);
                        existingReaction.HasCurrentUserReacted = false;
                        if (existingReaction.Count == 0)
                        {
                            message.Reactions.Remove(existingReaction);
                        }
                    }
                    else
                    {
                        existingReaction.Count++;
                        existingReaction.UserIds.Add(_currentUserId);
                        existingReaction.HasCurrentUserReacted = true;
                    }
                }
                else
                {
                    message.Reactions.Add(new MessageReactionDto
                    {
                        Emoji = emoji,
                        Count = 1,
                        UserIds = new List<Guid> { _currentUserId },
                        HasCurrentUserReacted = true
                    });
                }
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unhandled exception in ChatInterface: {Message}", ex.Message);
            AppNotification.ShowError($"Error adding reaction: {ex.Message}");
        }
    }

