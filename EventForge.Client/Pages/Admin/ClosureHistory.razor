@namespace EventForge.Client.Pages.FiscalAdmin
@page "/admin/fiscal-printers/{PrinterId:guid}/closures"
@using EventForge.DTOs.FiscalPrinting
@using EventForge.Client.Services
@using EventForge.Client.Shared.Components.FiscalPrinting
@using EventForge.Client.Shared.Components.Dialogs
@using MudBlazor
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager")]
@inject IFiscalPrintingService FiscalPrintingService
@inject IHttpClientService HttpClientService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ILogger<ClosureHistory> Logger
@implements IAsyncDisposable

<PageTitle>Storico Chiusure Fiscali</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 pa-0" />

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.EventNote" Class="mr-2 mb-1" Style="vertical-align:middle;" />
        Storico Chiusure Fiscali
        @if (!string.IsNullOrEmpty(_printerName))
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-2">@_printerName</MudChip>
        }
    </MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Warning"
               StartIcon="@Icons.Material.Filled.EventNote"
               OnClick="OpenDailyClosureDialogAsync">
        Nuova Chiusura
    </MudButton>
</MudStack>

@* ──────────────────── FILTRI ──────────────────── *@
<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid Spacing="2">
        <MudItem xs="12" md="4">
            <MudDatePicker @bind-Date="_filterFromDate"
                           Label="Data da"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           DateFormat="dd/MM/yyyy" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudDatePicker @bind-Date="_filterToDate"
                           Label="Data a"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           DateFormat="dd/MM/yyyy" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_filterZReport"
                          Label="N° Z-Report"
                          Variant="Variant.Outlined"
                          Clearable="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" />
        </MudItem>
        <MudItem xs="12">
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Search"
                           OnClick="ApplyFilters">
                    Cerca
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Clear"
                           OnClick="ClearFilters">
                    Pulisci
                </MudButton>
                <MudSpacer />
                <MudTooltip Text="Esporta CSV">
                    <MudIconButton Icon="@Icons.Material.Filled.Download"
                                   OnClick="ExportCsvAsync"
                                   Disabled="@(_closures.Count == 0)" />
                </MudTooltip>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudPaper>

@* ──────────────────── TABELLA ──────────────────── *@
<MudPaper Elevation="1">
    <MudTable T="DailyClosureHistoryDto"
              Items="@_closuresFiltered"
              Dense="true"
              Hover="true"
              Striped="true"
              Loading="@_isLoading"
              LoadingProgressColor="Color.Primary">
        <ToolBarContent>
            <MudText Typo="Typo.subtitle1">
                Chiusure (@_closuresFiltered.Count di @_closures.Count totali)
            </MudText>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel T="DailyClosureHistoryDto" SortBy="c => c.ClosedAt" InitialDirection="SortDirection.Descending">Data/Ora</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="DailyClosureHistoryDto" SortBy="c => c.ZReportNumber">N° Z-Report</MudTableSortLabel></MudTh>
            <MudTh Style="text-align:right"><MudTableSortLabel T="DailyClosureHistoryDto" SortBy="c => c.ReceiptCount">Scontrini</MudTableSortLabel></MudTh>
            <MudTh Style="text-align:right"><MudTableSortLabel T="DailyClosureHistoryDto" SortBy="c => c.TotalAmount">Totale</MudTableSortLabel></MudTh>
            <MudTh>Operatore</MudTh>
            <MudTh>Azioni</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Data/Ora">@context.ClosedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
            <MudTd DataLabel="N° Z-Report"><b>#@context.ZReportNumber</b></MudTd>
            <MudTd DataLabel="Scontrini" Style="text-align:right">@context.ReceiptCount</MudTd>
            <MudTd DataLabel="Totale" Style="text-align:right">@context.TotalAmount.ToString("C2")</MudTd>
            <MudTd DataLabel="Operatore">@(context.Operator ?? "—")</MudTd>
            <MudTd>
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true">
                    <MudMenuItem Icon="@Icons.Material.Filled.PictureAsPdf"
                                 Disabled="@(!context.HasPdf)"
                                 OnClick="@(() => DownloadPdfAsync(context.Id))">
                        Scarica PDF
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Print"
                                 OnClick="@(() => ReprintAsync(context.Id, context.ZReportNumber))">
                        Ristampa Z-Report
                    </MudMenuItem>
                </MudMenu>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 10, 20, 50 }" />
        </PagerContent>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Outlined.EventNote" Size="Size.Large" Color="Color.Default" />
                <MudText Typo="Typo.body1">Nessuna chiusura trovata</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Modifica i filtri o esegui la prima chiusura giornaliera</MudText>
            </MudStack>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    // ─────────────────────────────────────────────────────────
    //  Route parameter
    // ─────────────────────────────────────────────────────────

    [Parameter] public Guid PrinterId { get; set; }

    // ─────────────────────────────────────────────────────────
    //  State
    // ─────────────────────────────────────────────────────────

    private bool _isLoading = true;
    private string? _printerName;
    private List<DailyClosureHistoryDto> _closures = new();
    private List<DailyClosureHistoryDto> _closuresFiltered = new();
    private HubConnection? _hubConnection;

    // Filters
    private DateTime? _filterFromDate;
    private DateTime? _filterToDate;
    private string _filterZReport = string.Empty;

    private List<BreadcrumbItem> _breadcrumbs = [];

    // ─────────────────────────────────────────────────────────
    //  Lifecycle
    // ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        // Load printer name for breadcrumb/header
        try
        {
            var printer = await HttpClientService.GetAsync<EventForge.DTOs.Station.PrinterDto>(
                $"api/v1/stations/printers/{PrinterId}");
            _printerName = printer?.Name;
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Could not load printer name for {PrinterId}.", PrinterId); }

        _breadcrumbs =
        [
            new BreadcrumbItem("Home", href: "/"),
            new BreadcrumbItem("Stampanti Fiscali", href: "/admin/fiscal-printers"),
            new BreadcrumbItem(_printerName ?? PrinterId.ToString("N")[..8], href: null, disabled: true),
            new BreadcrumbItem("Storico Chiusure", href: null, disabled: true)
        ];

        await LoadHistoryAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _hubConnection is not null) return;
        await ConnectToHubAsync();
    }

    // ─────────────────────────────────────────────────────────
    //  SignalR
    // ─────────────────────────────────────────────────────────

    private async Task ConnectToHubAsync()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl("/hubs/fiscal-printer")
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<Guid, string>("ClosureRequired", async (printerId, _) =>
            {
                if (printerId != PrinterId) return;
                await InvokeAsync(async () =>
                {
                    await LoadHistoryAsync();
                    StateHasChanged();
                });
            });

            await _hubConnection.StartAsync();
            await _hubConnection.SendAsync("SubscribeToPrinter", PrinterId);

            Logger.LogDebug("ClosureHistory: subscribed to printer {PrinterId}", PrinterId);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "ClosureHistory: could not connect to SignalR hub for printer {PrinterId}", PrinterId);
        }
    }

    // ─────────────────────────────────────────────────────────
    //  IAsyncDisposable
    // ─────────────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            try
            {
                await _hubConnection.SendAsync("UnsubscribeFromPrinter", PrinterId);
                await _hubConnection.DisposeAsync();
            }
            catch { /* intentionally swallowed during disposal */ }
            _hubConnection = null;
        }
    }

    // ─────────────────────────────────────────────────────────
    //  Data loading
    // ─────────────────────────────────────────────────────────

    private async Task LoadHistoryAsync()
    {
        _isLoading = true;
        try
        {
            _closures = await FiscalPrintingService.GetClosureHistoryAsync(
                PrinterId, page: 1, pageSize: 200) ?? new();
            ApplyLocalFilters();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "LoadHistoryAsync failed for printer {PrinterId}", PrinterId);
            AppNotification.ShowError("Errore nel caricamento dello storico.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ─────────────────────────────────────────────────────────
    //  Filters
    // ─────────────────────────────────────────────────────────

    private void ApplyLocalFilters()
    {
        IEnumerable<DailyClosureHistoryDto> query = _closures;

        if (_filterFromDate.HasValue)
            query = query.Where(c => c.ClosedAt >= _filterFromDate.Value);

        if (_filterToDate.HasValue)
            query = query.Where(c => c.ClosedAt <= _filterToDate.Value.AddDays(1));

        if (!string.IsNullOrWhiteSpace(_filterZReport)
            && int.TryParse(_filterZReport, out var zNum))
            query = query.Where(c => c.ZReportNumber == zNum);

        _closuresFiltered = query.ToList();
    }

    private void ApplyFilters()
    {
        ApplyLocalFilters();
    }

    private void ClearFilters()
    {
        _filterFromDate = null;
        _filterToDate = null;
        _filterZReport = string.Empty;
        ApplyLocalFilters();
    }

    // ─────────────────────────────────────────────────────────
    //  Actions
    // ─────────────────────────────────────────────────────────

    private async Task OpenDailyClosureDialogAsync()
    {
        var parameters = new DialogParameters
        {
            [nameof(DailyClosureDialog.PrinterId)] = PrinterId,
            [nameof(DailyClosureDialog.PrinterName)] = _printerName
        };

        var dialog = await DialogService.ShowAsync<DailyClosureDialog>(
            string.Empty, parameters, EFDialogDefaults.Options);

        var result = await dialog.Result;
        if (result?.Canceled == false)
        {
            // Refresh history after successful closure
            await LoadHistoryAsync();
        }
    }

    private async Task DownloadPdfAsync(Guid closureId)
    {
        AppNotification.ShowInfo("PDF in generazione…");
        try
        {
            var pdfBytes = await FiscalPrintingService.DownloadClosurePdfAsync(closureId);
            if (pdfBytes is null || pdfBytes.Length == 0)
            {
                AppNotification.ShowError("PDF non disponibile per questa chiusura.");
                return;
            }
            var fileName = $"ZReport_{closureId:N}.pdf";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, pdfBytes, "application/pdf");
            AppNotification.ShowSuccess("PDF scaricato.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "DownloadPdfAsync failed for closure {ClosureId}.", closureId);
            AppNotification.ShowError($"Errore download PDF: {ex.Message}");
        }
    }

    private async Task ReprintAsync(Guid closureId, int zNumber)
    {
        try
        {
            var result = await FiscalPrintingService.ReprintZReportAsync(closureId);
            if (result?.Success == true)
                AppNotification.ShowSuccess($"Z-Report #{zNumber} ristampato.");
            else
                AppNotification.ShowError($"Ristampa fallita: {result?.ErrorMessage ?? "errore"}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore durante la ristampa del Z-Report #{ZNumber} per la chiusura {ClosureId}.", zNumber, closureId);
            AppNotification.ShowWarning("Si è verificato un errore.");
        }
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var sb = new System.Text.StringBuilder();
            sb.AppendLine("Data/Ora,N° Z-Report,Scontrini,Totale,Contanti,Carte,Operatore");
            foreach (var c in _closuresFiltered)
            {
                sb.AppendLine(string.Join(",",
                    c.ClosedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm"),
                    c.ZReportNumber,
                    c.ReceiptCount,
                    c.TotalAmount.ToString("F2"),
                    c.CashAmount.ToString("F2"),
                    c.CardAmount.ToString("F2"),
                    $"\"{c.Operator ?? ""}\""));
            }

            var csvBytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
            var fileName = $"Chiusure_{PrinterId}_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, csvBytes, "text/csv;charset=utf-8");
            AppNotification.ShowSuccess($"CSV esportato: {fileName}");
        }
        catch (Exception ex)
        {
            AppNotification.ShowError($"Errore export CSV: {ex.Message}");
        }
    }
}
