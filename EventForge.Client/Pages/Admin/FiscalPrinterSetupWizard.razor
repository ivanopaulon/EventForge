@namespace EventForge.Client.Pages.FiscalAdmin
@page "/admin/fiscal-printers/setup"
@page "/admin/fiscal-printers-wizard/{PrinterId:guid}"
@using EventForge.DTOs.FiscalPrinting
@using EventForge.DTOs.Station
@using EventForge.DTOs.VatRates
@using EventForge.DTOs.Sales
@using EventForge.DTOs.Store
@using EventForge.DTOs.Common
@using EventForge.Client.Services
@using EventForge.Client.Services.Sales
@using MudBlazor
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@inject IFiscalPrintingService FiscalPrintingService
@inject IFinancialService FinancialService
@inject IPaymentMethodService PaymentMethodService
@inject IHttpClientService HttpClientService
@inject IAppNotificationService AppNotification
@inject NavigationManager NavigationManager
@inject ILogger<FiscalPrinterSetupWizard> Logger

<PageTitle>@(_isEditMode ? "Modifica Stampante" : "Wizard Configurazione Stampante Fiscale")</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 pa-0" />

<MudText Typo="Typo.h5" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Outlined.Print" Class="mr-2 mb-1" Style="vertical-align:middle;" />
    @(_isEditMode ? "Modifica Stampante" : "Configurazione Stampante Fiscale")
</MudText>

@* ──────────────────── STEP INDICATOR ──────────────────── *@
<MudStepper @ref="_stepper" @bind-ActiveStepIndex="_activeStep" Linear="false" Class="mb-4">
    <MudStep Title="Connessione"         Icon="@Icons.Material.Filled.SettingsEthernet" />
    <MudStep Title="Impostazioni"        Icon="@Icons.Material.Filled.Tune" />
    <MudStep Title="Info Stampante"      Icon="@Icons.Material.Filled.Info" />
    <MudStep Title="Configurazione"      Icon="@Icons.Material.Filled.TextFields" />
    <MudStep Title="Tipo &amp; Carta"    Icon="@Icons.Material.Filled.Print" />
    <MudStep Title="Dati Fiscali"        Icon="@Icons.Material.Filled.Code" />
    <MudStep Title="Associa POS"         Icon="@Icons.Material.Filled.PointOfSale" />
    <MudStep Title="Test &amp; Salva"    Icon="@Icons.Material.Filled.CheckCircle" />
</MudStepper>

@* ══════════════════════════════════════════════════════════════
   STEP 0 – Tipo Connessione
   ══════════════════════════════════════════════════════════════ *@
@if (_activeStep == 0)
{
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        <MudText Typo="Typo.subtitle1" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.SettingsEthernet" Class="mr-2" />
            Seleziona il tipo di connessione della stampante fiscale
        </MudText>

        <MudRadioGroup T="string" @bind-Value="_connectionType">
            <MudStack Spacing="3">
                <MudPaper Class="pa-4" Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudRadio Value="@("TCP")" Color="Color.Primary">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1"><b>TCP/IP</b> – Rete Ethernet / Wi-Fi</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">La stampante è connessa in rete e accessibile via indirizzo IP (porta 9100)</MudText>
                        </MudStack>
                    </MudRadio>
                </MudPaper>
                <MudPaper Class="pa-4" Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudRadio Value="@("Serial")" Color="Color.Primary">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1"><b>Seriale RS232</b> – Porta COM</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">La stampante è connessa direttamente via cavo seriale (COM1, /dev/ttyUSB0, ecc.)</MudText>
                        </MudStack>
                    </MudRadio>
                </MudPaper>
                <MudPaper Class="pa-4" Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudRadio Value="@("UsbViaAgent")" Color="Color.Primary">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1"><b>USB via Agente</b> – EventForge UpdateAgent</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">La stampante è connessa via USB al client; il server la raggiunge tramite l'agente installato</MudText>
                        </MudStack>
                    </MudRadio>
                </MudPaper>
                <MudPaper Class="pa-4" Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudRadio Value="@("NetworkShare")" Color="Color.Primary">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1"><b>Condivisione di Rete</b> – Windows Network Share</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">La stampante è condivisa sulla rete locale Windows (\\server\stampante)</MudText>
                        </MudStack>
                    </MudRadio>
                </MudPaper>
            </MudStack>
        </MudRadioGroup>

        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-6">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="@(() => _activeStep = 1)">
                Avanti
            </MudButton>
        </MudStack>
    </MudPaper>
}

@* ══════════════════════════════════════════════════════════════
   STEP 1 – TCP / Serial / UsbViaAgent / NetworkShare config
   ══════════════════════════════════════════════════════════════ *@
@if (_activeStep == 1)
{
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        @if (_connectionType == "TCP")
        {
            @* ── TCP config ── *@
            <MudText Typo="Typo.subtitle1" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Wifi" Class="mr-2" />
                Configurazione TCP/IP
            </MudText>

            <MudGrid>
                <MudItem xs="12">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Search"
                               OnClick="ScanNetworkAsync"
                               Disabled="@_isScanRunning">
                        @if (_isScanRunning)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Scansione in corso...</span>
                        }
                        else
                        {
                            <span>Trova Stampanti in Rete</span>
                        }
                    </MudButton>
                </MudItem>

                @if (_scanResults is not null && _scanResults.Count > 0)
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Class="mb-2">@_scanResults.Count stampant@(_scanResults.Count == 1 ? "e trovata" : "i trovate") — clicca per selezionare</MudText>
                        <MudTable T="NetworkScanResultDto" Items="_scanResults" Dense="true" Hover="true" Striped="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>IP</MudTh>
                                <MudTh>Porta</MudTh>
                                <MudTh>RTT</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.IpAddress</MudTd>
                                <MudTd>@context.Port</MudTd>
                                <MudTd>@context.RoundTripMs ms</MudTd>
                                <MudTd>
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                               OnClick="@(() => SelectDiscoveredPrinter(context))">
                                        Seleziona
                                    </MudButton>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudItem>
                }
                else if (_scanResults is not null && _scanResults.Count == 0)
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Info" Dense="true">Nessuna stampante trovata nella rete locale. Inserisci l'IP manualmente.</MudAlert>
                    </MudItem>
                }

                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="_tcpIpAddress"
                                  Label="Indirizzo IP *"
                                  Variant="Variant.Outlined"
                                  Placeholder="es. 192.168.1.100"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Router" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField T="int" @bind-Value="_tcpPort"
                                     Label="Porta *"
                                     Variant="Variant.Outlined"
                                     Min="1" Max="65535" />
                </MudItem>
                @if (_protocolType == "Epson")
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_usbDeviceId"
                                      Label="Device ID Epson"
                                      Variant="Variant.Outlined"
                                      Placeholder="local_printer"
                                      HelperText="Identificativo dispositivo configurato sul server web della stampante (default: local_printer)"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Print" />
                    </MudItem>
                }
            </MudGrid>

            @if (_testConnectionResult is not null)
            {
                <MudAlert Severity="@(_testConnectionResult.Success ? Severity.Success : Severity.Error)"
                          Dense="true" Class="mt-3">
                    @(_testConnectionResult.Success
                        ? "✅ Connessione riuscita! La stampante risponde."
                        : $"❌ Connessione fallita: {_testConnectionResult.ErrorMessage}")
                </MudAlert>
            }

            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
                <MudButton Variant="Variant.Text" OnClick="@(() => _activeStep = 0)"
                           StartIcon="@Icons.Material.Filled.ArrowBack">
                    Indietro
                </MudButton>
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.NetworkCheck"
                               OnClick="TestTcpAsync"
                               Disabled="@(_isTesting || string.IsNullOrWhiteSpace(_tcpIpAddress))">
                        @if (_isTesting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Test Connessione
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               EndIcon="@Icons.Material.Filled.ArrowForward"
                               OnClick="AdvanceFromStep1Tcp"
                               Disabled="@(!_isEditMode && !(_testConnectionResult?.Success ?? false))">
                        Avanti
                    </MudButton>
                </MudStack>
            </MudStack>
        }
        else if (_connectionType == "Serial")
        {
            @* ── Serial config ── *@
            <MudText Typo="Typo.subtitle1" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Cable" Class="mr-2" />
                Configurazione Seriale RS232
            </MudText>

            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" @bind-Value="_serialPortName"
                               Label="Porta Seriale *"
                               Variant="Variant.Outlined"
                               AdornmentIcon="@Icons.Material.Filled.Cable">
                        <MudSelectItem Value="@("COM1")">COM1</MudSelectItem>
                        <MudSelectItem Value="@("COM2")">COM2</MudSelectItem>
                        <MudSelectItem Value="@("COM3")">COM3</MudSelectItem>
                        <MudSelectItem Value="@("COM4")">COM4</MudSelectItem>
                        <MudSelectItem Value="@("/dev/ttyS0")">/dev/ttyS0</MudSelectItem>
                        <MudSelectItem Value="@("/dev/ttyUSB0")">/dev/ttyUSB0</MudSelectItem>
                        <MudSelectItem Value="@("/dev/ttyUSB1")">/dev/ttyUSB1</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="int" @bind-Value="_serialBaudRate"
                               Label="Baud Rate *"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="9600">9600</MudSelectItem>
                        <MudSelectItem Value="19200">19200</MudSelectItem>
                        <MudSelectItem Value="38400">38400</MudSelectItem>
                        <MudSelectItem Value="57600">57600</MudSelectItem>
                        <MudSelectItem Value="115200">115200</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>

            @if (_testConnectionResult is not null)
            {
                <MudAlert Severity="@(_testConnectionResult.Success ? Severity.Success : Severity.Error)"
                          Dense="true" Class="mt-3">
                    @(_testConnectionResult.Success
                        ? "✅ Connessione seriale riuscita!"
                        : $"❌ Connessione fallita: {_testConnectionResult.ErrorMessage}")
                </MudAlert>
            }

            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
                <MudButton Variant="Variant.Text" OnClick="@(() => _activeStep = 0)"
                           StartIcon="@Icons.Material.Filled.ArrowBack">
                    Indietro
                </MudButton>
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.NetworkCheck"
                               OnClick="TestSerialAsync"
                               Disabled="@(_isTesting || string.IsNullOrWhiteSpace(_serialPortName))">
                        @if (_isTesting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Test Connessione
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               EndIcon="@Icons.Material.Filled.ArrowForward"
                               OnClick="AdvanceFromStep1Serial"
                               Disabled="@(!_isEditMode && !(_testConnectionResult?.Success ?? false))">
                        Avanti
                    </MudButton>
                </MudStack>
            </MudStack>
        }
        else
        {
            @* ── UsbViaAgent / NetworkShare config ── *@
            <MudText Typo="Typo.subtitle1" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Usb" Class="mr-2" />
                @(_connectionType == "UsbViaAgent" ? "Configurazione USB via Agente" : "Configurazione Condivisione di Rete")
            </MudText>

            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_agentId"
                                  Label="ID Agente UpdateAgent"
                                  Variant="Variant.Outlined"
                                  Placeholder="es. 00000000-0000-0000-0000-000000000001"
                                  HelperText="GUID dell'agente UpdateAgent registrato nel sistema" />
                </MudItem>
                @if (_connectionType == "UsbViaAgent")
                {
                    <MudItem xs="12" md="6">
                        <div class="d-flex align-center gap-2">
                            <MudAutocomplete T="string"
                                             @bind-Value="_usbDeviceId"
                                             Label="Stampante di sistema (USB)"
                                             Variant="Variant.Outlined"
                                             SearchFunc="@SearchSystemPrinters"
                                             ResetValueOnEmptyText="false"
                                             CoerceValue="true"
                                             HelperText="Seleziona dalla lista o digita manualmente l'ID dispositivo"
                                             Placeholder="es. Microsoft Print to PDF" />
                            <MudTooltip Text="Carica stampanti installate sull'agente">
                                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                               Color="Color.Primary"
                                               OnClick="LoadAgentSystemPrintersAsync"
                                               Disabled="_loadingAgentPrinters" />
                            </MudTooltip>
                        </div>
                        @if (_loadingAgentPrinters)
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" Style="width:14px;height:14px;display:inline-block;" />
                                Caricamento stampanti dall'agente...
                            </MudText>
                        }
                        else if (_agentSystemPrinters.Count > 0)
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                @_agentSystemPrinters.Count stampant@(_agentSystemPrinters.Count == 1 ? "e" : "i") trovat@(_agentSystemPrinters.Count == 1 ? "a" : "e") sull'agente
                            </MudText>
                        }
                        else if (_agentSystemPrintersLoaded)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-1">
                                Nessuna stampante trovata. Verifica che l'agente sia in esecuzione e l'ID sia corretto.
                            </MudText>
                        }
                    </MudItem>
                }
                else
                {
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_usbDeviceId"
                                      Label="Percorso Condivisione di Rete"
                                      Variant="Variant.Outlined"
                                      Placeholder="es. \\server\stampante"
                                      HelperText="Percorso UNC della stampante condivisa" />
                    </MudItem>
                }
            </MudGrid>

            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
                <MudButton Variant="Variant.Text" OnClick="@(() => _activeStep = 0)"
                           StartIcon="@Icons.Material.Filled.ArrowBack">
                    Indietro
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           OnClick="AdvanceFromStep1Agent">
                    Avanti
                </MudButton>
            </MudStack>
        }
    </MudPaper>
}

@* ══════════════════════════════════════════════════════════════
   STEP 2 – Info Stampante
   ══════════════════════════════════════════════════════════════ *@
@if (_activeStep == 2)
{
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        <MudText Typo="Typo.subtitle1" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
            Informazioni Stampante
        </MudText>

        @if (_printerInfo is null)
        {
            <MudAlert Severity="Severity.Info">
                Caricamento informazioni stampante in corso...
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-2" />
            </MudAlert>
        }
        else if (!_printerInfo.IsOnline)
        {
            <MudAlert Severity="Severity.Error">
                Non è stato possibile leggere le informazioni: @(_printerInfo.ErrorMessage ?? "connessione fallita")
            </MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField Value="@(_printerInfo.Model ?? "—")" Label="Modello" ReadOnly="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField Value="@(_printerInfo.FirmwareVersion ?? "—")" Label="Versione Firmware" ReadOnly="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField Value="@(_printerInfo.FiscalSerialNumber ?? "—")" Label="Matricola Fiscale" ReadOnly="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    @if (_printerInfo.FiscalMemoryUsedPercent.HasValue)
                    {
                        <MudField Label="Memoria Fiscale Utilizzata" Variant="Variant.Outlined">
                            <MudProgressLinear Value="@((double)_printerInfo.FiscalMemoryUsedPercent.Value)"
                                              Max="100"
                                              Color="@(_printerInfo.FiscalMemoryUsedPercent > 90 ? Color.Error : _printerInfo.FiscalMemoryUsedPercent > 70 ? Color.Warning : Color.Success)"
                                              Class="mt-1" />
                            <MudText Typo="Typo.caption">@_printerInfo.FiscalMemoryUsedPercent.Value:F1%</MudText>
                        </MudField>
                    }
                    else
                    {
                        <MudTextField Value="@("N/D")" Label="Memoria Fiscale Utilizzata" ReadOnly="true" Variant="Variant.Outlined" />
                    }
                </MudItem>
            </MudGrid>
        }

        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
            <MudButton Variant="Variant.Text" OnClick="@(() => _activeStep = 1)"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Indietro
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="@(() => _activeStep = 3)"
                       Disabled="@(_printerInfo is null)">
                Avanti
            </MudButton>
        </MudStack>
    </MudPaper>
}

@* ══════════════════════════════════════════════════════════════
   STEP 3 – Configurazione Base
   ══════════════════════════════════════════════════════════════ *@
@if (_activeStep == 3)
{
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        <MudText Typo="Typo.subtitle1" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.TextFields" Class="mr-2" />
            Configurazione Base
        </MudText>

        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_printerName"
                              Label="Nome Stampante *"
                              Variant="Variant.Outlined"
                              Placeholder="es. Stampante Fiscale Cassa 1"
                              HelperText="Nome descrittivo per identificare la stampante nel sistema"
                              Required="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_printerLocation"
                              Label="Posizione Fisica"
                              Variant="Variant.Outlined"
                              Placeholder="es. Cassa principale, piano terra" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="string" Value="_protocolType"
                           Label="Protocollo *"
                           Variant="Variant.Outlined"
                           HelperText="Seleziona il protocollo di comunicazione della stampante"
                           ValueChanged="OnProtocolTypeChanged">
                    <MudSelectItem Value="@("Custom")">Custom (Stampante Fiscale Custom – seriale/USB/TCP)</MudSelectItem>
                    <MudSelectItem Value="@("Epson")">Epson WebAPI (TM-T88, TM-m30, TM-m50 – rete)</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
            <MudButton Variant="Variant.Text" OnClick="@(() => _activeStep = 2)"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Indietro
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="AdvanceFromStep3"
                       Disabled="@string.IsNullOrWhiteSpace(_printerName)">
                Avanti
            </MudButton>
        </MudStack>
    </MudPaper>
}

@* ══════════════════════════════════════════════════════════════
   STEP 4 (NEW) – Tipo Stampante
   ══════════════════════════════════════════════════════════════ *@
@if (_activeStep == 4)
{
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        <MudText Typo="Typo.subtitle1" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Print" Class="mr-2" />
            Tipo Stampante
        </MudText>

        @if (_printerCategory == PrinterCategory.Fiscal)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                💡 Per le stampanti fiscali vengono applicati valori predefiniti: Termica = Sì, Larghezza carta = 80mm, Linguaggio = ESC/POS
            </MudAlert>
        }

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudSelect T="PrinterCategory" @bind-Value="_printerCategory"
                           Label="Categoria Stampante *"
                           Variant="Variant.Outlined"
                           @bind-Value:after="@(() => OnCategoryChanged(_printerCategory))"
                           HelperText="Seleziona la funzione principale della stampante">
                    <MudSelectItem Value="PrinterCategory.Fiscal">Fiscale (con memoria fiscale)</MudSelectItem>
                    <MudSelectItem Value="PrinterCategory.Receipt">Scontrino non fiscale (termica)</MudSelectItem>
                    <MudSelectItem Value="PrinterCategory.KDS">KDS – Kitchen Display / Cucina</MudSelectItem>
                    <MudSelectItem Value="PrinterCategory.Label">Etichette (barcode, prezzi)</MudSelectItem>
                    <MudSelectItem Value="PrinterCategory.Report">Report / Documenti</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudField Label="Stampa Termica" Variant="Variant.Outlined">
                    <MudCheckBox T="bool" @bind-Value="_isThermal" Color="Color.Primary"
                                 Label="Stampante termica (carta termica, no inchiostro)" />
                </MudField>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudNumericField T="int?" @bind-Value="_printerWidth"
                                 Label="Caratteri per riga (es. 42, 58, 80)"
                                 Variant="Variant.Outlined"
                                 Min="10" Max="200"
                                 HelperText="Larghezza di stampa in caratteri (opzionale)" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="PaperWidth?" @bind-Value="_paperWidth"
