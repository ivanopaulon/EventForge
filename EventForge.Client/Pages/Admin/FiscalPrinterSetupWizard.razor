    private async Task PrintTestReceiptAsync()
    {
        var printerIdForTest = _savedPrinterId ?? (_isEditMode ? PrinterId : null);
        if (printerIdForTest is null)
        {
            AppNotification.ShowInfo("Salva prima la configurazione per stampare uno scontrino di test.");
            return;
        }

        _isTestPrinting = true;
        try
        {
            var testReceipt = new FiscalReceiptData
            {
                Items = [new FiscalReceiptItem { Description = "SCONTRINO DI PROVA", Quantity = 1, UnitPrice = 0.01m, VatCode = 1, Department = 1 }],
                Payments = [new FiscalPayment { Amount = 0.01m, MethodCode = 1, Description = "Contanti" }]
            };
            _testPrintResult = await FiscalPrintingService.PrintReceiptAsync(printerIdForTest.Value, testReceipt);
        }
        finally
        {
            _isTestPrinting = false;
        }
    }

    private async Task SaveConfigurationAsync()
    {
        _isSaving = true;
        _saveError = null;
        try
        {
            var agentGuid = Guid.TryParse(_agentId, out var g) ? g : (Guid?)null;

            var setup = new FiscalPrinterSetupDto
            {
                ConnectionType = _connectionType,
                IpAddress = _connectionType == "TCP" ? _tcpIpAddress : null,
                TcpPort = _connectionType == "TCP" ? _tcpPort : null,
                SerialPortName = _connectionType == "Serial" ? _serialPortName : null,
                BaudRate = _connectionType == "Serial" ? _serialBaudRate : null,
                AgentId = _connectionType == "UsbViaAgent" ? agentGuid : null,
                UsbDeviceId = (_connectionType == "UsbViaAgent" || _protocolType == "Epson")
                    ? _usbDeviceId
                    : null,
                Name = _printerName,
                Location = _printerLocation,
                ProtocolType = _protocolType,
                Category = _printerCategory,
                IsThermal = _isThermal,
                PrinterWidth = _printerWidth,
                PaperWidth = _paperWidth,
                PrintLanguage = _printLanguage,
                VatFiscalCodeOverrides = _vatMappingRows.ToDictionary(r => r.Id, r => r.FiscalCode),
                PaymentFiscalCodeOverrides = _paymentMappingRows.ToDictionary(r => r.Id, r => r.FiscalCode),
                AssociatedStationIds = _stationRows.Where(r => r.Selected).Select(r => r.Id).ToList()
            };

            PrinterDto? printer;
            if (_isEditMode)
            {
                printer = await FiscalPrintingService.UpdateSetupAsync(PrinterId!.Value, setup);
            }
            else
            {
                printer = await FiscalPrintingService.SaveSetupAsync(setup);
            }

            if (printer is null)
            {
                _saveError = _isEditMode
                    ? "Errore nell'aggiornamento della configurazione. Riprova."
                    : "Errore nel salvataggio della configurazione. Riprova.";
                return;
            }

            _savedPrinterId = printer.Id;
            AppNotification.ShowSuccess(_isEditMode
                ? $"Stampante '{printer.Name}' aggiornata con successo!"
                : $"Stampante '{printer.Name}' configurata con successo!");

            await Task.Delay(1500);
            NavigationManager.NavigateTo("/admin/fiscal-printers");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "SaveConfigurationAsync failed");
            _saveError = $"Errore imprevisto: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

