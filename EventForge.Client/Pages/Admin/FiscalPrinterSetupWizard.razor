@* ══════════════════════════════════════════════════════════════
   STEP 7 – Test Finale & Salva (was 6)
   ══════════════════════════════════════════════════════════════ *@
@if (_activeStep == 7)
{
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        <MudText Typo="Typo.subtitle1" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" />
            Test Finale e @(_isEditMode ? "Aggiornamento" : "Salvataggio")
        </MudText>

        @* Riepilogo configurazione *@
        <MudExpansionPanels Elevation="0" Class="mb-4">
            <MudExpansionPanel Text="Riepilogo Configurazione" Icon="@Icons.Material.Filled.Summarize">
                <MudGrid Dense="true">
                    <MudItem xs="6"><MudText Typo="Typo.caption">Nome</MudText><MudText>@_printerName</MudText></MudItem>
                    <MudItem xs="6"><MudText Typo="Typo.caption">Protocollo</MudText><MudText>@_protocolType</MudText></MudItem>
                    <MudItem xs="6"><MudText Typo="Typo.caption">Connessione</MudText>
                        <MudText>@GetConnectionSummary()</MudText>
                    </MudItem>
                    @if (_protocolType == "Epson" && !string.IsNullOrWhiteSpace(_usbDeviceId))
                    {
                        <MudItem xs="6"><MudText Typo="Typo.caption">Device ID Epson</MudText><MudText>@_usbDeviceId</MudText></MudItem>
                    }
                    <MudItem xs="6"><MudText Typo="Typo.caption">Posizione</MudText><MudText>@(_printerLocation ?? "—")</MudText></MudItem>
                    <MudItem xs="6"><MudText Typo="Typo.caption">Categoria</MudText><MudText>@_printerCategory</MudText></MudItem>
                    <MudItem xs="6"><MudText Typo="Typo.caption">POS Associati</MudText>
                        <MudText>@(_stationRows.Count(r => r.Selected))</MudText>
                    </MudItem>
                </MudGrid>
            </MudExpansionPanel>
        </MudExpansionPanels>

        @* Test scontrino *@
        <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Class="mb-2">Stampa Scontrino di Test</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    @if (_isEditMode)
                    {
                        <span>Puoi stampare uno scontrino di prova sulla stampante esistente prima di aggiornare la configurazione.</span>
                    }
                    else
                    {
                        <span>Prima del salvataggio, è consigliato stampare uno scontrino di prova per verificare la corretta comunicazione con la stampante.</span>
                    }
                </MudText>

                @if (_testPrintResult is not null)
                {
                    <MudAlert Severity="@(_testPrintResult.Success ? Severity.Success : Severity.Error)"
                              Dense="true" Class="mb-2">
                        @(_testPrintResult.Success
                            ? $"✅ Scontrino di test stampato! Numero: {_testPrintResult.ReceiptNumber}"
                            : $"❌ Stampa fallita: {_testPrintResult.ErrorMessage}")
                    </MudAlert>
                }

                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Print"
                           OnClick="PrintTestReceiptAsync"
                           Disabled="@_isTestPrinting">
                    @if (_isTestPrinting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Stampa Scontrino di Test
                </MudButton>
            </MudCardContent>
        </MudCard>

        @if (_saveError is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_saveError</MudAlert>
        }

        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
            <MudButton Variant="Variant.Text" OnClick="@(() => _activeStep = 6)"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Indietro
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveConfigurationAsync"
                       Disabled="@_isSaving">
                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>@(_isEditMode ? "Aggiornamento..." : "Salvataggio...")</span>
                }
                else
                {
                    <span>@(_isEditMode ? "Aggiorna Configurazione" : "Salva Configurazione")</span>
                }
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    // ──────────────────────────────────────────────────────────
    //  Parameters
    // ──────────────────────────────────────────────────────────

    [Parameter] public Guid? PrinterId { get; set; }

    // ──────────────────────────────────────────────────────────
    //  State
    // ──────────────────────────────────────────────────────────

    private MudStepper? _stepper;
    private int _activeStep;
    private bool _isEditMode => PrinterId.HasValue;

    // Step 0
    private string _connectionType = "TCP";

    // Step 1 – TCP
    private string _tcpIpAddress = string.Empty;
    private int _tcpPort = 9100;
    private bool _isScanRunning;
    private List<NetworkScanResultDto>? _scanResults;

    // Step 1 – Serial
    private string _serialPortName = "COM1";
    private int _serialBaudRate = 9600;

    // Step 1 – UsbViaAgent / NetworkShare
    private string _agentId = string.Empty;
    private string _usbDeviceId = string.Empty;
    private List<string> _agentSystemPrinters = [];
    private bool _loadingAgentPrinters;
    private bool _agentSystemPrintersLoaded;

    // Step 1 – shared
    private bool _isTesting;
    private FiscalPrintResult? _testConnectionResult;

    // Step 2 – printer info
    private FiscalPrinterInfoDto? _printerInfo;

    // Step 3 – base config
    private string _printerName = string.Empty;
    private string? _printerLocation;
    private string _protocolType = "Custom";

    // Step 4 – printer type
    private PrinterCategory _printerCategory = PrinterCategory.Receipt;
    private bool _isThermal;
    private int? _printerWidth;
    private PaperWidth? _paperWidth;
    private PrintLanguage? _printLanguage;

    // Step 5 – fiscal mapping
    private List<VatRateDto> _vatRates = new();
    private List<PaymentMethodDto> _paymentMethods = new();
    private List<VatMappingRow> _vatMappingRows = new();
    private List<PaymentMappingRow> _paymentMappingRows = new();

    // Step 6 – POS association
    private List<StationDto> _stations = new();
    private List<StationSelectionRow> _stationRows = new();

    // Step 7 – test print & save
    private bool _isTestPrinting;
    private FiscalPrintResult? _testPrintResult;
    private bool _isSaving;
    private string? _saveError;
    private Guid? _savedPrinterId;

    // ──────────────────────────────────────────────────────────
    //  Breadcrumbs
    // ──────────────────────────────────────────────────────────

    private List<BreadcrumbItem> _breadcrumbs = new();

    // ──────────────────────────────────────────────────────────
    //  Lifecycle
    // ──────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new BreadcrumbItem("Home", href: "/"),
            new BreadcrumbItem("Stampanti Fiscali", href: "/admin/fiscal-printers"),
            new BreadcrumbItem(_isEditMode ? "Modifica Wizard" : "Nuovo Wizard", href: null, disabled: true)
        ];

        var vatTask = FinancialService.GetVatRatesAsync(1, 100);
        var paymentTask = PaymentMethodService.GetAllAsync();
        var stationsTask = HttpClientService.GetAsync<PagedResult<StationDto>>(
            "api/v1/stations?page=1&pageSize=100");

        Task<FiscalPrinterSetupDto?>? setupTask = null;

        if (_isEditMode)
        {
            setupTask = FiscalPrintingService.GetSetupAsync(PrinterId!.Value);
            await Task.WhenAll(vatTask, paymentTask, stationsTask, setupTask);
            PopulateFromSetup(setupTask.Result);
            _savedPrinterId = PrinterId;
            // In edit mode, printer info step is bypassed; provide a placeholder so the step is not blocked
            _printerInfo = new FiscalPrinterInfoDto { IsOnline = true };
        }
        else
        {
            await Task.WhenAll(vatTask, paymentTask, stationsTask);
        }

        var vatResult = vatTask.Result;
        _vatRates = vatResult?.Items?.ToList() ?? new();
        _vatMappingRows = _vatRates.Select(v => new VatMappingRow
        {
            Id = v.Id,
            Name = v.Name,
            Percentage = v.Percentage,
            FiscalCode = v.FiscalCode ?? GetSuggestedVatCode(v.Percentage),
            SuggestedCode = GetSuggestedVatCode(v.Percentage)
        }).ToList();

        _paymentMethods = paymentTask.Result?.ToList() ?? new();
        _paymentMappingRows = _paymentMethods.Select(p => new PaymentMappingRow
        {
            Id = p.Id,
            Code = p.Code,
            Name = p.Name,
            FiscalCode = p.FiscalCode ?? GetSuggestedPaymentCode(p.Code),
            SuggestedCode = GetSuggestedPaymentCode(p.Code)
        }).ToList();

        _stations = stationsTask.Result?.Items?.ToList() ?? new();
        _stationRows = _stations.Select(s => new StationSelectionRow
        {
            Id = s.Id,
            Name = s.Name,
            Location = s.Location,
            StationType = s.StationType
        }).ToList();

        // In edit mode, pre-select stations already associated with this printer
        if (_isEditMode && _savedPrinterId.HasValue)
        {
            var associatedIds = (setupTask?.Result?.AssociatedStationIds ?? new()).ToHashSet();
            foreach (var row in _stationRows)
                row.Selected = associatedIds.Contains(row.Id);
        }
    }

    private void PopulateFromSetup(FiscalPrinterSetupDto? setup)
    {
        if (setup is null) return;

        _connectionType = setup.ConnectionType;
        _tcpIpAddress = setup.IpAddress ?? string.Empty;
        _tcpPort = setup.TcpPort ?? 9100;
        _serialPortName = setup.SerialPortName ?? "COM1";
        _serialBaudRate = setup.BaudRate ?? 9600;
        _agentId = setup.AgentId?.ToString() ?? string.Empty;
        _usbDeviceId = setup.UsbDeviceId ?? string.Empty;
        _printerName = setup.Name;
        _printerLocation = setup.Location;
        _protocolType = setup.ProtocolType;
        _printerCategory = setup.Category;
        _isThermal = setup.IsThermal;
        _printerWidth = setup.PrinterWidth;
        _paperWidth = setup.PaperWidth;
        _printLanguage = setup.PrintLanguage;
    }

    // ──────────────────────────────────────────────────────────
    //  Step 1 – TCP
    // ──────────────────────────────────────────────────────────

    private async Task ScanNetworkAsync()
    {
        if (string.IsNullOrWhiteSpace(_tcpIpAddress))
        {
            _isScanRunning = true;
            StateHasChanged();
            _scanResults = await FiscalPrintingService.ScanNetworkAsync("192.168.1", _tcpPort, 300);
        }
        else
        {
            var parts = _tcpIpAddress.Split('.');
            var subnet = parts.Length >= 3 ? string.Join('.', parts[0], parts[1], parts[2]) : "192.168.1";
            _isScanRunning = true;
            StateHasChanged();
            _scanResults = await FiscalPrintingService.ScanNetworkAsync(subnet, _tcpPort, 300);
        }

        _isScanRunning = false;
    }

    private void SelectDiscoveredPrinter(NetworkScanResultDto result)
    {
        _tcpIpAddress = result.IpAddress;
        _tcpPort = result.Port;
        _testConnectionResult = null;
    }

    private async Task TestTcpAsync()
    {
        _isTesting = true;
        _testConnectionResult = null;
        try
        {
            _testConnectionResult = await FiscalPrintingService.TestTcpConnectionAsync(_tcpIpAddress, _tcpPort);
        }
        finally
        {
            _isTesting = false;
        }
    }

    private async Task AdvanceFromStep1Tcp()
    {
        _activeStep = 2;
        await LoadPrinterInfoAsync();
    }

    // ──────────────────────────────────────────────────────────
    //  Step 1 – Serial
    // ──────────────────────────────────────────────────────────

    private async Task TestSerialAsync()
    {
        _isTesting = true;
        _testConnectionResult = null;
        try
        {
            _testConnectionResult = await FiscalPrintingService.TestSerialConnectionAsync(
                _serialPortName, _serialBaudRate);
        }
        finally
        {
            _isTesting = false;
        }
    }

    private async Task AdvanceFromStep1Serial()
    {
        _activeStep = 2;
        _printerInfo = new FiscalPrinterInfoDto { IsOnline = true };
    }

    // ──────────────────────────────────────────────────────────
    //  Step 1 – UsbViaAgent / NetworkShare
    // ──────────────────────────────────────────────────────────

    private async Task AdvanceFromStep1Agent()
    {
        _activeStep = 2;
        _printerInfo = new FiscalPrinterInfoDto { IsOnline = true };
        await Task.CompletedTask;
    }

    private async Task LoadAgentSystemPrintersAsync()
    {
        if (!Guid.TryParse(_agentId, out var agentGuid))
        {
            Logger.LogWarning("Cannot load agent printers: '{AgentId}' is not a valid GUID", _agentId);
            return;
        }

        _loadingAgentPrinters = true;
        _agentSystemPrintersLoaded = false;
        StateHasChanged();

        try
        {
            _agentSystemPrinters = await FiscalPrintingService.GetAgentSystemPrintersAsync(agentGuid);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load agent system printers for agent {AgentId}", agentGuid);
            _agentSystemPrinters = [];
        }
        finally
        {
            _loadingAgentPrinters = false;
            _agentSystemPrintersLoaded = true;
            StateHasChanged();
        }
    }

    private Task<IEnumerable<string>> SearchSystemPrinters(string? value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<string>>(_agentSystemPrinters);

        var filtered = _agentSystemPrinters
            .Where(p => p.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(filtered);
    }

    // ──────────────────────────────────────────────────────────
    //  Step 2 – Printer info
    // ──────────────────────────────────────────────────────────

    private async Task LoadPrinterInfoAsync()
    {
        _printerInfo = null;
        StateHasChanged();
        _printerInfo = await FiscalPrintingService.GetPrinterInfoByAddressAsync(_tcpIpAddress, _tcpPort);
    }

    // ──────────────────────────────────────────────────────────
    //  Step 3 – Base config
    // ──────────────────────────────────────────────────────────

    private void AdvanceFromStep3()
    {
        if (string.IsNullOrWhiteSpace(_printerName) && _printerInfo?.Model is not null)
            _printerName = $"Stampante Fiscale – {_printerInfo.Model}";
        _activeStep = 4;
    }

    private void OnProtocolTypeChanged(string newProtocol)
    {
        _protocolType = newProtocol;

        // When Epson WebAPI is selected, enforce TCP as connection type
        // and default the port to 80 (embedded web server port).
        if (string.Equals(newProtocol, "Epson", StringComparison.OrdinalIgnoreCase))
        {
            _connectionType = "TCP";
            if (_tcpPort is 0 or 9100)
                _tcpPort = 80;
        }
        else if (string.Equals(newProtocol, "Custom", StringComparison.OrdinalIgnoreCase))
        {
            if (_tcpPort is 0 or 80)
                _tcpPort = 9100;
        }
    }

    // ──────────────────────────────────────────────────────────
    //  Step 4 – Printer type
    // ──────────────────────────────────────────────────────────

    private void OnCategoryChanged(PrinterCategory newCategory)
    {
        if (newCategory == PrinterCategory.Fiscal)
        {
            _isThermal = true;
            _paperWidth = PaperWidth.Mm80;
            _printLanguage = PrintLanguage.EscPos;
        }
    }

    // ──────────────────────────────────────────────────────────
    //  Step 5 – Fiscal mapping
    // ──────────────────────────────────────────────────────────

    private void ApplyVatSuggestions()
    {
        foreach (var row in _vatMappingRows)
            row.FiscalCode = row.SuggestedCode;
    }

    private void ApplyPaymentSuggestions()
    {
        foreach (var row in _paymentMappingRows)
            row.FiscalCode = row.SuggestedCode;
    }

    private static int GetSuggestedVatCode(decimal percentage) => percentage switch
    {
        22m or 21m or 20m => 1,
        10m => 2,
        >= 4m and <= 5m => 3,
        0m => 4,
        _ => 1
    };

    private static int GetSuggestedPaymentCode(string code)
    {
        var upper = code?.ToUpperInvariant() ?? string.Empty;
        if (upper.Contains("CASH") || upper.Contains("CONT") || upper.Contains("CASSA")) return 1;
        if (upper.Contains("CHECK") || upper.Contains("ASS")) return 2;
        if (upper.Contains("CREDIT") || upper.Contains("DEBIT")
            || upper.Contains("CARD") || upper.Contains("POS")
            || upper.Contains("VISA") || upper.Contains("MASTER")) return 4;
        if (upper.Contains("TICKET") || upper.Contains("VOUCHER")) return 5;
        return 1;
    }

