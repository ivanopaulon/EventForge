                           HelperText="Larghezza della carta in millimetri (opzionale)"
                           Clearable="true">
                    <MudSelectItem T="PaperWidth?" Value="null">— Nessuna —</MudSelectItem>
                    <MudSelectItem T="PaperWidth?" Value="PaperWidth.Mm57">57 mm</MudSelectItem>
