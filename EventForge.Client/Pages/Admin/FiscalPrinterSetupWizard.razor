@namespace EventForge.Client.Pages.FiscalAdmin
@page "/admin/fiscal-printers/setup"
@using EventForge.DTOs.FiscalPrinting
@using EventForge.DTOs.Station
@using EventForge.DTOs.VatRates
@using EventForge.DTOs.Sales
@using EventForge.DTOs.Store
@using EventForge.DTOs.Common
@using EventForge.Client.Services
@using EventForge.Client.Services.Sales
@using MudBlazor
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject IFiscalPrintingService FiscalPrintingService
@inject IFinancialService FinancialService
@inject IPaymentMethodService PaymentMethodService
@inject IHttpClientService HttpClientService
@inject IAppNotificationService AppNotification
@inject NavigationManager NavigationManager
@inject ILogger<FiscalPrinterSetupWizard> Logger

<PageTitle>Wizard Configurazione Stampante Fiscale</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 pa-0" />

<MudText Typo="Typo.h5" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Outlined.Print" Class="mr-2 mb-1" Style="vertical-align:middle;" />
    Configurazione Stampante Fiscale
</MudText>

@* ──────────────────── STEP INDICATOR ──────────────────── *@
<MudStepper @ref="_stepper" @bind-ActiveStepIndex="_activeStep" Linear="true" Class="mb-4">
    <MudStep Title="Connessione"         Icon="@Icons.Material.Filled.SettingsEthernet" />
    <MudStep Title="Impostazioni"        Icon="@Icons.Material.Filled.Tune" />
    <MudStep Title="Info Stampante"      Icon="@Icons.Material.Filled.Info" />
    <MudStep Title="Configurazione Base" Icon="@Icons.Material.Filled.TextFields" />
    <MudStep Title="Codici Fiscali"      Icon="@Icons.Material.Filled.Code" />
    <MudStep Title="Associa POS"         Icon="@Icons.Material.Filled.PointOfSale" />
    <MudStep Title="Test &amp; Salva"    Icon="@Icons.Material.Filled.CheckCircle" />
</MudStepper>

@* ══════════════════════════════════════════════════════════════
   STEP 0 – Tipo Connessione
   ══════════════════════════════════════════════════════════════ *@
@if (_activeStep == 0)
{
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        <MudText Typo="Typo.subtitle1" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.SettingsEthernet" Class="mr-2" />
            Seleziona il tipo di connessione della stampante fiscale
        </MudText>

        <MudRadioGroup T="string" @bind-Value="_connectionType">
            <MudStack Spacing="3">
                <MudPaper Class="pa-4" Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudRadio Value="@("TCP")" Color="Color.Primary">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1"><b>TCP/IP</b> – Rete Ethernet / Wi-Fi</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">La stampante è connessa in rete e accessibile via indirizzo IP (porta 9100)</MudText>
                        </MudStack>
                    </MudRadio>
                </MudPaper>
                <MudPaper Class="pa-4" Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudRadio Value="@("Serial")" Color="Color.Primary">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1"><b>Seriale RS232</b> – Porta COM</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">La stampante è connessa direttamente via cavo seriale (COM1, /dev/ttyUSB0, ecc.)</MudText>
                        </MudStack>
                    </MudRadio>
                </MudPaper>
            </MudStack>
        </MudRadioGroup>

        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-6">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="@(() => _activeStep = 1)">
                Avanti
            </MudButton>
        </MudStack>
    </MudPaper>
}

@* ══════════════════════════════════════════════════════════════
   STEP 1 – TCP / Serial config
   ══════════════════════════════════════════════════════════════ *@
@if (_activeStep == 1)
{
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        @if (_connectionType == "TCP")
        {
            @* ── TCP config ── *@
            <MudText Typo="Typo.subtitle1" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Wifi" Class="mr-2" />
                Configurazione TCP/IP
            </MudText>

            <MudGrid>
                <MudItem xs="12">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Search"
                               OnClick="ScanNetworkAsync"
                               Disabled="@_isScanRunning">
                        @if (_isScanRunning)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Scansione in corso...</span>
                        }
                        else
                        {
                            <span>Trova Stampanti in Rete</span>
                        }
                    </MudButton>
                </MudItem>

                @if (_scanResults is not null && _scanResults.Count > 0)
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Class="mb-2">@_scanResults.Count stampant@(_scanResults.Count == 1 ? "e trovata" : "i trovate") — clicca per selezionare</MudText>
                        <MudTable T="NetworkScanResultDto" Items="_scanResults" Dense="true" Hover="true" Striped="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>IP</MudTh>
                                <MudTh>Porta</MudTh>
                                <MudTh>RTT</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.IpAddress</MudTd>
                                <MudTd>@context.Port</MudTd>
                                <MudTd>@context.RoundTripMs ms</MudTd>
                                <MudTd>
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                               OnClick="@(() => SelectDiscoveredPrinter(context))">
                                        Seleziona
                                    </MudButton>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudItem>
                }
                else if (_scanResults is not null && _scanResults.Count == 0)
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Info" Dense="true">Nessuna stampante trovata nella rete locale. Inserisci l'IP manualmente.</MudAlert>
                    </MudItem>
                }

                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="_tcpIpAddress"
                                  Label="Indirizzo IP *"
                                  Variant="Variant.Outlined"
                                  Placeholder="es. 192.168.1.100"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Router" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField T="int" @bind-Value="_tcpPort"
                                     Label="Porta *"
                                     Variant="Variant.Outlined"
                                     Min="1" Max="65535" />
                </MudItem>
            </MudGrid>

            @if (_testConnectionResult is not null)
            {
                <MudAlert Severity="@(_testConnectionResult.Success ? Severity.Success : Severity.Error)"
                          Dense="true" Class="mt-3">
                    @(_testConnectionResult.Success
                        ? "✅ Connessione riuscita! La stampante risponde."
                        : $"❌ Connessione fallita: {_testConnectionResult.ErrorMessage}")
                </MudAlert>
            }

            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
                <MudButton Variant="Variant.Text" OnClick="@(() => _activeStep = 0)"
                           StartIcon="@Icons.Material.Filled.ArrowBack">
                    Indietro
                </MudButton>
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.NetworkCheck"
                               OnClick="TestTcpAsync"
                               Disabled="@(_isTesting || string.IsNullOrWhiteSpace(_tcpIpAddress))">
                        @if (_isTesting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Test Connessione
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               EndIcon="@Icons.Material.Filled.ArrowForward"
                               OnClick="AdvanceFromStep1Tcp"
                               Disabled="@(!_testConnectionResult?.Success ?? true)">
                        Avanti
                    </MudButton>
                </MudStack>
            </MudStack>
        }
        else
        {
            @* ── Serial config ── *@
            <MudText Typo="Typo.subtitle1" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Cable" Class="mr-2" />
                Configurazione Seriale RS232
            </MudText>

            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" @bind-Value="_serialPortName"
                               Label="Porta Seriale *"
                               Variant="Variant.Outlined"
                               AdornmentIcon="@Icons.Material.Filled.Cable">
                        <MudSelectItem Value="@("COM1")">COM1</MudSelectItem>
                        <MudSelectItem Value="@("COM2")">COM2</MudSelectItem>
                        <MudSelectItem Value="@("COM3")">COM3</MudSelectItem>
                        <MudSelectItem Value="@("COM4")">COM4</MudSelectItem>
                        <MudSelectItem Value="@("/dev/ttyS0")">/dev/ttyS0</MudSelectItem>
                        <MudSelectItem Value="@("/dev/ttyUSB0")">/dev/ttyUSB0</MudSelectItem>
                        <MudSelectItem Value="@("/dev/ttyUSB1")">/dev/ttyUSB1</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="int" @bind-Value="_serialBaudRate"
                               Label="Baud Rate *"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="9600">9600</MudSelectItem>
                        <MudSelectItem Value="19200">19200</MudSelectItem>
                        <MudSelectItem Value="38400">38400</MudSelectItem>
                        <MudSelectItem Value="57600">57600</MudSelectItem>
                        <MudSelectItem Value="115200">115200</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>

            @if (_testConnectionResult is not null)
            {
                <MudAlert Severity="@(_testConnectionResult.Success ? Severity.Success : Severity.Error)"
                          Dense="true" Class="mt-3">
                    @(_testConnectionResult.Success
                        ? "✅ Connessione seriale riuscita!"
                        : $"❌ Connessione fallita: {_testConnectionResult.ErrorMessage}")
                </MudAlert>
            }

            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
                <MudButton Variant="Variant.Text" OnClick="@(() => _activeStep = 0)"
                           StartIcon="@Icons.Material.Filled.ArrowBack">
                    Indietro
                </MudButton>
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.NetworkCheck"
                               OnClick="TestSerialAsync"
                               Disabled="@(_isTesting || string.IsNullOrWhiteSpace(_serialPortName))">
                        @if (_isTesting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Test Connessione
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               EndIcon="@Icons.Material.Filled.ArrowForward"
                               OnClick="AdvanceFromStep1Serial"
                               Disabled="@(!_testConnectionResult?.Success ?? true)">
                        Avanti
                    </MudButton>
                </MudStack>
            </MudStack>
        }
    </MudPaper>
}

@* ══════════════════════════════════════════════════════════════
   STEP 2 – Info Stampante
   ══════════════════════════════════════════════════════════════ *@
@if (_activeStep == 2)
{
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        <MudText Typo="Typo.subtitle1" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
            Informazioni Stampante
        </MudText>

        @if (_printerInfo is null)
        {
            <MudAlert Severity="Severity.Info">
                Caricamento informazioni stampante in corso...
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-2" />
            </MudAlert>
        }
        else if (!_printerInfo.IsOnline)
        {
            <MudAlert Severity="Severity.Error">
                Non è stato possibile leggere le informazioni: @(_printerInfo.ErrorMessage ?? "connessione fallita")
            </MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField Value="@(_printerInfo.Model ?? "—")" Label="Modello" ReadOnly="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField Value="@(_printerInfo.FirmwareVersion ?? "—")" Label="Versione Firmware" ReadOnly="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField Value="@(_printerInfo.FiscalSerialNumber ?? "—")" Label="Matricola Fiscale" ReadOnly="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    @if (_printerInfo.FiscalMemoryUsedPercent.HasValue)
                    {
                        <MudField Label="Memoria Fiscale Utilizzata" Variant="Variant.Outlined">
                            <MudProgressLinear Value="@((double)_printerInfo.FiscalMemoryUsedPercent.Value)"
                                              Max="100"
                                              Color="@(_printerInfo.FiscalMemoryUsedPercent > 90 ? Color.Error : _printerInfo.FiscalMemoryUsedPercent > 70 ? Color.Warning : Color.Success)"
                                              Class="mt-1" />
                            <MudText Typo="Typo.caption">@_printerInfo.FiscalMemoryUsedPercent.Value:F1%</MudText>
                        </MudField>
                    }
                    else
                    {
                        <MudTextField Value="@("N/D")" Label="Memoria Fiscale Utilizzata" ReadOnly="true" Variant="Variant.Outlined" />
                    }
                </MudItem>
            </MudGrid>
        }

        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
            <MudButton Variant="Variant.Text" OnClick="@(() => _activeStep = 1)"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Indietro
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="@(() => _activeStep = 3)"
                       Disabled="@(_printerInfo is null)">
                Avanti
            </MudButton>
        </MudStack>
    </MudPaper>
}

@* ══════════════════════════════════════════════════════════════
   STEP 3 – Configurazione Base
   ══════════════════════════════════════════════════════════════ *@
@if (_activeStep == 3)
{
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        <MudText Typo="Typo.subtitle1" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.TextFields" Class="mr-2" />
            Configurazione Base
        </MudText>

        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_printerName"
                              Label="Nome Stampante *"
                              Variant="Variant.Outlined"
                              Placeholder="es. Stampante Fiscale Cassa 1"
                              HelperText="Nome descrittivo per identificare la stampante nel sistema"
                              Required="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_printerLocation"
                              Label="Posizione Fisica"
                              Variant="Variant.Outlined"
                              Placeholder="es. Cassa principale, piano terra" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="string" @bind-Value="_protocolType"
                           Label="Protocollo *"
                           Variant="Variant.Outlined"
                           HelperText="Solo il protocollo Custom è attualmente supportato">
                    <MudSelectItem Value="@("Custom")">Custom (Stampante Fiscale Custom)</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
            <MudButton Variant="Variant.Text" OnClick="@(() => _activeStep = 2)"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Indietro
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="AdvanceFromStep3"
                       Disabled="@string.IsNullOrWhiteSpace(_printerName)">
                Avanti
            </MudButton>
        </MudStack>
    </MudPaper>
}

@* ══════════════════════════════════════════════════════════════
   STEP 4 – Mapping Codici Fiscali
   ══════════════════════════════════════════════════════════════ *@
@if (_activeStep == 4)
{
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        <MudText Typo="Typo.subtitle1" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Code" Class="mr-2" />
            Mapping Codici Fiscali
        </MudText>

        <MudTabs Elevation="0" Rounded="true" Border="true" PanelClass="pa-4">
            @* ── Tab 1: Aliquote IVA ── *@
            <MudTabPanel Text="Aliquote IVA" Icon="@Icons.Material.Filled.Percent">
                <MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-2">
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                               OnClick="ApplyVatSuggestions"
                               StartIcon="@Icons.Material.Filled.AutoFixHigh">
                        Applica Suggerimenti Automatici
                    </MudButton>
                </MudStack>
                @if (_vatRates.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">Caricamento aliquote IVA...</MudAlert>
                }
                else
                {
                    <MudTable T="VatMappingRow" Items="_vatMappingRows" Dense="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Aliquota %</MudTh>
                            <MudTh>Nome</MudTh>
                            <MudTh>Codice Fiscale (1-10)</MudTh>
                            <MudTh>Suggerito</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Percentage %</MudTd>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>
                                <MudNumericField T="int" @bind-Value="context.FiscalCode"
                                                 Min="1" Max="10" Dense="true" Margin="Margin.Dense"
                                                 Variant="Variant.Outlined" Style="max-width:100px;" />
                            </MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.SuggestedCode</MudChip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>

            @* ── Tab 2: Metodi Pagamento ── *@
            <MudTabPanel Text="Metodi Pagamento" Icon="@Icons.Material.Filled.Payment">
                <MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-2">
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                               OnClick="ApplyPaymentSuggestions"
                               StartIcon="@Icons.Material.Filled.AutoFixHigh">
                        Applica Suggerimenti Automatici
                    </MudButton>
                </MudStack>
                @if (_paymentMethods.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">Caricamento metodi pagamento...</MudAlert>
                }
                else
                {
                    <MudTable T="PaymentMappingRow" Items="_paymentMappingRows" Dense="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Codice</MudTh>
                            <MudTh>Nome</MudTh>
                            <MudTh>Codice Fiscale (1-10)</MudTh>
                            <MudTh>Suggerito</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Code</MudTd>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>
                                <MudNumericField T="int" @bind-Value="context.FiscalCode"
                                                 Min="1" Max="10" Dense="true" Margin="Margin.Dense"
                                                 Variant="Variant.Outlined" Style="max-width:100px;" />
                            </MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.SuggestedCode</MudChip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>
        </MudTabs>

        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
            <MudButton Variant="Variant.Text" OnClick="@(() => _activeStep = 3)"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Indietro
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="@(() => _activeStep = 5)">
                Avanti
            </MudButton>
        </MudStack>
    </MudPaper>
}

@* ══════════════════════════════════════════════════════════════
   STEP 5 – Associa POS
   ══════════════════════════════════════════════════════════════ *@
@if (_activeStep == 5)
{
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        <MudText Typo="Typo.subtitle1" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.PointOfSale" Class="mr-2" />
            Associa POS
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Seleziona i punti vendita a cui associare questa stampante come stampante fiscale predefinita.
        </MudText>

        @if (_stations.Count == 0)
        {
            <MudAlert Severity="Severity.Info">Caricamento stazioni POS...</MudAlert>
        }
        else
        {
            <MudTable T="StationSelectionRow" Items="_stationRows" Dense="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Seleziona</MudTh>
                    <MudTh>Nome</MudTh>
                    <MudTh>Posizione</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudCheckBox T="bool" @bind-Value="context.Selected" Color="Color.Primary" />
                    </MudTd>
                    <MudTd>@context.Name</MudTd>
                    <MudTd>@(context.Location ?? "—")</MudTd>
                </RowTemplate>
            </MudTable>
        }

        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
            <MudButton Variant="Variant.Text" OnClick="@(() => _activeStep = 4)"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Indietro
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="@(() => _activeStep = 6)">
                Avanti
            </MudButton>
        </MudStack>
    </MudPaper>
}

@* ══════════════════════════════════════════════════════════════
   STEP 6 – Test Finale & Salva
   ══════════════════════════════════════════════════════════════ *@
@if (_activeStep == 6)
{
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        <MudText Typo="Typo.subtitle1" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" />
            Test Finale e Salvataggio
        </MudText>

        @* Riepilogo configurazione *@
        <MudExpansionPanels Elevation="0" Class="mb-4">
            <MudExpansionPanel Text="Riepilogo Configurazione" Icon="@Icons.Material.Filled.Summarize">
                <MudGrid Dense="true">
                    <MudItem xs="6"><MudText Typo="Typo.caption">Nome</MudText><MudText>@_printerName</MudText></MudItem>
                    <MudItem xs="6"><MudText Typo="Typo.caption">Protocollo</MudText><MudText>@_protocolType</MudText></MudItem>
                    <MudItem xs="6"><MudText Typo="Typo.caption">Connessione</MudText>
                        <MudText>@(_connectionType == "TCP" ? $"{_tcpIpAddress}:{_tcpPort}" : $"{_serialPortName} @ {_serialBaudRate}")</MudText>
                    </MudItem>
                    <MudItem xs="6"><MudText Typo="Typo.caption">Posizione</MudText><MudText>@(_printerLocation ?? "—")</MudText></MudItem>
                    <MudItem xs="6"><MudText Typo="Typo.caption">POS Associati</MudText>
                        <MudText>@(_stationRows.Count(r => r.Selected))</MudText>
                    </MudItem>
                </MudGrid>
            </MudExpansionPanel>
        </MudExpansionPanels>

        @* Test scontrino *@
        <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Class="mb-2">Stampa Scontrino di Test</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Prima del salvataggio, è consigliato stampare uno scontrino di prova per
                    verificare la corretta comunicazione con la stampante.
                </MudText>

                @if (_testPrintResult is not null)
                {
                    <MudAlert Severity="@(_testPrintResult.Success ? Severity.Success : Severity.Error)"
                              Dense="true" Class="mb-2">
                        @(_testPrintResult.Success
                            ? $"✅ Scontrino di test stampato! Numero: {_testPrintResult.ReceiptNumber}"
                            : $"❌ Stampa fallita: {_testPrintResult.ErrorMessage}")
                    </MudAlert>
                }

                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Print"
                           OnClick="PrintTestReceiptAsync"
                           Disabled="@_isTestPrinting">
                    @if (_isTestPrinting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Stampa Scontrino di Test
                </MudButton>
            </MudCardContent>
        </MudCard>

        @if (_saveError is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_saveError</MudAlert>
        }

        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
            <MudButton Variant="Variant.Text" OnClick="@(() => _activeStep = 5)"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Indietro
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveConfigurationAsync"
                       Disabled="@_isSaving">
                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Salvataggio...</span>
                }
                else
                {
                    <span>Salva Configurazione</span>
                }
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    // ──────────────────────────────────────────────────────────
    //  State
    // ──────────────────────────────────────────────────────────

    private MudStepper? _stepper;
    private int _activeStep;

    // Step 0
    private string _connectionType = "TCP";

    // Step 1 – TCP
    private string _tcpIpAddress = string.Empty;
    private int _tcpPort = 9100;
    private bool _isScanRunning;
    private List<NetworkScanResultDto>? _scanResults;

    // Step 1 – Serial
    private string _serialPortName = "COM1";
    private int _serialBaudRate = 9600;

    // Step 1 – shared
    private bool _isTesting;
    private FiscalPrintResult? _testConnectionResult;

    // Step 2 – printer info
    private FiscalPrinterInfoDto? _printerInfo;

    // Step 3 – base config
    private string _printerName = string.Empty;
    private string? _printerLocation;
    private string _protocolType = "Custom";

    // Step 4 – fiscal mapping
    private List<VatRateDto> _vatRates = new();
    private List<PaymentMethodDto> _paymentMethods = new();
    private List<VatMappingRow> _vatMappingRows = new();
    private List<PaymentMappingRow> _paymentMappingRows = new();

    // Step 5 – POS association
    private List<StationDto> _stations = new();
    private List<StationSelectionRow> _stationRows = new();

    // Step 6 – test print & save
    private bool _isTestPrinting;
    private FiscalPrintResult? _testPrintResult;
    private bool _isSaving;
    private string? _saveError;
    private Guid? _savedPrinterId;

    // ──────────────────────────────────────────────────────────
    //  Breadcrumbs
    // ──────────────────────────────────────────────────────────

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new BreadcrumbItem("Home", href: "/"),
        new BreadcrumbItem("Stampanti Fiscali", href: "/admin/fiscal-printers"),
        new BreadcrumbItem("Nuovo Wizard", href: null, disabled: true)
    ];

    // ──────────────────────────────────────────────────────────
    //  Lifecycle
    // ──────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        // Load VAT rates, payment methods and stations in parallel for later steps
        var vatTask = FinancialService.GetVatRatesAsync(1, 100);
        var paymentTask = PaymentMethodService.GetAllAsync();
        var stationsTask = HttpClientService.GetAsync<PagedResult<StationDto>>(
            "api/v1/stations?page=1&pageSize=100");

        await Task.WhenAll(vatTask, paymentTask, stationsTask);

        var vatResult = vatTask.Result;
        _vatRates = vatResult?.Items?.ToList() ?? new();
        _vatMappingRows = _vatRates.Select(v => new VatMappingRow
        {
            Id = v.Id,
            Name = v.Name,
            Percentage = v.Percentage,
            FiscalCode = v.FiscalCode ?? GetSuggestedVatCode(v.Percentage),
            SuggestedCode = GetSuggestedVatCode(v.Percentage)
        }).ToList();

        _paymentMethods = paymentTask.Result?.ToList() ?? new();
        _paymentMappingRows = _paymentMethods.Select(p => new PaymentMappingRow
        {
            Id = p.Id,
            Code = p.Code,
            Name = p.Name,
            FiscalCode = p.FiscalCode ?? GetSuggestedPaymentCode(p.Code),
            SuggestedCode = GetSuggestedPaymentCode(p.Code)
        }).ToList();

        _stations = stationsTask.Result?.Items?.ToList() ?? new();
        _stationRows = _stations.Select(s => new StationSelectionRow
        {
            Id = s.Id,
            Name = s.Name,
            Location = s.Location
        }).ToList();
    }

    // ──────────────────────────────────────────────────────────
    //  Step 1 – TCP
    // ──────────────────────────────────────────────────────────

    private async Task ScanNetworkAsync()
    {
        if (string.IsNullOrWhiteSpace(_tcpIpAddress))
        {
            // Try to infer subnet from a guess; default to 192.168.1
            _isScanRunning = true;
            StateHasChanged();
            _scanResults = await FiscalPrintingService.ScanNetworkAsync("192.168.1", _tcpPort, 300);
        }
        else
        {
            // Use the subnet from the already-entered IP
            var parts = _tcpIpAddress.Split('.');
            var subnet = parts.Length >= 3 ? string.Join('.', parts[0], parts[1], parts[2]) : "192.168.1";
            _isScanRunning = true;
            StateHasChanged();
            _scanResults = await FiscalPrintingService.ScanNetworkAsync(subnet, _tcpPort, 300);
        }

        _isScanRunning = false;
    }

    private void SelectDiscoveredPrinter(NetworkScanResultDto result)
    {
        _tcpIpAddress = result.IpAddress;
        _tcpPort = result.Port;
        _testConnectionResult = null;
    }

    private async Task TestTcpAsync()
    {
        _isTesting = true;
        _testConnectionResult = null;
        try
        {
            _testConnectionResult = await FiscalPrintingService.TestTcpConnectionAsync(_tcpIpAddress, _tcpPort);
        }
        finally
        {
            _isTesting = false;
        }
    }

    private async Task AdvanceFromStep1Tcp()
    {
        _activeStep = 2;
        await LoadPrinterInfoAsync();
    }

    // ──────────────────────────────────────────────────────────
    //  Step 1 – Serial
    // ──────────────────────────────────────────────────────────

    private async Task TestSerialAsync()
    {
        _isTesting = true;
        _testConnectionResult = null;
        try
        {
            _testConnectionResult = await FiscalPrintingService.TestSerialConnectionAsync(
                _serialPortName, _serialBaudRate);
        }
        finally
        {
            _isTesting = false;
        }
    }

    private async Task AdvanceFromStep1Serial()
    {
        _activeStep = 2;
        // For serial, printer info reading via TCP is not applicable; mark as basic online
        _printerInfo = new FiscalPrinterInfoDto { IsOnline = true };
    }

    // ──────────────────────────────────────────────────────────
    //  Step 2 – Printer info
    // ──────────────────────────────────────────────────────────

    private async Task LoadPrinterInfoAsync()
    {
        _printerInfo = null;
        StateHasChanged();
        _printerInfo = await FiscalPrintingService.GetPrinterInfoByAddressAsync(_tcpIpAddress, _tcpPort);
    }

    // ──────────────────────────────────────────────────────────
    //  Step 3 – Base config
    // ──────────────────────────────────────────────────────────

    private void AdvanceFromStep3()
    {
        // Pre-fill printer name from model if empty
        if (string.IsNullOrWhiteSpace(_printerName) && _printerInfo?.Model is not null)
            _printerName = $"Stampante Fiscale – {_printerInfo.Model}";
        _activeStep = 4;
    }

    // ──────────────────────────────────────────────────────────
    //  Step 4 – Fiscal mapping
    // ──────────────────────────────────────────────────────────

    private void ApplyVatSuggestions()
    {
        foreach (var row in _vatMappingRows)
            row.FiscalCode = row.SuggestedCode;
    }

    private void ApplyPaymentSuggestions()
    {
        foreach (var row in _paymentMappingRows)
            row.FiscalCode = row.SuggestedCode;
    }

    private static int GetSuggestedVatCode(decimal percentage) => percentage switch
    {
        22m or 21m or 20m => 1,
        10m => 2,
        >= 4m and <= 5m => 3,
        0m => 4,
        _ => 1
    };

    private static int GetSuggestedPaymentCode(string code)
    {
        var upper = code?.ToUpperInvariant() ?? string.Empty;
        if (upper.Contains("CASH") || upper.Contains("CONT") || upper.Contains("CASSA")) return 1;
        if (upper.Contains("CHECK") || upper.Contains("ASS")) return 2;
        if (upper.Contains("CREDIT") || upper.Contains("DEBIT")
            || upper.Contains("CARD") || upper.Contains("POS")
            || upper.Contains("VISA") || upper.Contains("MASTER")) return 4;
        if (upper.Contains("TICKET") || upper.Contains("VOUCHER")) return 5;
        return 1;
    }

    // ──────────────────────────────────────────────────────────
    //  Step 6 – Test print & save
    // ──────────────────────────────────────────────────────────

    private async Task PrintTestReceiptAsync()
    {
        if (_savedPrinterId is null)
        {
            // Printer not saved yet: show informational toast
            AppNotification.ShowInfo("Salva prima la configurazione per stampare uno scontrino di test.");
            return;
        }

        _isTestPrinting = true;
        try
        {
            var testReceipt = new FiscalReceiptData
            {
                Items = [new FiscalReceiptItem { Description = "SCONTRINO DI PROVA", Quantity = 1, UnitPrice = 0.01m, VatCode = 1, Department = 1 }],
                Payments = [new FiscalPayment { Amount = 0.01m, MethodCode = 1, Description = "Contanti" }]
            };
            _testPrintResult = await FiscalPrintingService.PrintReceiptAsync(_savedPrinterId.Value, testReceipt);
        }
        finally
        {
            _isTestPrinting = false;
        }
    }

    private async Task SaveConfigurationAsync()
    {
        _isSaving = true;
        _saveError = null;
        try
        {
            var setup = new FiscalPrinterSetupDto
            {
                ConnectionType = _connectionType,
                IpAddress = _connectionType == "TCP" ? _tcpIpAddress : null,
                TcpPort = _connectionType == "TCP" ? _tcpPort : null,
                SerialPortName = _connectionType == "Serial" ? _serialPortName : null,
                BaudRate = _connectionType == "Serial" ? _serialBaudRate : null,
                Name = _printerName,
                Location = _printerLocation,
                ProtocolType = _protocolType,
                VatFiscalCodeOverrides = _vatMappingRows.ToDictionary(r => r.Id, r => r.FiscalCode),
                PaymentFiscalCodeOverrides = _paymentMappingRows.ToDictionary(r => r.Id, r => r.FiscalCode),
                AssociatedStationIds = _stationRows.Where(r => r.Selected).Select(r => r.Id).ToList()
            };

            var printer = await FiscalPrintingService.SaveSetupAsync(setup);
            if (printer is null)
            {
                _saveError = "Errore nel salvataggio della configurazione. Riprova.";
                return;
            }

            _savedPrinterId = printer.Id;
            AppNotification.ShowSuccess($"Stampante '{printer.Name}' configurata con successo!");

            // Navigate to dashboard after short delay
            await Task.Delay(1500);
            NavigationManager.NavigateTo("/admin/fiscal-printers");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "SaveConfigurationAsync failed");
            _saveError = $"Errore imprevisto: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    // ──────────────────────────────────────────────────────────
    //  Inner model classes
    // ──────────────────────────────────────────────────────────

    private sealed class VatMappingRow
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal Percentage { get; set; }
        public int FiscalCode { get; set; }
        public int SuggestedCode { get; set; }
    }

    private sealed class PaymentMappingRow
    {
        public Guid Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public int FiscalCode { get; set; }
        public int SuggestedCode { get; set; }
    }

    private sealed class StationSelectionRow
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Location { get; set; }
        public bool Selected { get; set; }
    }
}
