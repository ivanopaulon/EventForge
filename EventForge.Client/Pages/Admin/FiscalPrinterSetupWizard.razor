                           Variant="Variant.Outlined"
                           HelperText="Linguaggio comandi della stampante (opzionale)"
                           Clearable="true">
                    <MudSelectItem T="PrintLanguage?" Value="null">— Nessuno —</MudSelectItem>
                    <MudSelectItem T="PrintLanguage?" Value="PrintLanguage.EscPos">ESC/POS (Epson, termica)</MudSelectItem>
                    <MudSelectItem T="PrintLanguage?" Value="PrintLanguage.Star">STAR</MudSelectItem>
