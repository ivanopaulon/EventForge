    private string GetConnectionSummary() => _connectionType switch
    {
        "TCP" => $"{_tcpIpAddress}:{_tcpPort}",
        "Serial" => $"{_serialPortName} @ {_serialBaudRate}",
        "UsbViaAgent" => $"Agente: {_agentId}, Dispositivo: {_usbDeviceId}",
        "NetworkShare" => $"Network Share",
        _ => _connectionType
    };

