@page "/management/reports/viewer/{ReportId:guid}"
@using Prym.DTOs.Reports
@using EventForge.Client.Shared.Components.Reports
@attribute [Authorize]

@inject IReportDefinitionService ReportService
@inject ITranslationService TranslationService
@inject IAppNotificationService AppNotification
@inject NavigationManager Navigation
@inject ILogger<ReportViewer> Logger

<PageTitle>@(_report?.Name ?? TranslationService.GetTranslation("reports.viewer", "Report Viewer"))</PageTitle>
<PageLoadingOverlay Visible="_isLoading"
                    Message="@TranslationService.GetTranslation("messages.loadingPage", "Caricamento report...")" />

@if (!_isLoading)
{
    <MudContainer MaxWidth="MaxWidth.False" Class="pa-0" Style="height:100%;display:flex;flex-direction:column;">
        <!-- Toolbar -->
        <MudPaper Elevation="1" Class="pa-3 mb-1" Style="flex:0 0 auto;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIconButton Icon="@Icons.Material.Outlined.ArrowBack"
                               Size="Size.Small"
                               Title="@TranslationService.GetTranslation("common.back", "Indietro")"
                               OnClick="@(() => Navigation.NavigateTo("/management/reports"))" />
                <MudIcon Icon="@Icons.Material.Outlined.Assessment" Color="Color.Primary" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1">
                        @(_report?.Name ?? TranslationService.GetTranslation("reports.viewer", "Report Viewer"))
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(_report?.Category))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_report.Category</MudText>
                    }
                </MudStack>
                <MudSpacer />
                @if (_report is not null)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Outlined.Edit"
                               OnClick="@(() => Navigation.NavigateTo($"/management/reports/designer/{ReportId}"))">
                        @TranslationService.GetTranslation("reports.designer", "Designer")
                    </MudButton>
                }
            </MudStack>
        </MudPaper>

        <!-- Viewer -->
        <div style="flex:1 1 auto;overflow:hidden;">
            <ReportViewerPanel ReportId="@ReportId" Height="100%" />
        </div>
    </MudContainer>
}

@code {
    [Parameter] public Guid ReportId { get; set; }

    private ReportDefinitionDto? _report;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _report = await ReportService.GetReportAsync(ReportId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading report {ReportId}", ReportId);
            AppNotification.ShowError(TranslationService.GetTranslation("reports.loadError", "Errore durante il caricamento del report."));
        }
        _isLoading = false;
    }
}
