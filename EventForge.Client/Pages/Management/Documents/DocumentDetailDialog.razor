@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR
@using Prym.DTOs.Common
@using Prym.DTOs.Documents
@using Prym.DTOs.Business
@using Prym.DTOs.Products
@using Prym.DTOs.PriceLists
@using EventForge.Client.Shared.Components.Dialogs.Documents
@using EventForge.Client.Shared.Components.Dialogs.Business
@using EventForge.Client.Shared.Documents
@using EventForge.Client.Shared.Components
@using EventForge.Client.Shared.Components.Business
@using EventForge.Client.Shared.Components.Common
@using EventForge.Client.Models.Documents
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,Operator")]
@implements IAsyncDisposable
@inject IDocumentHeaderService DocumentHeaderService
@inject IDocumentStatusService DocumentStatusService
@inject IDocumentTypeService DocumentTypeService
@inject IBusinessPartyService BusinessPartyService
@inject IPriceListService PriceListService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<DocumentDetailDialog> Logger
@inject IRealtimeService RealtimeService

<MudDialog Class="doc-detail-fs-dialog">
    <DialogContent>
        <div class="gdp-page-root">

            <!-- ── Title bar ─────────────────────────────────────────────── -->
            <div class="gdp-title-bar">
                <div class="d-flex align-center justify-space-between flex-wrap gap-2">
                    <MudText Typo="Typo.h5">
                        <MudIcon Icon="@Icons.Material.Outlined.Description" Class="mr-2" Size="Size.Small" />
                        @_pageTitle
                    </MudText>
                    <MudButton StartIcon="@Icons.Material.Outlined.Close"
                               Color="Color.Default"
                               Variant="Variant.Outlined"
                               Size="Size.Small"
                               OnClick="@CloseDialogAsync">
                        @TranslationService.GetTranslation("common.close", "Chiudi")
                    </MudButton>
                </div>

                <PageLoadingOverlay Visible="_isLoading"
                                    Message="@_loadingMessage"
                                    ShowProgressLog="true"
                                    ProgressMessages="@_documentLoadingProgressMessages"
                                    ShowElapsedTime="true"
                                    ProgressIntervalMs="2500" />

                @if (_isReadOnly)
                {
                    @if (!string.IsNullOrEmpty(_lockHolderName))
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">
                            <MudText Typo="Typo.body2">
                                @TranslationService.GetTranslation("documents.lockedBy", "Documento bloccato da")
                                <strong>@_lockHolderName</strong>
                                @TranslationService.GetTranslation("documents.lockedBySuffix", " — apertura in sola lettura.")
                            </MudText>
                        </MudAlert>
                    }
                    else if (_isReadOnlyDueToError)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">
                            <MudText Typo="Typo.body2">
                                @TranslationService.GetTranslation("documents.readOnlyMode", "Modalità sola lettura")
                            </MudText>
                        </MudAlert>
                    }
                }
            </div>

            <!-- ── Two-column body ───────────────────────────────────────── -->
            <div class="gdp-body">

                <!-- Left column: header summary + status + totals -->
                <div class="gdp-left-col">

                    <!-- Testata Documento (summary + edit button) -->
                    <MudPaper Elevation="2" Class="gdp-panel pa-3">
                        <div class="d-flex align-center justify-space-between mb-2">
                            <MudText Typo="Typo.subtitle1" Class="fw-medium">
                                @TranslationService.GetTranslation("documents.documentData", "Dati Documento")
                            </MudText>
                            @if (!_isReadOnly)
                            {
                                <MudTooltip Text="@TranslationService.GetTranslation("documents.editHeader", "Modifica Testata")">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="@OpenHeaderDialogAsync"
                                                   Disabled="@_isLoading" />
                                </MudTooltip>
                            }
                        </div>

                        @if (_currentDocument == null)
                        {
                            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="py-2">
                                <MudIcon Icon="@Icons.Material.Outlined.EditNote" Size="Size.Large" Color="Color.Primary" />
                                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("documents.headerNotYetFilled", "Testata non ancora compilata.")
                                </MudText>
                                <MudButton StartIcon="@Icons.Material.Outlined.Add"
                                           Color="Color.Primary"
                                           Variant="Variant.Outlined"
                                           Size="Size.Small"
                                           OnClick="@OpenHeaderDialogAsync">
                                    @TranslationService.GetTranslation("documents.fillHeader", "Compila Testata")
                                </MudButton>
                            </MudStack>
                        }
                        else
                        {
                            <MudStack Spacing="1">
                                <!-- Tipo Documento -->
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @TranslationService.GetTranslation("documents.documentType", "Tipo Documento")
                                    </MudText>
                                    <MudText Typo="Typo.body2" Class="fw-medium">
                                        @(_headerDocTypeName ?? "—")
                                    </MudText>
                                </div>
                                <!-- Numero / Serie -->
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @TranslationService.GetTranslation("documents.number", "Numero")
                                    </MudText>
                                    <MudText Typo="Typo.body2">
                                        @if (!string.IsNullOrEmpty(_model.Series))
                                        {
                                            <span>@_model.Series /</span>
                                        }
                                        @(_model.Number ?? TranslationService.GetTranslation("documents.autoGenerated", "Auto-generato"))
                                    </MudText>
                                </div>
                                <!-- Data -->
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @TranslationService.GetTranslation("documents.date", "Data Documento")
                                    </MudText>
                                    <MudText Typo="Typo.body2">
                                        @(_documentDate?.ToString("dd/MM/yyyy") ?? "—")
                                    </MudText>
                                </div>
                                <!-- Controparte -->
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @TranslationService.GetTranslation("documents.businessPartner", "Controparte")
                                    </MudText>
                                    <MudText Typo="Typo.body2">
                                        @(_selectedBusinessParty?.Name ?? "—")
                                    </MudText>
                                </div>
                                <!-- Listino -->
                                @if (_model.PriceListId.HasValue)
                                {
                                    <div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @TranslationService.GetTranslation("documents.priceList", "Listino Prezzi")
                                        </MudText>
                                        <MudText Typo="Typo.body2">
                                            @(_headerPriceListName ?? "—")
                                        </MudText>
                                    </div>
                                }
                                <!-- Note -->
                                @if (!string.IsNullOrWhiteSpace(_model.Notes))
                                {
                                    <div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @TranslationService.GetTranslation("documents.notes", "Note")
                                        </MudText>
                                        <MudText Typo="Typo.body2" Class="text-wrap">@_model.Notes</MudText>
                                    </div>
                                }
                            </MudStack>
                        }
                    </MudPaper>

                    <!-- Stato Documento -->
                    @if (_isEditMode && _currentDocument != null)
                    {
                        <MudPaper Elevation="2" Class="gdp-panel pa-3">
                            <MudText Typo="Typo.subtitle1" Class="mb-2 fw-medium">
                                @TranslationService.GetTranslation("documents.status", "Stato")
                            </MudText>
                            <MudSelect T="DocumentStatus"
                                       Value="_documentStatus"
                                       ValueChanged="@OnStatusChanged"
                                       Label="@TranslationService.GetTranslation("documents.status", "Stato")"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Disabled="@(!IsDocumentEditable() || _isReadOnly)">
                                <MudSelectItem Value="@DocumentStatus.Draft">
                                    @TranslationService.GetTranslation("status.draft", "Bozza")
                                </MudSelectItem>
                                <MudSelectItem Value="@DocumentStatus.Open">
                                    @TranslationService.GetTranslation("status.open", "Aperto")
                                </MudSelectItem>
                                <MudSelectItem Value="@DocumentStatus.Closed">
                                    @TranslationService.GetTranslation("status.closed", "Chiuso")
                                </MudSelectItem>
                                <MudSelectItem Value="@DocumentStatus.Cancelled">
                                    @TranslationService.GetTranslation("status.cancelled", "Annullato")
                                </MudSelectItem>
                            </MudSelect>
                        </MudPaper>
                    }

                    <!-- Riepilogo e Totali (fills remaining left-column space) -->
                    <MudPaper Elevation="2" Class="gdp-panel-fill pa-3">
                        <MudText Typo="Typo.subtitle1" Class="mb-2 fw-medium">
                            @TranslationService.GetTranslation("documents.summary", "Riepilogo e Totali")
                        </MudText>
                        <MudStack Spacing="2">
                            <DocumentVatSummary Rows="@_currentDocument?.Rows" />
                            <DocumentTotalsCard Document="@_currentDocument" />
                        </MudStack>
                    </MudPaper>

                </div> <!-- /gdp-left-col -->

                <!-- Right column: document rows (full-height table) -->
                <div class="gdp-right-col">

                    <!-- Toolbar: pinned, always visible -->
                    <div class="gdp-rows-toolbar">
                        @if (_currentDocument == null)
                        {
                            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Outlined.Info">
                                <MudStack Spacing="1">
                                    <MudText>
                                        <strong>@TranslationService.GetTranslation("documents.saveFirstTitle", "Salva prima il documento")</strong>
                                    </MudText>
                                    <MudText Typo="Typo.body2">
                                        @TranslationService.GetTranslation("documents.saveFirstMessage", "Per poter aggiungere righe al documento, è necessario salvarlo prima compilando i campi della testata (Tipo Documento, Cliente, Data) e cliccando su 'Salva'.")
                                    </MudText>
                                </MudStack>
                            </MudAlert>
                        }
                    </div>

                    <!-- Table area: fills remaining height, scrolls internally -->
                    <div class="gdp-rows-area">
                        @if (_currentDocument != null)
                        {
                            <EFTable @ref="_efTable"
                                     TItem="DocumentRowDto"
                                     Items="@_filteredRows"
                                     ComponentKey="GenericDocumentRows"
                                     InitialColumnConfigurations="@_documentRowColumns"
                                     MultiSelection="true"
                                     @bind-SelectedItems="_selectedRows"
                                     AllowDragDropGrouping="true"
                                     ShowColumnConfiguration="true"
                                     ShowExport="true"
                                     ShowExportDialog="true"
                                     ExcelFileName="@GetDocumentExcelFileName()"
                                     IsDataFiltered="@(!string.IsNullOrEmpty(_searchQuery))"
                                     TotalItemsCount="@(_currentDocument.Rows?.Count ?? 0)"
                                     Dense="true"
                                     Hover="true"
                                     Striped="true"
                                     FixedHeader="true"
                                     FixedFooter="true"
                                     Height="100%"
                                     Virtualize="@(_currentDocument.Rows?.Count > 100)"
                                     ShowSearch="true"
                                     OnSearch="@OnTableSearch"
                                     SearchPlaceholder="@TranslationService.GetTranslation("documents.searchArticles", "Cerca articolo")"
                                     ShowCreate="true"
                                     OnCreate="@AddRowAsync"
                                     CreateTooltip="documents.addRowTooltip"
                                     ShowSelectionBadge="true"
                                     ShowBulkDelete="true"
                                     OnBulkDelete="@DeleteSelectedRowsAsync"
                                     IsToolbarDisabled="@_isLoading">
                                <AdditionalToolbarContent>
                                    @if (_selectedRows.Count >= 2 && CanMergeSelectedRows())
                                    {
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Outlined.MergeType"
                                                   OnClick="@MergeSelectedRowsAsync"
                                                   Disabled="@_isLoading"
                                                   Size="Size.Small">
                                            @TranslationService.GetTranslation("documents.mergeRows", "Unisci Righe")
                                        </MudButton>
                                    }
                                </AdditionalToolbarContent>
                                <HeaderContent Context="columnConfigurations">
                                    @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
                                    {
                                        <EFTableColumnHeader TItem="DocumentRowDto"
                                                           PropertyName="@column.PropertyName"
                                                           OnDragStartCallback="@_efTable.HandleColumnDragStart">
                                            <MudTableSortLabel T="DocumentRowDto">@column.DisplayName</MudTableSortLabel>
                                        </EFTableColumnHeader>
                                    }
                                    <!-- Actions column - always visible -->
                                    <MudTh Class="text-right text-nowrap ef-min-120">
                                        @TranslationService.GetTranslation("common.actions", "Azioni")
                                    </MudTh>
                                </HeaderContent>
                                <RowTemplate Context="row">
                                    @{
                                        var visibleCols = _efTable?.ColumnConfigurations
                                            ?.Where(c => c.IsVisible)
                                            .OrderBy(c => c.Order)
                                            .ToList() ?? _documentRowColumns.Where(c => c.IsVisible).OrderBy(c => c.Order).ToList();

                                        var grossTotal = row.LineTotal + row.VatTotal;
                                    }

                                    @foreach (var column in visibleCols)
                                    {
                                        @if (column.PropertyName == "ProductCode")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                <MudText Typo="Typo.body2">@row.ProductCode</MudText>
                                            </MudTd>
                                        }
                                        else if (column.PropertyName == "Description")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                @if (!string.IsNullOrWhiteSpace(_searchQuery))
                                                {
                                                    <MudHighlighter Text="@row.Description"
                                                                   HighlightedText="@_searchQuery"
                                                                   CaseSensitive="false" />
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2">@row.Description</MudText>
                                                }
                                            </MudTd>
                                        }
                                        else if (column.PropertyName == "Quantity")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                <MudText Typo="Typo.body2">@row.Quantity.ToString("N2")</MudText>
                                            </MudTd>
                                        }
                                        else if (column.PropertyName == "UnitOfMeasure")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                                    @row.UnitOfMeasure
                                                </MudChip>
                                            </MudTd>
                                        }
                                        else if (column.PropertyName == "UnitPrice")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                <MudText Typo="Typo.body2">@row.UnitPrice.ToString("C2")</MudText>
                                            </MudTd>
                                        }
                                        else if (column.PropertyName == "VatRate")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Outlined.Percent">
                                                    @row.VatRate.ToString("N0")%
                                                </MudChip>
                                            </MudTd>
                                        }
                                        else if (column.PropertyName == "UnitPriceGross")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                <MudText Typo="Typo.body2" Color="Color.Primary">
                                                    @((row.UnitPrice * (1 + row.VatRate / 100)).ToString("C2"))
                                                </MudText>
                                            </MudTd>
                                        }
                                        else if (column.PropertyName == "DiscountTotal")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                @if (row.DiscountTotal > 0)
                                                {
                                                    <MudText Typo="Typo.body2" Color="Color.Success">
                                                        -@row.DiscountTotal.ToString("C2")
                                                    </MudText>
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2" Class="text-disabled">—</MudText>
                                                }
                                            </MudTd>
                                        }
                                        else if (column.PropertyName == "LineTotal")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                <MudText Typo="Typo.body2" Class="fw-medium">
                                                    @row.LineTotal.ToString("C2")
                                                </MudText>
                                            </MudTd>
                                        }
                                        else if (column.PropertyName == "VatTotal")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                <MudText Typo="Typo.body2" Color="Color.Info">
                                                    @row.VatTotal.ToString("C2")
                                                </MudText>
                                            </MudTd>
                                        }
                                        else if (column.PropertyName == "GrossTotal")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                <MudText Typo="Typo.body2" Color="Color.Primary" Class="fw-semibold">
                                                    @grossTotal.ToString("C2")
                                                </MudText>
                                            </MudTd>
                                        }
                                        else if (column.PropertyName == "VatDescription")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                <MudText Typo="Typo.caption">@row.VatDescription</MudText>
                                            </MudTd>
                                        }
                                        else if (column.PropertyName == "LineDiscount")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                @if (row.LineDiscount > 0)
                                                {
                                                    <MudText Typo="Typo.body2">@row.LineDiscount.ToString("N2")%</MudText>
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2" Class="text-disabled">—</MudText>
                                                }
                                            </MudTd>
                                        }
                                        else if (column.PropertyName == "LineDiscountValue")
                                        {
                                            <MudTd DataLabel="@column.DisplayName">
                                                @if (row.LineDiscountValue > 0)
                                                {
                                                    <MudText Typo="Typo.body2">@row.LineDiscountValue.ToString("C2")</MudText>
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2" Class="text-disabled">—</MudText>
                                                }
                                            </MudTd>
                                        }
                                    }

                                    <!-- Actions cell -->
                                    <MudTd DataLabel="@TranslationService.GetTranslation("common.actions", "Azioni")">
                                        <MudTooltip Text="@TranslationService.GetTranslation("common.edit", "Modifica")">
                                            <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                                          Size="Size.Small"
                                                          Color="Color.Primary"
                                                          OnClick="@(() => EditRow(row))" />
                                        </MudTooltip>
                                        <MudTooltip Text="@TranslationService.GetTranslation("common.delete", "Elimina")">
                                            <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                                          Size="Size.Small"
                                                          Color="Color.Error"
                                                          OnClick="@(() => DeleteRow(row))" />
                                        </MudTooltip>
                                    </MudTd>
                                </RowTemplate>
                            </EFTable>

                            @* Info badge when virtualization is active *@
                            @if (_currentDocument.Rows?.Count > 100)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-1" Variant="Variant.Outlined">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Outlined.Speed" Size="Size.Small" />
                                        <MudText Typo="Typo.caption">
                                            <strong>@TranslationService.GetTranslation("documents.virtualizedMode", "Modalità Virtualizzata")</strong>:
                                            @TranslationService.GetTranslationFormatted("documents.virtualizedModeDesc", "Rendering ottimizzato per {0} righe", _currentDocument.Rows.Count)
                                        </MudText>
                                    </MudStack>
                                </MudAlert>
                            }
                        }
                    </div> <!-- /gdp-rows-area -->

                </div> <!-- /gdp-right-col -->

            </div> <!-- /gdp-body -->

        </div> <!-- /gdp-page-root -->
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? DocumentId { get; set; }

    private bool _isLoading = false;
    private string _loadingMessage = string.Empty;
    private bool _lockReleased = false;

    private static readonly IReadOnlyList<string> _documentLoadingProgressMessages = new[]
    {
        "Caricamento testata documento...",
        "Caricamento righe documento...",
        "Caricamento anagrafica...",
        "Calcolo totali e riepilogo IVA...",
        "Preparazione interfaccia...",
    };

    // _isEditMode is true once a document has been saved (either loaded from server or just created)
    private bool _isEditMode => _currentDocument != null;
    private string _pageTitle = "";
    private CreateDocumentHeaderDto _model = new();
    private DocumentHeaderDto? _currentDocument = null;
    private DateTime? _documentDate = DateTime.UtcNow;
    private List<DocumentTypeDto> _documentTypes = new();
    private List<PriceListDto> _priceLists = new();
    // O(1) lookup maps built whenever the lists are (re)loaded
    private Dictionary<Guid, string> _docTypeNames = new();
    private Dictionary<Guid, string> _priceListNames = new();
    private BusinessPartyDto? _selectedBusinessParty = null;

    // Cached display values for the left-column summary (avoids per-render lookup)
    private string? _headerDocTypeName;
    private string? _headerPriceListName;

    // Document status binding
    private DocumentStatus _documentStatus = DocumentStatus.Draft;

    // Lock management state
    private bool _hasEditLock = false;
    private bool _isReadOnly = false;
    private bool _isReadOnlyDueToError = false;
    private string? _lockHolderName = null;

    // Selection management for rows
    private HashSet<DocumentRowDto> _selectedRows = new();

    // Search functionality
    private string _searchQuery = string.Empty;
    private List<DocumentRowDto>? _filteredRows;

    private void UpdateFilteredRows()
    {
        if (_currentDocument?.Rows == null)
        {
            _filteredRows = null;
            return;
        }
        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _filteredRows = _currentDocument.Rows;
            return;
        }
        _filteredRows = _currentDocument.Rows.Where(row =>
            (!string.IsNullOrEmpty(row.ProductCode) &&
             row.ProductCode.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)) ||
            (!string.IsNullOrEmpty(row.Description) &&
             row.Description.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
        ).ToList();
    }

    // EFTable reference
    private EFTable<DocumentRowDto> _efTable = null!;

    // Column configuration for EFTable
    private List<EFTableColumnConfiguration> _documentRowColumns = new();

    /// <summary>
    /// Checks if the document can be modified (not closed or cancelled)
    /// </summary>
    private bool IsDocumentEditable()
    {
        return _currentDocument?.Status != DocumentStatus.Closed &&
               _currentDocument?.Status != DocumentStatus.Cancelled;
    }

    protected override async Task OnInitializedAsync()
    {
        _documentRowColumns = new List<EFTableColumnConfiguration>
        {
            new() { PropertyName = "ProductCode", DisplayName = TranslationService.GetTranslation("documents.column.productcode", "Codice"), IsVisible = true, Order = 0 },
            new() { PropertyName = "Description", DisplayName = TranslationService.GetTranslation("documents.column.description", "Descrizione"), IsVisible = true, Order = 1 },
            new() { PropertyName = "Quantity", DisplayName = TranslationService.GetTranslation("documents.column.quantity", "Quantità"), IsVisible = true, Order = 2 },
            new() { PropertyName = "UnitOfMeasure", DisplayName = TranslationService.GetTranslation("documents.column.unitofmeasure", "UM"), IsVisible = true, Order = 3 },
            new() { PropertyName = "UnitPrice", DisplayName = TranslationService.GetTranslation("documents.column.unitprice", "Prezzo Unit. Netto"), IsVisible = true, Order = 4 },
            new() { PropertyName = "VatRate", DisplayName = TranslationService.GetTranslation("documents.column.vatrate", "IVA %"), IsVisible = true, Order = 5 },
            new() { PropertyName = "UnitPriceGross", DisplayName = TranslationService.GetTranslation("documents.column.unitpricegross", "Prezzo Unit. Lordo"), IsVisible = true, Order = 6 },
            new() { PropertyName = "DiscountTotal", DisplayName = TranslationService.GetTranslation("documents.column.discounttotal", "Sconto"), IsVisible = true, Order = 7 },
            new() { PropertyName = "LineTotal", DisplayName = TranslationService.GetTranslation("documents.column.linetotal", "Imponibile"), IsVisible = true, Order = 8 },
            new() { PropertyName = "VatTotal", DisplayName = TranslationService.GetTranslation("documents.column.vattotal", "Imposta"), IsVisible = true, Order = 9 },
            new() { PropertyName = "GrossTotal", DisplayName = TranslationService.GetTranslation("documents.column.grosstotal", "Totale Lordo"), IsVisible = true, Order = 10 },
            new() { PropertyName = "VatDescription", DisplayName = TranslationService.GetTranslation("documents.column.vatdescription", "Desc. IVA"), IsVisible = false, Order = 11 },
            new() { PropertyName = "LineDiscount", DisplayName = TranslationService.GetTranslation("documents.column.linediscount", "Sconto %"), IsVisible = false, Order = 12 },
            new() { PropertyName = "LineDiscountValue", DisplayName = TranslationService.GetTranslation("documents.column.linediscountvalue", "Valore Sconto"), IsVisible = false, Order = 13 },
        };

        _pageTitle = DocumentId.HasValue
            ? TranslationService.GetTranslation("documents.editDocument", "Modifica Documento")
            : TranslationService.GetTranslation("documents.createDocument", "Nuovo Documento");

        // Load document types and price lists in parallel
        await Task.WhenAll(
            LoadDocumentTypesAsync(),
            LoadPriceListsAsync()
        );

        if (DocumentId.HasValue)
        {
            await LoadDocumentAsync(DocumentId.Value);
            await SetupCollaborationAsync(DocumentId.Value);
        }
        else
        {
            _model.Date = DateTime.UtcNow;
            _documentStatus = DocumentStatus.Draft;

            var defaultDocType = _documentTypes.FirstOrDefault(dt => dt.Code == "DDT_VEND");
            if (defaultDocType != null)
            {
                _model.DocumentTypeId = defaultDocType.Id;
            }

            // Auto-open the header dialog for new documents so the user fills in header data immediately
            await OpenHeaderDialogAsync();
        }
    }

