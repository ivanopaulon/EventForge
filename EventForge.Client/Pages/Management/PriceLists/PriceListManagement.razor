@page "/management/pricelists"
@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.PriceLists
@using EventForge.DTOs.Common
@using EventForge.Client.Shared.Components
@using EventForge.Client.Shared.Management.Adapters
@using MudBlazor
@using EventForge.Client.Shared.Components.Dialogs
@attribute [Authorize]
@inject IPriceListService PriceListService
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject IAppNotificationService AppNotification
@inject ILogger<PriceListManagement> Logger

<PageTitle>@TranslationService.GetTranslation("pricelist.management.title", "Gestione Listini Prezzi")</PageTitle>
<EntityManagementPage @ref="_entityPage"
                      TEntity="PriceListDto"
                      Config="_config"
                      Service="_service"
                      OnCreateOverride="@OpenCreateDialog"
                      OnEditOverride="@(id => OpenDetailDialogAsync(id))"
                      AdditionalFilter="@(pl => !_onlyDefault || pl.IsDefault)">
    <AdditionalToolbarContent>
        <MudSwitch @bind-Value="_onlyDefault"
                   Label="@TranslationService.GetTranslation("pricelist.onlyDefault", "Solo Default")"
                   Color="Color.Primary"
                   Class="mr-2" />
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.PriceChange"
                   OnClick="@OpenGenerateFromDefaultPricesDialog">
            @TranslationService.GetTranslation("pricelist.generateFromDefaults", "Da Prezzi Default")
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   StartIcon="@Icons.Material.Outlined.AutoAwesome"
                   OnClick="@OpenGenerateFromDocumentsDialog">
            @TranslationService.GetTranslation("pricelist.generateFromDocuments", "Genera da Documenti")
        </MudButton>
        <MudButton Variant="Variant.Text"
                   Color="Color.Success"
                   StartIcon="@Icons.Material.Outlined.CheckCircle"
                   OnClick="@BulkActivate">
            @TranslationService.GetTranslation("pricelist.bulkActivate", "Attiva")
        </MudButton>
        <MudButton Variant="Variant.Text"
                   Color="Color.Warning"
                   StartIcon="@Icons.Material.Outlined.Pause"
                   OnClick="@BulkSuspend">
            @TranslationService.GetTranslation("pricelist.bulkSuspend", "Sospendi")
        </MudButton>
    </AdditionalToolbarContent>

    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Name")
            {
                <EFTableColumnHeader TItem="PriceListDto" PropertyName="Name">
                    <MudTableSortLabel SortBy="@(new Func<PriceListDto, object>(x => x.Name))">@TranslationService.GetTranslation("field.name", "Nome")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Code")
            {
                <EFTableColumnHeader TItem="PriceListDto" PropertyName="Code">
                    <MudTableSortLabel SortBy="@(new Func<PriceListDto, object>(x => x.Code ?? string.Empty))">@TranslationService.GetTranslation("field.code", "Codice")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Type")
            {
                <EFTableColumnHeader TItem="PriceListDto" PropertyName="Type">
                    <MudTableSortLabel SortBy="@(new Func<PriceListDto, object>(x => x.Type))">@TranslationService.GetTranslation("pricelist.type", "Tipo")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Status")
            {
                <EFTableColumnHeader TItem="PriceListDto" PropertyName="Status">
                    <MudTableSortLabel SortBy="@(new Func<PriceListDto, object>(x => x.Status))">@TranslationService.GetTranslation("common.status", "Stato")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Priority")
            {
                <EFTableColumnHeader TItem="PriceListDto" PropertyName="Priority">
                    <MudTableSortLabel SortBy="@(new Func<PriceListDto, object>(x => x.Priority))">@TranslationService.GetTranslation("field.priority", "Priorità")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ValidFrom")
            {
                <EFTableColumnHeader TItem="PriceListDto" PropertyName="ValidFrom">
                    <MudTableSortLabel SortBy="@(new Func<PriceListDto, object>(x => x.ValidFrom ?? DateTime.MinValue))">@TranslationService.GetTranslation("field.validFrom", "Valido Da")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ValidTo")
            {
                <EFTableColumnHeader TItem="PriceListDto" PropertyName="ValidTo">
                    <MudTableSortLabel SortBy="@(new Func<PriceListDto, object>(x => x.ValidTo ?? DateTime.MaxValue))">@TranslationService.GetTranslation("field.validTo", "Valido Fino")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "EntryCount")
            {
                <EFTableColumnHeader TItem="PriceListDto" PropertyName="EntryCount">
                    <MudTableSortLabel SortBy="@(new Func<PriceListDto, object>(x => x.EntryCount))">@TranslationService.GetTranslation("field.products", "Prodotti")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center" Style="min-width:120px;">@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Name")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.name", "Nome")">
                    <div class="d-flex align-center">
                        @if (ctx.Item.IsDefault)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" Class="mr-2" />
                        }
                        <div>
                            <MudText Typo="Typo.body2">@ctx.Item.Name</MudText>
                            @if (!string.IsNullOrEmpty(ctx.Item.Code))
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@ctx.Item.Code</MudText>
                            }
                        </div>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "Code")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.code", "Codice")">
                    <MudText Typo="Typo.body2">@(ctx.Item.Code ?? "-")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Type")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("pricelist.type", "Tipo")">
                    <MudChip T="string" Size="Size.Small" Color="@GetTypeColor(ctx.Item.Type)">
                        @TranslationService.GetTranslation($"pricelist.type.{ctx.Item.Type.ToString().ToLower()}", ctx.Item.Type.ToString())
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "Status")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("common.status", "Stato")">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(ctx.Item.Status)" Icon="@GetStatusIcon(ctx.Item.Status)">
                        @TranslationService.GetTranslation($"common.{ctx.Item.Status.ToString().ToLower()}", ctx.Item.Status.ToString())
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "Priority")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.priority", "Priorità")">
                    <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(ctx.Item.Priority)">
                        @ctx.Item.Priority
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "ValidFrom")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.validFrom", "Valido Da")">
                    @if (ctx.Item.ValidFrom.HasValue)
                    {
                        <MudText Typo="Typo.body2">@ctx.Item.ValidFrom.Value.ToShortDateString()</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">-</MudText>
                    }
                </MudTd>
            }
            else if (column.PropertyName == "ValidTo")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.validTo", "Valido Fino")">
                    <div class="d-flex align-center">
                        @if (ctx.Item.ValidTo.HasValue)
                        {
                            @if (GetValidityStatus(ctx.Item) == "expired")
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" Class="mr-1" />
                            }
                            else if (GetValidityStatus(ctx.Item) == "expiring")
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" Class="mr-1" />
                            }
                            <MudText Typo="Typo.body2">@ctx.Item.ValidTo.Value.ToShortDateString()</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">-</MudText>
                        }
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "EntryCount")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.products", "Prodotti")">
                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.Inventory">
                        @ctx.Item.EntryCount
                    </MudChip>
                </MudTd>
            }
        }
    </RowTemplate>
</EntityManagementPage>

@code {
    private EntityManagementPage<PriceListDto> _entityPage = null!;
    private IEntityManagementService<PriceListDto> _service = null!;
    private EntityManagementConfig<PriceListDto> _config = null!;
    private bool _onlyDefault = false;

    protected override void OnInitialized()
    {
        _service = new PriceListManagementService(PriceListService);
        _config = new EntityManagementConfig<PriceListDto>
        {
            ComponentKey = "PriceListManagement",
            PageTitleKey = "pricelist.management.title",
            PageTitleDefault = "Gestione Listini Prezzi",
            EntityIcon = Icons.Material.Outlined.PriceCheck,
            PageRootCssClass = "pricelist-page-root",
            BaseRoute = "/management/pricelists",
            ExcelFileName = "Listini",
            SearchPlaceholderKey = "common.search",
            SearchPlaceholderDefault = "Cerca...",
            CreateTooltip = "pricelist.create",
            EntityTypeName = "PriceList",
            ShowToggleStatus = false,
            ShowAuditLog = false,
            GetDisplayName = pl => pl.Name,
            GetId = pl => pl.Id,
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Listini", null, disabled: true),
                new BreadcrumbItem("Gestione Listini", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Name", DisplayName = "Nome", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "Code", DisplayName = "Codice", IsVisible = true, Order = 1, IsSearchable = true },
                new() { PropertyName = "Type", DisplayName = "Tipo", IsVisible = true, Order = 2, IsSearchable = false },
                new() { PropertyName = "Status", DisplayName = "Stato", IsVisible = true, Order = 3, IsSearchable = false },
                new() { PropertyName = "Priority", DisplayName = "Priorità", IsVisible = true, Order = 4, IsSearchable = false },
                new() { PropertyName = "ValidFrom", DisplayName = "Valido Da", IsVisible = true, Order = 5, IsSearchable = false },
                new() { PropertyName = "ValidTo", DisplayName = "Valido Fino", IsVisible = true, Order = 6, IsSearchable = false },
                new() { PropertyName = "EntryCount", DisplayName = "Prodotti", IsVisible = true, Order = 7, IsSearchable = false },
                new() { PropertyName = "IsDefault", DisplayName = "Default", IsVisible = false, Order = 8, IsSearchable = false },
                new() { PropertyName = "Direction", DisplayName = "Direzione", IsVisible = false, Order = 9, IsSearchable = false },
            },
            QuickFilters = new()
            {
                new() { Id = "all", Label = "Tutti", Predicate = _ => true, Description = "Mostra tutti i listini" },
                new() { Id = "active", Label = "Attivi", Predicate = pl => pl.Status == PriceListStatus.Active, Color = Color.Success, Icon = Icons.Material.Outlined.CheckCircle, Description = "Listini attivi" },
                new() { Id = "suspended", Label = "Sospesi", Predicate = pl => pl.Status == PriceListStatus.Suspended, Color = Color.Warning, Icon = Icons.Material.Outlined.Pause, Description = "Listini sospesi" },
                new() { Id = "default", Label = "Predefiniti", Predicate = pl => pl.IsDefault, Color = Color.Primary, Icon = Icons.Material.Outlined.Star, Description = "Listini predefiniti" },
                new() { Id = "selling", Label = "Vendita", Predicate = pl => pl.Type == PriceListType.Sales, Color = Color.Primary, Icon = Icons.Material.Outlined.Sell, Description = "Listini di vendita" },
                new() { Id = "purchase", Label = "Acquisto", Predicate = pl => pl.Type == PriceListType.Purchase, Color = Color.Secondary, Icon = Icons.Material.Outlined.ShoppingCart, Description = "Listini di acquisto" }
            }
        };
    }

    private Color GetTypeColor(PriceListType type) => type switch
    {
        PriceListType.Sales => Color.Primary,
        PriceListType.Purchase => Color.Info,
        _ => Color.Default
    };

    private Color GetStatusColor(PriceListStatus status) => status switch
    {
        PriceListStatus.Active => Color.Success,
        PriceListStatus.Suspended => Color.Warning,
        _ => Color.Default
    };

    private string GetStatusIcon(PriceListStatus status) => status switch
    {
        PriceListStatus.Active => Icons.Material.Filled.CheckCircle,
        PriceListStatus.Suspended => Icons.Material.Filled.Pause,
        _ => Icons.Material.Filled.Circle
    };

    private Color GetPriorityColor(int priority) => priority switch
    {
        <= 10 => Color.Error,      // High priority (red)
        <= 50 => Color.Warning,    // Medium priority (yellow)
        _ => Color.Info            // Low priority (blue)
    };

    private string GetValidityStatus(PriceListDto item)
    {
        if (!item.ValidTo.HasValue) return "valid";

        var now = DateTime.Now;
        var daysUntilExpiry = (item.ValidTo.Value - now).TotalDays;

        if (daysUntilExpiry < 0) return "expired";
        if (daysUntilExpiry <= 7) return "expiring";
        if (item.ValidFrom.HasValue && item.ValidFrom.Value > now) return "future";

        return "valid";
    }

    private async Task OpenDetailDialogAsync(Guid id)
    {
        try
        {
            var parameters = new DialogParameters { [nameof(PriceListDetailDialog.EntityId)] = (Guid?)id };
            var dialog = await DialogService.ShowAsync<PriceListDetailDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await _entityPage!.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening price list detail dialog.");
            await AppNotification.ShowWarningAsync("Si è verificato un errore nell'apertura del dialogo.");
        }
    }

    private async Task OpenCreateDialog()
    {
        try
        {
            var dialog = await DialogService.ShowAsync<CreatePriceListDialog>(
                TranslationService.GetTranslation("pricelist.create", "Nuovo Listino"),
                new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });

            var result = await dialog.Result;

            if (result is { Canceled: false })
            {
                await _entityPage!.RefreshAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening create price list dialog.");
            await AppNotification.ShowWarningAsync("Si è verificato un errore nell'apertura del dialogo.");
        }
    }

    private async Task OpenGenerateFromDocumentsDialog()
    {
        try
        {
            var dialog = await DialogService.ShowAsync<GeneratePriceListFromDocumentsDialog>(
                TranslationService.GetTranslation("pricelist.generateFromDocuments", "Genera da Documenti"),
                new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true });

            var result = await dialog.Result;

            if (result is { Canceled: false })
            {
                await _entityPage!.RefreshAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening generate price list from documents dialog.");
            await AppNotification.ShowWarningAsync("Si è verificato un errore nell'apertura del dialogo.");
        }
    }

    private async Task OpenGenerateFromDefaultPricesDialog()
    {
        try
        {
            var dialog = await DialogService.ShowAsync<GenerateFromDefaultPricesDialog>(
                TranslationService.GetTranslation("pricelist.generateFromDefaults", "Genera Listino da Prezzi Default"),
                new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });

            var result = await dialog.Result;
            if (result is { Canceled: false } && result.Data != null)
            {
                await _entityPage!.RefreshAsync();
                AppNotification.ShowSuccess(TranslationService.GetTranslation("pricelist.generatedSuccess", "Listino generato con successo"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening generate price list from default prices dialog.");
            await AppNotification.ShowWarningAsync("Si è verificato un errore nella generazione del listino.");
        }
    }

    private async Task BulkActivate()
    {
        // TODO: Implement bulk activate functionality
        AppNotification.ShowInfo(TranslationService.GetTranslation("common.notImplemented", "Funzionalità non ancora implementata"));
        await Task.CompletedTask;
    }

    private async Task BulkSuspend()
    {
        // TODO: Implement bulk suspend functionality
        AppNotification.ShowInfo(TranslationService.GetTranslation("common.notImplemented", "Funzionalità non ancora implementata"));
        await Task.CompletedTask;
    }
}
