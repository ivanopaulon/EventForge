@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.Business
@using EventForge.DTOs.Common
@using EventForge.Client.Shared.Components
@using EventForge.Client.Shared.Components.Dialogs
@using EventForge.Client.Pages.Management.Business.BusinessPartyDetailTabs
@using EventForge.Client.Shared.BusinessParty
@attribute [Authorize]
@inject IBusinessPartyService BusinessPartyService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<BusinessPartyDetailDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.Business"
          Title="@(_isCreateMode ? $"{GetEntityTypeName()} - {TranslationService.GetTranslation("common.create", "Crea")}" : (_party?.Name ?? string.Empty))"
          IsProcessing="@(_isLoading || _isSaving)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <ChildContent>
        @if (_isLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (_party == null && !_isCreateMode)
        {
            <MudAlert Severity="Severity.Error">
                @TranslationService.GetTranslation("businessParty.notFound", "Business party non trovato")
            </MudAlert>
        }
        else
        {
            <MudTabs Elevation="0" Rounded="false" PanelClass="pa-4" Class="ef-tabs" ApplyEffectsToContainer="true" ActivePanelIndex="_activeTab" ActivePanelIndexChanged="OnTabChanged">

                <MudTabPanel Text="@TranslationService.GetTranslation("businessParty.general", "Generale")"
                             Icon="@Icons.Material.Filled.Info">
                    <MudForm @ref="_form">
                    <GeneralInfoTab Party="@_party"
                                    IsEditMode="@_isEditMode"
                                    IsNewParty="@_isCreateMode"
                                    OnPartyUpdated="@HandlePartyLocallyChanged"
                                    OnAddressCreated="@HandleAddressCreated"
                                    OnManageGroupsClicked="@OnManageGroupsClicked"
                                    OnRemoveGroup="@OnRemoveGroup" />
                    </MudForm>
                </MudTabPanel>

                @if (!_isCreateMode && _party != null)
                {
                    <MudTabPanel Text="@TranslationService.GetTranslation("businessParty.recapiti", "Recapiti")"
                                 Icon="@Icons.Material.Filled.ContactPhone"
                                 BadgeData="@(_party.AddressCount + _party.ContactCount + _party.ReferenceCount)"
                                 BadgeDot="@(_party.AddressCount > 0 || _party.ContactCount > 0 || _party.ReferenceCount > 0)">
                        <RecapitiTab Party="@_party"
                                     IsEditMode="@_isEditMode"
                                     OnPartyUpdated="@HandlePartyLocallyChanged" />
                    </MudTabPanel>

                    <MudTabPanel Text="@TranslationService.GetTranslation("businessParty.operativo", "Operativo")"
                                 Icon="@Icons.Material.Filled.Inventory">
                        <OperativoTab BusinessPartyId="@_party.Id"
                                      PartyType="@_party.PartyType" />
                    </MudTabPanel>

                    <MudTabPanel Text="Commerciale"
                                 Icon="@Icons.Material.Filled.ShoppingCart"
                                 BadgeData="@_priceListsCount"
                                 BadgeDot="@(_priceListsCount > 0)">
                        @if (_tabStates["Commerciale"] == TabLoadState.Loaded)
                        {
                            <CommercialeTab BusinessPartyId="@_party.Id"
                                            PartyType="@_party.PartyType" />
                        }
                    </MudTabPanel>

                    @if (_party.HasAccountingData)
                    {
                        <MudTabPanel Text="@TranslationService.GetTranslation("businessParty.accounting", "Dati Contabili")"
                                     Icon="@Icons.Material.Filled.AccountBalance">
                            <AccountingTab Party="@_party"
                                           IsEditMode="@_isEditMode"
                                           OnPartyUpdated="@HandlePartyLocallyChanged" />
                        </MudTabPanel>
                    }
                }
            </MudTabs>
        }
    </ChildContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="_isSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SavePartyAsync" Disabled="_isSaving || _isLoading || _party == null">
            @TranslationService.GetTranslation("common.save", "Salva")
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? EntityId { get; set; }
    [Parameter] public bool IsSupplierMode { get; set; }

    private BusinessPartyDto? _party;
    private bool _isLoading = true;
    private bool _isCreateMode => EntityId == null || EntityId == Guid.Empty;
    private bool _isEditMode = true;
    private bool _isSaving = false;
    private MudForm? _form;
    private int _activeTab = 0;

    private string _originalPartySnapshot = string.Empty;
    private bool _hasLocalChanges = false;

    private static readonly System.Text.Json.JsonSerializerOptions _jsonOptions = new()
    {
        PropertyNameCaseInsensitive = true,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
    };

    private int _priceListsCount = 0;

    private readonly Dictionary<string, TabLoadState> _tabStates = new()
    {
        { "General", TabLoadState.Loaded },
        { "Recapiti", TabLoadState.NotLoaded },
        { "Operativo", TabLoadState.NotLoaded },
        { "Commerciale", TabLoadState.NotLoaded },
        { "Contabilita", TabLoadState.NotLoaded }
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadPartyAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing BusinessPartyDetailDialog.");
        }
    }

    private async Task LoadPartyAsync()
    {
        _isLoading = true;
        try
        {
            if (_isCreateMode)
            {
                _party = new BusinessPartyDto
                {
                    PartyType = IsSupplierMode ? BusinessPartyType.Supplier : BusinessPartyType.Cliente,
                    Name = string.Empty,
                    IsActive = true
                };
                _originalPartySnapshot = SerializeParty(_party);
            }
            else if (EntityId.HasValue)
            {
                var party = await BusinessPartyService.GetBusinessPartyAsync(EntityId.Value);
                _party = party;
                if (_party != null)
                    _originalPartySnapshot = SerializeParty(_party);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading business party {EntityId}", EntityId);
            AppNotification.ShowError(TranslationService.GetTranslation("businessParty.loadError", "Errore nel caricamento"));
        }
        finally
        {
            _isLoading = false;
            _hasLocalChanges = false;
        }
    }

    private async Task SavePartyAsync()
    {
        if (_party == null) return;

        if (_form != null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid) return;
        }

        _isSaving = true;
        try
        {
            if (_isCreateMode)
            {
                var createDto = new CreateBusinessPartyDto
                {
                    PartyType = _party.PartyType,
                    Name = _party.Name ?? string.Empty,
                    TaxCode = _party.TaxCode,
                    VatNumber = _party.VatNumber,
                    SdiCode = _party.SdiCode,
                    Pec = _party.Pec,
                    Notes = _party.Notes
                };
                await BusinessPartyService.CreateBusinessPartyAsync(createDto);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("businessParty.createSuccess", "Business party creato con successo"));
            }
            else if (EntityId.HasValue)
            {
                var updateDto = new UpdateBusinessPartyDto
                {
                    PartyType = _party.PartyType,
                    Name = _party.Name ?? string.Empty,
                    TaxCode = _party.TaxCode,
                    VatNumber = _party.VatNumber,
                    SdiCode = _party.SdiCode,
                    Pec = _party.Pec,
                    Notes = _party.Notes,
                    DateOfBirth = _party.DateOfBirth,
                    DefaultSalesPriceListId = _party.DefaultSalesPriceListId,
                    DefaultPurchasePriceListId = _party.DefaultPurchasePriceListId,
                    DefaultPriceApplicationMode = _party.DefaultPriceApplicationMode,
                    ForcedPriceListId = _party.ForcedPriceListId,
                    RowVersion = _party.RowVersion
                };
                await BusinessPartyService.UpdateBusinessPartyAsync(EntityId.Value, updateDto);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("businessParty.updateSuccess", "Business party aggiornato con successo"));
            }

            _hasLocalChanges = false;
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving business party");
            AppNotification.ShowError(TranslationService.GetTranslation("businessParty.saveError", "Errore nel salvataggio"));
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void HandlePartyLocallyChanged()
    {
        _hasLocalChanges = true;
        StateHasChanged();
    }

    private void HandleAddressCreated()
    {
        if (_party != null)
        {
            _party.AddressCount++;
            StateHasChanged();
        }
    }

    private string SerializeParty(BusinessPartyDto? p)
    {
        if (p == null) return string.Empty;
        return System.Text.Json.JsonSerializer.Serialize(p, _jsonOptions);
    }

    private bool HasUnsavedChanges()
    {
        if (_party == null) return false;
        if (_hasLocalChanges) return true;
        var current = SerializeParty(_party);
        return !string.Equals(current, _originalPartySnapshot, StringComparison.Ordinal);
    }

    private string GetEntityTypeName()
    {
        return IsSupplierMode
            ? TranslationService.GetTranslation("entity.supplier", "Fornitore")
            : TranslationService.GetTranslation("entity.customer", "Cliente");
    }

    private void OnManageGroupsClicked()
    {
        AppNotification.ShowInfo("Gestione gruppi: implementazione in fase successiva");
    }

    private void OnRemoveGroup(Guid groupId)
    {
        if (_party?.Groups != null)
        {
            var group = _party.Groups.FirstOrDefault(g => g.Id == groupId);
            if (group != null)
            {
                _party.Groups.Remove(group);
                StateHasChanged();
                AppNotification.ShowWarning($"Gruppo '{group.Name}' rimosso (solo UI - backend non implementato)");
            }
        }
    }

    private void OnTabChanged(int index)
    {
        _activeTab = index;

        var tabName = index switch
        {
            0 => "General",
            1 => "Recapiti",
            2 => "Operativo",
            3 => "Commerciale",
            4 => "Contabilita",
            _ => null
        };

        if (tabName != null && _tabStates.ContainsKey(tabName) && _tabStates[tabName] == TabLoadState.NotLoaded)
        {
            _tabStates[tabName] = TabLoadState.Loaded;
            StateHasChanged();
        }
    }

    private async Task Cancel()
    {
        if (HasUnsavedChanges())
        {
            var result = await DialogService.ShowMessageBoxAsync(
                TranslationService.GetTranslation("common.confirm", "Conferma"),
                TranslationService.GetTranslation("common.unsavedChangesConfirm", "Ci sono modifiche non salvate. Vuoi salvare prima di uscire?"),
                yesText: TranslationService.GetTranslation("common.save", "Salva"),
                noText: TranslationService.GetTranslation("common.discard", "Non salvare"),
                cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
            if (result == null) return;
            if (result == true) { await SavePartyAsync(); return; }
        }
        MudDialog.Close();
    }
}
