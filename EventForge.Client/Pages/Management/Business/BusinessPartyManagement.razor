@page "/business/parties"
@page "/business/parties/{FilterType}"
@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.Business
@using EventForge.DTOs.Common
@using EventForge.Client.Shared.Components
@using EventForge.Client.Shared.Components.Dialogs
@using EventForge.Client.Shared.Management
@using EventForge.Client.Shared.Management.Adapters
@using EventForge.Client.Extensions
@using EventForge.Client.Services.External
@using MudBlazor
@attribute [Authorize]
@inject IBusinessPartyService BusinessPartyService
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<BusinessPartyManagement> Logger
@inject IAppNotificationService AppNotification

<PageTitle>@TranslationService.GetTranslation("businessparty.management", "Gestione Business Party")</PageTitle>
<EntityManagementPage @ref="_entityPage"
                      TEntity="BusinessPartyDto"
                      Config="_config"
                      Service="_service"
                      AdditionalFilter="@_urlFilter"
                      OnCreateOverride="@CreateBusinessPartyAsync"
                      OnEditOverride="@(id => OpenDetailDialogAsync(id))">
    <AdditionalToolbarContent>
        <MudTooltip Text="@(_entityPage?.EFTableRef?.SelectedItems.Count > 0
                            ? $"Aggiorna da P.IVA ({_entityPage.EFTableRef.SelectedItems.Count(p => !string.IsNullOrWhiteSpace(p.VatNumber))} selezionati con P.IVA)"
                            : "Aggiorna ragione sociale da P.IVA per tutti i business party")">
            <MudIconButton Icon="@Icons.Material.Outlined.ManageSearch"
                           Color="Color.Primary"
                           Size="Size.Medium"
                           OnClick="@OpenBulkVatUpdateDialogAsync" />
        </MudTooltip>
    </AdditionalToolbarContent>

    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Name")
            {
                <EFTableColumnHeader TItem="BusinessPartyDto" PropertyName="Name" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<BusinessPartyDto, object>(x => x.Name))">@TranslationService.GetTranslation("field.name", "Nome")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "VatNumber")
            {
                <EFTableColumnHeader TItem="BusinessPartyDto" PropertyName="VatNumber" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<BusinessPartyDto, object>(x => x.VatNumber ?? string.Empty))">@TranslationService.GetTranslation("field.vatNumber", "P.IVA")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "TaxCode")
            {
                <EFTableColumnHeader TItem="BusinessPartyDto" PropertyName="TaxCode" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<BusinessPartyDto, object>(x => x.TaxCode ?? string.Empty))">@TranslationService.GetTranslation("field.taxCode", "C.F.")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Groups")
            {
                <EFTableColumnHeader TItem="BusinessPartyDto" PropertyName="Groups" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTh>@TranslationService.GetTranslation("field.groups", "Gruppi")</MudTh>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "City")
            {
                <EFTableColumnHeader TItem="BusinessPartyDto" PropertyName="City" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<BusinessPartyDto, object>(x => x.City ?? string.Empty))">@TranslationService.GetTranslation("field.city", "Località")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Province")
            {
                <EFTableColumnHeader TItem="BusinessPartyDto" PropertyName="Province" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<BusinessPartyDto, object>(x => x.Province ?? string.Empty))">@TranslationService.GetTranslation("field.province", "Provincia")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Country")
            {
                <EFTableColumnHeader TItem="BusinessPartyDto" PropertyName="Country" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTableSortLabel SortBy="@(new Func<BusinessPartyDto, object>(x => x.Country ?? string.Empty))">@TranslationService.GetTranslation("field.country", "Nazione")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Contacts")
            {
                <EFTableColumnHeader TItem="BusinessPartyDto" PropertyName="Contacts" OnDragStartCallback="@_entityPage!.EFTableRef!.HandleColumnDragStart">
                    <MudTh>@TranslationService.GetTranslation("field.contacts", "Contatti")</MudTh>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center" Style="min-width:120px;">@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Name")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.name", "Nome")">
                    <div class="d-flex align-center">
                        <MudAvatar Color="@GetAvatarColor(ctx.Item)" Size="Size.Small" Class="mr-2">
                            <MudIcon Icon="@GetIcon(ctx.Item)" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2">@ctx.Item.Name</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">ID: @(ctx.Item.Id.ToString()[..Math.Min(8, ctx.Item.Id.ToString().Length)])...</MudText>
                        </div>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "VatNumber")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.vatNumber", "P.IVA")">
                    <MudText Typo="Typo.body2">@(ctx.Item.VatNumber ?? "-")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "TaxCode")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.taxCode", "C.F.")">
                    <MudText Typo="Typo.body2">@(ctx.Item.TaxCode ?? "-")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Groups")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.groups", "Gruppi")">
                    @if (ctx.Item.Groups != null && ctx.Item.Groups.Any())
                    {
                        var sortedGroups = GetSortedGroups(ctx.Item.Groups).ToList();
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Style="max-width: 300px;">
                            @foreach (var group in sortedGroups.Take(3))
                            {
                                <MudTooltip Text="@GetGroupTooltip(group)" Placement="Placement.Top">
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Style="@GetGroupBadgeStyle(group)"
                                             Icon="@(group.Icon ?? Icons.Material.Filled.Group)">
                                        @group.Name
                                    </MudChip>
                                </MudTooltip>
                            }
                            @if (sortedGroups.Count > 3)
                            {
                                <MudTooltip Text="@GetRemainingGroupsTooltip(sortedGroups.Skip(3))">
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="Color.Default"
                                             Variant="Variant.Outlined">
                                        +@(sortedGroups.Count - 3)
                                    </MudChip>
                                </MudTooltip>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">-</MudText>
                    }
                </MudTd>
            }
            else if (column.PropertyName == "City")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.city", "Località")">
                    <MudText Typo="Typo.body2">@(ctx.Item.City ?? "-")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Province")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.province", "Provincia")">
                    <MudText Typo="Typo.body2">@(ctx.Item.Province ?? "-")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Country")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.country", "Nazione")">
                    <MudText Typo="Typo.body2">@(ctx.Item.Country ?? "-")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Contacts")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.contacts", "Contatti")">
                    <div class="d-flex gap-2">
                        <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.LocationOn">@ctx.Item.AddressCount</MudChip>
                        <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.Phone">@ctx.Item.ContactCount</MudChip>
                        <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.Person">@ctx.Item.ReferenceCount</MudChip>
                    </div>
                </MudTd>
            }
        }
    </RowTemplate>

    <AdditionalRowActions Context="item">
        @if (item.PartyType == BusinessPartyType.Supplier || item.PartyType == BusinessPartyType.Both)
        {
            <MudTooltip Text="@TranslationService.GetTranslation("supplier.manageProducts", "Gestisci Prodotti")">
                <MudIconButton Icon="@Icons.Material.Outlined.Inventory2"
                               Color="Color.Dark"
                               Size="Size.Small"
                               OnClick="@(() => ManageSupplierProductsAsync(item))" />
            </MudTooltip>
        }
        <MudTooltip Text="@TranslationService.GetTranslation("common.edit", "Modifica")">
            <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="@(() => EditBusinessParty(item))" />
        </MudTooltip>
    </AdditionalRowActions>
</EntityManagementPage>

@code {
    [Parameter] public string? FilterType { get; set; }

    private EntityManagementPage<BusinessPartyDto> _entityPage = null!;
    private BusinessPartyManagementService _service = null!;
    private EntityManagementConfig<BusinessPartyDto> _config = null!;

    // URL-driven additional filter (set by OnParametersSet based on FilterType route param)
    private Func<BusinessPartyDto, bool>? _urlFilter;

    // Quick-filter list (also used by OnParametersSet to initialise _urlFilter)
    private static readonly List<QuickFilter<BusinessPartyDto>> _quickFilters = new()
    {
        new()
        {
            Id = "all",
            Label = "Tutti",
            Predicate = _ => true,
            Description = "Mostra tutte le anagrafiche"
        },
        new()
        {
            Id = "customers",
            Label = "Clienti",
            Predicate = bp => bp.PartyType == BusinessPartyType.Cliente || bp.PartyType == BusinessPartyType.Both,
            Color = Color.Primary,
            Icon = Icons.Material.Outlined.People,
            Description = "Solo clienti"
        },
        new()
        {
            Id = "suppliers",
            Label = "Fornitori",
            Predicate = bp => bp.PartyType == BusinessPartyType.Supplier || bp.PartyType == BusinessPartyType.Both,
            Color = Color.Secondary,
            Icon = Icons.Material.Outlined.LocalShipping,
            Description = "Solo fornitori"
        },
        new()
        {
            Id = "both",
            Label = "Cliente + Fornitore",
            Predicate = bp => bp.PartyType == BusinessPartyType.Both,
            Color = Color.Info,
            Icon = Icons.Material.Outlined.Handshake,
            Description = "Anagrafiche sia cliente che fornitore"
        },
        new()
        {
            Id = "active",
            Label = "Attivi",
            Predicate = bp => bp.IsActive,
            Color = Color.Success,
            Icon = Icons.Material.Outlined.CheckCircle,
            Description = "Anagrafiche attive"
        },
        new()
        {
            Id = "with_vat",
            Label = "Con P.IVA",
            Predicate = bp => !string.IsNullOrWhiteSpace(bp.VatNumber),
            Color = Color.Warning,
            Icon = Icons.Material.Outlined.Numbers,
            Description = "Anagrafiche con Partita IVA"
        }
    };

    protected override void OnInitialized()
    {
        _service = new BusinessPartyManagementService(BusinessPartyService);
        _config = new EntityManagementConfig<BusinessPartyDto>
        {
            ComponentKey = "BusinessPartyManagement",
            PageTitleKey = "businessparty.management",
            PageTitleDefault = "Gestione Business Party",
            EntityIcon = Icons.Material.Outlined.Business,
            PageRootCssClass = "businessparty-page-root management-page-root",
            BaseRoute = "/business/parties",
            ExcelFileName = "AnagraficheAziendali",
            SearchPlaceholderKey = "businessparty.search",
            SearchPlaceholderDefault = "Cerca",
            CreateTooltip = "businessparty.createNew",
            EntityTypeName = "BusinessParty",
            ShowToggleStatus = false,
            ShowEdit = false,
            ShowView = false,
            GetDisplayName = bp => bp.Name,
            GetId = bp => bp.Id,
            GetIsActive = bp => bp.IsActive,
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Anagrafiche", null, disabled: true),
                new BreadcrumbItem("Business Party", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Name", DisplayName = "Nome", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "VatNumber", DisplayName = "P.IVA", IsVisible = true, Order = 1, IsSearchable = true },
                new() { PropertyName = "TaxCode", DisplayName = "C.F.", IsVisible = true, Order = 2, IsSearchable = true },
                new() { PropertyName = "Groups", DisplayName = "Gruppi", IsVisible = true, Order = 3, IsSearchable = false },
                new() { PropertyName = "City", DisplayName = "Località", IsVisible = true, Order = 4, IsSearchable = true },
                new() { PropertyName = "Province", DisplayName = "Provincia", IsVisible = true, Order = 5, IsSearchable = true },
                new() { PropertyName = "Country", DisplayName = "Nazione", IsVisible = true, Order = 6, IsSearchable = false },
                new() { PropertyName = "Contacts", DisplayName = "Contatti", IsVisible = true, Order = 7, IsSearchable = false }
            },
            QuickFilters = _quickFilters,
            DeleteConfirmMessageKey = "businessparty.confirmDelete",
            DeleteSuccessMessageKey = "businessparty.deleted",
            DeleteErrorMessageKey = "businessparty.deleteError",
            BulkDeleteConfirmMessageKey = "businessparty.confirmDeleteMultiple",
            LoadErrorMessageKey = "businessparty.loadingPageError"
        };
    }

    protected override void OnParametersSet()
    {
        // Apply URL-driven filter (e.g. /business/parties/customers → show only customers).
        // The filter is cleared to null for "all" so EntityManagementPage doesn't double-filter
        // when the user also selects a QuickFilter.
        var filterId = FilterType?.ToLower() switch
        {
            "customers" or "clienti" => "customers",
            "suppliers" or "fornitori" => "suppliers",
            "both" or "entrambi" => "both",
            _ => null
        };

        _urlFilter = filterId == null
            ? null
            : _quickFilters.FirstOrDefault(f => f.Id == filterId)?.Predicate;
    }

    private async Task CreateBusinessPartyAsync()
    {
        try
        {
            var isSupplierMode = FilterType?.ToLower() is "suppliers" or "fornitori";
            var parameters = new DialogParameters
            {
                [nameof(BusinessPartyDetailDialog.EntityId)] = (Guid?)null,
                [nameof(BusinessPartyDetailDialog.IsSupplierMode)] = isSupplierMode
            };
            var dialog = await DialogService.ShowAsync<BusinessPartyDetailDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await _entityPage.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening create business party dialog.");
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }

    private async Task OpenDetailDialogAsync(Guid id)
    {
        try
        {
            var isSupplierMode = FilterType?.ToLower() is "suppliers" or "fornitori";
            var parameters = new DialogParameters
            {
                [nameof(BusinessPartyDetailDialog.EntityId)] = (Guid?)id,
                [nameof(BusinessPartyDetailDialog.IsSupplierMode)] = isSupplierMode
            };
            var dialog = await DialogService.ShowAsync<BusinessPartyDetailDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await _entityPage.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening business party detail dialog for ID {Id}.", id);
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }

    private async Task EditBusinessParty(BusinessPartyDto businessParty)
    {
        await OpenDetailDialogAsync(businessParty.Id);
    }

    private async Task ManageSupplierProductsAsync(BusinessPartyDto supplier)
    {
        try
        {
            var parameters = new DialogParameters
            {
                { "SupplierId", supplier.Id },
                { "SupplierName", supplier.Name }
            };

            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
                CloseButton = true
            };

            var dialog = await DialogService.ShowAsync<ManageSupplierProductsDialog>(
                TranslationService.GetTranslation("supplier.manageProducts", "Gestisci Prodotti") + $" - {supplier.Name}",
                parameters,
                options);

            await dialog.Result;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening manage supplier products dialog for {SupplierId}.", supplier.Id);
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }

    private async Task OpenBulkVatUpdateDialogAsync()
    {
        try
        {
            var allParties = _service.CachedItems;
            var selectedParties = _entityPage?.EFTableRef?.SelectedItems ?? new HashSet<BusinessPartyDto>();

            var parameters = new DialogParameters<BulkVatUpdateDialog>
            {
                { x => x.AllParties, allParties },
                { x => x.SelectedParties, selectedParties }
            };

            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                CloseButton = false,
                CloseOnEscapeKey = false
            };

            var dialog = await DialogService.ShowAsync<BulkVatUpdateDialog>(
                "Aggiornamento massivo da P.IVA",
                parameters,
                options);

            var result = await dialog.Result;
            if (result is { Canceled: false, Data: true })
            {
                // Names were updated in place by the dialog; reload for a clean server-side refresh
                await _entityPage!.RefreshAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening bulk VAT update dialog.");
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }
    // ──────────────────────────── Display helpers ────────────────────────────

    private static IEnumerable<BusinessPartyGroupDto> GetSortedGroups(List<BusinessPartyGroupDto> groups)
        => groups
            .Where(g => g.IsActive && g.IsCurrentlyValid)
            .OrderByDescending(g => g.Priority)
            .ThenBy(g => g.Name);

    private static string GetGroupBadgeStyle(BusinessPartyGroupDto group)
    {
        if (string.IsNullOrEmpty(group.ColorHex))
            return string.Empty;

        var bgColor = $"{group.ColorHex}20";
        var borderColor = $"{group.ColorHex}40";
        return $"background-color: {bgColor}; color: {group.ColorHex}; border: 1px solid {borderColor}; font-weight: 500;";
    }

    private static string GetGroupTooltip(BusinessPartyGroupDto group)
    {
        var tooltip = group.Name;

        if (!string.IsNullOrEmpty(group.Description))
            tooltip += $"\n{group.Description}";

        if (group.ValidFrom.HasValue || group.ValidTo.HasValue)
        {
            tooltip += "\n\nValidità: ";
            tooltip += group.ValidFrom.HasValue ? $"dal {group.ValidFrom.Value:dd/MM/yyyy}" : "da sempre";
            tooltip += " ";
            tooltip += group.ValidTo.HasValue ? $"al {group.ValidTo.Value:dd/MM/yyyy}" : "per sempre";
        }

        tooltip += $"\n\nPriorità: {group.Priority}";
        tooltip += $"\nMembri attivi: {group.ActiveMembersCount}";

        return tooltip;
    }

    private static string GetRemainingGroupsTooltip(IEnumerable<BusinessPartyGroupDto> remainingGroups)
    {
        var groups = remainingGroups.ToList();
        if (!groups.Any()) return string.Empty;

        return "Altri gruppi:\n" + string.Join("\n", groups.Select(g => $"• {g.Name}"));
    }

    private static Color GetAvatarColor(BusinessPartyDto bp) => bp.PartyType switch
    {
        BusinessPartyType.Cliente => Color.Info,
        BusinessPartyType.Customer => Color.Info,
        BusinessPartyType.Supplier => Color.Primary,
        BusinessPartyType.Both => Color.Secondary,
        _ => Color.Default
    };

    private static string GetIcon(BusinessPartyDto bp) => bp.PartyType switch
    {
        BusinessPartyType.Cliente => Icons.Material.Outlined.Person,
        BusinessPartyType.Customer => Icons.Material.Outlined.Person,
        BusinessPartyType.Supplier => Icons.Material.Outlined.Business,
        BusinessPartyType.Both => Icons.Material.Outlined.Handshake,
        _ => Icons.Material.Outlined.Business
    };
}
