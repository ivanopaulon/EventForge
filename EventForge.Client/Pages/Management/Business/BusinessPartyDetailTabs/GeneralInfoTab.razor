@using Prym.DTOs.Business
@using Prym.DTOs.External
@using Prym.DTOs.Common
@using EventForge.Client.Services
@using EventForge.Client.Services.External
@using EventForge.Client.Shared.Components.Common
@inject ITranslationService TranslationService
@inject IVatLookupService VatLookupService
@inject IEntityManagementService EntityManagementService
@inject IAppNotificationService AppNotification
@inject ILogger<GeneralInfoTab> Logger

<MudGrid Spacing="4">
    
    <!-- ========== SEZIONE 1: DATI ANAGRAFICI ========== -->
    <MudItem xs="12">
        <MudPaper Elevation="1" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Outlined.Business" Class="mr-2" />
                @TranslationService.GetTranslation("businessParty.masterData", "Dati Anagrafici")
            </MudText>
            <MudGrid Spacing="3">
                <!-- Party Type -->
                <MudItem xs="12" md="6">
                <PrymSelect @bind-Value="Party.PartyType"
                            Label="@($"{TranslationService.GetTranslation("field.partyType", "Tipo")} *")"
                            ReadOnly="@(!IsEditMode)"
                            Required="true"
                            @bind-Value:after="NotifyUpdated">
                    <MudSelectItem Value="@BusinessPartyType.Cliente">@TranslationService.GetTranslation("partyType.cliente", "Cliente")</MudSelectItem>
                    <MudSelectItem Value="@BusinessPartyType.Supplier">@TranslationService.GetTranslation("partyType.supplier", "Fornitore")</MudSelectItem>
                    <MudSelectItem Value="@BusinessPartyType.Both">@TranslationService.GetTranslation("partyType.both", "Cliente/Fornitore")</MudSelectItem>
                </PrymSelect>
            </MudItem>
            
            <!-- Name -->
            <MudItem xs="12" md="6">
                <PrymTextField @bind-Value="Party.Name"
                               Label="@($"{TranslationService.GetTranslation("field.name", "Nome")} *")"
                               ReadOnly="@(!IsEditMode)"
                               Required="true"
                               RequiredError="Il nome è obbligatorio."
                               MaxLength="200"
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.Business"
                               @bind-Value:after="NotifyUpdated" />
            </MudItem>
            
            <!-- Tax Code -->
            <MudItem xs="12" md="6">
                <PrymTextField @bind-Value="Party.TaxCode"
                               Label="@TranslationService.GetTranslation("field.taxCode", "Codice Fiscale")"
                               ReadOnly="@(!IsEditMode)"
                               MaxLength="20"
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.Badge"
                               @bind-Value:after="NotifyUpdated" />
            </MudItem>
            
            <!-- VAT Number with Lookup -->
            <MudItem xs="12">
                <div class="d-flex gap-2">
                    <PrymTextField Class="flex-grow-1"
                                   @bind-Value="Party.VatNumber"
                                   Label="@TranslationService.GetTranslation("field.vatNumber", "Partita IVA")"
                                   ReadOnly="@(!IsEditMode)"
                                   MaxLength="20"
                                   Placeholder="IT12345678901"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Outlined.Business"
                                   HelperText="@TranslationService.GetTranslation("businessParty.vatNumberHelper", "Partita IVA (con o senza codice paese)")"
                                   @bind-Value:after="NotifyUpdated" />
                    @if (IsEditMode)
                    {
                        <PrymButton Intent="PrymButton.ButtonIntent.Primary"
                                    StartIcon="@Icons.Material.Filled.Search"
                                    OnClick="@LookupVatAsync"
                                    Disabled="@(_isLookingUp || string.IsNullOrWhiteSpace(Party.VatNumber))"
                                    Class="align-self-start mt-1-em">
                            @if (_isLookingUp)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            @TranslationService.GetTranslation("common.search", "Cerca")
                        </PrymButton>
                    }
                </div>
            </MudItem>
            
            <!-- VAT Lookup Result -->
            @if (_lookupResult != null && _lookupResult.IsValid)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                        <div class="d-flex justify-space-between align-center">
                            <div>
                                <MudText Typo="Typo.subtitle2">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1" />
                                    @TranslationService.GetTranslation("vat.validVat", "P.IVA Valida")
                                </MudText>
                                <MudText Typo="Typo.body2"><strong>@_lookupResult.Name</strong></MudText>
                                <MudText Typo="Typo.caption">@_lookupResult.Address</MudText>
                            </div>
                            <PrymButton Intent="PrymButton.ButtonIntent.Ghost"
                                        OnClick="@(async () => await ApplyLookupData())">
                                @TranslationService.GetTranslation("vat.useData", "Usa questi dati")
                            </PrymButton>
                        </div>
                    </MudAlert>
                </MudItem>
            }
            else if (_lookupResult != null && !_lookupResult.IsValid)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        @TranslationService.GetTranslation("vat.invalidVat", "P.IVA non valida o non trovata")
                        @if (!string.IsNullOrEmpty(_lookupResult.ErrorMessage))
                        {
                            <MudText Typo="Typo.caption" Class="mt-2">@_lookupResult.ErrorMessage</MudText>
                        }
                    </MudAlert>
                </MudItem>
            }
            
            <!-- SDI Code -->
            <MudItem xs="12" md="6">
                <PrymTextField @bind-Value="Party.SdiCode"
                               Label="@TranslationService.GetTranslation("field.sdiCode", "Codice SDI")"
                               ReadOnly="@(!IsEditMode)"
                               MaxLength="10"
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.QrCode"
                               @bind-Value:after="NotifyUpdated" />
            </MudItem>
            
            <!-- PEC -->
            <MudItem xs="12" md="6">
                <PrymTextField @bind-Value="Party.Pec"
                               Label="@TranslationService.GetTranslation("field.pec", "PEC")"
                               ReadOnly="@(!IsEditMode)"
                               MaxLength="100"
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.Email"
                               @bind-Value:after="NotifyUpdated" />
            </MudItem>

            <!-- Is Active -->
            <MudItem xs="12" md="6">
                <MudSwitch T="bool"
                           Checked="@Party.IsActive"
                           Label="@TranslationService.GetTranslation("field.isActive", "Attivo")"
                           Color="Color.Primary"
                           Disabled="true" />
            </MudItem>
            
            <!-- Notes -->
            <MudItem xs="12">
                <PrymTextField @bind-Value="Party.Notes"
                               Label="@TranslationService.GetTranslation("field.notes", "Note")"
                               Lines="4"
                               ReadOnly="@(!IsEditMode)"
                               MaxLength="500"
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.Notes"
                               @bind-Value:after="NotifyUpdated" />
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
    
    <!-- ========== SEZIONE 2: GRUPPI (NUOVA) ========== -->
    <MudItem xs="12">
        <MudPaper Elevation="1" Class="pa-4">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Outlined.Group" Class="mr-2" />
                    @TranslationService.GetTranslation("businessParty.groups", "Gruppi Business Party")
                </MudText>
                @if (IsEditMode)
                {
                    <PrymButton Intent="PrymButton.ButtonIntent.Secondary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Outlined.Edit"
                               OnClick="@OnManageGroupsClicked">
                        @TranslationService.GetTranslation("action.manageGroups", "Gestisci Gruppi")
                    </PrymButton>
                }
            </MudStack>
            
            @if (Party.Groups != null && Party.Groups.Any())
            {
                <MudStack Row Spacing="2" Wrap="Wrap.Wrap">
                    @foreach (var group in Party.Groups.OrderByDescending(g => g.Priority))
                    {
                        <GroupBadge Group="@group" 
                                    ShowPriority="true"
                                    OnRemove="@(IsEditMode ? OnRemoveGroup : default)" />
                    }
                </MudStack>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Dense Variant="Variant.Text">
                    <MudText Typo="Typo.body2">
                        @TranslationService.GetTranslation("businessParty.noGroups", "Nessun gruppo assegnato. I gruppi permettono di organizzare i business party per applicare listini, sconti o promozioni personalizzate.")
                    </MudText>
                </MudAlert>
            }
        </MudPaper>
    </MudItem>
    
    <!-- ========== SEZIONE 3: CATEGORIE/TAG (PLACEHOLDER) ========== -->
    <MudItem xs="12">
        <MudPaper Elevation="1" Class="pa-4">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Outlined.Category" Class="mr-2" />
                    @TranslationService.GetTranslation("businessParty.categories", "Categorie e Tag")
                </MudText>
                <MudTooltip Text="@TranslationService.GetTranslation("info.featureInDevelopment", "Funzionalità in sviluppo")">
                    <PrymButton Intent="PrymButton.ButtonIntent.Secondary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Outlined.Edit"
                               Disabled="true">
                        @TranslationService.GetTranslation("action.manageCategories", "Gestisci Categorie")
                    </PrymButton>
                </MudTooltip>
            </MudStack>
            
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense>
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2" Class="fw-semibold">
                        🚧 @TranslationService.GetTranslation("info.featureInDesign", "Funzionalità in Fase di Progettazione")
                    </MudText>
                    <MudText Typo="Typo.body2">
                        @TranslationService.GetTranslation("businessParty.categoriesPlaceholder", "La classificazione dei business party tramite categorie gerarchiche sarà disponibile prossimamente. Permetterà di organizzare clienti e fornitori in tassonomie personalizzate.")
                    </MudText>
                </MudStack>
            </MudAlert>
        </MudPaper>
    </MudItem>

    @if (!IsNewParty)
    {
        <!-- Audit Information -->
        <MudItem xs="12">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Outlined.History" Class="mr-2" />
                    @TranslationService.GetTranslation("common.auditInfo", "Informazioni di Sistema")
                </MudText>
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="6">
                        <PrymTextField Value="@Party.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                       Label="@TranslationService.GetTranslation("field.createdAt", "Creato il")"
                                       ReadOnly="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <PrymTextField Value="@Party.CreatedBy"
                                       Label="@TranslationService.GetTranslation("field.createdBy", "Creato da")"
                                       ReadOnly="true" />
                    </MudItem>
                    @if (Party.ModifiedAt.HasValue)
                    {
                        <MudItem xs="12" md="6">
                            <PrymTextField Value="@Party.ModifiedAt.Value.ToString("dd/MM/yyyy HH:mm")"
                                           Label="@TranslationService.GetTranslation("field.modifiedAt", "Modificato il")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <PrymTextField Value="@Party.ModifiedBy"
                                           Label="@TranslationService.GetTranslation("field.modifiedBy", "Modificato da")"
                                           ReadOnly="true" />
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>
        </MudItem>
    }
    
</MudGrid>

@code {
    [Parameter, EditorRequired] 
    public BusinessPartyDto Party { get; set; } = null!;
    
    [Parameter] 
    public bool IsEditMode { get; set; } = true;
    
    [Parameter] 
    public bool IsNewParty { get; set; } = false;
    
    [Parameter] 
    public EventCallback OnPartyUpdated { get; set; }
    
    [Parameter] 
    public EventCallback OnAddressCreated { get; set; }
    
    [Parameter] 
    public EventCallback OnManageGroupsClicked { get; set; }
    
    [Parameter] 
    public EventCallback<Guid> OnRemoveGroup { get; set; }

    // VAT lookup fields
    private bool _isLookingUp = false;
    private VatLookupResultDto? _lookupResult;

    private async Task NotifyUpdated()
    {
        await OnPartyUpdated.InvokeAsync();
    }

    private async Task LookupVatAsync()
    {
        if (string.IsNullOrWhiteSpace(Party.VatNumber))
            return;

        _isLookingUp = true;
        _lookupResult = null;

        try
        {
            _lookupResult = await VatLookupService.LookupAsync(Party.VatNumber);
            
            if (_lookupResult == null)
            {
                AppNotification.ShowError(TranslationService.GetTranslation("vat.lookupError", "Errore durante la ricerca. Riprova più tardi."));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during VAT lookup");
            AppNotification.ShowError(TranslationService.GetTranslation("vat.lookupError", "Errore durante la ricerca. Riprova più tardi."));
        }
        finally
        {
            _isLookingUp = false;
        }
    }

    private async Task ApplyLookupData()
    {
        if (_lookupResult == null || !_lookupResult.IsValid)
            return;

        // Capture and immediately clear to prevent duplicate executions
        var result = _lookupResult;
        _lookupResult = null;

        // Populate the form fields
        if (!string.IsNullOrEmpty(result.Name))
            Party.Name = result.Name;

        StateHasChanged();
        await NotifyUpdated();

        bool hasAddress = !string.IsNullOrEmpty(result.Street) ||
                          !string.IsNullOrEmpty(result.City) ||
                          !string.IsNullOrEmpty(result.PostalCode);

        // Create address if party is already saved and we have address data
        if (Party.Id != Guid.Empty && hasAddress)
        {
            try
            {
                var address = new CreateAddressDto
                {
                    OwnerId = Party.Id,
                    OwnerType = "BusinessParty",
                    AddressType = AddressType.Legal,
                    Street = result.Street,
                    City = result.City,
                    ZipCode = result.PostalCode,
                    Province = result.Province,
                    Country = GetCountryFromVatNumber(result),
                    Notes = TranslationService.GetTranslation("address.viesNotes", "Indirizzo da ricerca P.IVA VIES")
                };

                await EntityManagementService.CreateAddressAsync(address);
                await OnAddressCreated.InvokeAsync();

                AppNotification.ShowSuccess(TranslationService.GetTranslation("vat.dataAndAddressApplied", "Dati e indirizzo applicati con successo"));
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error creating address from VAT lookup for party {PartyId}", Party.Id);
                AppNotification.ShowWarning(TranslationService.GetTranslation("vat.dataAppliedAddressError", "Dati applicati, ma errore nella creazione dell'indirizzo"));
            }
        }
        else if (Party.Id == Guid.Empty && hasAddress)
        {
            // Party is new (not yet saved)
            AppNotification.ShowInfo(TranslationService.GetTranslation("vat.dataAppliedSaveFirst", "Dati applicati. Salva prima il Business Party per creare l'indirizzo automaticamente."));
        }
        else
        {
            // No address data available
            AppNotification.ShowSuccess(TranslationService.GetTranslation("vat.dataApplied", "Dati applicati con successo"));
        }
    }

    private string? GetCountryFromVatNumber(VatLookupResultDto? lookupResult = null)
    {
        // Extract country from VAT number prefix (e.g., "IT" from "IT12345678901")
        if (!string.IsNullOrEmpty(Party.VatNumber) && Party.VatNumber.Length >= 2)
        {
            var prefix = Party.VatNumber[..2].ToUpperInvariant();
            if (char.IsLetter(prefix[0]) && char.IsLetter(prefix[1]))
            {
                return prefix switch
                {
                    "IT" => "Italia",
                    "DE" => "Germania",
                    "FR" => "Francia",
                    "ES" => "Spagna",
                    "AT" => "Austria",
                    "BE" => "Belgio",
                    "NL" => "Paesi Bassi",
                    "PT" => "Portogallo",
                    "GR" => "Grecia",
                    "PL" => "Polonia",
                    _ => prefix
                };
            }
        }
        return lookupResult?.CountryCode;
    }
}
