@page "/business/groups"
@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.Business
@using EventForge.Client.Shared.Management.Adapters
@using EventForge.Client.Shared.Components.Dialogs
@attribute [Authorize]
@inject IBusinessPartyGroupService GroupService
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject ILogger<BusinessPartyGroupManagement> Logger
@inject IAppNotificationService AppNotification

<PageTitle>@TranslationService.GetTranslation("businessPartyGroup.management", "Gestione Gruppi Business Party")</PageTitle>
<EntityManagementPage TEntity="BusinessPartyGroupDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      OnCreateOverride="@(() => OpenDetailDialogAsync(null))"
                      OnEditOverride="@(id => OpenDetailDialogAsync(id))">
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Priority")
            {
                <EFTableColumnHeader TItem="BusinessPartyGroupDto" PropertyName="Priority">
                    <MudTableSortLabel SortBy="@(new Func<BusinessPartyGroupDto, object>(x => x.Priority))" InitialDirection="SortDirection.Descending">@TranslationService.GetTranslation("field.priority", "Priorità")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Name")
            {
                <EFTableColumnHeader TItem="BusinessPartyGroupDto" PropertyName="Name">
                    <MudTableSortLabel SortBy="@(new Func<BusinessPartyGroupDto, object>(x => x.Name))">@TranslationService.GetTranslation("field.name", "Nome")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Code")
            {
                <EFTableColumnHeader TItem="BusinessPartyGroupDto" PropertyName="Code">
                    <MudTableSortLabel SortBy="@(new Func<BusinessPartyGroupDto, object>(x => x.Code ?? string.Empty))">@TranslationService.GetTranslation("field.code", "Codice")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "GroupType")
            {
                <EFTableColumnHeader TItem="BusinessPartyGroupDto" PropertyName="GroupType">
                    <MudTableSortLabel SortBy="@(new Func<BusinessPartyGroupDto, object>(x => x.GroupType))">@TranslationService.GetTranslation("field.groupType", "Tipo")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ActiveMembersCount")
            {
                <EFTableColumnHeader TItem="BusinessPartyGroupDto" PropertyName="ActiveMembersCount">
                    <MudTableSortLabel SortBy="@(new Func<BusinessPartyGroupDto, object>(x => x.ActiveMembersCount))">@TranslationService.GetTranslation("field.members", "Membri")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ColorPreview")
            {
                <EFTableColumnHeader TItem="BusinessPartyGroupDto" PropertyName="ColorPreview">
                    @TranslationService.GetTranslation("field.color", "Colore")
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center" Style="min-width:120px;">@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Priority")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.priority", "Priorità")">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@GetPriorityColor(ctx.Item.Priority)"
                             Variant="Variant.Filled">
                        @ctx.Item.Priority
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "Name")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.name", "Nome")">
                    <MudChip T="string"
                             Size="Size.Small"
                             Variant="Variant.Filled"
                             Style="@GetGroupBadgeStyle(ctx.Item)"
                             Icon="@ctx.Item.Icon">
                        @ctx.Item.Name
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "Code")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.code", "Codice")">
                    <MudText Typo="Typo.body2">@(ctx.Item.Code ?? "-")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "GroupType")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.groupType", "Tipo")">
                    <MudChip T="string" Size="Size.Small" Color="@GetGroupTypeColor(ctx.Item.GroupType)">
                        @GetGroupTypeLabel(ctx.Item.GroupType)
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "ActiveMembersCount")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.members", "Membri")">
                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.People">
                        @ctx.Item.ActiveMembersCount / @ctx.Item.TotalMembersCount
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "ColorPreview")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.color", "Colore")">
                    @if (!string.IsNullOrEmpty(ctx.Item.ColorHex))
                    {
                        <div style="width:30px; height:30px; background:@ctx.Item.ColorHex; border-radius:4px; border:1px solid #ccc;"></div>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">-</MudText>
                    }
                </MudTd>
            }
        }
    </RowTemplate>
</EntityManagementPage>

@code {
    private EntityManagementPage<BusinessPartyGroupDto>? _entityPage;
    private IEntityManagementService<BusinessPartyGroupDto> _service = null!;
    private EntityManagementConfig<BusinessPartyGroupDto> _config = null!;

    protected override void OnInitialized()
    {
        _service = new BusinessPartyGroupManagementService(GroupService);
        _config = new EntityManagementConfig<BusinessPartyGroupDto>
        {
            ComponentKey = "BusinessPartyGroupManagement",
            PageTitleKey = "businessPartyGroup.management",
            PageTitleDefault = "Gestione Gruppi Business Party",
            EntityIcon = Icons.Material.Outlined.Group,
            PageRootCssClass = "group-page-root",
            BaseRoute = "/business/groups",
            ExcelFileName = "GruppiBusinessParty",
            SearchPlaceholderKey = "businessPartyGroup.search",
            SearchPlaceholderDefault = "Cerca gruppi",
            CreateTooltip = "businessPartyGroup.createNew",
            EntityTypeName = "BusinessPartyGroup",
            ShowToggleStatus = false,
            ShowView = false,
            GetDisplayName = g => g.Name,
            GetId = g => g.Id,
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Business", null, disabled: true),
                new BreadcrumbItem("Gruppi", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Priority", DisplayName = "Priorità", IsVisible = true, Order = 0, IsSearchable = false },
                new() { PropertyName = "Name", DisplayName = "Nome", IsVisible = true, Order = 1, IsSearchable = true },
                new() { PropertyName = "Code", DisplayName = "Codice", IsVisible = true, Order = 2, IsSearchable = true },
                new() { PropertyName = "GroupType", DisplayName = "Tipo", IsVisible = true, Order = 3, IsSearchable = false },
                new() { PropertyName = "ActiveMembersCount", DisplayName = "Membri", IsVisible = true, Order = 4, IsSearchable = false },
                new() { PropertyName = "ColorPreview", DisplayName = "Colore", IsVisible = true, Order = 5, IsSearchable = false }
            },
            QuickFilters = new()
            {
                new() { Id = "all", Label = "Tutti", Predicate = _ => true, Description = "Mostra tutti i gruppi" },
                new() { Id = "active", Label = "Attivi", Predicate = g => g.IsActive, Color = Color.Success, Icon = Icons.Material.Outlined.CheckCircle, Description = "Solo gruppi attivi" },
                new() { Id = "inactive", Label = "Inattivi", Predicate = g => !g.IsActive, Color = Color.Default, Icon = Icons.Material.Outlined.Block, Description = "Solo gruppi inattivi" },
                new() { Id = "with_parties", Label = "Con Soggetti", Predicate = g => g.TotalMembersCount > 0, Color = Color.Primary, Icon = Icons.Material.Outlined.People, Description = "Gruppi con almeno un soggetto" },
                new() { Id = "recent", Label = "Recenti", Predicate = g => g.CreatedAt >= DateTime.UtcNow.AddDays(-30), Color = Color.Info, Icon = Icons.Material.Outlined.NewReleases, Description = "Creati negli ultimi 30 giorni" }
            },
            DeleteConfirmMessageKey = "businessPartyGroup.confirmDelete",
            DeleteSuccessMessageKey = "businessPartyGroup.groupDeleted",
            DeleteErrorMessageKey = "businessPartyGroup.deleteGroupError"
        };
    }

    private Color GetPriorityColor(int priority) => priority switch
    {
        >= 90 => Color.Error,
        >= 70 => Color.Warning,
        >= 50 => Color.Info,
        >= 30 => Color.Success,
        _ => Color.Default
    };

    private string GetGroupBadgeStyle(BusinessPartyGroupDto group)
    {
        if (string.IsNullOrEmpty(group.ColorHex))
            return string.Empty;

        var bgColor = $"{group.ColorHex}20";
        return $"background-color: {bgColor}; color: {group.ColorHex}; border: 1px solid {group.ColorHex}40;";
    }

    private Color GetGroupTypeColor(BusinessPartyGroupType type) => type switch
    {
        BusinessPartyGroupType.Customer => Color.Primary,
        BusinessPartyGroupType.Supplier => Color.Success,
        BusinessPartyGroupType.Both => Color.Secondary,
        _ => Color.Default
    };

    private string GetGroupTypeLabel(BusinessPartyGroupType type) => type switch
    {
        BusinessPartyGroupType.Customer => "Cliente",
        BusinessPartyGroupType.Supplier => "Fornitore",
        BusinessPartyGroupType.Both => "Entrambi",
        _ => "N/D"
    };

    private async Task OpenDetailDialogAsync(Guid? id)
    {
        try
        {
            var parameters = new DialogParameters { [nameof(BusinessPartyGroupDetailDialog.EntityId)] = id };
            var options = EFDialogDefaults.Options;
            var dialog = await DialogService.ShowAsync<BusinessPartyGroupDetailDialog>(string.Empty, parameters, options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await _entityPage!.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening business party group detail dialog.");
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }
}
