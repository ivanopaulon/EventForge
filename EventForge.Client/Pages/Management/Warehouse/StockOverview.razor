    // UI State Management
    private bool _isLoading = true;
    private bool _isLoadingStock = false;

    // Filter and search state
    private StockFilters _filters = new();
    private CancellationTokenSource? _searchDebounceCts = new CancellationTokenSource();
    
    // Quick Filters
    private List<QuickFilter<StockLocationDetail>> _quickFilters = new()
    {
