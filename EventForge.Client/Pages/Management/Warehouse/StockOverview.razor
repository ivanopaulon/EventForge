    private Guid? _editingWarehouseId = null;
    private Guid? _editingLocationId = null;
    private List<StorageLocationDto> _editingLocations = new();
    private string? _editingValidationError = null;

    // Data collections
    private List<StockLocationDetail> _stockItems = new();
    private List<StorageFacilityDto> _warehouses = new();
    private List<StorageLocationDto> _locations = new();
    private HashSet<StockLocationDetail> _selectedStockItems = new();

    // EFTable reference
    private EFTable<StockLocationDetail> _efTable = null!;

    // Reconciliation overlay state
    private Dictionary<Guid, StockReconciliationItemDto> _reconciliationData = new();
    private bool _reconciliationCalculated = false;

    // Column configuration for EFTable
    // Default view shows core columns only (ProductCode, ProductName, WarehouseName, LocationCode, Quantity, Available, Status)
    // Secondary columns (LotCode, Reserved, ReorderPoint, SafetyStock) hidden by default to reduce clutter
    private List<EFTableColumnConfiguration> _initialColumns = new()
    {
        new() { PropertyName = "ProductCode", DisplayName = "Codice", IsVisible = true, Order = 0, IsSearchable = true },
        new() { PropertyName = "ProductName", DisplayName = "Nome Prodotto", IsVisible = true, Order = 1, IsSearchable = true },
        new() { PropertyName = "WarehouseName", DisplayName = "Magazzino", IsVisible = true, Order = 2, IsSearchable = true },
        new() { PropertyName = "LocationCode", DisplayName = "Ubicazione", IsVisible = true, Order = 3, IsSearchable = true },
        new() { PropertyName = "LotCode", DisplayName = "Lotto", IsVisible = false, Order = 4, IsSearchable = true }, // Hidden by default
        new() { PropertyName = "Quantity", DisplayName = "Quantità", IsVisible = true, Order = 5, IsSearchable = false },
        new() { PropertyName = "Reserved", DisplayName = "Riservato", IsVisible = false, Order = 6, IsSearchable = false }, // Hidden by default
        new() { PropertyName = "Available", DisplayName = "Disponibile", IsVisible = true, Order = 7, IsSearchable = false },
        new() { PropertyName = "ReorderPoint", DisplayName = "Punto Riordino", IsVisible = false, Order = 8, IsSearchable = false }, // Hidden by default
        new() { PropertyName = "SafetyStock", DisplayName = "Scorta Sicurezza", IsVisible = false, Order = 9, IsSearchable = false }, // Hidden by default
        new() { PropertyName = "Status", DisplayName = "Stato", IsVisible = true, Order = 10, IsSearchable = false },
        new() { PropertyName = "ReconciledQty", DisplayName = "Qtà Riconciliata", IsVisible = true, Order = 11, IsSearchable = false }
