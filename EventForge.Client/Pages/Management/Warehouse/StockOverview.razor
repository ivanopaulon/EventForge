    /// <summary>
    /// Opens the step-by-step dialog to rebuild missing stock movements from documents.
    /// After closing, reloads stock data if any movements were created.
    /// </summary>
    private async Task OpenRebuildMovementsDialogAsync()
    {
        try
        {
            var parameters = new DialogParameters
            {
                ["InitialWarehouseId"] = _filters.WarehouseId
            };

            var options = new DialogOptions
            {
                CloseButton = false,
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                CloseOnEscapeKey = false
            };

            var dialog = await DialogService.ShowAsync<RebuildMovementsDialog>(
                string.Empty,
                parameters,
                options);

            var result = await dialog.Result;

            if (result is { Canceled: false } && result.Data is RebuildMovementsResultDto applyResult
                && (applyResult.MovementsCreated > 0 || applyResult.MovementsUpdated > 0))
            {
                var msg = applyResult.MovementsCreated > 0 && applyResult.MovementsUpdated > 0
                    ? TranslationService.GetTranslationFormatted("stock.rebuildMovements.reloadingBoth",
                        "{0} creato/i, {1} aggiornato/i — ricarico le giacenze.", applyResult.MovementsCreated, applyResult.MovementsUpdated)
                    : applyResult.MovementsCreated > 0
                        ? TranslationService.GetTranslationFormatted("stock.rebuildMovements.reloading",
                            "{0} movimento/i creati — ricarico le giacenze.", applyResult.MovementsCreated)
                        : TranslationService.GetTranslationFormatted("stock.rebuildMovements.reloadingUpdated",
                            "{0} movimento/i aggiornati — ricarico le giacenze.", applyResult.MovementsUpdated);
                AppNotification.ShowSuccess(msg);
                await LoadAndReconcileAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OpenRebuildMovementsDialogAsync.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    /// <summary>
    /// Reloads stock data and then recalculates reconciliation.
    /// Used by the refresh button and after rebuild operations.
    /// </summary>
    private async Task LoadAndReconcileAsync()
    {
        try
        {
            await LoadStockOverviewAsync();
            await CalculateReconciliationAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in LoadAndReconcileAsync.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    /// <summary>
    /// Calls the reconciliation calculation API for items visible in the current page
    /// and stores the result in <see cref="_reconciliationData"/> to display as an overlay column.
    /// Activates the "Qtà Riconciliata" column automatically.
    /// </summary>
    private async Task CalculateReconciliationAsync()
    {
        try
        {
            var request = new StockReconciliationRequestDto
            {
                WarehouseId = _filters.WarehouseId,
                LocationId = _filters.LocationId,
                IncludeDocuments = true,
                IncludeInventories = true,
                IncludeStockMovements = true,
                OnlyWithDiscrepancies = false
            };

            var result = await StockReconciliationService.CalculateReconciliationAsync(request);
            if (result?.Items != null)
            {
                _reconciliationData = result.Items.ToDictionary(i => i.StockId);
                _reconciliationCalculated = true;

                // Auto-enable the ReconciledQty column if it is currently hidden
                if (_efTable?.ColumnConfigurations != null)
                {
                    var col = _efTable.ColumnConfigurations.FirstOrDefault(c => c.PropertyName == "ReconciledQty");
                    if (col != null && !col.IsVisible)
                        col.IsVisible = true;
                }

                var discrepancies = result.Items.Count(i => i.Severity != ReconciliationSeverity.Correct);
                if (discrepancies > 0)
                {
                    AppNotification.ShowWarning(TranslationService.GetTranslationFormatted("stock.reconciliationDone",
                            "Riconciliazione completata: {0} discrepanz{1} trovat{1}.",
                            discrepancies, discrepancies == 1 ? "a" : "e"));
                }
                else
                {
                    AppNotification.ShowSuccess(TranslationService.GetTranslation("stock.reconciliationOk", "Riconciliazione completata: nessuna discrepanza trovata."));
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error calculating stock reconciliation");
            AppNotification.ShowError(TranslationService.GetTranslation("stock.reconciliationError", "Errore nel calcolo della riconciliazione"));
        }
    }

    /// <summary>
    /// Opens the full edit popover pre-filled with the reconciled (calculated) quantity,
    /// so the operator can apply it with a single click.
    /// </summary>
    private async Task OpenFullEditPopoverWithReconciledQty(StockLocationDetail item, decimal reconciledQty)
    {
        try
        {
            await OpenFullEditPopover(item, new MouseEventArgs());
            _editingNewQuantity = reconciledQty;
