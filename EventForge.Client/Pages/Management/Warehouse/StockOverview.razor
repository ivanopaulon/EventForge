            Description = "Prodotti sotto il punto di riordino"
        },
        new() 
        { 
            Id = "critical_stock", 
            Label = "Critici",
            Predicate = s => s.SafetyStock.HasValue && s.Quantity > 0 && s.Quantity <= s.SafetyStock.Value,
            Color = Color.Error,
            Icon = Icons.Material.Outlined.Error,
            Description = "Prodotti sotto la scorta di sicurezza"
        },
        new() 
        { 
