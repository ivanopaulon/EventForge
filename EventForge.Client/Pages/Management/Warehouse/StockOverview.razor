    /// <summary>
    /// Starts quick edit mode for a stock item.
    /// </summary>
    private void StartQuickEdit(StockLocationDetail item, string field)
    {
        _editingStockId = item.StockId;
        _editingField = field;
        _editingNewQuantity = item.Quantity;
        StateHasChanged();
    }

    /// <summary>
    /// Cancels quick edit mode.
    /// </summary>
    private void CancelQuickEdit()
    {
        _editingStockId = null;
        _editingField = null;
        _editingNewQuantity = 0;
        StateHasChanged();
    }

    /// <summary>
    /// Saves quick edit changes.
    /// </summary>
    private async Task SaveQuickEdit(StockLocationDetail item)
    {
        try
        {
            // Check if stock entry exists
            if (item.StockId == Guid.Empty)
            {
                AppNotification.ShowInfo(TranslationService.GetTranslation("stock.useFullEditForNewStock", 
                        "Prodotto senza giacenza. Usa il pulsante 'Modifica' per creare il primo record."));
                return;
            }

            var difference = Math.Abs(_editingNewQuantity - item.Quantity);
            
            // Block if difference exceeds quick edit limit
            if (difference > QuickEditMaxDifference)
            {
                var message = TranslationService.GetTranslationFormatted(
                    "stock.quickEditLimitExceeded", 
                    "Differenza troppo grande (> {0} unità). Usa la modalità di modifica completa.", 
                    QuickEditMaxDifference);
                AppNotification.ShowWarning(message);
                return;
            }

            var adjustDto = new AdjustStockDto
            {
                StockId = item.StockId,
                ProductId = item.ProductId,
                StorageLocationId = item.LocationId,
                NewQuantity = _editingNewQuantity,
                PreviousQuantity = item.Quantity,
                Reason = StockAdjustmentReason.QuickCorrection,
                Notes = $"Correzione rapida: {item.Quantity} → {_editingNewQuantity}",
                RequiresAudit = false
            };

            var result = await StockService.AdjustStockAsync(adjustDto);
            
            if (result != null)
            {
                AppNotification.ShowSuccess(TranslationService.GetTranslation("stock.quantityUpdated", "Quantità aggiornata con successo!"));
                await LoadStockOverviewAsync();
                CancelQuickEdit();
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslation("stock.updateError", "Errore nell'aggiornamento della quantità"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving quick edit for stock {StockId}", item.StockId);
            AppNotification.ShowError(TranslationService.GetTranslation("stock.updateError", "Errore nell'aggiornamento: {0}", ex.Message));
        }
    }

    /// <summary>
    /// Opens the full edit popover.
    /// </summary>
    private async Task OpenFullEditPopover(StockLocationDetail item, MouseEventArgs e)
    {
        try
        {
            _editingItem = item;
            _editingNewQuantity = item.Quantity;
            _editingReason = StockAdjustmentReason.ManualCorrection;
            _editingNotes = string.Empty;
            
            // Inizializza i dropdown per creazione/modifica
            if (item.StockId == Guid.Empty)
            {
                // Nuova giacenza - resetta i dropdown
                _editingWarehouseId = null;
                _editingLocationId = null;
                _editingLocations = new();
            }
            else
            {
                // Giacenza esistente - pre-popola con i valori attuali (read-only)
                _editingWarehouseId = item.WarehouseId;
                _editingLocationId = item.LocationId;
                
                // Carica le ubicazioni del magazzino corrente
                if (_editingWarehouseId.HasValue)
                {
                    try
                    {
                        var result = await StorageLocationService.GetStorageLocationsByWarehouseAsync(_editingWarehouseId.Value);
                        _editingLocations = result?.Items?.ToList() ?? new();
                    }
                    catch (Exception ex)
                    {
                        Logger.LogError(ex, "Error loading locations for warehouse {WarehouseId}", _editingWarehouseId);
                        _editingLocations = new();
                    }
                }
            }
            
            UpdateEditingValidation();
            _isPopoverOpen = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OpenFullEditPopover.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    /// <summary>
    /// Closes the full edit popover.
    /// </summary>
    private void CloseFullEditPopover()
    {
        _isPopoverOpen = false;
        _editingItem = null;
        _editingNewQuantity = 0;
        _editingReason = StockAdjustmentReason.ManualCorrection;
        _editingNotes = string.Empty;
        _editingWarehouseId = null;
        _editingLocationId = null;
        _editingLocations = new();
        _editingValidationError = null;
        StateHasChanged();
    }

    /// <summary>
    /// Handles warehouse selection changes and loads corresponding locations.
    /// </summary>
    private async Task OnEditingWarehouseChanged()
    {
        // Reset location selection when warehouse changes
        _editingLocationId = null;
        _editingLocations = new();
        
        // Load locations for the selected warehouse
        if (_editingWarehouseId.HasValue)
        {
            try
            {
                var result = await StorageLocationService.GetStorageLocationsByWarehouseAsync(_editingWarehouseId.Value);
                _editingLocations = result?.Items?.ToList() ?? new();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error loading locations for warehouse {WarehouseId}", _editingWarehouseId);
                AppNotification.ShowError(TranslationService.GetTranslation("stock.locationLoadError", "Errore nel caricamento delle ubicazioni"));
            }
        }
        
        UpdateEditingValidation();
        StateHasChanged();
    }

    /// <summary>
    /// Saves full edit changes.
    /// </summary>
    private async Task SaveFullEdit()
    {
        var validationError = ValidateFullEdit();
        if (validationError != null)
        {
            AppNotification.ShowWarning(validationError);
            return;
        }

        if (_editingItem == null) return;

        try
        {
            _isSavingEdit = true;
            StateHasChanged();
            
            // Handle creation of stock if it doesn't exist
            if (_editingItem.StockId == Guid.Empty)
            {
                // Create a new stock record instead of adjusting
                var createStockDto = new CreateStockDto
                {
                    ProductId = _editingItem.ProductId,
                    StorageLocationId = _editingLocationId!.Value,
                    Quantity = _editingNewQuantity,
                    ReservedQuantity = 0,
                    Notes = _editingNotes
                };

                var createdStock = await StockService.CreateOrUpdateStockAsync(createStockDto);
                
                if (createdStock != null)
                {
                    AppNotification.ShowSuccess(TranslationService.GetTranslation("stock.stockCreated", 
                        "Giacenza creata con successo!"));
                    await LoadStockOverviewAsync();
                    CloseFullEditPopover();
                }
                else
                {
                    AppNotification.ShowError(TranslationService.GetTranslation("stock.createError", 
                        "Errore nella creazione della giacenza"));
                }
                return;
            }

            // Existing code for stock adjustment
            var adjustDto = new AdjustStockDto
            {
                StockId = _editingItem.StockId,
                ProductId = _editingItem.ProductId,
                StorageLocationId = _editingItem.LocationId,
                NewQuantity = _editingNewQuantity,
                PreviousQuantity = _editingItem.Quantity,
                Reason = _editingReason,
                Notes = _editingNotes,
                RequiresAudit = true
            };

            var result = await StockService.AdjustStockAsync(adjustDto);
            
            if (result != null)
            {
                AppNotification.ShowSuccess(TranslationService.GetTranslation("stock.quantityUpdated", "Quantità aggiornata con successo!"));
                await LoadStockOverviewAsync();
                CloseFullEditPopover();
            }
            else
            {
                AppNotification.ShowError(TranslationService.GetTranslation("stock.updateError", "Errore nell'aggiornamento della quantità"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving stock adjustment");
            AppNotification.ShowError(TranslationService.GetTranslationFormatted("stock.updateErrorWithDetails", "Errore nell'aggiornamento: {0}", ex.Message));
        }
        finally
        {
            _isSavingEdit = false;
        }
    }

    /// <summary>
    /// Opens the audit log dialog for a stock item using IDialogService.
    /// </summary>
    private async Task ViewStockAuditLog(StockLocationDetail item)
    {
        try
        {
            var parameters = new DialogParameters<AuditHistoryDialog>
            {
                { x => x.EntityType, "Stock" },
                { x => x.EntityId, item.StockId },
                { x => x.EntityName, $"{item.ProductName} - {item.LocationCode}" }
            };

            await DialogService.ShowAsync<AuditHistoryDialog>(
                TranslationService.GetTranslation("audit.historyDialog.title", "Cronologia Modifiche"),
                parameters,
                _auditDialogOptions);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in ViewStockAuditLog.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    /// <summary>
    /// Determines the stock status based on quantity, reorder point, and safety stock.
    /// </summary>
    private StockStatus GetStockStatus(StockLocationDetail item)
    {
        if (item.Quantity == 0)
            return StockStatus.OutOfStock;

        if (item.SafetyStock.HasValue && item.Quantity <= item.SafetyStock.Value)
            return StockStatus.Critical;

        if (item.ReorderPoint.HasValue && item.Quantity <= item.ReorderPoint.Value)
            return StockStatus.LowStock;

        return StockStatus.OK;
    }

    /// <summary>
    /// Gets the color for a stock status.
    /// </summary>
    private Color GetStatusColor(StockStatus status) => status switch
    {
        StockStatus.OK => Color.Success,
        StockStatus.LowStock => Color.Warning,
        StockStatus.Critical => Color.Error,
        StockStatus.OutOfStock => Color.Dark,
        _ => Color.Default
    };

    /// <summary>
    /// Validates full edit form.
    /// </summary>
    private string? ValidateFullEdit()
    {
        if (_editingItem == null) 
            return TranslationService.GetTranslation("stock.validation.noItemSelected", "Nessun elemento selezionato");
        
        if (_editingNewQuantity < 0)
            return TranslationService.GetTranslation("stock.validation.negativeQuantity", "La quantità non può essere negativa");
        
        if (_editingNewQuantity > MaxQuantityValue)
            return TranslationService.GetTranslationFormatted("stock.validation.maxQuantity", "La quantità massima è {0}", MaxQuantityValue);
        
        // Validazione per creazione nuova giacenza
        if (_editingItem.StockId == Guid.Empty)
        {
            if (!_editingWarehouseId.HasValue)
                return TranslationService.GetTranslation("stock.validation.warehouseRequired", "Seleziona un magazzino");
            
            if (!_editingLocationId.HasValue)
                return TranslationService.GetTranslation("stock.validation.locationRequired", "Seleziona un'ubicazione");
        }
        
        var difference = Math.Abs(_editingNewQuantity - _editingItem.Quantity);
        if (difference > FullEditNotesRequiredDifference && string.IsNullOrWhiteSpace(_editingNotes))
            return TranslationService.GetTranslationFormatted("stock.validation.notesRequired", 
                "Note obbligatorie per variazioni superiori a {0}", FullEditNotesRequiredDifference);
        
        if (!string.IsNullOrWhiteSpace(_editingNotes) && _editingNotes.Length > 500)
            return TranslationService.GetTranslation("stock.validation.notesTooLong", "Le note non possono superare 500 caratteri");
        
        return null;
    }

    /// <summary>
    /// Updates the cached validation error to avoid multiple validation calls during render.
    /// </summary>
    private void UpdateEditingValidation()
    {
        _editingValidationError = ValidateFullEdit();
    }

    /// <summary>
    /// Gets a tooltip for stock status.
    /// </summary>
    private string GetStatusTooltip(StockStatus status)
    {
        return status switch
        {
            StockStatus.Critical => TranslationService.GetTranslation("stock.status.criticalTooltip", "Giacenza sotto la scorta di sicurezza - ordinare urgentemente"),
            StockStatus.LowStock => TranslationService.GetTranslation("stock.status.lowStockTooltip", "Giacenza sotto il punto di riordino - considerare riordino"),
            StockStatus.OutOfStock => TranslationService.GetTranslation("stock.status.outOfStockTooltip", "Prodotto esaurito - nessuna giacenza disponibile"),
            StockStatus.OK => TranslationService.GetTranslation("stock.status.normalTooltip", "Livello giacenza nella norma"),
            _ => status.ToString()
        };
    }

    /// <summary>
    /// Disposes resources used by the component.
    /// </summary>
    public void Dispose()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
    }
}
