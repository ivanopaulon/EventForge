    }

    /// <summary>
    /// Handles quick filter selection - updates server-side filters and reloads data
    /// </summary>
    private async Task HandleQuickFilter(QuickFilter<StockLocationDetail>? filter)
    {
        try
        {
            _activeQuickFilter = filter;
            
            // Update server-side filters based on quick filter selection
            _filters.ShowOnlyLowStock = false;
            _filters.ShowOnlyCritical = false;
            _filters.ShowOnlyOutOfStock = false;
            _filters.ShowOnlyInStock = false;
            
            if (filter?.Id == "in_stock")
            {
                _filters.ShowOnlyInStock = true;
            }
            else if (filter?.Id == "low_stock")
            {
                _filters.ShowOnlyLowStock = true;
            }
            else if (filter?.Id == "critical_stock")
            {
                _filters.ShowOnlyCritical = true;
            }
            else if (filter?.Id == "out_of_stock")
            {
                _filters.ShowOnlyOutOfStock = true;
            }
            // Note: negative_stock handled client-side via predicate
            
            await LoadStockOverviewAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in HandleQuickFilter.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    /// <summary>
    /// Checks if any filters are currently active
    /// </summary>
    private bool HasActiveFilters()
    {
        return _filters.HasActiveFilters || _activeQuickFilter != null;
    }

    /// <summary>
    /// Navigates to the reconciliation tab (or page) when the "Verifica" button is clicked.
    /// When embedded inside StockManagement tabs, raises the event to switch tabs;
    /// otherwise navigates to the standalone reconciliation page.
    /// </summary>
    private async Task HandleVerifyReconciliation()
    {
        try
        {
            if (IsEmbedded)
                await OnVerifyReconciliation.InvokeAsync();
            else
                NavigationManager.NavigateTo("/warehouse/stock-management/reconciliation");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in HandleVerifyReconciliation.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    /// <summary>
    /// Component initialization.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        if (!IsEmbedded)
        {
            NavigationManager.NavigateTo("/warehouse/stock-management", replace: true);
            return;
        }

        try
        {
            // Initialize dashboard metrics
            // Clear filters before initial load to show all data
            _filters.ShowOnlyLowStock = false;
            _filters.ShowOnlyCritical = false;
            _filters.ShowOnlyOutOfStock = false;
            _filters.ShowOnlyInStock = false;
            _filters.DetailedView = true; // Default to detailed view

            // Check authentication
            var isAuthenticated = await AuthService.IsAuthenticatedAsync();
            if (!isAuthenticated)
            {
                await ShowLoginDialogAsync();
                return;
            }

            // Load initial data
            await Task.WhenAll(
                LoadWarehousesAsync(),
                LoadStockOverviewAsync()
            );
            await CalculateReconciliationAsync();
        }
        catch (Exception ex)
        {
            AppNotification.ShowError(TranslationService.GetTranslation("stock.loadingPageError", "Errore nel caricamento della pagina: {0}", ex.Message));
            Logger.LogError(ex, "Error loading stock overview page");
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Initializes dashboard metrics.
    /// </summary>
    /// <summary>
    /// Shows the login dialog.
    /// </summary>
    private async Task ShowLoginDialogAsync()
    {
        try
        {
            await AuthenticationDialogService.ShowLoginDialogAsync();
            var isAuthenticated = await AuthService.IsAuthenticatedAsync();
            
            if (isAuthenticated)
            {
                await LoadStockOverviewAsync();
                _isLoading = false;
            }
            else
            {
                NavigationManager.NavigateTo("/");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error showing login dialog");
            AppNotification.ShowError(TranslationService.GetTranslation("auth.loginError", "Errore durante il login"));
        }
    }

    /// <summary>
    /// Loads warehouse data for the dropdown filter.
    /// </summary>
    private async Task LoadWarehousesAsync()
    {
        try
        {
            var result = await WarehouseService.GetStorageFacilitiesAsync();
            if (result != null)
            {
                _warehouses = result.Items.ToList();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading warehouses");
            AppNotification.ShowError(TranslationService.GetTranslation("stock.loadingWarehousesError", "Errore nel caricamento dei magazzini"));
        }
    }

    /// <summary>
    /// Loads stock overview data.
    /// </summary>
    private async Task LoadStockOverviewAsync()
    {
        try
        {
            _isLoadingStock = true;
            var result = await StockService.GetStockOverviewAsync(
                page: 1,
                pageSize: int.MaxValue,
                searchTerm: null,
                warehouseId: _filters.WarehouseId,
                locationId: _filters.LocationId,
                lowStock: _filters.ShowOnlyLowStock ? true : null,
                criticalStock: _filters.ShowOnlyCritical ? true : null,
                outOfStock: _filters.ShowOnlyOutOfStock ? true : null,
                inStockOnly: _filters.ShowOnlyInStock ? true : null,
                showAllProducts: _filters.ShowAllProducts ? true : null,
                detailedView: _filters.DetailedView
            );

            _stockItems = result?.Items?.ToList() ?? new List<StockLocationDetail>();
            Logger.LogInformation("Loaded {Count} stock items", _stockItems.Count);
        }
        catch (Exception ex)
        {
            AppNotification.ShowError(TranslationService.GetTranslation("stock.loadingError", "Errore nel caricamento delle giacenze: {0}", ex.Message));
            Logger.LogError(ex, "Error loading stock overview");
