@using EventForge.DTOs.Products
@using EventForge.Client.Services
@using EventForge.Client.Shared.Components
@inject ITranslationService TranslationService
@inject IProductService ProductService
@inject IDialogService DialogService
@inject IAppNotificationService AppNotification
@inject ILogger<ProductCodesTab> Logger

<MudStack Spacing="3">
    <MudPaper Elevation="1" Class="pa-4">
        <MudGrid Spacing="3">
            <MudItem xs="12" Class="d-flex justify-end align-center mb-2">
                <PrymButton Intent="PrymButton.ButtonIntent.Primary"
                            StartIcon="@Icons.Material.Filled.Add"
                            OnClick="@OpenCreateDialog">
                    @TranslationService.GetTranslation("common.add", "Aggiungi")
                </PrymButton>
            </MudItem>

            <MudItem xs="12">
                @if (_productCodes == null || !_productCodes.Any())
                {
                    <MudAlert Severity="Severity.Info">
                        @TranslationService.GetTranslation("product.noAlternativeCodes", "Nessun codice alternativo configurato")
                    </MudAlert>
                }
                else
                {
                    <MudTable Items="_productCodes" Hover="true" Striped="true" Dense="true">
                        <HeaderContent>
                            <MudTh>@TranslationService.GetTranslation("field.codeType", "Tipo Codice")</MudTh>
                            <MudTh>@TranslationService.GetTranslation("field.code", "Codice")</MudTh>
                            <MudTh>@TranslationService.GetTranslation("field.description", "Descrizione")</MudTh>
                            <MudTh>@TranslationService.GetTranslation("field.status", "Stato")</MudTh>
                            <MudTh >@TranslationService.GetTranslation("field.actions", "Azioni")</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@TranslationService.GetTranslation("field.codeType", "Tipo Codice")">@context.CodeType</MudTd>
                            <MudTd DataLabel="@TranslationService.GetTranslation("field.code", "Codice")">@context.Code</MudTd>
                            <MudTd DataLabel="@TranslationService.GetTranslation("field.description", "Descrizione")">@context.AlternativeDescription</MudTd>
                            <MudTd DataLabel="@TranslationService.GetTranslation("field.status", "Stato")">@context.Status</MudTd>
                            <MudTd DataLabel="@TranslationService.GetTranslation("field.actions", "Azioni")" >
                                <PrymIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="@(() => OpenEditDialog(context))" />
                                <PrymIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteCodeAsync(context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudStack>

@code {
    [Parameter, EditorRequired]
    public ProductDto Product { get; set; } = default!;

    // Notifications for parent
    [Parameter] public EventCallback OnProductUpdated { get; set; }
    [Parameter] public EventCallback OnProductUpdatedPersisted { get; set; }

    [Parameter]
    public bool IsEditMode { get; set; }

    private IEnumerable<ProductCodeDto>? _productCodes;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            if (Product?.Id != Guid.Empty)
            {
                await LoadCodesAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OnParametersSetAsync.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task LoadCodesAsync()
    {
        try
        {
            _productCodes = await ProductService.GetProductCodesAsync(Product.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading product codes for product {ProductId}", Product.Id);
            AppNotification.ShowError(TranslationService.GetTranslation("product.loadCodesError", "Errore nel caricamento dei codici"));
        }
    }

    private async Task OpenCreateDialog()
    {
        try
        {
            var productUnits = await ProductService.GetProductUnitsAsync(Product.Id) ?? new List<ProductUnitDto>();

            var parameters = new DialogParameters
 {
 { "ProductId", Product.Id },
 { "ProductUnits", productUnits }
 };

            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                CloseButton = true
            };

            var dialog = await DialogService.ShowAsync<EditProductCodeDialog>(
            TranslationService.GetTranslation("product.addCode", "Aggiungi Codice Alternativo"),
            parameters,
            options);

            var result = await dialog.Result;
            if (result is { Canceled: false })
            {
                await LoadCodesAsync();
                await NotifyPersisted();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OpenCreateDialog.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task OpenEditDialog(ProductCodeDto code)
    {
        try
        {
            var productUnits = await ProductService.GetProductUnitsAsync(Product.Id) ?? new List<ProductUnitDto>();

            var parameters = new DialogParameters
 {
 { "Code", code },
 { "ProductUnits", productUnits }
 };

            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                CloseButton = true
            };

            var dialog = await DialogService.ShowAsync<EditProductCodeDialog>(
            TranslationService.GetTranslation("product.editCode", "Modifica Codice Alternativo"),
            parameters,
            options);

            var result = await dialog.Result;
            if (result is { Canceled: false })
            {
                await LoadCodesAsync();
                await NotifyPersisted();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OpenEditDialog.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task DeleteCodeAsync(ProductCodeDto code)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
        TranslationService.GetTranslation("common.confirm", "Conferma"),
        TranslationService.GetTranslation("product.confirmDeleteCode", "Sei sicuro di voler eliminare questo codice?"),
        yesText: TranslationService.GetTranslation("common.yes", "Sì"),
        noText: TranslationService.GetTranslation("common.no", "No"));

        if (confirmed == true)
        {
            try
            {
                await ProductService.DeleteProductCodeAsync(code.Id);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("product.codeDeleted", "Codice eliminato con successo"));
                await LoadCodesAsync();
                await NotifyPersisted();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error deleting product code {CodeId}", code.Id);
                AppNotification.ShowError(TranslationService.GetTranslation("product.deleteCodeError", "Errore nell'eliminazione del codice"));
            }
        }
    }

    private async Task NotifyUpdated()
    {
        try
        {
            if (OnProductUpdated.HasDelegate)
                await OnProductUpdated.InvokeAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error invoking OnProductUpdated from ProductCodesTab");
        }
    }

    private async Task NotifyPersisted()
    {
        try
        {
            if (OnProductUpdatedPersisted.HasDelegate)
                await OnProductUpdatedPersisted.InvokeAsync();
            else if (OnProductUpdated.HasDelegate)
                await OnProductUpdated.InvokeAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error invoking OnProductUpdatedPersisted from ProductCodesTab");
        }
    }
}
