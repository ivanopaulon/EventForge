@page "/settings/unit-of-measures"
@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.UnitOfMeasures
@using EventForge.Client.Shared.Components.Dialogs
@attribute [Authorize]
@inject IUMService UMService
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject ILogger<UnitOfMeasureManagement> Logger
@inject IAppNotificationService AppNotification

<PageTitle>@TranslationService.GetTranslation("um.management", "Gestione Unità di Misura")</PageTitle>
<EntityManagementPage TEntity="UMDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      OnCreateOverride="@(() => OpenDetailDialogAsync(null))"
                      OnEditOverride="@(id => OpenDetailDialogAsync(id))">
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Name")
            {
                <EFTableColumnHeader TItem="UMDto" PropertyName="Name">
                    <MudTableSortLabel SortBy="@(new Func<UMDto, object>(x => x.Name))">@TranslationService.GetTranslation("field.name", "Nome")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Symbol")
            {
                <EFTableColumnHeader TItem="UMDto" PropertyName="Symbol">
                    <MudTableSortLabel SortBy="@(new Func<UMDto, object>(x => x.Symbol))">@TranslationService.GetTranslation("field.symbol", "Simbolo")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Description")
            {
                <EFTableColumnHeader TItem="UMDto" PropertyName="Description">
                    <MudTableSortLabel SortBy="@(new Func<UMDto, object>(x => x.Description ?? string.Empty))">@TranslationService.GetTranslation("field.description", "Descrizione")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "IsDefault")
            {
                <EFTableColumnHeader TItem="UMDto" PropertyName="IsDefault">
                    <MudTableSortLabel SortBy="@(new Func<UMDto, object>(x => x.IsDefault))">@TranslationService.GetTranslation("field.default", "Predefinita")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "CreatedAt")
            {
                <EFTableColumnHeader TItem="UMDto" PropertyName="CreatedAt">
                    <MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="@(new Func<UMDto, object>(x => x.CreatedAt))">@TranslationService.GetTranslation("field.createdAt", "Creato il")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center ef-min-120" >@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Name")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.name", "Nome")">
                    <div class="d-flex align-center">
                        <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2">
                            <MudIcon Icon="@Icons.Material.Outlined.Straighten" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2">@ctx.Item.Name</MudText>
                        </div>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "Symbol")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.symbol", "Simbolo")">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@ctx.Item.Symbol</MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "Description")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.description", "Descrizione")">
                    <MudText Typo="Typo.body2" Class="text-truncate ef-max-400" >
                        @(string.IsNullOrEmpty(ctx.Item.Description) ? "-" : ctx.Item.Description)
                    </MudText>
                </MudTd>
            }
            else if (column.PropertyName == "IsDefault")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.default", "Predefinita")">
                    @if (ctx.Item.IsDefault)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Outlined.Star">
                            @TranslationService.GetTranslation("field.default", "Predefinita")
                        </MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">-</MudText>
                    }
                </MudTd>
            }
            else if (column.PropertyName == "CreatedAt")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.createdAt", "Creato il")">
                    <MudText Typo="Typo.body2">@ctx.Item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudText>
                </MudTd>
            }
        }
    </RowTemplate>
</EntityManagementPage>

@code {
    private EntityManagementPage<UMDto>? _entityPage;
    private IEntityManagementService<UMDto> _service = null!;
    private EntityManagementConfig<UMDto> _config = null!;

    protected override void OnInitialized()
    {
        _service = new UnitOfMeasureManagementService(UMService);
        _config = new EntityManagementConfig<UMDto>
        {
            ComponentKey = "UnitOfMeasureManagement",
            PageTitleKey = "um.management",
            PageTitleDefault = "Gestione Unità di Misura",
            EntityIcon = Icons.Material.Outlined.Straighten,
            PageRootCssClass = "um-page-root",
            BaseRoute = "/settings/unit-of-measures",
            ExcelFileName = "UnitaDiMisura",
            SearchPlaceholderKey = "um.search",
            SearchPlaceholderDefault = "Cerca unità di misura",
            CreateTooltip = "um.createNew",
            EntityTypeName = "UM",
            ShowToggleStatus = false,
            GetDisplayName = u => u.Name,
            GetId = u => u.Id,
            GetIsActive = u => u.IsActive,
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Catalogo", null, disabled: true),
                new BreadcrumbItem("Unità di Misura", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Name", DisplayName = "Nome", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "Symbol", DisplayName = "Simbolo", IsVisible = true, Order = 1, IsSearchable = true },
                new() { PropertyName = "Description", DisplayName = "Descrizione", IsVisible = true, Order = 2, IsSearchable = true },
                new() { PropertyName = "IsDefault", DisplayName = "Predefinita", IsVisible = true, Order = 3, IsSearchable = false },
                new() { PropertyName = "CreatedAt", DisplayName = "Creato il", IsVisible = true, Order = 4, IsSearchable = false }
            },
            QuickFilters = new()
            {
                new() { Id = "all", Label = "Tutti", Predicate = _ => true, Description = "Mostra tutte le unità di misura" },
                new() { Id = "default", Label = "Predefinite", Predicate = u => u.IsDefault, Color = Color.Success, Icon = Icons.Material.Outlined.Star, Description = "Unità di misura predefinite" },
                new() { Id = "active", Label = "Attive", Predicate = u => u.IsActive, Color = Color.Info, Icon = Icons.Material.Outlined.CheckCircle, Description = "Unità di misura attive" },
                new() { Id = "with_description", Label = "Con Descrizione", Predicate = u => !string.IsNullOrEmpty(u.Description), Color = Color.Primary, Icon = Icons.Material.Outlined.Description, Description = "Unità con descrizione" },
                new() { Id = "recent", Label = "Recenti", Predicate = u => u.CreatedAt >= DateTime.UtcNow.AddDays(-30), Color = Color.Warning, Icon = Icons.Material.Outlined.NewReleases, Description = "Unità aggiunte negli ultimi 30 giorni" }
            }
        };
    }

    private async Task OpenDetailDialogAsync(Guid? id)
    {
        try
        {
            var parameters = new DialogParameters { [nameof(UnitOfMeasureDetailDialog.EntityId)] = id };
            var options = EFDialogDefaults.Options;
            var dialog = await DialogService.ShowAsync<UnitOfMeasureDetailDialog>(string.Empty, parameters, options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await _entityPage!.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening unit of measure detail dialog.");
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }
}
