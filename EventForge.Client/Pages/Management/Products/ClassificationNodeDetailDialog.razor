@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.Common
@using EventForge.Client.Shared.Components
@using EventForge.Client.Shared.Components.Dialogs
@attribute [Authorize]
@inject IEntityManagementService EntityManagementService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<ClassificationNodeDetailDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.AccountTree"
          Title="@(_isCreateMode ? TranslationService.GetTranslation("classificationNode.create", "Crea Nodo di Classificazione") : (_node?.Name ?? string.Empty))"
          IsProcessing="@(_isLoading || _isSaving)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <ChildContent>
        @if (_isLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (!_isCreateMode && _node == null)
        {
            <MudAlert Severity="Severity.Error">
                @TranslationService.GetTranslation("classificationNode.notFound", "Nodo di classificazione non trovato")
            </MudAlert>
        }
        else
        {
            @if (_loadError)
            {
                <MudAlert Severity="Severity.Warning" Class="mb-2">
                    @TranslationService.GetTranslation("classificationNode.parentLoadWarning", "Impossibile caricare i nodi padre. Il campo Nodo Padre potrebbe non essere disponibile, ma puoi comunque procedere.")
                </MudAlert>
            }
            <MudTabs Elevation="0" Rounded="false" PanelClass="pa-4" Class="ef-tabs" ApplyEffectsToContainer="true" @bind-ActivePanelIndex="_activeTab">

                <MudTabPanel Text="@TranslationService.GetTranslation("classificationNode.generalInfo", "Informazioni")" Icon="@Icons.Material.Outlined.Info">
                    <MudForm @ref="_form">
                        <MudGrid>
                            <MudItem xs="12" md="8">
                                <MudGrid>
                                    <MudItem xs="12" md="6">
                                        <PrymTextField @bind-Value="NodeName"
                                                       Label="@($"{TranslationService.GetTranslation("field.name", "Nome")} *")"
                                                       Required="true"
                                                       RequiredError="@TranslationService.GetTranslation("validation.nameRequired", "Il nome è obbligatorio")"
                                                       MaxLength="100"
                                                       Immediate="true"
                                                       OnBlur="@(()=> MarkChanged())" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <PrymTextField T="string" Value="@(NodeCode ?? "-")"
                                                       Label="@TranslationService.GetTranslation("field.code", "Codice")"
                                                       ReadOnly="true" />
                                    </MudItem>

                                    <MudItem xs="12">
                                        <PrymTextField @bind-Value="NodeDescription"
                                                       Label="@TranslationService.GetTranslation("field.description", "Descrizione")"
                                                       Lines="3"
                                                       MaxLength="200"
                                                       OnBlur="@(()=> MarkChanged())" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <PrymSelect T="ProductClassificationType" @bind-Value="NodeType"
                                                    Label="@TranslationService.GetTranslation("field.type", "Tipo")"
                                                    Required="true"
                                                    Disabled="@(_isCreateMode && NodeParentId.HasValue)"
                                                    @bind-Value:after="@MarkChanged">
                                            <MudSelectItem Value="@ProductClassificationType.Category">@TranslationService.GetTranslation("classificationType.category", "Categoria")</MudSelectItem>
                                            <MudSelectItem Value="@ProductClassificationType.Family">@TranslationService.GetTranslation("classificationType.family", "Famiglia")</MudSelectItem>
                                            <MudSelectItem Value="@ProductClassificationType.MerchandiseGroup">@TranslationService.GetTranslation("classificationType.merchandiseGroup", "Gruppo Merceologico")</MudSelectItem>
                                        </PrymSelect>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <PrymSelect T="ProductClassificationNodeStatus" @bind-Value="NodeStatus"
                                                    Label="@TranslationService.GetTranslation("field.status", "Stato")"
                                                    Required="true"
                                                    @bind-Value:after="@MarkChanged">
                                            <MudSelectItem Value="@ProductClassificationNodeStatus.Active">@TranslationService.GetTranslation("status.active", "Attivo")</MudSelectItem>
                                            <MudSelectItem Value="@ProductClassificationNodeStatus.Inactive">@TranslationService.GetTranslation("status.inactive", "Inattivo")</MudSelectItem>
                                            <MudSelectItem Value="@ProductClassificationNodeStatus.Pending">@TranslationService.GetTranslation("status.pending", "In attesa")</MudSelectItem>
                                        </PrymSelect>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <PrymSelect T="Guid?" @bind-Value="NodeParentId"
                                                    Label="@TranslationService.GetTranslation("field.parentNode", "Nodo Padre")"
                                                    Clearable="true"
                                                    @bind-Value:after="@MarkChanged">
                                            <MudSelectItem T="Guid?" Value="@((Guid?)null)">@TranslationService.GetTranslation("classificationNode.rootNode", "Nodo Radice")</MudSelectItem>
                                            @foreach (var p in _availableParentNodes.Where(p => _isCreateMode || (p.Id != (EntityId ?? Guid.Empty) && !IsDescendant(p.Id, EntityId ?? Guid.Empty))))
                                            {
                                                <MudSelectItem T="Guid?" Value="@((Guid?)p.Id)">@GetNodeDisplayName(p)</MudSelectItem>
                                            }
                                        </PrymSelect>
                                    </MudItem>
                                </MudGrid>
                            </MudItem>

                            <MudItem xs="12" md="4">
                                <MudText Typo="Typo.h6" Class="mb-2">@TranslationService.GetTranslation("common.metadata", "Metadati")</MudText>
                                <MudDivider Class="mb-2" />
                                <MudText Typo="Typo.caption" Class="d-block mt-2">@TranslationService.GetTranslation("field.level", "Livello"): @NodeLevel</MudText>
                                <MudText Typo="Typo.caption" Class="d-block mt-1">@TranslationService.GetTranslation("field.order", "Ordine"): @NodeOrder</MudText>

                                @if (!_isCreateMode && _node != null)
                                {
                                    <MudText Typo="Typo.caption" Class="d-block mt-2">@TranslationService.GetTranslation("field.createdAt", "Creato il"): @_node.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudText>
                                    @if (!string.IsNullOrWhiteSpace(_node.CreatedBy))
                                    {
                                        <MudText Typo="Typo.caption" Class="d-block mt-1">@TranslationService.GetTranslation("field.createdBy", "Creato da"): @_node.CreatedBy</MudText>
                                    }
                                }
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                </MudTabPanel>

                @if (!_isCreateMode)
                {
                    <MudTabPanel Text="@TranslationService.GetTranslation("classificationNode.children", "Figli")" Icon="@Icons.Material.Outlined.List">
                        @if (_node != null)
                        {
                            <div class="d-flex justify-end mb-2">
                                <PrymButton Intent="PrymButton.ButtonIntent.Secondary"
                                           StartIcon="@Icons.Material.Outlined.AddCircleOutline"
                                           OnClick="@OpenCreateChildDialogAsync">
                                    @TranslationService.GetTranslation("classificationNode.addChild", "Aggiungi figlio")
                                </PrymButton>
                            </div>
                            @if (_childrenLoading)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                            }
                            else if (!_treeItems.Any())
                            {
                                <div class="text-center pa-4">
                                    <MudText Typo="Typo.body2">@TranslationService.GetTranslation("classificationNode.noChildren", "Nessun nodo figlio")</MudText>
                                </div>
                            }
                            else
                            {
                                <MudTreeView Items="@_treeItems" T="ClassificationNodePicker.ClassificationNodeTreeItem" Hover="true" Dense="true">
                                    <ItemTemplate Context="it">
                                        @if (it is ClassificationNodePicker.ClassificationNodeTreeItem nodeItem)
                                        {
                                            <MudTreeViewItem Items="@nodeItem.Children" Expanded="@nodeItem.Expanded">
                                                <BodyContent>
                                                    <div class="d-flex justify-space-between align-center w-full">
                                                        <div class="d-flex align-center gap-2">
                                                            <MudText Typo="Typo.body2">@nodeItem.Node.Name</MudText>
                                                            @if (!string.IsNullOrWhiteSpace(nodeItem.Node.Code))
                                                            {
                                                                <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1">(@nodeItem.Node.Code)</MudText>
                                                            }
                                                            <MudChip T="string" Size="Size.Small" Color="@GetTypeColor(nodeItem.Node.Type)">@GetTypeDisplayName(nodeItem.Node.Type)</MudChip>
                                                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(nodeItem.Node.Status)">@GetStatusDisplayName(nodeItem.Node.Status)</MudChip>
                                                        </div>
                                                        <PrymIconButton Icon="@Icons.Material.Outlined.OpenInNew" Size="Size.Small" Color="Color.Info"
                                                                       OnClick="@(() => OpenChildDetailDialogAsync(nodeItem.Node.Id))" />
                                                    </div>
                                                </BodyContent>
                                            </MudTreeViewItem>
                                        }
                                    </ItemTemplate>
                                </MudTreeView>
                            }
                        }
                    </MudTabPanel>

                    <MudTabPanel Text="@TranslationService.GetTranslation("classificationNode.audit", "Audit")" Icon="@Icons.Material.Outlined.History">
                        <MudText Typo="Typo.body2">@TranslationService.GetTranslation("messages.auditFullscreen", "Storia modifiche disponibile in modalità fullscreen")</MudText>
                        <PrymButton Class="mt-3"
                                   StartIcon="@Icons.Material.Outlined.History"
                                   OnClick="@OpenAuditDialog">
                            @TranslationService.GetTranslation("classificationNode.viewAudit", "Apri cronologia")
                        </PrymButton>
                    </MudTabPanel>
                }
            </MudTabs>
        }
    </ChildContent>
    <DialogActions>
        <PrymButton Intent="PrymButton.ButtonIntent.Ghost" OnClick="Cancel" Disabled="_isSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </PrymButton>
        <PrymButton StartIcon="@Icons.Material.Outlined.Save"
                    OnClick="SaveAsync" Disabled="_isSaving || _isLoading">
            @TranslationService.GetTranslation("common.save", "Salva")
        </PrymButton>
    </DialogActions>
</EFDialog>

@code {
    private readonly DialogOptions _auditDialogOptions = new()
    {
        FullScreen = true,
        CloseButton = true,
        MaxWidth = MaxWidth.False
    };

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? EntityId { get; set; }
    [Parameter] public Guid? ParentId { get; set; }

    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _isCreateMode = false;
    private bool _childrenLoading = false;
    private bool _loadError = false;
    private int _activeTab = 0;

    private ClassificationNodeDto? _node;
    private CreateClassificationNodeDto _createModel = new();
    private UpdateClassificationNodeDto _updateModel = new();
    private IEntityManagementService _ems => EntityManagementService;

    private List<ClassificationNodeDto> _availableParentNodes = new();
    private IEnumerable<ClassificationNodeDto>? _children;
    private List<ClassificationNodePicker.ClassificationNodeTreeItem> _treeItems = new();

    private string _originalSnapshot = string.Empty;
    private bool _hasLocalChanges = false;
    private static readonly System.Text.Json.JsonSerializerOptions _json_options = new()
    {
        PropertyNameCaseInsensitive = true,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
    };

    private MudForm? _form;

    private string NodeName
    {
        get => _isCreateMode ? (_createModel.Name ?? string.Empty) : (_updateModel.Name ?? string.Empty);
        set
        {
            if (_isCreateMode)
                _createModel.Name = value;
            else
                _updateModel.Name = value;
            MarkChanged();
        }
    }

    private string? NodeCode => _isCreateMode ? _createModel.Code : _updateModel.Code;

    private string NodeDescription
    {
        get => _isCreateMode ? (_createModel.Description ?? string.Empty) : (_updateModel.Description ?? string.Empty);
        set
        {
            if (_isCreateMode)
                _createModel.Description = value;
            else
                _updateModel.Description = value;
            MarkChanged();
        }
    }

    private ProductClassificationType NodeType
    {
        get => _isCreateMode ? _createModel.Type : _updateModel.Type;
        set
        {
            if (_isCreateMode)
                _createModel.Type = value;
            else
                _updateModel.Type = value;
            MarkChanged();
        }
    }

    private ProductClassificationNodeStatus NodeStatus
    {
        get => _isCreateMode ? _createModel.Status : _updateModel.Status;
        set
        {
            if (_isCreateMode)
                _createModel.Status = value;
            else
                _updateModel.Status = value;
            MarkChanged();
        }
    }

    private Guid? NodeParentId
    {
        get => _isCreateMode ? _createModel.ParentId : _updateModel.ParentId;
        set
        {
            if (_isCreateMode)
            {
                _createModel.ParentId = value;
                if (value.HasValue)
                {
                    var parent = _availableParentNodes.FirstOrDefault(p => p.Id == value.Value);
                    if (parent != null)
                    {
                        _createModel.Type = parent.Type;
                        _createModel.Level = parent.Level + 1;
                    }
                }
                else
                {
                    _createModel.Type = ProductClassificationType.Category;
                    _createModel.Level = 0;
                }
            }
            else
            {
                _updateModel.ParentId = value;
            }
            MarkChanged();
        }
    }

    private int NodeLevel
    {
        get => _isCreateMode ? _createModel.Level : _updateModel.Level;
        set
        {
            if (_isCreateMode)
                _createModel.Level = value;
            else
                _updateModel.Level = value;
            MarkChanged();
        }
    }

    private int NodeOrder
    {
        get => _isCreateMode ? _createModel.Order : _updateModel.Order;
        set
        {
            if (_isCreateMode)
                _createModel.Order = value;
            else
                _updateModel.Order = value;
            MarkChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _isCreateMode = EntityId == null || EntityId == Guid.Empty;
        _isLoading = true;
        try
        {
            await LoadAvailableParentsAsync();

            if (_isCreateMode)
                InitializeCreateModel();
            else
                await LoadNodeAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing classification node detail");
            AppNotification.ShowError(TranslationService.GetTranslation("classificationNode.loadError", "Errore nel caricamento del nodo"));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void InitializeCreateModel()
    {
        _createModel = new CreateClassificationNodeDto
        {
            Status = ProductClassificationNodeStatus.Active,
            Type = ProductClassificationType.Category,
            Order = 0,
            Level = 0,
            ParentId = ParentId
        };

        if (ParentId.HasValue)
        {
            var parent = _availableParentNodes.FirstOrDefault(p => p.Id == ParentId.Value);
            if (parent != null)
            {
                _createModel.Type = parent.Type;
                _createModel.Level = parent.Level + 1;
            }
        }

        _originalSnapshot = SerializeCurrentModel();
        _hasLocalChanges = false;
    }

    private async Task LoadNodeAsync()
    {
        try
        {
            if (!EntityId.HasValue) return;
            _node = await _ems.GetClassificationNodeAsync(EntityId.Value);
            if (_node == null)
            {
                AppNotification.ShowError(TranslationService.GetTranslation("classificationNode.notFound", "Nodo di classificazione non trovato"));
                return;
            }

            _updateModel = new UpdateClassificationNodeDto
            {
                Code = _node.Code,
                Name = _node.Name,
                Description = _node.Description,
                Type = _node.Type,
                Status = _node.Status,
                Level = _node.Level,
                Order = _node.Order,
                ParentId = _node.ParentId
            };

            _originalSnapshot = SerializeCurrentModel();
            _hasLocalChanges = false;

            await LoadChildrenAsync();
            BuildChildrenTree();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading node {EntityId}", EntityId);
            AppNotification.ShowError(TranslationService.GetTranslation("classificationNode.loadError", "Errore nel caricamento del nodo"));
            _node = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadAvailableParentsAsync()
    {
        try
        {
            var all = (await _ems.GetClassificationNodesAsync())?.ToList() ?? new List<ClassificationNodeDto>();
            _availableParentNodes = all
                .OrderBy(n => n.Level)
                .ThenBy(n => n.Order)
                .ThenBy(n => n.Name)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading parent nodes");
            _loadError = true;
            AppNotification.ShowWarning(TranslationService.GetTranslation("classificationNode.parentLoadWarning",
                "Impossibile caricare i nodi padre. Il campo Nodo Padre potrebbe non essere disponibile."));
        }
    }

    private async Task LoadChildrenAsync()
    {
        if (_node == null) return;
        _childrenLoading = true;
        try
        {
            _children = await _ems.GetChildrenClassificationNodesAsync(_node.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading children for node {NodeId}", _node.Id);
            _children = Enumerable.Empty<ClassificationNodeDto>();
        }
        finally
        {
            _childrenLoading = false;
            BuildChildrenTree();
        }
    }

    private void BuildChildrenTree()
    {
        if (_node == null) { _treeItems = new(); return; }

        var lookup = _availableParentNodes.ToDictionary(
            n => n.Id,
            n => new ClassificationNodePicker.ClassificationNodeTreeItem(n));

        foreach (var item in lookup.Values)
        {
            item.Children = lookup.Values
                .Where(v => v.Node.ParentId == item.Node.Id)
                .ToList();
            if (item.Children.Any()) item.Expanded = true;
        }

        _treeItems = lookup.Values
            .Where(v => v.Node.ParentId == _node.Id)
            .ToList();
    }

    private bool IsDescendant(Guid potentialDescendantId, Guid ancestorId)
    {
        var dict = _availableParentNodes.ToDictionary(n => n.Id);
        if (!dict.TryGetValue(potentialDescendantId, out var node)) return false;
        while (node != null && node.ParentId.HasValue)
        {
            if (node.ParentId.Value == ancestorId) return true;
            if (!dict.TryGetValue(node.ParentId.Value, out node)) break;
        }
        return false;
    }

    private async Task SaveAsync()
    {
        if (_isSaving) return;
        if (_form != null) await _form.ValidateAsync();

        if (_form != null && _form.IsValid == false)
        {
            AppNotification.ShowWarning(TranslationService.GetTranslation("validation.formInvalid", "Modulo non valido"));
            return;
        }

        _isSaving = true;
        try
        {
            if (_isCreateMode)
            {
                var created = await _ems.CreateClassificationNodeAsync(_createModel);
                if (created != null)
                {
                    AppNotification.ShowSuccess(TranslationService.GetTranslation("classificationNode.created", "Nodo creato con successo"));
                    _hasLocalChanges = false;
                    MudDialog.Close(DialogResult.Ok(true));
                    return;
                }
                AppNotification.ShowError(TranslationService.GetTranslation("classificationNode.createError", "Errore nella creazione del nodo"));
            }
            else if (_node != null)
            {
                var updated = await _ems.UpdateClassificationNodeAsync(_node.Id, _updateModel);
                if (updated != null)
                {
                    AppNotification.ShowSuccess(TranslationService.GetTranslation("classificationNode.updated", "Nodo aggiornato con successo"));
                    _hasLocalChanges = false;
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    AppNotification.ShowError(TranslationService.GetTranslation("classificationNode.updateError", "Errore nell'aggiornamento del nodo"));
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving classification node");
            AppNotification.ShowError(TranslationService.GetTranslation("classificationNode.saveError", "Errore nel salvataggio del nodo: {0}", ex.Message));
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void MarkChanged()
    {
        _hasLocalChanges = true;
        StateHasChanged();
    }

    private string SerializeCurrentModel()
    {
        var model = _isCreateMode ? (object)_createModel : (object)_updateModel;
        return System.Text.Json.JsonSerializer.Serialize(model, _json_options);
    }

    private bool HasUnsavedChanges()
    {
        if (_isCreateMode) return _hasLocalChanges;
        if (_node == null) return false;
        var current = SerializeCurrentModel();
        return !string.Equals(current, _originalSnapshot, StringComparison.Ordinal);
    }

    private async Task OpenCreateChildDialogAsync()
    {
        try
        {
            if (_node == null) return;
            var p = new DialogParameters
            {
                [nameof(ClassificationNodeDetailDialog.EntityId)] = (Guid?)null,
                [nameof(ClassificationNodeDetailDialog.ParentId)] = (Guid?)_node.Id
            };
            var d = await DialogService.ShowAsync<ClassificationNodeDetailDialog>(string.Empty, p, EFDialogDefaults.Options);
            var _dr = await d.Result; if (_dr is { Canceled: false }) await LoadChildrenAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OpenCreateChildDialogAsync.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task OpenChildDetailDialogAsync(Guid childId)
    {
        try
        {
            var p = new DialogParameters
            {
                [nameof(ClassificationNodeDetailDialog.EntityId)] = (Guid?)childId
            };
            var d = await DialogService.ShowAsync<ClassificationNodeDetailDialog>(string.Empty, p, EFDialogDefaults.Options);
            var _dr = await d.Result; if (_dr is { Canceled: false }) await LoadChildrenAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OpenChildDetailDialogAsync.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task OpenAuditDialog()
    {
        try
        {
            if (_node == null || _isCreateMode) return;

            var parameters = new DialogParameters<AuditHistoryDialog>
            {
                { x => x.EntityType, "ClassificationNode" },
                { x => x.EntityId, _node.Id },
                { x => x.EntityName, _node.Name }
            };

            await DialogService.ShowAsync<AuditHistoryDialog>(
                TranslationService.GetTranslation("audit.historyDialog.title", "Cronologia Modifiche"),
                parameters,
                _auditDialogOptions);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OpenAuditDialog.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task Cancel()
    {
        try
        {
            if (HasUnsavedChanges())
            {
                var result = await DialogService.ShowMessageBoxAsync(
                    TranslationService.GetTranslation("common.confirm", "Conferma"),
                    TranslationService.GetTranslation("classificationNode.unsavedChangesConfirm", "Ci sono modifiche non salvate. Vuoi salvare prima di uscire?"),
                    yesText: TranslationService.GetTranslation("common.save", "Salva"),
                    noText: TranslationService.GetTranslation("common.discard", "Non salvare"),
                    cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
                if (result == null) return;
                if (result == true) { await SaveAsync(); return; }
            }
            MudDialog.Close();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in Cancel.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private string GetNodeDisplayName(ClassificationNodeDto node)
    {
        var indent = new string(' ', Math.Max(0, node.Level * 2));
        return $"{indent}{node.Name} ({GetTypeDisplayName(node.Type)})";
    }

    private Color GetStatusColor(ProductClassificationNodeStatus status) => status switch
    {
        ProductClassificationNodeStatus.Active => Color.Success,
        ProductClassificationNodeStatus.Inactive => Color.Default,
        ProductClassificationNodeStatus.Pending => Color.Warning,
        _ => Color.Default
    };

    private string GetStatusDisplayName(ProductClassificationNodeStatus status) => status switch
    {
        ProductClassificationNodeStatus.Active => TranslationService.GetTranslation("status.active", "Attivo"),
        ProductClassificationNodeStatus.Inactive => TranslationService.GetTranslation("status.inactive", "Inattivo"),
        ProductClassificationNodeStatus.Pending => TranslationService.GetTranslation("status.pending", "In attesa"),
        _ => status.ToString()
    };

    private Color GetTypeColor(ProductClassificationType type) => type switch
    {
        ProductClassificationType.Category => Color.Primary,
        ProductClassificationType.Family => Color.Secondary,
        ProductClassificationType.MerchandiseGroup => Color.Tertiary,
        _ => Color.Default
    };

    private string GetTypeDisplayName(ProductClassificationType type) => type switch
    {
        ProductClassificationType.Category => TranslationService.GetTranslation("classificationType.category", "Categoria"),
        ProductClassificationType.Family => TranslationService.GetTranslation("classificationType.family", "Famiglia"),
        ProductClassificationType.MerchandiseGroup => TranslationService.GetTranslation("classificationType.merchandiseGroup", "Gruppo Merceologico"),
        _ => type.ToString()
    };
}
