@page "/product-management/brands"
@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.Products
@using EventForge.Client.Shared.Components.Dialogs
@attribute [Authorize]
@inject IBrandService BrandService
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject ILogger<BrandManagement> Logger
@inject IAppNotificationService AppNotification

<PageTitle>@TranslationService.GetTranslation("brand.management", "Gestione Marchi")</PageTitle>
<EntityManagementPage TEntity="BrandDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      OnCreateOverride="@(() => OpenDetailDialogAsync(null))"
                      OnEditOverride="@(id => OpenDetailDialogAsync(id))">
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Name")
            {
                <EFTableColumnHeader TItem="BrandDto" PropertyName="Name">
                    <MudTableSortLabel SortBy="@(new Func<BrandDto, object>(x => x.Name))">@TranslationService.GetTranslation("field.name", "Nome")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Description")
            {
                <EFTableColumnHeader TItem="BrandDto" PropertyName="Description">
                    <MudTableSortLabel SortBy="@(new Func<BrandDto, object>(x => x.Description ?? string.Empty))">@TranslationService.GetTranslation("field.description", "Descrizione")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Country")
            {
                <EFTableColumnHeader TItem="BrandDto" PropertyName="Country">
                    <MudTableSortLabel SortBy="@(new Func<BrandDto, object>(x => x.Country ?? string.Empty))">@TranslationService.GetTranslation("field.country", "Paese")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Website")
            {
                <EFTableColumnHeader TItem="BrandDto" PropertyName="Website">
                    <MudTableSortLabel SortBy="@(new Func<BrandDto, object>(x => x.Website ?? string.Empty))">@TranslationService.GetTranslation("field.website", "Sito Web")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "CreatedAt")
            {
                <EFTableColumnHeader TItem="BrandDto" PropertyName="CreatedAt">
                    <MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="@(new Func<BrandDto, object>(x => x.CreatedAt))">@TranslationService.GetTranslation("field.createdAt", "Creato il")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center ef-min-120" >@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Name")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.name", "Nome")">
                    <div class="d-flex align-center">
                        <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2">
                            <MudIcon Icon="@Icons.Material.Outlined.Sell" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2">@ctx.Item.Name</MudText>
                        </div>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "Description")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.description", "Descrizione")">
                    <MudText Typo="Typo.body2" Class="text-truncate ef-max-400" >
                        @(string.IsNullOrEmpty(ctx.Item.Description) ? "-" : ctx.Item.Description)
                    </MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Country")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.country", "Paese")">
                    <MudText Typo="Typo.body2">@(ctx.Item.Country ?? "-")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Website")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.website", "Sito Web")">
                    @if (!string.IsNullOrWhiteSpace(ctx.Item.Website))
                    {
                        <MudLink Href="@ctx.Item.Website" Target="_blank">@TranslationService.GetTranslation("action.visit", "Visita")</MudLink>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">-</MudText>
                    }
                </MudTd>
            }
            else if (column.PropertyName == "CreatedAt")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.createdAt", "Creato il")">
                    <MudText Typo="Typo.body2">@ctx.Item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudText>
                </MudTd>
            }
        }
    </RowTemplate>
</EntityManagementPage>

@code {
    private EntityManagementPage<BrandDto>? _entityPage;
    private IEntityManagementService<BrandDto> _service = null!;
    private EntityManagementConfig<BrandDto> _config = null!;

    protected override void OnInitialized()
    {
        _service = new BrandManagementService(BrandService);
        _config = new EntityManagementConfig<BrandDto>
        {
            ComponentKey = "BrandManagement",
            PageTitleKey = "brand.management",
            PageTitleDefault = "Gestione Marchi",
            EntityIcon = Icons.Material.Outlined.Sell,
            PageRootCssClass = "brand-page-root",
            BaseRoute = "/product-management/brands",
            ExcelFileName = "Marchi",
            SearchPlaceholderKey = "brand.search",
            SearchPlaceholderDefault = "Cerca marchi",
            CreateTooltip = "brand.createNew",
            EntityTypeName = "Brand",
            ShowToggleStatus = false,
            GetDisplayName = b => b.Name,
            GetId = b => b.Id,
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Catalogo", null, disabled: true),
                new BreadcrumbItem("Marchi", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Name", DisplayName = "Nome", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "Description", DisplayName = "Descrizione", IsVisible = true, Order = 1, IsSearchable = true },
                new() { PropertyName = "Country", DisplayName = "Paese", IsVisible = true, Order = 2, IsSearchable = true },
                new() { PropertyName = "Website", DisplayName = "Sito Web", IsVisible = true, Order = 3, IsSearchable = true },
                new() { PropertyName = "CreatedAt", DisplayName = "Creato il", IsVisible = true, Order = 4, IsSearchable = false }
            },
            QuickFilters = new()
            {
                new() { Id = "all", Label = "Tutti", Predicate = _ => true, Description = "Mostra tutti i marchi" },
                new() { Id = "with_country", Label = "Con Paese", Predicate = b => !string.IsNullOrEmpty(b.Country), Color = Color.Success, Icon = Icons.Material.Outlined.Flag, Description = "Marchi con paese specificato" },
                new() { Id = "with_website", Label = "Con Sito Web", Predicate = b => !string.IsNullOrEmpty(b.Website), Color = Color.Info, Icon = Icons.Material.Outlined.Language, Description = "Marchi con sito web" },
                new() { Id = "with_description", Label = "Con Descrizione", Predicate = b => !string.IsNullOrEmpty(b.Description), Color = Color.Primary, Icon = Icons.Material.Outlined.Description, Description = "Marchi con descrizione" },
                new() { Id = "recent", Label = "Recenti", Predicate = b => b.CreatedAt >= DateTime.UtcNow.AddDays(-30), Color = Color.Warning, Icon = Icons.Material.Outlined.NewReleases, Description = "Marchi aggiunti negli ultimi 30 giorni" }
            }
        };
    }

    private async Task OpenDetailDialogAsync(Guid? id)
    {
        try
        {
            var parameters = new DialogParameters
            {
                [nameof(BrandDetailDialog.EntityId)] = id
            };
            var options = EFDialogDefaults.Options;
            var dialog = await DialogService.ShowAsync<BrandDetailDialog>(string.Empty, parameters, options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await _entityPage!.RefreshAsync();
    
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening BrandDetailDialog for ID {Id}.", id);
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }
}
