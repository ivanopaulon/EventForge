@page "/financial/vat-rates"
@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.VatRates
@using EventForge.Client.Shared.Components.Dialogs
@attribute [Authorize]
@inject IFinancialService FinancialService
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject ILogger<VatRateManagement> Logger
@inject IAppNotificationService AppNotification

<PageTitle>@TranslationService.GetTranslation("financial.vatRateManagement", "Gestione Aliquote IVA")</PageTitle>
<EntityManagementPage TEntity="VatRateDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      OnCreateOverride="@(() => OpenDetailDialogAsync(null))"
                      OnEditOverride="@(id => OpenDetailDialogAsync(id))">
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Name")
            {
                <EFTableColumnHeader TItem="VatRateDto" PropertyName="Name">
                    <MudTableSortLabel SortBy="@(new Func<VatRateDto, object>(x => x.Name))">@TranslationService.GetTranslation("field.name", "Nome")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Percentage")
            {
                <EFTableColumnHeader TItem="VatRateDto" PropertyName="Percentage">
                    <MudTableSortLabel SortBy="@(new Func<VatRateDto, object>(x => x.Percentage))">@TranslationService.GetTranslation("field.percentage", "Percentuale")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Status")
            {
                <EFTableColumnHeader TItem="VatRateDto" PropertyName="Status">
                    <MudTableSortLabel SortBy="@(new Func<VatRateDto, object>(x => x.Status))">@TranslationService.GetTranslation("field.status", "Stato")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ValidFrom")
            {
                <EFTableColumnHeader TItem="VatRateDto" PropertyName="ValidFrom">
                    <MudTableSortLabel SortBy="@(new Func<VatRateDto, object>(x => x.ValidFrom ?? DateTime.MinValue))">@TranslationService.GetTranslation("field.validFrom", "Valido Da")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ValidTo")
            {
                <EFTableColumnHeader TItem="VatRateDto" PropertyName="ValidTo">
                    <MudTableSortLabel SortBy="@(new Func<VatRateDto, object>(x => x.ValidTo ?? DateTime.MaxValue))">@TranslationService.GetTranslation("field.validTo", "Valido A")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "CreatedAt")
            {
                <EFTableColumnHeader TItem="VatRateDto" PropertyName="CreatedAt">
                    <MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="@(new Func<VatRateDto, object>(x => x.CreatedAt))">@TranslationService.GetTranslation("field.createdAt", "Creato il")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center" Style="min-width:120px;">@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Name")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.name", "Nome")">
                    <div class="d-flex align-center">
                        <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2">
                            <MudIcon Icon="@Icons.Material.Outlined.Percent" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2">@ctx.Item.Name</MudText>
                        </div>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "Percentage")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.percentage", "Percentuale")">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@($"{ctx.Item.Percentage}%")</MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "Status")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.status", "Stato")">
                    <MudChip T="string" Color="@GetStatusColor(ctx.Item.Status)"
                             Size="Size.Small"
                             Icon="@GetStatusIcon(ctx.Item.Status)">
                        @GetStatusText(ctx.Item.Status)
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "ValidFrom")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.validFrom", "Valido Da")">
                    <MudText Typo="Typo.body2">@(ctx.Item.ValidFrom?.ToString("dd/MM/yyyy") ?? "-")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "ValidTo")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.validTo", "Valido A")">
                    <MudText Typo="Typo.body2">@(ctx.Item.ValidTo?.ToString("dd/MM/yyyy") ?? "-")</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "CreatedAt")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.createdAt", "Creato il")">
                    <MudText Typo="Typo.body2">@ctx.Item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudText>
                </MudTd>
            }
        }
    </RowTemplate>
</EntityManagementPage>

@code {
    private EntityManagementPage<VatRateDto>? _entityPage;
    private IEntityManagementService<VatRateDto> _service = null!;
    private EntityManagementConfig<VatRateDto> _config = null!;

    protected override void OnInitialized()
    {
        _service = new VatRateManagementService(FinancialService);
        _config = new EntityManagementConfig<VatRateDto>
        {
            ComponentKey = "VatRateManagement",
            PageTitleKey = "financial.vatRateManagement",
            PageTitleDefault = "Gestione Aliquote IVA",
            EntityIcon = Icons.Material.Outlined.Percent,
            PageRootCssClass = "vat-rate-page-root",
            BaseRoute = "/financial/vat-rates",
            ExcelFileName = "AliquoteIVA",
            SearchPlaceholderKey = "financial.searchVatRates",
            SearchPlaceholderDefault = "Cerca aliquote IVA",
            CreateTooltip = "financial.createNewVatRate",
            EntityTypeName = "VatRate",
            ShowToggleStatus = false,
            GetDisplayName = v => v.Name,
            GetId = v => v.Id,
            GetIsActive = v => v.IsActive,
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Contabilità", null, disabled: true),
                new BreadcrumbItem("Aliquote IVA", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Name", DisplayName = "Nome", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "Percentage", DisplayName = "Percentuale", IsVisible = true, Order = 1, IsSearchable = false },
                new() { PropertyName = "Status", DisplayName = "Stato", IsVisible = true, Order = 2, IsSearchable = false },
                new() { PropertyName = "ValidFrom", DisplayName = "Valido Da", IsVisible = true, Order = 3, IsSearchable = false },
                new() { PropertyName = "ValidTo", DisplayName = "Valido A", IsVisible = true, Order = 4, IsSearchable = false },
                new() { PropertyName = "CreatedAt", DisplayName = "Creato il", IsVisible = true, Order = 5, IsSearchable = false }
            },
            QuickFilters = new()
            {
                new() { Id = "all", Label = "Tutte", Predicate = _ => true, Description = "Mostra tutte le aliquote IVA" },
                new() { Id = "active", Label = "Attive", Predicate = v => v.Status == VatRateStatus.Active, Color = Color.Success, Icon = Icons.Material.Outlined.CheckCircle, Description = "Aliquote IVA attive" },
                new() { Id = "suspended", Label = "Sospese", Predicate = v => v.Status == VatRateStatus.Suspended, Color = Color.Warning, Icon = Icons.Material.Outlined.Warning, Description = "Aliquote IVA sospese" },
                new() { Id = "archived", Label = "Eliminate", Predicate = v => v.Status == VatRateStatus.Deleted, Color = Color.Default, Icon = Icons.Material.Outlined.Archive, Description = "Aliquote IVA eliminate" },
                new() { Id = "standard", Label = "Standard (≥ 20%)", Predicate = v => v.Percentage >= 20, Color = Color.Primary, Icon = Icons.Material.Outlined.TrendingUp, Description = "Aliquote standard (20% o superiori)" },
                new() { Id = "reduced", Label = "Ridotte (< 20%)", Predicate = v => v.Percentage < 20, Color = Color.Info, Icon = Icons.Material.Outlined.TrendingDown, Description = "Aliquote ridotte (inferiori al 20%)" }
            }
        };
    }

    private Color GetStatusColor(VatRateStatus status) => status switch
    {
        VatRateStatus.Active => Color.Success,
        VatRateStatus.Suspended => Color.Warning,
        VatRateStatus.Deleted => Color.Error,
        _ => Color.Default
    };

    private string GetStatusIcon(VatRateStatus status) => status switch
    {
        VatRateStatus.Active => Icons.Material.Outlined.CheckCircle,
        VatRateStatus.Suspended => Icons.Material.Outlined.Pause,
        VatRateStatus.Deleted => Icons.Material.Outlined.Cancel,
        _ => Icons.Material.Outlined.Help
    };

    private string GetStatusText(VatRateStatus status) => status switch
    {
        VatRateStatus.Active => TranslationService.GetTranslation("field.active", "Attivo"),
        VatRateStatus.Suspended => TranslationService.GetTranslation("field.suspended", "Sospeso"),
        VatRateStatus.Deleted => TranslationService.GetTranslation("field.deleted", "Eliminato"),
        _ => status.ToString()
    };

    private async Task OpenDetailDialogAsync(Guid? id)
    {
        try
        {
            var parameters = new DialogParameters
            {
                [nameof(VatRateDetailDialog.EntityId)] = id
            };
            var options = EFDialogDefaults.Options;
            var dialog = await DialogService.ShowAsync<VatRateDetailDialog>(string.Empty, parameters, options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await _entityPage!.RefreshAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening VAT rate detail dialog for ID {Id}.", id);
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }
}
