@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.Store
@using EventForge.DTOs.Common
@using EventForge.Client.Shared.Components
@using EventForge.Client.Shared.Components.Dialogs
@using EventForge.Client.ViewModels
@attribute [Authorize]
@inject FiscalDrawerDetailViewModel ViewModel
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject IAppNotificationService AppNotification
@inject ILogger<FiscalDrawerDetailDialog> Logger
@implements IDisposable

<EFDialog Icon="@Icons.Material.Outlined.Inbox"
          Title="@(ViewModel.IsNewEntity ? TranslationService.GetTranslation("store.newFiscalDrawer", "Nuovo Cassetto Fiscale") : (ViewModel.Entity?.Name ?? "Cassetto Fiscale"))"
          IsProcessing="@(ViewModel.IsLoading || ViewModel.IsSaving)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <ChildContent>
        @if (ViewModel.IsLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (!ViewModel.IsNewEntity && ViewModel.Entity == null)
        {
            <MudAlert Severity="Severity.Error">@TranslationService.GetTranslation("store.fiscalDrawerNotFound", "Cassetto fiscale non trovato.")</MudAlert>
        }
        else if (ViewModel.Entity != null)
        {
            <MudTabs Elevation="0" Rounded="false" PanelClass="pa-4" Class="ef-tabs" ApplyEffectsToContainer="true">

                @* ─── Tab 1: Generale ─────────────────────────────────── *@
                <MudTabPanel Text="Generale" Icon="@Icons.Material.Outlined.Info">
                    @if (!ViewModel.IsNewEntity)
                    {
                        <div class="d-flex align-center gap-4 flex-wrap mb-3">
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Color="@GetStatusColor(ViewModel.Entity.Status)" Size="Size.Medium">
                                    <MudIcon Icon="@Icons.Material.Outlined.Inbox" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.body1"  Class="fw-semibold">@ViewModel.Entity.Name</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        ID: @ViewModel.Entity.Id.ToString()[..8]...
                                    </MudText>
                                </div>
                            </div>
                            <MudChip T="string" Size="Size.Medium" Color="@GetStatusColor(ViewModel.Entity.Status)">
                                @GetStatusText(ViewModel.Entity.Status)
                            </MudChip>
                            @if (ViewModel.Entity.HasOpenSession)
                            {
                                <MudChip T="string" Size="Size.Medium" Color="Color.Success" Icon="@Icons.Material.Outlined.LockOpen">
                                    Sessione Aperta
                                </MudChip>
                            }
                        </div>
                        <MudDivider Class="mb-3" />
                    }

                    <MudForm @ref="_form" Model="@ViewModel.Entity">
                        <MudGrid>
                            <MudItem xs="12" md="8">
                                <MudTextField @bind-Value="ViewModel.Entity.Name"
                                              Label="@TranslationService.GetTranslation("field.name", "Nome")"
                                              Required="true"
                                              MaxLength="100"
                                              Variant="Variant.Outlined"
                                              Class="ef-input"
                                              @bind-Value:after="HandleEntityChanged"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="ViewModel.Entity.Code"
                                              Label="Codice"
                                              MaxLength="20"
                                              Variant="Variant.Outlined"
                                              Class="ef-input"
                                              @bind-Value:after="HandleEntityChanged"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="ViewModel.Entity.Description"
                                              Label="Descrizione"
                                              MaxLength="200"
                                              Variant="Variant.Outlined"
                                              Class="ef-input"
                                              @bind-Value:after="HandleEntityChanged"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect @bind-Value="ViewModel.Entity.AssignmentType"
                                           Label="Tipo Assegnazione"
                                           Variant="Variant.Outlined"
                                           Class="ef-select"
                                           @bind-Value:after="OnAssignmentTypeChanged">
                                    <MudSelectItem Value="FiscalDrawerAssignmentType.Fixed">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Outlined.PointOfSale" Size="Size.Small" />
                                            <span>Fisso (POS)</span>
                                        </MudStack>
                                    </MudSelectItem>
                                    <MudSelectItem Value="FiscalDrawerAssignmentType.Floating">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Small" />
                                            <span>Flottante (Operatore)</span>
                                        </MudStack>
                                    </MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect @bind-Value="ViewModel.Entity.Status"
                                           Label="@TranslationService.GetTranslation("field.status", "Stato")"
                                           Variant="Variant.Outlined"
                                           Class="ef-select"
                                           @bind-Value:after="HandleEntityChanged">
                                    @foreach (FiscalDrawerStatus s in Enum.GetValues(typeof(FiscalDrawerStatus)))
                                    {
                                        <MudSelectItem Value="@s">@GetStatusText(s)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect @bind-Value="ViewModel.Entity.CurrencyCode"
                                           Label="Valuta"
                                           Variant="Variant.Outlined"
                                           Class="ef-select"
                                           Disabled="@(!ViewModel.IsNewEntity)"
                                           HelperText="@(ViewModel.IsNewEntity ? "Seleziona la valuta del cassetto." : "La valuta non è modificabile dopo la creazione.")"
                                           @bind-Value:after="HandleEntityChanged">
                                    <MudSelectItem Value="@("EUR")">🇪🇺 EUR — Euro</MudSelectItem>
                                    <MudSelectItem Value="@("USD")">🇺🇸 USD — Dollaro USA</MudSelectItem>
                                    <MudSelectItem Value="@("GBP")">🇬🇧 GBP — Sterlina</MudSelectItem>
                                    <MudSelectItem Value="@("JPY")">🇯🇵 JPY — Yen</MudSelectItem>
                                    <MudSelectItem Value="@("CNY")">🇨🇳 CNY — Yuan</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField @bind-Value="ViewModel.Entity.OpeningBalance"
                                                 Label="Fondo Cassa Iniziale"
                                                 Min="0"
                                                 Format="N2"
                                                 Variant="Variant.Outlined"
                                                 Disabled="@(!ViewModel.IsNewEntity)"
                                                 HelperText="@(ViewModel.IsNewEntity ? "Il fondo cassa iniziale è impostabile solo alla creazione." : "Non modificabile dopo la creazione.")"
                                                 @bind-Value:after="HandleEntityChanged"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="ViewModel.Entity.Notes"
                                              Label="Note"
                                              MaxLength="200"
                                              Variant="Variant.Outlined"
                                              Class="ef-input"
                                              Lines="2"
                                              @bind-Value:after="HandleEntityChanged"
                    Margin="Margin.Dense"/>
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                </MudTabPanel>

                @* ─── Tab 2: Assegnazione ──────────────────────────────── *@
                <MudTabPanel Text="Assegnazione" Icon="@Icons.Material.Outlined.LinkOff">
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                        @if (ViewModel.Entity.AssignmentType == FiscalDrawerAssignmentType.Fixed)
                        {
                            <span>Il cassetto è <strong>fisso</strong>: associalo ad un punto cassa (POS).</span>
                        }
                        else
                        {
                            <span>Il cassetto è <strong>flottante</strong>: associalo ad un operatore di cassa.</span>
                        }
                    </MudText>

                    @if (ViewModel.Entity.AssignmentType == FiscalDrawerAssignmentType.Fixed)
                    {
                        <MudSelect @bind-Value="ViewModel.Entity.PosId"
                                   Label="Punto Cassa (POS)"
                                   Variant="Variant.Outlined"
                                   Class="ef-select"
                                   @bind-Value:after="HandleEntityChanged"
                                   HelperText="Seleziona il POS a cui questo cassetto è fisicamente associato.">
                            <MudSelectItem Value="@((Guid?)null)">— Nessuno —</MudSelectItem>
                            @foreach (var pos in ViewModel.AvailablePos)
                            {
                                <MudSelectItem Value="@((Guid?)pos.Id)">@pos.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        <MudSelect @bind-Value="ViewModel.Entity.OperatorId"
                                   Label="Operatore di Cassa"
                                   Variant="Variant.Outlined"
                                   Class="ef-select"
                                   @bind-Value:after="HandleEntityChanged"
                                   HelperText="Seleziona l'operatore a cui questo cassetto è personalmente assegnato.">
                            <MudSelectItem Value="@((Guid?)null)">— Nessuno —</MudSelectItem>
                            @foreach (var op in ViewModel.AvailableOperators)
                            {
                                <MudSelectItem Value="@((Guid?)op.Id)">@op.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }

                    @if (!ViewModel.IsNewEntity)
                    {
                        <MudDivider Class="my-4" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Riepilogo Saldi</MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="4">
                                <MudPaper Class="pa-3" Elevation="0" Style="background: var(--mud-palette-background-grey);">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Fondo cassa iniziale</MudText>
                                    <MudText Typo="Typo.h6">@FormatBalance(ViewModel.Entity.OpeningBalance)</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudPaper Class="pa-3" Elevation="0" Style="background: var(--mud-palette-background-grey);">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Saldo attuale</MudText>
                                    <MudText Typo="Typo.h6"  Class="fw-bold">@FormatBalance(ViewModel.Entity.CurrentBalance)</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudPaper Class="pa-3" Elevation="0" Style="background: var(--mud-palette-background-grey);">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Sessione</MudText>
                                    @if (ViewModel.Entity.HasOpenSession)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Outlined.LockOpen">Aperta</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.Lock">Chiusa</MudChip>
                                    }
                                </MudPaper>
                            </MudItem>
                        </MudGrid>
                    }
                </MudTabPanel>

                @* ─── Tab 3: Tagli Valuta ──────────────────────────────── *@
                @if (!ViewModel.IsNewEntity)
                {
                    <MudTabPanel Text="Tagli Valuta" Icon="@Icons.Material.Outlined.Money">
                        <div class="d-flex align-center justify-space-between mb-3 flex-wrap gap-2">
                            <div>
                                <MudText Typo="Typo.body2">
                                    Configura le quantità di banconote e monete presenti nel cassetto.
                                    Questo permette il calcolo ottimizzato del resto.
                                </MudText>
                            </div>
                            <MudButton Size="Size.Small"
                                       StartIcon="@Icons.Material.Outlined.Refresh"
                                       Variant="Variant.Outlined"
                                       OnClick="InitializeDenominationsAsync"
                                       Disabled="@_initializingDenominations">
                                @if (_initializingDenominations)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                }
                                Inizializza tagli @ViewModel.Entity.CurrencyCode
                            </MudButton>
                        </div>

                        @if (ViewModel.CashDenominations.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-3">
                                Nessun taglio configurato. Usa il pulsante "Inizializza" per caricare i tagli standard per <strong>@ViewModel.Entity.CurrencyCode</strong>.
                            </MudAlert>
                        }
                        else
                        {
                            <MudSimpleTable Dense="true" Hover="true" Class="mb-3">
                                <thead>
                                    <tr>
                                        <th>Tipo</th>
                                        <th>Valore</th>
                                        <th style="width:140px;">Quantità</th>
                                        <th>Totale</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var denom in ViewModel.CashDenominations)
                                    {
                                        <tr>
                                            <td>
                                                <MudChip T="string" Size="Size.Small"
                                                         Icon="@(denom.DenominationType == DenominationType.Banknote ? Icons.Material.Outlined.Money : Icons.Material.Outlined.Circle)"
                                                         Variant="Variant.Outlined">
                                                    @(denom.DenominationType == DenominationType.Banknote ? "Banconota" : "Moneta")
                                                </MudChip>
                                            </td>
                                            <td><strong>@($"{ViewModel.Entity.CurrencyCode} {denom.Value:G}")</strong></td>
                                            <td>
                                                <MudNumericField Value="@denom.Quantity"
                                                                 ValueChanged="@((int qty) => UpdateDenominationAsync(denom.Id, qty))"
                                                                 T="int" Min="0" Max="9999"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Style="width:100px;" />
                                            </td>
                                            <td>@($"{ViewModel.Entity.CurrencyCode} {denom.TotalValue:N2}")</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>

                            <MudPaper Class="pa-3" Elevation="0" Style="background: var(--mud-palette-background-grey);">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">
                                        <strong>Totale contante contato:</strong>
                                    </MudText>
                                    <MudText Typo="Typo.h6"  Class="fw-bold">
                                        @FormatBalance(ViewModel.CashDenominations.Sum(d => d.TotalValue))
                                    </MudText>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudTabPanel>
                }

                @* ─── Tab 4: Audit ─────────────────────────────────────── *@
                @if (!ViewModel.IsNewEntity)
                {
                    <MudTabPanel Text="Audit" Icon="@Icons.Material.Outlined.History">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@ViewModel.Entity.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                              Label="@TranslationService.GetTranslation("field.createdAt", "Creato il")"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              Class="ef-input"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@(ViewModel.Entity.CreatedBy ?? "-")"
                                              Label="@TranslationService.GetTranslation("field.createdBy", "Creato da")"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              Class="ef-input"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@(ViewModel.Entity.ModifiedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")"
                                              Label="@TranslationService.GetTranslation("field.modifiedAt", "Modificato il")"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              Class="ef-input"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField Value="@(ViewModel.Entity.ModifiedBy ?? "-")"
                                              Label="@TranslationService.GetTranslation("field.modifiedBy", "Modificato da")"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              Class="ef-input"
                    Margin="Margin.Dense"/>
                            </MudItem>
                        </MudGrid>
                    </MudTabPanel>
                }

            </MudTabs>
        }
    </ChildContent>
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Variant="Variant.Text"
                   Disabled="@ViewModel.IsSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </MudButton>
        <MudButton OnClick="SaveAsync"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(ViewModel.IsLoading || ViewModel.IsSaving || ViewModel.Entity == null)">
            @TranslationService.GetTranslation("common.save", "Salva")
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? EntityId { get; set; }

    private MudForm? _form;
    private bool _initializingDenominations;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ViewModel.StateChanged += OnViewModelStateChanged;
            await ViewModel.LoadEntityAsync(EntityId ?? Guid.Empty);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in FiscalDrawerDetailDialog.OnInitializedAsync.");
            AppNotification.ShowWarning("Si è verificato un errore nel caricamento del cassetto fiscale.");
        }
    }

    private void OnAssignmentTypeChanged()
    {
        if (ViewModel.Entity is null) return;
        ViewModel.Entity.PosId = null;
        ViewModel.Entity.OperatorId = null;
        HandleEntityChanged();
    }

    private void HandleEntityChanged() => ViewModel.NotifyEntityChanged();

    private async Task InitializeDenominationsAsync()
    {
        _initializingDenominations = true;
        try
        {
            var ok = await ViewModel.InitializeDenominationsAsync();
            if (ok)
                AppNotification.ShowSuccess($"Tagli {ViewModel.Entity?.CurrencyCode} inizializzati.");
            else
                AppNotification.ShowError("Errore nell'inizializzazione dei tagli.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing denominations.");
            AppNotification.ShowWarning("Si è verificato un errore nell'inizializzazione dei tagli.");
        }
        finally
        {
            _initializingDenominations = false;
        }
    }

    private async Task UpdateDenominationAsync(Guid denominationId, int quantity)
    {
        try
        {
            await ViewModel.UpdateDenominationQuantityAsync(denominationId, quantity);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating denomination {DenominationId} quantity.", denominationId);
            AppNotification.ShowWarning("Si è verificato un errore nell'aggiornamento della denominazione.");
        }
    }

    private async Task SaveAsync()
    {
        if (_form != null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid) return;
        }

        try
        {
            var success = await ViewModel.SaveEntityAsync();
            if (success)
                MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving fiscal drawer.");
            AppNotification.ShowWarning("Si è verificato un errore nel salvataggio.");
        }
    }

    private async Task Cancel()
    {
        if (ViewModel.HasUnsavedChanges())
        {
            var result = await DialogService.ShowMessageBoxAsync(
                TranslationService.GetTranslation("common.confirm", "Conferma"),
                TranslationService.GetTranslation("common.unsavedChangesConfirm", "Ci sono modifiche non salvate. Vuoi salvare prima di uscire?"),
                yesText: TranslationService.GetTranslation("common.save", "Salva"),
                noText: TranslationService.GetTranslation("common.discard", "Non salvare"),
                cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
            if (result == null) return;
            if (result == true) { await SaveAsync(); return; }
        }
        MudDialog.Close();
    }

    private void OnViewModelStateChanged() => InvokeAsync(StateHasChanged);

    private static Color GetStatusColor(FiscalDrawerStatus status) => status switch
    {
        FiscalDrawerStatus.Active    => Color.Success,
        FiscalDrawerStatus.Suspended => Color.Warning,
        FiscalDrawerStatus.Closed    => Color.Default,
        _                            => Color.Default
    };

    private static string GetStatusText(FiscalDrawerStatus status) => status switch
    {
        FiscalDrawerStatus.Active    => "Attivo",
        FiscalDrawerStatus.Suspended => "Sospeso",
        FiscalDrawerStatus.Closed    => "Chiuso",
        _                            => status.ToString()
    };

    public void Dispose() => ViewModel.StateChanged -= OnViewModelStateChanged;

    private string FormatBalance(decimal amount)
    {
        var currency = ViewModel.Entity?.CurrencyCode ?? "EUR";
        return $"{currency} {amount:N2}";
    }
}
