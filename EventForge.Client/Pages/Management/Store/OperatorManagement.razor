@page "/store/operators"
@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.Store
@using EventForge.Client.Shared.Components.Dialogs
@attribute [Authorize]
@inject EventForge.Client.Services.Store.IStoreUserService StoreUserService
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject ILogger<OperatorManagement> Logger
@inject IAppNotificationService AppNotification

<PageTitle>@TranslationService.GetTranslation("store.operatorsList", "Operatori")</PageTitle>
<EntityManagementPage TEntity="StoreUserDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      OnCreateOverride="@(() => OpenDetailDialogAsync(null))"
                      OnEditOverride="@(id => OpenDetailDialogAsync(id))">
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Name")
            {
                <EFTableColumnHeader TItem="StoreUserDto" PropertyName="Name">
                    <MudTableSortLabel SortBy="@(new Func<StoreUserDto, object>(x => x.Name))">@TranslationService.GetTranslation("field.name", "Nome")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Username")
            {
                <EFTableColumnHeader TItem="StoreUserDto" PropertyName="Username">
                    <MudTableSortLabel SortBy="@(new Func<StoreUserDto, object>(x => x.Username))">@TranslationService.GetTranslation("field.username", "Username")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Email")
            {
                <EFTableColumnHeader TItem="StoreUserDto" PropertyName="Email">
                    <MudTableSortLabel SortBy="@(new Func<StoreUserDto, object>(x => x.Email ?? string.Empty))">@TranslationService.GetTranslation("field.email", "Email")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Role")
            {
                <EFTableColumnHeader TItem="StoreUserDto" PropertyName="Role">
                    <MudTableSortLabel SortBy="@(new Func<StoreUserDto, object>(x => x.Role ?? string.Empty))">@TranslationService.GetTranslation("field.role", "Ruolo")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Status")
            {
                <EFTableColumnHeader TItem="StoreUserDto" PropertyName="Status">
                    <MudTableSortLabel SortBy="@(new Func<StoreUserDto, object>(x => x.Status))">@TranslationService.GetTranslation("field.status", "Status")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "CashierGroupName")
            {
                <EFTableColumnHeader TItem="StoreUserDto" PropertyName="CashierGroupName">
                    <MudTableSortLabel SortBy="@(new Func<StoreUserDto, object>(x => x.CashierGroupName ?? string.Empty))">@TranslationService.GetTranslation("field.group", "Gruppo")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "IsOnShift")
            {
                <EFTableColumnHeader TItem="StoreUserDto" PropertyName="IsOnShift">
                    <MudTableSortLabel SortBy="@(new Func<StoreUserDto, object>(x => x.IsOnShift))">@TranslationService.GetTranslation("field.isOnShift", "In Turno")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center" Style="min-width:120px;">@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Name")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.name", "Nome")">
                    <div class="d-flex align-center">
                        <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2">
                            <MudIcon Icon="@Icons.Material.Outlined.Person" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2">@ctx.Item.Name</MudText>
                        </div>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "Username")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.username", "Username")">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@ctx.Item.Username</MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "Email")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.email", "Email")">
                    <MudText Typo="Typo.body2">@(string.IsNullOrEmpty(ctx.Item.Email) ? "-" : ctx.Item.Email)</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Role")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.role", "Ruolo")">
                    <MudText Typo="Typo.body2">@(string.IsNullOrEmpty(ctx.Item.Role) ? "-" : ctx.Item.Role)</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Status")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.status", "Status")">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(ctx.Item.Status)">@GetStatusText(ctx.Item.Status)</MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "CashierGroupName")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.group", "Gruppo")">
                    <MudText Typo="Typo.body2">@(string.IsNullOrEmpty(ctx.Item.CashierGroupName) ? "-" : ctx.Item.CashierGroupName)</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "IsOnShift")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.isOnShift", "In Turno")">
                    <MudChip T="string" Size="Size.Small" Color="@(ctx.Item.IsOnShift ? Color.Success : Color.Default)" Icon="@(ctx.Item.IsOnShift ? Icons.Material.Outlined.CheckCircle : Icons.Material.Outlined.Circle)">
                        @(ctx.Item.IsOnShift ? "In Turno" : "Fuori Turno")
                    </MudChip>
                </MudTd>
            }
        }
    </RowTemplate>
</EntityManagementPage>

@code {
    private EntityManagementPage<StoreUserDto>? _entityPage;
    private IEntityManagementService<StoreUserDto> _service = null!;
    private EntityManagementConfig<StoreUserDto> _config = null!;

    protected override void OnInitialized()
    {
        _service = new OperatorManagementService(StoreUserService);
        _config = new EntityManagementConfig<StoreUserDto>
        {
            ComponentKey = "OperatorManagement",
            PageTitleKey = "store.operatorsList",
            PageTitleDefault = "Operatori",
            EntityIcon = Icons.Material.Outlined.Person,
            PageRootCssClass = "management-page-root",
            BaseRoute = "/store/operators",
            ExcelFileName = "Operatori",
            SearchPlaceholderKey = "common.search",
            SearchPlaceholderDefault = "Cerca",
            CreateTooltip = "store.createNewOperator",
            EntityTypeName = "StoreUser",
            ShowToggleStatus = false,
            ShowAuditLog = false,
            GetDisplayName = o => o.Name,
            GetId = o => o.Id,
            DeleteConfirmMessageKey = "store.confirmDeleteOperator",
            BulkDeleteConfirmMessageKey = "store.confirmDeleteMultipleOperators",
            DeleteSuccessMessageKey = "store.operatorDeleted",
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Configurazione Store", null, disabled: true),
                new BreadcrumbItem("Operatori", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Name", DisplayName = "Nome", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "Username", DisplayName = "Username", IsVisible = true, Order = 1, IsSearchable = true },
                new() { PropertyName = "Email", DisplayName = "Email", IsVisible = true, Order = 2, IsSearchable = true },
                new() { PropertyName = "Role", DisplayName = "Ruolo", IsVisible = true, Order = 3, IsSearchable = true },
                new() { PropertyName = "Status", DisplayName = "Status", IsVisible = true, Order = 4, IsSearchable = false },
                new() { PropertyName = "CashierGroupName", DisplayName = "Gruppo", IsVisible = true, Order = 5, IsSearchable = true },
                new() { PropertyName = "IsOnShift", DisplayName = "In Turno", IsVisible = true, Order = 6, IsSearchable = false }
            },
            QuickFilters = new()
            {
                new() { Id = "all", Label = "Tutti", Predicate = _ => true, Description = "Mostra tutti gli operatori" },
                new() { Id = "active", Label = "Attivi", Predicate = o => o.Status == CashierStatus.Active, Color = Color.Success, Icon = Icons.Material.Outlined.CheckCircle, Description = "Operatori attivi" },
                new() { Id = "onshift", Label = "In Turno", Predicate = o => o.IsOnShift, Color = Color.Primary, Icon = Icons.Material.Outlined.WorkHistory, Description = "Operatori in turno" },
                new() { Id = "recent", Label = "Recenti", Predicate = o => o.CreatedAt >= DateTime.UtcNow.AddDays(-30), Color = Color.Info, Icon = Icons.Material.Outlined.NewReleases, Description = "Operatori creati negli ultimi 30 giorni" }
            }
        };
    }

    private Color GetStatusColor(CashierStatus status) => status switch
    {
        CashierStatus.Active => Color.Success,
        CashierStatus.Suspended => Color.Warning,
        CashierStatus.Deleted => Color.Error,
        _ => Color.Default
    };

    private string GetStatusText(CashierStatus status) => status switch
    {
        CashierStatus.Active => TranslationService.GetTranslation("status.active", "Attivo"),
        CashierStatus.Suspended => TranslationService.GetTranslation("status.suspended", "Sospeso"),
        CashierStatus.Deleted => TranslationService.GetTranslation("status.deleted", "Eliminato"),
        _ => status.ToString()
    };

    private async Task OpenDetailDialogAsync(Guid? id)
    {
        try
        {
            var parameters = new DialogParameters { [nameof(OperatorDetailDialog.EntityId)] = id };
            var dialog = await DialogService.ShowAsync<OperatorDetailDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await (_entityPage?.RefreshAsync() ?? Task.CompletedTask);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening operator detail dialog for ID {Id}.", id);
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }
}
