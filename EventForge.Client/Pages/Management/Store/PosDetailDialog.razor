@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.Store
@using EventForge.DTOs.Station
@using EventForge.DTOs.Common
@using EventForge.DTOs.PaymentTerminal
@using EventForge.Client.Shared.Components
@using EventForge.Client.Shared.Components.Dialogs
@using EventForge.Client.ViewModels
@using EventForge.Client.Services.Station
@using EventForge.Client.Services.Store
@attribute [Authorize]
@inject PosDetailViewModel ViewModel
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<PosDetailDialog> Logger
@inject IStationService StationService
@inject IStoreUserGroupService UserGroupService
@inject IAppNotificationService AppNotification
@inject IPaymentTerminalService PaymentTerminalService
@implements IDisposable

<EFDialog Icon="@Icons.Material.Outlined.PointOfSale"
          Title="@(ViewModel.IsNewEntity ? TranslationService.GetTranslation("store.newPos", "Nuovo Punto Cassa") : (ViewModel.Entity?.Name ?? string.Empty))"
          IsProcessing="@(ViewModel.IsLoading || ViewModel.IsSaving)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <ChildContent>
        @if (ViewModel.IsLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (!ViewModel.IsNewEntity && ViewModel.Entity == null)
        {
            <MudAlert Severity="Severity.Error">
                @TranslationService.GetTranslation("store.posNotFound", "Punto cassa non trovato")
            </MudAlert>
        }
        else if (ViewModel.Entity != null)
        {
            <MudTabs Elevation="0" Rounded="false" PanelClass="pa-4" Class="ef-tabs" ApplyEffectsToContainer="true">

                @* ─── Tab 1: Generale ─────────────────────────────────── *@
                <MudTabPanel Text="Generale" Icon="@Icons.Material.Outlined.Info">
                    @if (!ViewModel.IsNewEntity)
                    {
                        <div class="d-flex align-center gap-4 flex-wrap mb-3">
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Color="Color.Primary" Size="Size.Medium">
                                    <MudIcon Icon="@Icons.Material.Outlined.PointOfSale" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.body1" Class="fw-semibold">@ViewModel.Entity.Name</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        ID: @ViewModel.Entity.Id.ToString()[..8]...
                                    </MudText>
                                </div>
                            </div>
                            <MudChip T="string" Size="Size.Medium" Color="GetStatusColor(ViewModel.Entity.Status)">
                                @GetStatusText(ViewModel.Entity.Status)
                            </MudChip>
                        </div>
                        <MudDivider Class="mb-3" />
                    }

                    <MudForm @ref="_form" Model="@ViewModel.Entity">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.Name"
                                               Label="@TranslationService.GetTranslation("field.name", "Nome")"
                                               Required="true"
                                               RequiredError="Il nome è obbligatorio."
                                               MaxLength="50"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <PrymSelect @bind-Value="ViewModel.Entity.Status"
                                            Label="@TranslationService.GetTranslation("field.status", "Status")"
                                            @bind-Value:after="HandleEntityChanged">
                                    @foreach (CashRegisterStatus status in Enum.GetValues(typeof(CashRegisterStatus)))
                                    {
                                        <MudSelectItem Value="@status">@GetStatusText(status)</MudSelectItem>
                                    }
                                </PrymSelect>
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.Location"
                                               Label="@TranslationService.GetTranslation("field.location", "Location")"
                                               MaxLength="100"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.TerminalIdentifier"
                                               Label="@TranslationService.GetTranslation("field.terminalIdentifier", "Identificatore Terminale")"
                                               MaxLength="100"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.IPAddress"
                                               Label="@TranslationService.GetTranslation("field.ipAddress", "Indirizzo IP")"
                                               MaxLength="45"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.CurrencyCode"
                                               Label="@TranslationService.GetTranslation("field.currencyCode", "Codice Valuta")"
                                               MaxLength="3"
                                               Placeholder="EUR"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.TimeZone"
                                               Label="@TranslationService.GetTranslation("field.timeZone", "Fuso Orario")"
                                               MaxLength="50"
                                               Placeholder="Europe/Rome"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <PrymNullableNumericField T="decimal" @bind-Value="ViewModel.Entity.LocationLatitude"
                                                          Label="@TranslationService.GetTranslation("field.locationLatitude", "Latitudine")"
                                                          Min="-90"
                                                          Max="90"
                                                          @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <PrymNullableNumericField T="decimal" @bind-Value="ViewModel.Entity.LocationLongitude"
                                                          Label="@TranslationService.GetTranslation("field.locationLongitude", "Longitudine")"
                                                          Min="-180"
                                                          Max="180"
                                                          @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12">
                                <PrymTextField @bind-Value="ViewModel.Entity.Description"
                                               Label="@TranslationService.GetTranslation("field.description", "Descrizione")"
                                               Lines="2"
                                               MaxLength="200"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12">
                                <PrymTextField @bind-Value="ViewModel.Entity.Notes"
                                               Label="@TranslationService.GetTranslation("field.notes", "Note")"
                                               Lines="2"
                                               MaxLength="200"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                </MudTabPanel>

                @* ─── Tab 2: Stampante ────────────────────────────────── *@
                <MudTabPanel Text="Stampante" Icon="@Icons.Material.Outlined.Print">
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                        Seleziona la stampante fiscale predefinita per questo punto cassa. Puoi scegliere tra quelle esistenti o crearne una nuova.
                    </MudText>

                    @if (_loadingPrinters)
                    {
                        <div class="d-flex justify-center pa-4">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                        </div>
                    }
                    else
                    {
                        @* Selected printer summary *@
                        @if (ViewModel.Entity.DefaultFiscalPrinterId.HasValue)
                        {
                            var selectedPrinter = _availablePrinters.FirstOrDefault(p => p.Id == ViewModel.Entity.DefaultFiscalPrinterId);
                            <MudAlert Severity="Severity.Success" Class="mb-4" Icon="@Icons.Material.Outlined.CheckCircle">
                                <div class="d-flex align-center justify-space-between flex-wrap gap-2">
                                    <div>
                                        <strong>@(selectedPrinter?.Name ?? "Stampante selezionata")</strong>
                                        @if (selectedPrinter != null)
                                        {
                                            <MudText Typo="Typo.caption" Class="d-block">
                                                @selectedPrinter.Type
                                                @if (!string.IsNullOrEmpty(selectedPrinter.Location)) { <text> · @selectedPrinter.Location</text> }
                                                @if (!string.IsNullOrEmpty(selectedPrinter.Address)) { <text> · @selectedPrinter.Address</text> }
                                            </MudText>
                                        }
                                    </div>
                                    <div class="d-flex gap-2">
                                        @if (selectedPrinter != null)
                                        {
                                            <MudChip T="string" Size="Size.Small"
                                                     Color="@(selectedPrinter.Status == PrinterConfigurationStatus.Active ? Color.Success : Color.Warning)">
                                                @(selectedPrinter.Status == PrinterConfigurationStatus.Active ? "Attiva" : "Disabilitata")
                                            </MudChip>
                                        }
                                        <MudIconButton Icon="@Icons.Material.Outlined.Close"
                                                       Size="Size.Small"
                                                       Title="Rimuovi stampante"
                                                       OnClick="@(() => { ViewModel.Entity.DefaultFiscalPrinterId = null; ViewModel.Entity.DefaultFiscalPrinterName = null; HandleEntityChanged(); })" />
                                    </div>
                                </div>
                            </MudAlert>
                        }

                        @* Printer list *@
                        @if (_availablePrinters.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-4">
                                Nessuna stampante disponibile. Aggiungi una nuova stampante usando il pulsante qui sotto.
                            </MudAlert>
                        }
                        else
                        {
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Stampanti disponibili</MudText>
                            <div class="d-flex flex-column gap-2 mb-4">
                                @foreach (var printer in _availablePrinters)
                                {
                                    var isSelected = ViewModel.Entity.DefaultFiscalPrinterId == printer.Id;
                                    <MudPaper Elevation="0"
                                              Class="@($"pa-3 cursor-pointer {(isSelected ? "mud-theme-primary" : "")}")"
                                              Style="@($"border: 2px solid {(isSelected ? "var(--mud-palette-primary)" : "rgba(255,255,255,0.12)")}; border-radius: 8px; transition: border-color 0.2s;")"
                                              @onclick="@(() => SelectPrinter(printer))">
                                        <div class="d-flex align-center justify-space-between">
                                            <div class="d-flex align-center gap-3">
                                                <MudIcon Icon="@(printer.IsFiscalPrinter ? Icons.Material.Outlined.ReceiptLong : Icons.Material.Outlined.Print)"
                                                         Color="@(isSelected ? Color.Primary : Color.Default)" />
                                                <div>
                                                    <MudText Typo="Typo.body2" Style="@(isSelected ? "font-weight:600;" : "")">@printer.Name</MudText>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                        @printer.Type
                                                        @if (!string.IsNullOrEmpty(printer.Location)) { <text> · @printer.Location</text> }
                                                        @if (!string.IsNullOrEmpty(printer.Address)) { <text> · @printer.Address</text> }
                                                    </MudText>
                                                </div>
                                            </div>
                                            <div class="d-flex align-center gap-2">
                                                <MudChip T="string" Size="Size.Small"
                                                         Color="@(printer.Status == PrinterConfigurationStatus.Active ? Color.Success : Color.Warning)">
                                                    @(printer.Status == PrinterConfigurationStatus.Active ? "Attiva" : "Disabilitata")
                                                </MudChip>
                                                @if (isSelected)
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" Size="Size.Small" />
                                                }
                                            </div>
                                        </div>
                                    </MudPaper>
                                }
                            </div>
                        }

                        <MudDivider Class="mb-3" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Aggiungi nuova stampante al volo</MudText>
                        @if (_showNewPrinterForm)
                        {
                            <MudPaper Class="pa-4 border-dark-sm-r8" Elevation="0">
                                <MudGrid>
                                    <MudItem xs="12" sm="6">
                                        <PrymTextField @bind-Value="_newPrinterName"
                                                       Label="Nome Stampante"
                                                       Required="true"
                                                       RequiredError="Il nome è obbligatorio."
                                                       MaxLength="50" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <PrymTextField @bind-Value="_newPrinterAddress"
                                                       Label="Indirizzo (IP / percorso)"
                                                       MaxLength="100" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <PrymTextField @bind-Value="_newPrinterLocation"
                                                       Label="Posizione"
                                                       MaxLength="50" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <PrymSelect @bind-Value="_newPrinterCategory" Label="Categoria">
                                            <MudSelectItem Value="PrinterCategory.Fiscal">Fiscale</MudSelectItem>
                                            <MudSelectItem Value="PrinterCategory.Receipt">Scontrino</MudSelectItem>
                                            <MudSelectItem Value="PrinterCategory.KDS">KDS</MudSelectItem>
                                            <MudSelectItem Value="PrinterCategory.Label">Etichette</MudSelectItem>
                                            <MudSelectItem Value="PrinterCategory.Report">Report</MudSelectItem>
                                        </PrymSelect>
                                    </MudItem>
                                </MudGrid>
                                <div class="d-flex gap-2 mt-3">
                                    <PrymButton Intent="PrymButton.ButtonIntent.Primary"
                                               StartIcon="@Icons.Material.Outlined.Save"
                                               OnClick="SaveNewPrinterAsync"
                                               Disabled="_savingNewPrinter">
                                        @(_savingNewPrinter ? "Salvataggio..." : "Salva & Seleziona")
                                    </PrymButton>
                                    <PrymButton Intent="PrymButton.ButtonIntent.Ghost"
                                               OnClick="@(() => _showNewPrinterForm = false)">
                                        Annulla
                                    </PrymButton>
                                </div>
                            </MudPaper>
                        }
                        else
                        {
                            <PrymButton Intent="PrymButton.ButtonIntent.Secondary"
                                       StartIcon="@Icons.Material.Outlined.Add"
                                       OnClick="@(() => _showNewPrinterForm = true)">
                                Crea nuova stampante
                            </PrymButton>
                        }
                    }
                </MudTabPanel>

                @* ─── Tab 2b: Terminale POS ─────────────────────────── *@
                <MudTabPanel Text="Terminale POS" Icon="@Icons.Material.Outlined.CreditCard">
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                        Seleziona il terminale di pagamento Protocol 17 predefinito per questo punto cassa.
                    </MudText>

                    @if (_loadingTerminals)
                    {
                        <div class="d-flex justify-center pa-4">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                        </div>
                    }
                    else
                    {
                        @if (ViewModel.Entity!.DefaultPaymentTerminalId.HasValue)
                        {
                            var selectedTerminal = _availableTerminals.FirstOrDefault(t => t.Id == ViewModel.Entity.DefaultPaymentTerminalId);
                            <MudAlert Severity="Severity.Success" Class="mb-4" Icon="@Icons.Material.Outlined.CheckCircle">
                                <div class="d-flex align-center justify-space-between flex-wrap gap-2">
                                    <div>
                                        <strong>@(selectedTerminal?.Name ?? "Terminale selezionato")</strong>
                                        @if (selectedTerminal != null)
                                        {
                                            <MudText Typo="Typo.caption" Class="d-block">
                                                @selectedTerminal.ConnectionType
                                                @if (!string.IsNullOrEmpty(selectedTerminal.IpAddress)) { <text> · @selectedTerminal.IpAddress:@selectedTerminal.Port</text> }
                                            </MudText>
                                        }
                                    </div>
                                    <MudIconButton Icon="@Icons.Material.Outlined.Close"
                                                   Size="Size.Small"
                                                   Title="Rimuovi terminale"
                                                   OnClick="@(() => { ViewModel.Entity.DefaultPaymentTerminalId = null; ViewModel.Entity.DefaultPaymentTerminalName = null; HandleEntityChanged(); })" />
                                </div>
                            </MudAlert>
                        }

                        @if (_availableTerminals.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-4">
                                Nessun terminale POS disponibile. Aggiungine uno dalla sezione "Terminali POS".
                            </MudAlert>
                        }
                        else
                        {
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Terminali disponibili</MudText>
                            <div class="d-flex flex-column gap-2 mb-4">
                                @foreach (var terminal in _availableTerminals)
                                {
                                    var isSelected = ViewModel.Entity!.DefaultPaymentTerminalId == terminal.Id;
                                    <MudPaper Elevation="0"
                                              Class="@($"pa-3 cursor-pointer {(isSelected ? "mud-theme-primary" : "")}")"
                                              Style="@($"border: 2px solid {(isSelected ? "var(--mud-palette-primary)" : "rgba(255,255,255,0.12)")}; border-radius: 8px; transition: border-color 0.2s;")"
                                              @onclick="@(() => SelectTerminal(terminal))">
                                        <div class="d-flex align-center justify-space-between">
                                            <div class="d-flex align-center gap-3">
                                                <MudIcon Icon="@Icons.Material.Outlined.CreditCard"
                                                         Color="@(isSelected ? Color.Primary : Color.Default)" />
                                                <div>
                                                    <MudText Typo="Typo.body2" Style="@(isSelected ? "font-weight:600;" : "")">@terminal.Name</MudText>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                        @terminal.ConnectionType
                                                        @if (!string.IsNullOrEmpty(terminal.IpAddress)) { <text> · @terminal.IpAddress:@terminal.Port</text> }
                                                    </MudText>
                                                </div>
                                            </div>
                                            <div class="d-flex align-center gap-2">
                                                <MudChip T="string" Size="Size.Small"
                                                         Color="@(terminal.IsEnabled ? Color.Success : Color.Default)">
                                                    @(terminal.IsEnabled ? "Abilitato" : "Disabilitato")
                                                </MudChip>
                                                @if (isSelected)
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" Size="Size.Small" />
                                                }
                                            </div>
                                        </div>
                                    </MudPaper>
                                }
                            </div>
                        }
                    }
                </MudTabPanel>

                @* ─── Tab 3: Operatori ────────────────────────────────── *@
                <MudTabPanel Text="Operatori" Icon="@Icons.Material.Outlined.Groups">
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                        Assegna un gruppo di operatori o crea un nuovo gruppo per questo punto cassa.
                    </MudText>

                    @if (_loadingGroups)
                    {
                        <div class="d-flex justify-center pa-4">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                        </div>
                    }
                    else
                    {
                        @* Selected group summary *@
                        @if (ViewModel.Entity.CashierGroupId.HasValue)
                        {
                            var selectedGroup = _availableGroups.FirstOrDefault(g => g.Id == ViewModel.Entity.CashierGroupId);
                            <MudAlert Severity="Severity.Success" Class="mb-4" Icon="@Icons.Material.Outlined.CheckCircle">
                                <div class="d-flex align-center justify-space-between flex-wrap gap-2">
                                    <div>
                                        <strong>@(selectedGroup?.Name ?? "Gruppo selezionato")</strong>
                                        @if (selectedGroup != null && !string.IsNullOrEmpty(selectedGroup.Description))
                                        {
                                            <MudText Typo="Typo.caption" Class="d-block">@selectedGroup.Description</MudText>
                                        }
                                        @if (selectedGroup != null)
                                        {
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                @selectedGroup.CashierCount operatori
                                            </MudText>
                                        }
                                    </div>
                                    <MudIconButton Icon="@Icons.Material.Outlined.Close"
                                                   Size="Size.Small"
                                                   Title="Rimuovi gruppo"
                                                   OnClick="@(() => { ViewModel.Entity.CashierGroupId = null; ViewModel.Entity.CashierGroupName = null; HandleEntityChanged(); })" />
                                </div>
                            </MudAlert>
                        }

                        @* Group list *@
                        @if (_availableGroups.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-4">
                                Nessun gruppo operatori disponibile. Creane uno nuovo usando il modulo qui sotto.
                            </MudAlert>
                        }
                        else
                        {
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Gruppi operatori disponibili</MudText>
                            <div class="d-flex flex-column gap-2 mb-4">
                                @foreach (var group in _availableGroups)
                                {
                                    var isSelected = ViewModel.Entity.CashierGroupId == group.Id;
                                    <MudPaper Elevation="0"
                                              Class="@($"pa-3 cursor-pointer")"
                                              Style="@($"border: 2px solid {(isSelected ? "var(--mud-palette-primary)" : "rgba(255,255,255,0.12)")}; border-radius: 8px; transition: border-color 0.2s;")"
                                              @onclick="@(() => SelectGroup(group))">
                                        <div class="d-flex align-center justify-space-between">
                                            <div class="d-flex align-center gap-3">
                                                <MudIcon Icon="@Icons.Material.Outlined.Groups"
                                                         Color="@(isSelected ? Color.Primary : Color.Default)" />
                                                <div>
                                                    <MudText Typo="Typo.body2" Style="@(isSelected ? "font-weight:600;" : "")">@group.Name</MudText>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                        Codice: @group.Code · @group.CashierCount operatori
                                                        @if (!string.IsNullOrEmpty(group.Description)) { <text> · @group.Description</text> }
                                                    </MudText>
                                                </div>
                                            </div>
                                            <div class="d-flex align-center gap-2">
                                                <MudChip T="string" Size="Size.Small"
                                                         Color="@(group.Status == CashierGroupStatus.Active ? Color.Success : Color.Warning)">
                                                    @(group.Status == CashierGroupStatus.Active ? "Attivo" : "Sospeso")
                                                </MudChip>
                                                @if (group.IsDefault)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                                             Icon="@Icons.Material.Outlined.Star">
                                                        Default
                                                    </MudChip>
                                                }
                                                @if (isSelected)
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" Size="Size.Small" />
                                                }
                                            </div>
                                        </div>
                                    </MudPaper>
                                }
                            </div>
                        }

                        <MudDivider Class="mb-3" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Crea nuovo gruppo al volo</MudText>
                        @if (_showNewGroupForm)
                        {
                            <MudPaper Class="pa-4 border-dark-sm-r8" Elevation="0">
                                <MudGrid>
                                    <MudItem xs="12" sm="6">
                                        <PrymTextField @bind-Value="_newGroupCode"
                                                       Label="Codice Gruppo"
                                                       Required="true"
                                                       RequiredError="Il codice è obbligatorio."
                                                       MaxLength="50" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <PrymTextField @bind-Value="_newGroupName"
                                                       Label="Nome Gruppo"
                                                       Required="true"
                                                       RequiredError="Il nome è obbligatorio."
                                                       MaxLength="50" />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <PrymTextField @bind-Value="_newGroupDescription"
                                                       Label="Descrizione"
                                                       MaxLength="200" />
                                    </MudItem>
                                </MudGrid>
                                <div class="d-flex gap-2 mt-3">
                                    <PrymButton Intent="PrymButton.ButtonIntent.Primary"
                                               StartIcon="@Icons.Material.Outlined.Save"
                                               OnClick="SaveNewGroupAsync"
                                               Disabled="_savingNewGroup">
                                        @(_savingNewGroup ? "Salvataggio..." : "Salva & Seleziona")
                                    </PrymButton>
                                    <PrymButton Intent="PrymButton.ButtonIntent.Ghost"
                                               OnClick="@(() => _showNewGroupForm = false)">
                                        Annulla
                                    </PrymButton>
                                </div>
                            </MudPaper>
                        }
                        else
                        {
                            <PrymButton Intent="PrymButton.ButtonIntent.Secondary"
                                       StartIcon="@Icons.Material.Outlined.Add"
                                       OnClick="@(() => _showNewGroupForm = true)">
                                Crea nuovo gruppo
                            </PrymButton>
                        }
                    }
                </MudTabPanel>

                @* ─── Tab 4: Audit ────────────────────────────────────── *@
                <MudTabPanel Text="Audit" Icon="@Icons.Material.Outlined.History" Disabled="@ViewModel.IsNewEntity">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <PrymTextField Value="@(ViewModel.Entity.Id.ToString())"
                                           Label="@TranslationService.GetTranslation("field.id", "ID")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <PrymTextField Value="@(ViewModel.Entity.CreatedAt.ToString("dd/MM/yyyy HH:mm"))"
                                           Label="@TranslationService.GetTranslation("field.createdAt", "Creato il")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <PrymTextField Value="@(ViewModel.Entity.CreatedBy ?? string.Empty)"
                                           Label="@TranslationService.GetTranslation("field.createdBy", "Creato da")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <PrymTextField Value="@(ViewModel.Entity.ModifiedAt?.ToString("dd/MM/yyyy HH:mm") ?? string.Empty)"
                                           Label="@TranslationService.GetTranslation("field.modifiedAt", "Modificato il")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <PrymTextField Value="@(ViewModel.Entity.ModifiedBy ?? string.Empty)"
                                           Label="@TranslationService.GetTranslation("field.modifiedBy", "Modificato da")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <PrymTextField Value="@(ViewModel.Entity.LastOpenedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")"
                                           Label="Ultima apertura"
                                           ReadOnly="true" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

            </MudTabs>
        }
    </ChildContent>
    <DialogActions>
        <PrymButton Intent="PrymButton.ButtonIntent.Ghost"
                    OnClick="Cancel"
                    Disabled="ViewModel.IsSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </PrymButton>
        <PrymButton Intent="PrymButton.ButtonIntent.Primary"
                    StartIcon="@Icons.Material.Filled.Save"
                    OnClick="SaveAsync"
                    Disabled="ViewModel.IsSaving || ViewModel.IsLoading || ViewModel.Entity == null">
            @TranslationService.GetTranslation("common.save", "Salva")
        </PrymButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? EntityId { get; set; }

    private MudForm? _form;

    // ── Printer tab state ─────────────────────────────────────
    private List<PrinterDto> _availablePrinters = [];
    private bool _loadingPrinters;
    private bool _showNewPrinterForm;
    private bool _savingNewPrinter;
    private string _newPrinterName = string.Empty;
    private string _newPrinterAddress = string.Empty;
    private string _newPrinterLocation = string.Empty;
    private PrinterCategory _newPrinterCategory = PrinterCategory.Receipt;

    private List<PaymentTerminalDto> _availableTerminals = [];
    private bool _loadingTerminals;

    // ── Operator group tab state ──────────────────────────────
    private List<StoreUserGroupDto> _availableGroups = [];
    private bool _loadingGroups;
    private bool _showNewGroupForm;
    private bool _savingNewGroup;
    private string _newGroupCode = string.Empty;
    private string _newGroupName = string.Empty;
    private string _newGroupDescription = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ViewModel.StateChanged += OnViewModelStateChanged;
            await ViewModel.LoadEntityAsync(EntityId ?? Guid.Empty);

            // Load printers and groups in parallel
            await Task.WhenAll(LoadPrintersAsync(), LoadGroupsAsync(), LoadTerminalsAsync());
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing PosDetailDialog.");
        }
    }

    private async Task LoadPrintersAsync()
    {
        _loadingPrinters = true;
        try
        {
            _availablePrinters = await StationService.GetAllPrintersAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error loading printers for POS dialog");
        }
        finally
        {
            _loadingPrinters = false;
        }
    }

    private async Task LoadGroupsAsync()
    {
        _loadingGroups = true;
        try
        {
            _availableGroups = await UserGroupService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error loading operator groups for POS dialog");
        }
        finally
        {
            _loadingGroups = false;
        }
    }

    private async Task LoadTerminalsAsync()
    {
        _loadingTerminals = true;
        try { _availableTerminals = await PaymentTerminalService.GetAllAsync(); }
        catch (Exception ex) { Logger.LogError(ex, "Error loading payment terminals."); }
        finally { _loadingTerminals = false; }
    }

    private void SelectTerminal(PaymentTerminalDto terminal)
    {
        ViewModel.Entity!.DefaultPaymentTerminalId = terminal.Id;
        ViewModel.Entity.DefaultPaymentTerminalName = terminal.Name;
        HandleEntityChanged();
    }

    private void SelectPrinter(PrinterDto printer)
    {
        if (ViewModel.Entity == null) return;
        ViewModel.Entity.DefaultFiscalPrinterId = printer.Id;
        ViewModel.Entity.DefaultFiscalPrinterName = printer.Name;
        HandleEntityChanged();
    }

    private void SelectGroup(StoreUserGroupDto group)
    {
        if (ViewModel.Entity == null) return;
        ViewModel.Entity.CashierGroupId = group.Id;
        ViewModel.Entity.CashierGroupName = group.Name;
        HandleEntityChanged();
    }

    private async Task SaveNewPrinterAsync()
    {
        if (string.IsNullOrWhiteSpace(_newPrinterName)) return;

        _savingNewPrinter = true;
        try
        {
            var dto = new CreatePrinterDto
            {
                Name = _newPrinterName,
                Type = _newPrinterCategory.ToString(),
                Address = _newPrinterAddress.Trim().Length > 0 ? _newPrinterAddress.Trim() : null,
                Location = _newPrinterLocation.Trim().Length > 0 ? _newPrinterLocation.Trim() : null,
                Category = _newPrinterCategory,
                Status = PrinterConfigurationStatus.Active,
                IsFiscalPrinter = _newPrinterCategory == PrinterCategory.Fiscal
            };

            var created = await StationService.CreatePrinterAsync(dto);
            if (created != null)
            {
                _availablePrinters.Add(created);
                SelectPrinter(created);
                _showNewPrinterForm = false;
                _newPrinterName = string.Empty;
                _newPrinterAddress = string.Empty;
                _newPrinterLocation = string.Empty;
                _newPrinterCategory = PrinterCategory.Receipt;
                AppNotification.ShowSuccess("Stampante creata e selezionata.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating printer");
            AppNotification.ShowError("Errore nella creazione della stampante.", exception: ex);
        }
        finally
        {
            _savingNewPrinter = false;
        }
    }

    private async Task SaveNewGroupAsync()
    {
        if (string.IsNullOrWhiteSpace(_newGroupCode) || string.IsNullOrWhiteSpace(_newGroupName)) return;

        _savingNewGroup = true;
        try
        {
            var dto = new CreateStoreUserGroupDto
            {
                Code = _newGroupCode.Trim(),
                Name = _newGroupName.Trim(),
                Description = _newGroupDescription.Trim().Length > 0 ? _newGroupDescription.Trim() : null,
                Status = CashierGroupStatus.Active
            };

            var created = await UserGroupService.CreateAsync(dto);
            if (created != null)
            {
                _availableGroups.Add(created);
                SelectGroup(created);
                _showNewGroupForm = false;
                _newGroupCode = string.Empty;
                _newGroupName = string.Empty;
                _newGroupDescription = string.Empty;
                AppNotification.ShowSuccess("Gruppo operatori creato e selezionato.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating operator group");
            AppNotification.ShowError("Errore nella creazione del gruppo.", exception: ex);
        }
        finally
        {
            _savingNewGroup = false;
        }
    }

    private void HandleEntityChanged()
    {
        ViewModel.NotifyEntityChanged();
    }

    private async Task SaveAsync()
    {
        if (_form != null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid) return;
        }

        try
        {
            var success = await ViewModel.SaveEntityAsync();
            if (success)
            {
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving POS.");
            AppNotification.ShowWarning("Si è verificato un errore nel salvataggio.");
        }
    }

    private async Task Cancel()
    {
        if (ViewModel.HasUnsavedChanges())
        {
            var result = await DialogService.ShowMessageBoxAsync(
                TranslationService.GetTranslation("common.confirm", "Conferma"),
                TranslationService.GetTranslation("common.unsavedChangesConfirm", "Ci sono modifiche non salvate. Vuoi salvare prima di uscire?"),
                yesText: TranslationService.GetTranslation("common.save", "Salva"),
                noText: TranslationService.GetTranslation("common.discard", "Non salvare"),
                cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
            if (result == null) return;
            if (result == true) { await SaveAsync(); return; }
        }
        MudDialog.Close();
    }

    private void OnViewModelStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private Color GetStatusColor(CashRegisterStatus status) => status switch
    {
        CashRegisterStatus.Active => Color.Success,
        CashRegisterStatus.Suspended => Color.Warning,
        CashRegisterStatus.Maintenance => Color.Info,
        CashRegisterStatus.Disabled => Color.Error,
        _ => Color.Default
    };

    private string GetStatusText(CashRegisterStatus status) => status switch
    {
        CashRegisterStatus.Active => TranslationService.GetTranslation("status.active", "Attivo"),
        CashRegisterStatus.Suspended => TranslationService.GetTranslation("status.suspended", "Sospeso"),
        CashRegisterStatus.Maintenance => TranslationService.GetTranslation("status.maintenance", "Manutenzione"),
        CashRegisterStatus.Disabled => TranslationService.GetTranslation("status.disabled", "Disabilitato"),
        _ => status.ToString()
    };

    public void Dispose()
    {
        ViewModel.StateChanged -= OnViewModelStateChanged;
    }
}
