@page "/store/pos"
@page "/admin/store-pos"
@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.Store
@using EventForge.Client.Shared.Components.Dialogs
@attribute [Authorize]
@inject EventForge.Client.Services.Store.IStorePosService StorePosService
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject ILogger<PosManagement> Logger
@inject IAppNotificationService AppNotification

<PageTitle>@TranslationService.GetTranslation("store.posManagement", "Gestione Punti Cassa")</PageTitle>
<EntityManagementPage TEntity="StorePosDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      OnCreateOverride="@(() => OpenDetailDialogAsync(null))"
                      OnEditOverride="@(id => OpenDetailDialogAsync(id))">
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Name")
            {
                <EFTableColumnHeader TItem="StorePosDto" PropertyName="Name">
                    <MudTableSortLabel SortBy="@(new Func<StorePosDto, object>(x => x.Name))">@TranslationService.GetTranslation("field.name", "Nome")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Location")
            {
                <EFTableColumnHeader TItem="StorePosDto" PropertyName="Location">
                    <MudTableSortLabel SortBy="@(new Func<StorePosDto, object>(x => x.Location ?? string.Empty))">@TranslationService.GetTranslation("field.location", "Location")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Status")
            {
                <EFTableColumnHeader TItem="StorePosDto" PropertyName="Status">
                    <MudTableSortLabel SortBy="@(new Func<StorePosDto, object>(x => x.Status))">@TranslationService.GetTranslation("field.status", "Status")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "IsOnline")
            {
                <EFTableColumnHeader TItem="StorePosDto" PropertyName="IsOnline">
                    <MudTableSortLabel SortBy="@(new Func<StorePosDto, object>(x => x.IsOnline))">@TranslationService.GetTranslation("field.isOnline", "Online")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "TerminalIdentifier")
            {
                <EFTableColumnHeader TItem="StorePosDto" PropertyName="TerminalIdentifier">
                    <MudTableSortLabel SortBy="@(new Func<StorePosDto, object>(x => x.TerminalIdentifier ?? string.Empty))">@TranslationService.GetTranslation("field.terminalId", "Terminal")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center ef-min-120" >@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Name")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.name", "Nome")">
                    <div class="d-flex align-center">
                        <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2">
                            <MudIcon Icon="@Icons.Material.Outlined.PointOfSale" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2">@ctx.Item.Name</MudText>
                        </div>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "Location")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.location", "Location")">
                    <MudText Typo="Typo.body2">@(string.IsNullOrEmpty(ctx.Item.Location) ? "-" : ctx.Item.Location)</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Status")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.status", "Status")">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(ctx.Item.Status)">@GetStatusText(ctx.Item.Status)</MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "IsOnline")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.isOnline", "Online")">
                    <MudChip T="string" Size="Size.Small" Color="@(ctx.Item.IsOnline ? Color.Success : Color.Default)" Icon="@(ctx.Item.IsOnline ? Icons.Material.Outlined.CheckCircle : Icons.Material.Outlined.Circle)">
                        @(ctx.Item.IsOnline ? "Online" : "Offline")
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "TerminalIdentifier")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.terminalId", "Terminal")">
                    <MudText Typo="Typo.body2">@(string.IsNullOrEmpty(ctx.Item.TerminalIdentifier) ? "-" : ctx.Item.TerminalIdentifier)</MudText>
                </MudTd>
            }
        }
    </RowTemplate>
</EntityManagementPage>

@code {
    private EntityManagementPage<StorePosDto>? _entityPage;
    private IEntityManagementService<StorePosDto> _service = null!;
    private EntityManagementConfig<StorePosDto> _config = null!;

    protected override void OnInitialized()
    {
        _service = new PosManagementService(StorePosService);
        _config = new EntityManagementConfig<StorePosDto>
        {
            ComponentKey = "PosManagement",
            PageTitleKey = "store.posManagement",
            PageTitleDefault = "Gestione Punti Cassa",
            EntityIcon = Icons.Material.Outlined.PointOfSale,
            PageRootCssClass = "management-page-root",
            BaseRoute = "/store/pos",
            ExcelFileName = "PuntiCassa",
            SearchPlaceholderKey = "common.search",
            SearchPlaceholderDefault = "Cerca",
            CreateTooltip = "store.createNewPos",
            EntityTypeName = "StorePos",
            ShowToggleStatus = false,
            ShowAuditLog = false,
            GetDisplayName = p => p.Name,
            GetId = p => p.Id,
            DeleteConfirmMessageKey = "store.confirmDeletePos",
            BulkDeleteConfirmMessageKey = "store.confirmDeleteMultiplePos",
            DeleteSuccessMessageKey = "store.posDeleted",
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Configurazione Store", null, disabled: true),
                new BreadcrumbItem("Punti Cassa", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Name", DisplayName = "Nome", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "Location", DisplayName = "Location", IsVisible = true, Order = 1, IsSearchable = true },
                new() { PropertyName = "Status", DisplayName = "Status", IsVisible = true, Order = 2, IsSearchable = false },
                new() { PropertyName = "IsOnline", DisplayName = "Online", IsVisible = true, Order = 3, IsSearchable = false },
                new() { PropertyName = "TerminalIdentifier", DisplayName = "Terminal", IsVisible = true, Order = 4, IsSearchable = true }
            },
            QuickFilters = new()
            {
                new() { Id = "all", Label = "Tutti", Predicate = _ => true, Description = "Mostra tutti i punti cassa" },
                new() { Id = "active", Label = "Attivi", Predicate = p => p.Status == CashRegisterStatus.Active, Color = Color.Success, Icon = Icons.Material.Outlined.CheckCircle, Description = "Punti cassa attivi" },
                new() { Id = "online", Label = "Online", Predicate = p => p.IsOnline, Color = Color.Primary, Icon = Icons.Material.Outlined.CloudDone, Description = "Punti cassa online" },
                new() { Id = "offline", Label = "Offline", Predicate = p => !p.IsOnline, Color = Color.Warning, Icon = Icons.Material.Outlined.CloudOff, Description = "Punti cassa offline" },
                new() { Id = "recent", Label = "Recenti", Predicate = p => p.CreatedAt >= DateTime.UtcNow.AddDays(-30), Color = Color.Info, Icon = Icons.Material.Outlined.NewReleases, Description = "Punti cassa creati negli ultimi 30 giorni" }
            }
        };
    }

    private Color GetStatusColor(CashRegisterStatus status) => status switch
    {
        CashRegisterStatus.Active => Color.Success,
        CashRegisterStatus.Suspended => Color.Warning,
        CashRegisterStatus.Maintenance => Color.Info,
        CashRegisterStatus.Disabled => Color.Error,
        _ => Color.Default
    };

    private string GetStatusText(CashRegisterStatus status) => status switch
    {
        CashRegisterStatus.Active => TranslationService.GetTranslation("status.active", "Attivo"),
        CashRegisterStatus.Suspended => TranslationService.GetTranslation("status.suspended", "Sospeso"),
        CashRegisterStatus.Maintenance => TranslationService.GetTranslation("status.maintenance", "Manutenzione"),
        CashRegisterStatus.Disabled => TranslationService.GetTranslation("status.disabled", "Disabilitato"),
        _ => status.ToString()
    };

    private async Task OpenDetailDialogAsync(Guid? id)
    {
        try
        {
            var parameters = new DialogParameters { [nameof(PosDetailDialog.EntityId)] = id };
            var dialog = await DialogService.ShowAsync<PosDetailDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await (_entityPage?.RefreshAsync() ?? Task.CompletedTask);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening POS detail dialog for ID {Id}.", id);
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }
}
