@page "/management/printers"
@using Prym.DTOs.Station
@using EventForge.Client.Services.Station
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,StoreManager")]
@inject IStationService StationService
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject ILogger<PrinterManagement> Logger
@inject IAppNotificationService AppNotification

<PageTitle>Stampanti</PageTitle>
<EntityManagementPage TEntity="PrinterDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      OnCreateOverride="@(() => OpenDetailDialogAsync(null))"
                      OnEditOverride="@(id => OpenDetailDialogAsync(id))">
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Name")
            {
                <EFTableColumnHeader TItem="PrinterDto" PropertyName="Name">
                    <MudTableSortLabel SortBy="@(new Func<PrinterDto, object>(x => x.Name))">
                        @TranslationService.GetTranslation("field.name", "Nome")
                    </MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Type")
            {
                <EFTableColumnHeader TItem="PrinterDto" PropertyName="Type">
                    <MudTableSortLabel SortBy="@(new Func<PrinterDto, object>(x => x.Type))">Tipo</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Category")
            {
                <EFTableColumnHeader TItem="PrinterDto" PropertyName="Category">
                    <MudTableSortLabel SortBy="@(new Func<PrinterDto, object>(x => x.Category))">Categoria</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Address")
            {
                <EFTableColumnHeader TItem="PrinterDto" PropertyName="Address">
                    <MudTableSortLabel SortBy="@(new Func<PrinterDto, object>(x => x.Address ?? string.Empty))">Indirizzo</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "ConnectionType")
            {
                <EFTableColumnHeader TItem="PrinterDto" PropertyName="ConnectionType">
                    <MudTableSortLabel SortBy="@(new Func<PrinterDto, object>(x => x.ConnectionType))">Connessione</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Status")
            {
                <EFTableColumnHeader TItem="PrinterDto" PropertyName="Status">
                    <MudTableSortLabel SortBy="@(new Func<PrinterDto, object>(x => x.Status))">
                        @TranslationService.GetTranslation("field.status", "Stato")
                    </MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center ef-min-120" >@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Name")
            {
                <MudTd DataLabel="Nome">
                    <div class="d-flex align-center">
                        <MudAvatar Color="@GetStatusColor(ctx.Item.Status)" Size="Size.Small" Class="mr-2">
                            <MudIcon Icon="@(ctx.Item.IsFiscalPrinter ? Icons.Material.Outlined.ReceiptLong : Icons.Material.Outlined.Print)" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2">@ctx.Item.Name</MudText>
                            @if (!string.IsNullOrEmpty(ctx.Item.Model))
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@ctx.Item.Model</MudText>
                            }
                        </div>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "Type")
            {
                <MudTd DataLabel="Tipo">
                    <MudText Typo="Typo.body2">@ctx.Item.Type</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Category")
            {
                <MudTd DataLabel="Categoria">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Icon="@GetCategoryIcon(ctx.Item.Category)">
                        @GetCategoryText(ctx.Item.Category)
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "Address")
            {
                <MudTd DataLabel="Indirizzo">
                    <MudText Typo="Typo.body2">@(string.IsNullOrEmpty(ctx.Item.Address) ? "-" : ctx.Item.Address)</MudText>
                    @if (ctx.Item.Port.HasValue)
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">porta: @ctx.Item.Port</MudText>
                    }
                </MudTd>
            }
            else if (column.PropertyName == "ConnectionType")
            {
                <MudTd DataLabel="Connessione">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                        @GetConnectionTypeText(ctx.Item.ConnectionType)
                    </MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "Status")
            {
                <MudTd DataLabel="Stato">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(ctx.Item.Status)">
                        @GetStatusText(ctx.Item.Status)
                    </MudChip>
                </MudTd>
            }
        }
    </RowTemplate>
</EntityManagementPage>

@code {
    private EntityManagementPage<PrinterDto>? _entityPage;
    private IEntityManagementService<PrinterDto> _service = null!;
    private EntityManagementConfig<PrinterDto> _config = null!;

    protected override void OnInitialized()
    {
        _service = new PrinterManagementService(StationService);
        _config = new EntityManagementConfig<PrinterDto>
        {
            ComponentKey = "PrinterManagement",
            PageTitleKey = "printer.list",
            PageTitleDefault = "Stampanti",
            EntityIcon = Icons.Material.Outlined.Print,
            PageRootCssClass = "management-page-root",
            BaseRoute = "/management/printers",
            ExcelFileName = "Stampanti",
            SearchPlaceholderKey = "common.search",
            SearchPlaceholderDefault = "Cerca stampante...",
            CreateTooltip = "printer.createNew",
            EntityTypeName = "Printer",
            ShowToggleStatus = false,
            ShowAuditLog = false,
            GetDisplayName = p => p.Name,
            GetId = p => p.Id,
            DeleteConfirmMessageKey = "printer.confirmDelete",
            BulkDeleteConfirmMessageKey = "printer.confirmDeleteMultiple",
            DeleteSuccessMessageKey = "printer.deleted",
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new("Home", "/", icon: Icons.Material.Outlined.Home),
                new("Stampanti & Stazioni", null, disabled: true),
                new("Stampanti", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Name",           DisplayName = "Nome",        IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "Type",           DisplayName = "Tipo",        IsVisible = true, Order = 1, IsSearchable = true },
                new() { PropertyName = "Category",       DisplayName = "Categoria",   IsVisible = true, Order = 2, IsSearchable = false },
                new() { PropertyName = "Address",        DisplayName = "Indirizzo",   IsVisible = true, Order = 3, IsSearchable = true },
                new() { PropertyName = "ConnectionType", DisplayName = "Connessione", IsVisible = true, Order = 4, IsSearchable = false },
                new() { PropertyName = "Status",         DisplayName = "Stato",       IsVisible = true, Order = 5, IsSearchable = false }
            },
            QuickFilters = new()
            {
                new() { Id = "all",     Label = "Tutte",    Predicate = _ => true,                                                                    Description = "Mostra tutte le stampanti" },
                new() { Id = "active",  Label = "Attive",   Predicate = p => p.Status == PrinterConfigurationStatus.Active, Color = Color.Success, Icon = Icons.Material.Outlined.CheckCircle, Description = "Stampanti attive" },
                new() { Id = "fiscal",  Label = "Fiscali",  Predicate = p => p.IsFiscalPrinter,                             Color = Color.Warning, Icon = Icons.Material.Outlined.ReceiptLong, Description = "Solo stampanti fiscali" },
                new() { Id = "thermal", Label = "Termiche", Predicate = p => p.IsThermal,                                                             Description = "Stampanti termiche" },
                new() { Id = "error",   Label = "Errore",   Predicate = p => p.Status == PrinterConfigurationStatus.Error,   Color = Color.Error,   Icon = Icons.Material.Outlined.Error,       Description = "Stampanti in errore" }
            }
        };
    }

    private static Color GetStatusColor(PrinterConfigurationStatus s) => s switch
    {
        PrinterConfigurationStatus.Active      => Color.Success,
        PrinterConfigurationStatus.Offline     => Color.Default,
        PrinterConfigurationStatus.Error       => Color.Error,
        PrinterConfigurationStatus.Maintenance => Color.Warning,
        PrinterConfigurationStatus.Suspended   => Color.Warning,
        _                                       => Color.Default
    };

    private static string GetStatusText(PrinterConfigurationStatus s) => s switch
    {
        PrinterConfigurationStatus.Active      => "Attiva",
        PrinterConfigurationStatus.Offline     => "Offline",
        PrinterConfigurationStatus.Error       => "Errore",
        PrinterConfigurationStatus.Maintenance => "Manutenzione",
        PrinterConfigurationStatus.Suspended   => "Sospesa",
        _                                       => s.ToString()
    };

    private static string GetCategoryText(PrinterCategory c) => c switch
    {
        PrinterCategory.Fiscal  => "Fiscale",
        PrinterCategory.Receipt => "Scontrini",
        PrinterCategory.KDS     => "Cucina",
        PrinterCategory.Label   => "Etichette",
        PrinterCategory.Report  => "Report",
        _                        => c.ToString()
    };

    private static string GetCategoryIcon(PrinterCategory c) => c switch
    {
        PrinterCategory.Fiscal  => Icons.Material.Outlined.ReceiptLong,
        PrinterCategory.Receipt => Icons.Material.Outlined.Receipt,
        PrinterCategory.KDS     => Icons.Material.Outlined.Kitchen,
        PrinterCategory.Label   => Icons.Material.Outlined.Label,
        PrinterCategory.Report  => Icons.Material.Outlined.Description,
        _                        => Icons.Material.Outlined.Print
    };

    private static string GetConnectionTypeText(PrinterConnectionType t) => t switch
    {
        PrinterConnectionType.Tcp          => "TCP",
        PrinterConnectionType.Serial       => "Seriale",
        PrinterConnectionType.UsbViaAgent  => "USB/Agent",
        PrinterConnectionType.NetworkShare => "Rete",
        PrinterConnectionType.TcpViaAgent  => "TCP/Agent",
        _                                   => t.ToString()
    };

    private async Task OpenDetailDialogAsync(Guid? id)
    {
        try
        {
            var parameters = new DialogParameters { [nameof(PrinterDetailDialog.EntityId)] = id };
            var dialog = await DialogService.ShowAsync<PrinterDetailDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await (_entityPage?.RefreshAsync() ?? Task.CompletedTask);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening PrinterDetailDialog for ID {Id}.", id);
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }
}
