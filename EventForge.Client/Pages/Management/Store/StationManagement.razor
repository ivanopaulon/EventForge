@page "/admin/stations"
@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.Station
@using EventForge.DTOs.Common
@using EventForge.Client.Shared.Components.Dialogs
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,StoreManager")]
@inject EventForge.Client.Services.Station.IStationService StationService
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject ILogger<StationManagement> Logger
@inject IAppNotificationService AppNotification

<PageTitle>@TranslationService.GetTranslation("station.list", "Stazioni")</PageTitle>
<EntityManagementPage TEntity="StationDto"
                      @ref="_entityPage"
                      Config="_config"
                      Service="_service"
                      OnCreateOverride="@(() => OpenDetailDialogAsync(null))"
                      OnEditOverride="@(id => OpenDetailDialogAsync(id))">
    <HeaderContent Context="columnConfigurations">
        @foreach (var column in columnConfigurations.Where(c => c.IsVisible).OrderBy(c => c.Order))
        {
            @if (column.PropertyName == "Name")
            {
                <EFTableColumnHeader TItem="StationDto" PropertyName="Name">
                    <MudTableSortLabel SortBy="@(new Func<StationDto, object>(x => x.Name))">@TranslationService.GetTranslation("field.name", "Nome")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "StationType")
            {
                <EFTableColumnHeader TItem="StationDto" PropertyName="StationType">
                    <MudTableSortLabel SortBy="@(new Func<StationDto, object>(x => x.StationType))">@TranslationService.GetTranslation("field.stationType", "Tipo")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Location")
            {
                <EFTableColumnHeader TItem="StationDto" PropertyName="Location">
                    <MudTableSortLabel SortBy="@(new Func<StationDto, object>(x => x.Location ?? string.Empty))">@TranslationService.GetTranslation("field.location", "Posizione")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "Status")
            {
                <EFTableColumnHeader TItem="StationDto" PropertyName="Status">
                    <MudTableSortLabel SortBy="@(new Func<StationDto, object>(x => x.Status))">@TranslationService.GetTranslation("field.status", "Status")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
            else if (column.PropertyName == "PrinterCount")
            {
                <EFTableColumnHeader TItem="StationDto" PropertyName="PrinterCount">
                    <MudTableSortLabel SortBy="@(new Func<StationDto, object>(x => x.PrinterCount))">@TranslationService.GetTranslation("field.printers", "Stampanti")</MudTableSortLabel>
                </EFTableColumnHeader>
            }
        }
        <MudTh Class="text-center" Style="min-width:120px;">@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
    </HeaderContent>

    <RowTemplate Context="ctx">
        @foreach (var column in ctx.Cols)
        {
            @if (column.PropertyName == "Name")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.name", "Nome")">
                    <div class="d-flex align-center">
                        <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2">
                            <MudIcon Icon="@Icons.Material.Outlined.Kitchen" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2">@ctx.Item.Name</MudText>
                        </div>
                    </div>
                </MudTd>
            }
            else if (column.PropertyName == "StationType")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.stationType", "Tipo")">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@ctx.Item.StationType</MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "Location")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.location", "Posizione")">
                    <MudText Typo="Typo.body2">@(string.IsNullOrEmpty(ctx.Item.Location) ? "—" : ctx.Item.Location)</MudText>
                </MudTd>
            }
            else if (column.PropertyName == "Status")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.status", "Status")">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(ctx.Item.Status)">@GetStatusText(ctx.Item.Status)</MudChip>
                </MudTd>
            }
            else if (column.PropertyName == "PrinterCount")
            {
                <MudTd DataLabel="@TranslationService.GetTranslation("field.printers", "Stampanti")">
                    <MudChip T="string" Size="Size.Small" Color="@(ctx.Item.PrinterCount > 0 ? Color.Default : Color.Warning)"
                             Icon="@Icons.Material.Outlined.Print">@ctx.Item.PrinterCount</MudChip>
                </MudTd>
            }
        }
    </RowTemplate>
</EntityManagementPage>

@code {
    private EntityManagementPage<StationDto>? _entityPage;
    private IEntityManagementService<StationDto> _service = null!;
    private EntityManagementConfig<StationDto> _config = null!;

    protected override void OnInitialized()
    {
        _service = new StationManagementService(StationService);
        _config = new EntityManagementConfig<StationDto>
        {
            ComponentKey = "StationManagement",
            PageTitleKey = "station.list",
            PageTitleDefault = "Stazioni",
            EntityIcon = Icons.Material.Outlined.Kitchen,
            PageRootCssClass = "management-page-root",
            BaseRoute = "/admin/stations",
            ExcelFileName = "Stazioni",
            SearchPlaceholderKey = "common.search",
            SearchPlaceholderDefault = "Cerca",
            CreateTooltip = "station.createNew",
            EntityTypeName = "Station",
            ShowToggleStatus = false,
            ShowAuditLog = false,
            GetDisplayName = s => s.Name,
            GetId = s => s.Id,
            DeleteConfirmMessageKey = "station.confirmDelete",
            BulkDeleteConfirmMessageKey = "station.confirmDeleteMultiple",
            DeleteSuccessMessageKey = "station.deleted",
            BreadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
                new BreadcrumbItem("Stampanti & Stazioni", null, disabled: true),
                new BreadcrumbItem("Stazioni", null, disabled: true)
            },
            Columns = new()
            {
                new() { PropertyName = "Name", DisplayName = "Nome", IsVisible = true, Order = 0, IsSearchable = true },
                new() { PropertyName = "StationType", DisplayName = "Tipo", IsVisible = true, Order = 1, IsSearchable = false },
                new() { PropertyName = "Location", DisplayName = "Posizione", IsVisible = true, Order = 2, IsSearchable = true },
                new() { PropertyName = "Status", DisplayName = "Status", IsVisible = true, Order = 3, IsSearchable = false },
                new() { PropertyName = "PrinterCount", DisplayName = "Stampanti", IsVisible = true, Order = 4, IsSearchable = false }
            },
            QuickFilters = new()
            {
                new() { Id = "all", Label = "Tutte", Predicate = _ => true, Description = "Mostra tutte le stazioni" },
                new() { Id = "active", Label = "Attive", Predicate = s => s.Status == StationStatus.Active, Color = Color.Success, Icon = Icons.Material.Outlined.CheckCircle, Description = "Stazioni attive" },
                new() { Id = "kds", Label = "KDS", Predicate = s => s.StationType == StationType.KDS, Color = Color.Info, Icon = Icons.Material.Outlined.Kitchen, Description = "Stazioni KDS" },
                new() { Id = "pos", Label = "POS", Predicate = s => s.StationType == StationType.POS, Color = Color.Primary, Icon = Icons.Material.Outlined.PointOfSale, Description = "Stazioni POS" }
            }
        };
    }

    private Color GetStatusColor(StationStatus status) => status switch
    {
        StationStatus.Active => Color.Success,
        StationStatus.Suspended => Color.Warning,
        StationStatus.Maintenance => Color.Info,
        StationStatus.Disabled => Color.Error,
        _ => Color.Default
    };

    private string GetStatusText(StationStatus status) => status switch
    {
        StationStatus.Active => TranslationService.GetTranslation("status.active", "Attivo"),
        StationStatus.Suspended => TranslationService.GetTranslation("status.suspended", "Sospeso"),
        StationStatus.Maintenance => TranslationService.GetTranslation("status.maintenance", "Manutenzione"),
        StationStatus.Disabled => TranslationService.GetTranslation("status.disabled", "Disabilitato"),
        _ => status.ToString()
    };

    private async Task OpenDetailDialogAsync(Guid? id)
    {
        try
        {
            var parameters = new DialogParameters { [nameof(StationDetailDialog.EntityId)] = id };
            var dialog = await DialogService.ShowAsync<StationDetailDialog>(string.Empty, parameters, EFDialogDefaults.Options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await (_entityPage?.RefreshAsync() ?? Task.CompletedTask);
    
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening StationDetailDialog for ID {Id}.", id);
            AppNotification.ShowWarning("Si è verificato un errore nell'apertura del dialogo.");
        }
    }
}
