@page "/store/fiscal-drawers"
@page "/management/fiscal-drawers"
@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.Store
@using EventForge.Client.Services.Store
@attribute [Authorize]
@inject IFiscalDrawerService FiscalDrawerService
@inject IStorePosService StorePosService
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject IAppNotificationService AppNotification
@inject NavigationManager NavigationManager

<PageTitle>@TranslationService.GetTranslation("store.fiscalDrawers", "Cassetti Fiscali")</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <div class="d-flex align-center justify-space-between mb-4 flex-wrap gap-2">
        <div class="d-flex align-center gap-3">
            <MudIcon Icon="@Icons.Material.Outlined.Inbox" Size="Size.Large" Color="Color.Primary" />
            <div>
                <MudText Typo="Typo.h5">@TranslationService.GetTranslation("store.fiscalDrawers", "Cassetti Fiscali")</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @TranslationService.GetTranslation("store.fiscalDrawersDesc", "Gestione cassetti fiscali e fondi cassa")
                </MudText>
            </div>
        </div>
        <div class="d-flex gap-2">
            <MudButton StartIcon="@Icons.Material.Outlined.BarChart" Variant="Variant.Outlined" Color="Color.Info"
                       Href="/sales/dashboard">
                Dashboard Vendite
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Outlined.Add" Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="@(() => OpenDetailDialogAsync(null))">
                @TranslationService.GetTranslation("common.add", "Aggiungi")
            </MudButton>
        </div>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }

    @if (_drawers.Count == 0 && !_loading)
    {
        <MudPaper Class="pa-8 text-center" Elevation="0" Style="border: 2px dashed var(--mud-palette-divider);">
            <MudIcon Icon="@Icons.Material.Outlined.Inbox" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">Nessun cassetto fiscale configurato</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                Crea il primo cassetto fiscale per iniziare a gestire i fondi cassa.
            </MudText>
            <MudButton StartIcon="@Icons.Material.Outlined.Add" Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="@(() => OpenDetailDialogAsync(null))">
                Crea Cassetto Fiscale
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudGrid Spacing="3">
            @foreach (var drawer in _drawers)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="2" Style="@GetCardBorderStyle(drawer)">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="@GetStatusColor(drawer.Status)" Size="Size.Medium">
                                    <MudIcon Icon="@Icons.Material.Outlined.Inbox" />
                                </MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@drawer.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @(drawer.Code is not null ? $"[{drawer.Code}] " : "")
                                    @GetAssignmentTypeText(drawer.AssignmentType)
                                </MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small">
                                    <MudMenuItem Icon="@Icons.Material.Outlined.Edit" OnClick="@(() => OpenDetailDialogAsync(drawer.Id))">
                                        Modifica
                                    </MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Outlined.Delete" Style="color: var(--mud-palette-error);"
                                                 OnClick="@(() => DeleteDrawerAsync(drawer.Id, drawer.Name))">
                                        Elimina
                                    </MudMenuItem>
                                </MudMenu>
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="1">
                                <div class="d-flex justify-space-between align-center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Saldo attuale</MudText>
                                    <MudText Typo="Typo.h6" Style="font-weight: 700;">
                                        @FormatCurrency(drawer.CurrentBalance, drawer.CurrencyCode)
                                    </MudText>
                                </div>
                                <div class="d-flex justify-space-between align-center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Valuta</MudText>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@drawer.CurrencyCode</MudChip>
                                </div>
                                @if (drawer.PosName is not null)
                                {
                                    <div class="d-flex justify-space-between align-center">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">POS</MudText>
                                        <MudText Typo="Typo.body2">@drawer.PosName</MudText>
                                    </div>
                                }
                                @if (drawer.OperatorName is not null)
                                {
                                    <div class="d-flex justify-space-between align-center">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Operatore</MudText>
                                        <MudText Typo="Typo.body2">@drawer.OperatorName</MudText>
                                    </div>
                                }
                                <div class="d-flex justify-space-between align-center mt-1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Sessione</MudText>
                                    @if (drawer.HasOpenSession)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Outlined.LockOpen">Aperta</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Outlined.Lock">Chiusa</MudChip>
                                    }
                                </div>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            @if (!drawer.HasOpenSession)
                            {
                                <MudButton Size="Size.Small" StartIcon="@Icons.Material.Outlined.PlayArrow" Color="Color.Success"
                                           OnClick="@(() => OpenSessionAsync(drawer))">
                                    Apri Sessione
                                </MudButton>
                            }
                            else
                            {
                                <MudButton Size="Size.Small" StartIcon="@Icons.Material.Outlined.Stop" Color="Color.Warning"
                                           OnClick="@(() => CloseSessionAsync(drawer))">
                                    Chiudi Sessione
                                </MudButton>
                            }
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private List<FiscalDrawerDto> _drawers = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDrawersAsync();
    }

    private async Task LoadDrawersAsync()
    {
        _loading = true;
        StateHasChanged();
        _drawers = await FiscalDrawerService.GetAllAsync();
        _loading = false;
        StateHasChanged();
    }

    private async Task OpenDetailDialogAsync(Guid? id)
    {
        var parameters = new DialogParameters { ["DrawerId"] = id };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<FiscalDrawerDetailDialog>("Cassetto Fiscale", parameters, options);
        var result = await dialog.Result;
        if (result?.Canceled == false)
            await LoadDrawersAsync();
    }

    private async Task DeleteDrawerAsync(Guid id, string name)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Conferma eliminazione",
            $"Eliminare il cassetto fiscale '{name}'?",
            yesText: "Elimina", cancelText: "Annulla");
        if (confirmed == true)
        {
            var ok = await FiscalDrawerService.DeleteAsync(id);
            if (ok)
            {
                AppNotification.ShowSuccess("Cassetto eliminato con successo.");
                await LoadDrawersAsync();
            }
            else
            {
                AppNotification.ShowError("Errore durante l'eliminazione.");
            }
        }
    }

    private async Task OpenSessionAsync(FiscalDrawerDto drawer)
    {
        var dto = new OpenFiscalDrawerSessionDto { OpeningBalance = drawer.OpeningBalance };
        var result = await FiscalDrawerService.OpenSessionAsync(drawer.Id, dto);
        if (result is not null)
        {
            AppNotification.ShowSuccess($"Sessione aperta per {drawer.Name}.");
            await LoadDrawersAsync();
        }
        else
        {
            AppNotification.ShowError("Errore apertura sessione.");
        }
    }

    private async Task CloseSessionAsync(FiscalDrawerDto drawer)
    {
        var dto = new CloseFiscalDrawerSessionDto { ClosingBalance = drawer.CurrentBalance };
        var result = await FiscalDrawerService.CloseSessionAsync(drawer.Id, dto);
        if (result is not null)
        {
            AppNotification.ShowSuccess($"Sessione chiusa per {drawer.Name}.");
            await LoadDrawersAsync();
        }
        else
        {
            AppNotification.ShowError("Errore chiusura sessione.");
        }
    }

    private static string FormatCurrency(decimal amount, string currencyCode)
    {
        var symbol = currencyCode switch
        {
            "EUR" => "€",
            "USD" => "$",
            "GBP" => "£",
            "JPY" => "¥",
            "CNY" => "¥",
            _ => currencyCode
        };
        return $"{symbol} {amount:N2}";
    }

    private static string GetAssignmentTypeText(FiscalDrawerAssignmentType type) => type switch
    {
        FiscalDrawerAssignmentType.Fixed => "Fisso (POS)",
        FiscalDrawerAssignmentType.Floating => "Flottante (Operatore)",
        _ => type.ToString()
    };

    private static Color GetStatusColor(FiscalDrawerStatus status) => status switch
    {
        FiscalDrawerStatus.Active => Color.Success,
        FiscalDrawerStatus.Suspended => Color.Warning,
        FiscalDrawerStatus.Closed => Color.Default,
        _ => Color.Default
    };

    private static string GetCardBorderStyle(FiscalDrawerDto drawer)
    {
        if (drawer.HasOpenSession) return "border-left: 4px solid var(--mud-palette-success);";
        if (drawer.Status == FiscalDrawerStatus.Suspended) return "border-left: 4px solid var(--mud-palette-warning);";
        return "border-left: 4px solid var(--mud-palette-divider);";
    }
}
