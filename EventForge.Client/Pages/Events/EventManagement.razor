@page "/events/management"
@using Microsoft.AspNetCore.Authorization
@using Prym.DTOs.Events
@using Prym.DTOs.Calendar
@using Prym.DTOs.Common
@using Prym.DTOs.Teams
@using Prym.DTOs.Store
@using Prym.DTOs.Warehouse
@using EventForge.Client.Services.Store
@using EventForge.Client.Shared.Components.Dialogs.Events
@attribute [Authorize]
@inject IEventService EventService
@inject ICalendarReminderService CalendarReminderService
@inject IBusinessPartyService BusinessPartyService
@inject IStoreUserService StoreUserService
@inject IPromotionClientService PromotionService
@inject IPriceListService PriceListService
@inject ILotService LotService
@inject IHttpClientService HttpClientService
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject NavigationManager NavigationManager
@inject IAppNotificationService AppNotification
@inject ILogger<EventManagement> Logger

<PageTitle>@TranslationService.GetTranslation("nav.events", "Gestione Calendario")</PageTitle>
<div class="management-page-root ef-flex-col-fill">
    <div class="ef-flex-col-fill gap-3">

        <MudPaper Elevation="1" Class="pa-3">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                <MudIcon Icon="@Icons.Material.Outlined.CalendarMonth" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h5">@TranslationService.GetTranslation("nav.events", "Gestione Calendario")</MudText>
                <MudSpacer />
                <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" OverrideStyles="false">
                    <MudButton StartIcon="@Icons.Material.Outlined.EventNote"
                               OnClick="@(() => OpenCreateEventDialog())"
                               Color="Color.Primary" Variant="Variant.Filled">
                        @TranslationService.GetTranslation("events.newEvent", "Evento")
                    </MudButton>
                    <MudButton StartIcon="@Icons.Material.Outlined.NotificationsActive"
                               OnClick="@(() => OpenCreateReminderDialog(CalendarItemType.Reminder))"
                               Color="Color.Secondary" Variant="Variant.Outlined">
                        @TranslationService.GetTranslation("events.newReminder", "Promemoria")
                    </MudButton>
                    <MudButton StartIcon="@Icons.Material.Outlined.CheckBox"
                               OnClick="@(() => OpenCreateReminderDialog(CalendarItemType.Task))"
                               Color="Color.Default" Variant="Variant.Outlined">
                        @TranslationService.GetTranslation("events.newTask", "Task")
                    </MudButton>
                </MudButtonGroup>
            </MudStack>
        </MudPaper>

        <!-- Category filter chips -->
        <MudPaper Elevation="0" Class="pa-2">
            <MudStack Spacing="1">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    <MudIcon Icon="@Icons.Material.Outlined.FilterList" Size="Size.Small" Class="mr-1" />
                    @TranslationService.GetTranslation("events.showFilter", "Categorie visibili:")
                </MudText>
                <MudStack Row Wrap="Wrap.Wrap" Spacing="1" AlignItems="AlignItems.Center">
                    @foreach (var cat in _categories)
                    {
                        <MudChip T="string"
                                 Color="@(cat.Enabled ? cat.ChipColor : Color.Default)"
                                 Variant="@(cat.Enabled ? Variant.Filled : Variant.Outlined)"
                                 OnClick="@(() => ToggleCategoryAsync(cat))"
                                 Size="Size.Small"
                                 Icon="@cat.Icon">
                            @cat.Label @(cat.Count > 0 ? $"({cat.Count})" : "")
                        </MudChip>
                    }
                    <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
                    @if (EventCategory?.Enabled == true)
                    {
                        @foreach (var sf in _eventStatusFilters)
                        {
                            <MudChip T="string"
                                     Color="@(sf.Active ? sf.Color : Color.Default)"
                                     Variant="@(sf.Active ? Variant.Filled : Variant.Outlined)"
                                     OnClick="@(() => ToggleEventStatusFilterAsync(sf))"
                                     Size="Size.Small">
                                @sf.Label
                            </MudChip>
                        }
                    }
                    <MudIconButton Icon="@Icons.Material.Outlined.Refresh"
                                   Size="Size.Small" OnClick="LoadAllDataAsync"
                                   title="@TranslationService.GetTranslation("common.refresh", "Aggiorna")" />
                </MudStack>
            </MudStack>
        </MudPaper>

        <!-- Scheduler -->
        <MudPaper Elevation="2" Class="pa-0" Style="flex:1; overflow:hidden; position:relative; min-height:400px;">
            @if (_isLoading)
            {
                <MudProgressLinear Class="progress-absolute-top" Indeterminate="true" Color="Color.Primary"
 />
            }
            <SfSchedule TValue="SchedulerItem"
                        @ref="_schedulerRef"
                        Width="100%"
                        Height="100%"
                        @bind-SelectedDate="_currentDate"
                        @bind-CurrentView="_currentView"
                        EnableAutoRowHeight="true"
                        ShowQuickInfo="false"
                        AllowResizing="false"
                        AllowDragAndDrop="false">
                <ScheduleViews>
                    <ScheduleView Option="View.Month" />
                    <ScheduleView Option="View.Week" />
                    <ScheduleView Option="View.WorkWeek" />
                    <ScheduleView Option="View.Day" />
                    <ScheduleView Option="View.Agenda" />
                </ScheduleViews>
                <ScheduleEventSettings DataSource="@_filteredItems"></ScheduleEventSettings>
                <ScheduleEvents TValue="SchedulerItem" OnPopupOpen="OnSchedulerPopupOpen" EventRendered="OnEventRendered" />
            </SfSchedule>
            </MudPaper>

        <!-- Active reminders / tasks below -->
        @if (_activeReminders.Count > 0 || _activeTasks.Count > 0)
        {
            <MudGrid Spacing="3">
                @if (_activeReminders.Count > 0)
                {
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="1" Class="pa-3">
                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.NotificationsActive" Color="Color.Warning" Size="Size.Small" Class="mr-1" />
                                @TranslationService.GetTranslation("events.activeReminders", "Promemoria attivi")
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="ml-1">@_activeReminders.Count</MudChip>
                            </MudText>
                            <MudList T="CalendarReminderDto" Dense="true">
                                @foreach (var r in _activeReminders.Take(5))
                                {
                                    <MudListItem>
                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                            <div class="color-dot-10" style="background:@(r.Color ?? "#FF9800");" />
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2">@r.Title</MudText>
                                                <MudText Typo="Typo.caption" Class="text-opacity-70">@r.DueDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                            </MudStack>
                                            <MudSpacer />
                                            @if (!string.IsNullOrEmpty(r.AssignedToUserId))
                                            {
                                                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.Person">@r.AssignedToUserId</MudChip>
                                            }
                                            <MudIconButton Icon="@Icons.Material.Outlined.CheckCircle"
                                                           Color="Color.Success" Size="Size.Small"
                                                           OnClick="@(() => CompleteReminderAsync(r.Id))"
                                                           title="@TranslationService.GetTranslation("events.complete", "Completa")" />
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        </MudPaper>
                    </MudItem>
                }
                @if (_activeTasks.Count > 0)
                {
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="1" Class="pa-3">
                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.CheckBox" Color="Color.Secondary" Size="Size.Small" Class="mr-1" />
                                @TranslationService.GetTranslation("events.activeTasks", "Task aperti")
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Class="ml-1">@_activeTasks.Count</MudChip>
                            </MudText>
                            <MudList T="CalendarReminderDto" Dense="true">
                                @foreach (var t in _activeTasks.Take(5))
                                {
                                    <MudListItem>
                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                            <div class="color-dot-10" style="background:@(t.Color ?? "#9C27B0");" />
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2">@t.Title</MudText>
                                                <MudText Typo="Typo.caption" Class="text-opacity-70">@t.DueDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                            </MudStack>
                                            <MudSpacer />
                                            @if (!string.IsNullOrEmpty(t.AssignedToUserId))
                                            {
                                                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.Person">@t.AssignedToUserId</MudChip>
                                            }
                                            <MudIconButton Icon="@Icons.Material.Outlined.CheckCircle"
                                                           Color="Color.Success" Size="Size.Small"
                                                           OnClick="@(() => CompleteReminderAsync(t.Id))"
                                                           title="@TranslationService.GetTranslation("events.complete", "Completa")" />
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }

    </div>
</div>

@code {
    [SupplyParameterFromQuery][Parameter] public string? Filter { get; set; }

    private bool _isLoading;
    private DateTime _currentDate = DateTime.Today;
    private View _currentView = View.Month;

    private SfSchedule<SchedulerItem>? _schedulerRef;

    private List<SchedulerItem> _allItems = new();
    private List<SchedulerItem> _filteredItems = new();
    private Dictionary<Guid, EventDto> _eventsMap = new();
    private Dictionary<Guid, CalendarReminderDto> _remindersMap = new();
    private List<CalendarReminderDto> _activeReminders = new();
    private List<CalendarReminderDto> _activeTasks = new();
    private List<SchedulerCategory> _categories = new();

    private SchedulerCategory? EventCategory => _categories.FirstOrDefault(c => c.Key == "events");

    private class SchedulerCategory(string key, string label, string icon, Color chipColor)
    {
        public string Key       { get; } = key;
        public string Label     { get; } = label;
        public string Icon      { get; } = icon;
        public Color  ChipColor { get; } = chipColor;
        public bool   Enabled   { get; set; } = true;
        public int    Count     { get; set; }
    }

    private record EventStatusFilter(string Key, string Label, Color Color, EventStatus Status)
    {
        public bool Active { get; set; } = true;
    }
    private List<EventStatusFilter> _eventStatusFilters = new();

    public class SchedulerItem
    {
        public int          Id             { get; set; }
        public string       EntityId       { get; set; } = string.Empty;
        public string       Subject        { get; set; } = string.Empty;
        public DateTime     StartTime      { get; set; }
        public DateTime     EndTime        { get; set; }
        public bool?        IsAllDay       { get; set; }
        public string?      Location       { get; set; }
        public string?      Description    { get; set; }
        public string?      RecurrenceRule { get; set; }
        public string?      Color          { get; set; }
        public string       CategoryKey    { get; set; } = string.Empty;
        public EventStatus? EventStatus    { get; set; }
        public string?      AssignedTo     { get; set; }
        public bool         IsPrivate      { get; set; }
    }

    private void RefreshFilteredItems()
    {
        var active = _categories.Where(c => c.Enabled).Select(c => c.Key).ToHashSet();
        var filtered = _allItems.Where(item =>
        {
            if (!active.Contains(item.CategoryKey)) return false;
            if (item.CategoryKey != "events") return true;
            if (!item.EventStatus.HasValue) return true;
            return _eventStatusFilters.Where(f => f.Active).Any(f => f.Status == item.EventStatus.Value);
        }).ToList();
        for (var i = 0; i < filtered.Count; i++)
            filtered[i].Id = i + 1;
        _filteredItems = filtered;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            InitCategories();
            InitEventStatusFilters();
            ApplyQueryFilter();
            await LoadAllDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OnInitializedAsync.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    protected override void OnParametersSet() => ApplyQueryFilter();

    private void InitCategories()
    {
        _categories = new List<SchedulerCategory>
        {
            new("events",     TranslationService.GetTranslation("scheduler.cat.events",     "Eventi"),          Icons.Material.Outlined.EventNote,            Color.Primary),
            new("reminders",  TranslationService.GetTranslation("scheduler.cat.reminders",  "Promemoria"),       Icons.Material.Outlined.NotificationsActive,   Color.Warning),
            new("tasks",      TranslationService.GetTranslation("scheduler.cat.tasks",      "Task"),             Icons.Material.Outlined.CheckBox,              Color.Secondary),
            new("pricelists", TranslationService.GetTranslation("scheduler.cat.pricelists", "Listini"),          Icons.Material.Outlined.PriceChange,           Color.Tertiary),
            new("promotions", TranslationService.GetTranslation("scheduler.cat.promotions", "Promozioni"),       Icons.Material.Outlined.LocalOffer,            Color.Success),
            new("lots",       TranslationService.GetTranslation("scheduler.cat.lots",       "Scadenze Lotti"),   Icons.Material.Outlined.Inventory2,            Color.Error),
            new("birthdays",  TranslationService.GetTranslation("scheduler.cat.birthdays",  "Compleanni"),       Icons.Material.Outlined.Cake,                  Color.Info),
        };
    }

    private void InitEventStatusFilters()
    {
        _eventStatusFilters = new List<EventStatusFilter>
        {
            new("planned",   TranslationService.GetTranslation("eventStatus.planned",   "Pianificati"),  Color.Info,    EventStatus.Planned)   { Active = true },
            new("ongoing",   TranslationService.GetTranslation("eventStatus.ongoing",   "In corso"),     Color.Success, EventStatus.Ongoing)   { Active = true },
            new("completed", TranslationService.GetTranslation("eventStatus.completed", "Completati"),   Color.Warning, EventStatus.Completed) { Active = true },
            new("cancelled", TranslationService.GetTranslation("eventStatus.cancelled", "Annullati"),    Color.Error,   EventStatus.Cancelled) { Active = true },
        };
    }

    private void ApplyQueryFilter()
    {
        if (string.IsNullOrEmpty(Filter)) return;
        if (Filter is "planned" or "completed")
        {
            foreach (var c in _categories) c.Enabled = c.Key == "events";
            foreach (var sf in _eventStatusFilters) sf.Active = sf.Key == Filter;
        }
        else
        {
            foreach (var c in _categories) c.Enabled = c.Key == Filter;
        }
    }

    private async Task LoadAllDataAsync()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            await Task.WhenAll(
                LoadEventsAsync(),
                LoadRemindersAndTasksAsync(),
                LoadPriceListsAsync(),
                LoadPromotionsAsync(),
                LoadLotsAsync(),
                LoadBirthdaysAsync()
            );
            foreach (var cat in _categories)
                cat.Count = _allItems.Count(i => i.CategoryKey == cat.Key);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading calendar data.");
            AppNotification.ShowError(TranslationService.GetTranslation("events.loadError", "Errore nel caricamento del calendario"));
        }
        finally
        {
            _isLoading = false;
            RefreshFilteredItems();
            StateHasChanged();
        }
    }

    private void ReplaceCategory(string key, IEnumerable<SchedulerItem> items)
        => _allItems = _allItems.Where(i => i.CategoryKey != key).Concat(items).ToList();

    private async Task LoadEventsAsync()
    {
        try
        {
            var startRange = DateTime.UtcNow.AddMonths(-12);
            var endRange   = DateTime.UtcNow.AddMonths(12);
            var items = (await EventService.GetEventsByDateRangeAsync(startRange, endRange)).ToList();
            _eventsMap = items.ToDictionary(e => e.Id);
            ReplaceCategory("events", items.Select(e => new SchedulerItem
            {
                EntityId = $"ev_{e.Id}", Subject = e.Name,
                StartTime = e.StartDate.ToLocalTime(),
                EndTime = (e.EndDate ?? e.StartDate.AddHours(1)).ToLocalTime(),
                Location = e.Location, Description = e.ShortDescription,
                Color = e.Color ?? "#4285F4", CategoryKey = "events",
                EventStatus = e.Status, AssignedTo = e.AssignedToUserId,
                IsPrivate = e.Visibility == CalendarVisibility.Private
            }));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading events.");
            AppNotification.ShowWarning("Si è verificato un errore nel caricamento degli eventi.");
        }
    }

    private async Task LoadRemindersAndTasksAsync()
    {
        try
        {
            var startRange = DateTime.UtcNow.AddMonths(-12);
            var endRange   = DateTime.UtcNow.AddMonths(12);
            var items = (await CalendarReminderService.GetCalendarRemindersByDateRangeAsync(startRange, endRange)).ToList();
            _remindersMap    = items.ToDictionary(r => r.Id);
            _activeReminders = items.Where(r => r.ItemType == CalendarItemType.Reminder && !r.IsCompleted).ToList();
            _activeTasks     = items.Where(r => r.ItemType == CalendarItemType.Task      && !r.IsCompleted).ToList();
            ReplaceCategory("reminders", items.Where(r => r.ItemType == CalendarItemType.Reminder).Select(r => ToSchedulerItem(r, "reminders")));
            ReplaceCategory("tasks",     items.Where(r => r.ItemType == CalendarItemType.Task).Select(r => ToSchedulerItem(r, "tasks")));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading reminders and tasks.");
            AppNotification.ShowWarning("Si è verificato un errore nel caricamento di promemoria e attività.");
        }
    }

    private static SchedulerItem ToSchedulerItem(CalendarReminderDto r, string cat) => new()
    {
        EntityId = $"rem_{r.Id}", Subject = r.Title,
        StartTime = r.DueDate.ToLocalTime(),
        EndTime = r.IsAllDay ? r.DueDate.ToLocalTime().AddDays(1) : r.DueDate.ToLocalTime().AddMinutes(30),
        IsAllDay = r.IsAllDay, Description = r.Description,
        Color = r.Color ?? (cat == "tasks" ? "#9C27B0" : "#FF9800"),
        CategoryKey = cat, RecurrenceRule = r.IsRecurring ? BuildRecurrenceRule(r) : null,
        AssignedTo = r.AssignedToUserId, IsPrivate = r.Visibility == CalendarVisibility.Private
    };

    private async Task LoadPriceListsAsync()
    {
        try
        {
            var result = await PriceListService.GetPagedAsync(1, 100);
            ReplaceCategory("pricelists", result.Items.Where(pl => pl.ValidFrom.HasValue || pl.ValidTo.HasValue).Select(pl => new SchedulerItem
            {
                EntityId = $"pl_{pl.Id}", Subject = $"\U0001f4cb {pl.Name}",
                StartTime = (pl.ValidFrom ?? pl.ValidTo!.Value.AddDays(-1)).ToLocalTime(),
                EndTime   = (pl.ValidTo   ?? pl.ValidFrom!.Value.AddDays(1)).ToLocalTime(),
                IsAllDay  = true, Description = $"Listino: {pl.Name}",
                Color = pl.Status == PriceListStatus.Active ? "#00BCD4" : "#607D8B",
                CategoryKey = "pricelists"
            }));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore nel caricamento dei listini prezzi.");
            AppNotification.ShowWarning("Si è verificato un errore nel caricamento dei listini.");
        }
    }

    private async Task LoadPromotionsAsync()
    {
        try
        {
            var promos = await PromotionService.GetActiveAsync();
            ReplaceCategory("promotions", promos.Select(p => new SchedulerItem
            {
                EntityId = $"promo_{p.Id}", Subject = $"\U0001f3f7\ufe0f {p.Name}",
                StartTime = p.StartDate.ToLocalTime(), EndTime = p.EndDate.ToLocalTime(),
                IsAllDay = true, Description = p.Name,
                Color = "#34A853", CategoryKey = "promotions"
            }));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading promotions.");
            AppNotification.ShowWarning("Si è verificato un errore nel caricamento delle promozioni.");
        }
    }

    private async Task LoadLotsAsync()
    {
        try
        {
            var lots = await LotService.GetExpiringLotsAsync(365);
            ReplaceCategory("lots", (lots ?? Enumerable.Empty<LotDto>()).Where(l => l.ExpiryDate.HasValue).Select(l => new SchedulerItem
            {
                EntityId = $"lot_{l.Id}", Subject = $"\u26a0\ufe0f {l.Code}",
                StartTime = l.ExpiryDate!.Value.ToLocalTime(),
                EndTime   = l.ExpiryDate!.Value.ToLocalTime().AddHours(1),
                IsAllDay  = true, Description = $"Lotto {l.Code} | {l.ProductCode}",
                Color = l.ExpiryDate.Value < DateTime.UtcNow.AddDays(30) ? "#F44336" : "#FF9800",
                CategoryKey = "lots"
            }));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading lots.");
            AppNotification.ShowWarning("Si è verificato un errore nel caricamento dei lotti.");
        }
    }

    private async Task LoadBirthdaysAsync()
    {
        try
        {
            var teamMembers = await HttpClientService.GetAsync<IEnumerable<TeamMemberDto>>("api/v1/teams/members-with-birthdays") ?? Enumerable.Empty<TeamMemberDto>();
            var parties     = await BusinessPartyService.GetBusinessPartiesWithBirthdayAsync();
            var storeUsers  = await StoreUserService.GetWithBirthdayAsync();

            var items = new List<SchedulerItem>();
            foreach (var m in teamMembers.Where(m => m.DateOfBirth.HasValue))
                items.AddRange(ProjectBirthday($"{m.FirstName} {m.LastName}".Trim(), m.DateOfBirth!.Value, $"tm_{m.Id}"));
            foreach (var p in parties.Where(p => p.DateOfBirth.HasValue))
                items.AddRange(ProjectBirthday(p.Name, p.DateOfBirth!.Value, $"bp_{p.Id}"));
            foreach (var u in storeUsers.Where(u => u.DateOfBirth.HasValue))
                items.AddRange(ProjectBirthday(u.Name, u.DateOfBirth!.Value, $"su_{u.Id}"));

            ReplaceCategory("birthdays", items);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading birthdays.");
            AppNotification.ShowWarning("Si è verificato un errore nel caricamento dei compleanni.");
        }
    }

    private static IEnumerable<SchedulerItem> ProjectBirthday(string name, DateTime dob, string idPrefix)
    {
        var today = DateTime.Today;
        foreach (var year in new[] { today.Year, today.Year + 1 })
        {
            var day = (dob.Month == 2 && dob.Day == 29 && !DateTime.IsLeapYear(year)) ? 28 : dob.Day;
            var bd = new DateTime(year, dob.Month, day);
            yield return new SchedulerItem
            {
                EntityId = $"bd_{idPrefix}_{year}", Subject = $"\U0001f382 {name}",
                StartTime = bd, EndTime = bd.AddDays(1), IsAllDay = true,
                Description = $"Compleanno di {name} ({today.Year - dob.Year} anni)",
                Color = "#E91E63", CategoryKey = "birthdays"
            };
        }
    }

    private static string? BuildRecurrenceRule(CalendarReminderDto r)
    {
        if (!r.IsRecurring || r.RecurrencePattern == null) return null;
        var freq = r.RecurrencePattern switch
        {
            RecurrencePattern.Daily   => "DAILY",
            RecurrencePattern.Weekly  => "WEEKLY",
            RecurrencePattern.Monthly => "MONTHLY",
            RecurrencePattern.Yearly  => "YEARLY",
            _                         => "DAILY"
        };
        var rule = $"FREQ={freq}";
        if (r.RecurrenceInterval is > 1) rule += $";INTERVAL={r.RecurrenceInterval}";
        if (r.RecurrenceEndDate.HasValue) rule += $";UNTIL={r.RecurrenceEndDate.Value:yyyyMMddTHHmmssZ}";
        return rule;
    }

    private async Task ToggleCategoryAsync(SchedulerCategory cat)
    {
        try
        {
            cat.Enabled = !cat.Enabled;
            await RefreshSchedulerAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in ToggleCategoryAsync.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task ToggleEventStatusFilterAsync(EventStatusFilter sf)
    {
        try
        {
            sf.Active = !sf.Active;
            await RefreshSchedulerAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in ToggleEventStatusFilterAsync.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task OpenCreateEventDialog(DateTime? start = null, DateTime? end = null)
    {
        try
        {
            var p = new DialogParameters<CreateEventDialog>
            {
                { x => x.PrefilledStartDate, start },
                { x => x.PrefilledEndDate,   end   }
            };
            var opts = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = false };
            var dlg  = await DialogService.ShowAsync<CreateEventDialog>(string.Empty, p, opts);
            var res  = await dlg.Result;
            if (res is { Canceled: false, Data: EventDto created })
            {
                _eventsMap[created.Id] = created;
                _allItems.Add(new SchedulerItem
                {
                    EntityId = $"ev_{created.Id}", Subject = created.Name,
                    StartTime = created.StartDate.ToLocalTime(),
                    EndTime = (created.EndDate ?? created.StartDate.AddHours(1)).ToLocalTime(),
                    Location = created.Location, Description = created.ShortDescription,
                    Color = created.Color ?? "#4285F4", CategoryKey = "events",
                    EventStatus = created.Status, AssignedTo = created.AssignedToUserId,
                    IsPrivate = created.Visibility == CalendarVisibility.Private
                });
                UpdateCount("events"); await RefreshSchedulerAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore durante l'apertura del dialogo di creazione evento.");
            AppNotification.ShowWarning("Si è verificato un errore durante la creazione dell'evento.");
        }
    }

    private async Task OpenEditEventDialog(EventDto ev)
    {
        try
        {
            var p = new DialogParameters<CreateEventDialog>
            {
                { x => x.ExistingEvent, ev }
            };
            var opts = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = false };
            var dlg  = await DialogService.ShowAsync<CreateEventDialog>(string.Empty, p, opts);
            var res  = await dlg.Result;
            if (res is { Canceled: false, Data: EventDto updated })
            {
                _eventsMap[updated.Id] = updated;
                var idx = _allItems.FindIndex(i => i.EntityId == $"ev_{updated.Id}");
                var item = new SchedulerItem
                {
                    EntityId = $"ev_{updated.Id}", Subject = updated.Name,
                    StartTime = updated.StartDate.ToLocalTime(),
                    EndTime = (updated.EndDate ?? updated.StartDate.AddHours(1)).ToLocalTime(),
                    Location = updated.Location, Description = updated.ShortDescription,
                    Color = updated.Color ?? "#4285F4", CategoryKey = "events",
                    EventStatus = updated.Status, AssignedTo = updated.AssignedToUserId,
                    IsPrivate = updated.Visibility == CalendarVisibility.Private
                };
                if (idx >= 0) _allItems[idx] = item;
                else _allItems.Add(item);
                UpdateCount("events"); await RefreshSchedulerAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore durante l'apertura del dialogo di modifica evento.");
            AppNotification.ShowWarning("Si è verificato un errore durante la modifica dell'evento.");
        }
    }

    private async Task OpenCreateReminderDialog(CalendarItemType itemType, DateTime? due = null)
    {
        try
        {
            var p = new DialogParameters<CreateCalendarReminderDialog>
            {
                { x => x.ItemType,         itemType },
                { x => x.PrefilledDueDate, due      }
            };
            var opts = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = false };
            var dlg  = await DialogService.ShowAsync<CreateCalendarReminderDialog>(string.Empty, p, opts);
            var res  = await dlg.Result;
            if (res is { Canceled: false, Data: CalendarReminderDto created })
            {
                var cat = itemType == CalendarItemType.Task ? "tasks" : "reminders";
                _allItems.Add(ToSchedulerItem(created, cat));
                _remindersMap[created.Id] = created;
                if (itemType == CalendarItemType.Reminder && !created.IsCompleted) _activeReminders.Insert(0, created);
                else if (itemType == CalendarItemType.Task && !created.IsCompleted) _activeTasks.Insert(0, created);
                UpdateCount(cat); await RefreshSchedulerAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore durante l'apertura del dialogo di creazione promemoria/task.");
            AppNotification.ShowWarning("Si è verificato un errore durante la creazione del promemoria.");
        }
    }

    private async Task OnSchedulerPopupOpen(PopupOpenEventArgs<SchedulerItem> args)
    {
        try
        {
            if (args.Type is PopupType.QuickInfo or PopupType.Editor)
                args.Cancel = true;

            if (args.Type != PopupType.Editor) return;

            var itemId = args.Data?.EntityId ?? string.Empty;

            if (itemId.StartsWith("ev_", StringComparison.Ordinal)
                && Guid.TryParse(itemId[3..], out var eventId)
                && _eventsMap.TryGetValue(eventId, out var ev))
            {
                await OpenEditEventDialog(ev);
            }
            else if (itemId.StartsWith("rem_", StringComparison.Ordinal)
                && Guid.TryParse(itemId[4..], out var remId)
                && _remindersMap.TryGetValue(remId, out var rem))
            {
                await OpenEditReminderDialog(rem);
            }
            else if (!itemId.StartsWith("pl_", StringComparison.Ordinal)
                  && !itemId.StartsWith("promo_", StringComparison.Ordinal)
                  && !itemId.StartsWith("lot_", StringComparison.Ordinal)
                  && !itemId.StartsWith("bd_", StringComparison.Ordinal))
            {
                var s = args.Data?.StartTime;
                var e = args.Data?.EndTime;
                await OpenCreateEventDialog(s, e);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore durante la gestione del popup dello scheduler.");
            AppNotification.ShowWarning("Si è verificato un errore durante l'apertura del dialogo.");
        }
    }

    private async Task CompleteReminderAsync(Guid id)
    {
        try
        {
            await CalendarReminderService.CompleteCalendarReminderAsync(id);
            _activeReminders.RemoveAll(r => r.Id == id);
            _activeTasks.RemoveAll(t => t.Id == id);
            _allItems.RemoveAll(i => i.EntityId == $"rem_{id}");
            _remindersMap.Remove(id);
            UpdateCount("reminders"); UpdateCount("tasks");
            AppNotification.ShowSuccess(TranslationService.GetTranslation("events.completed", "Completato"));
            await RefreshSchedulerAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error completing reminder {Id}.", id);
            AppNotification.ShowError(TranslationService.GetTranslation("events.completeError", "Errore nel completamento"));
        }
    }

    private Task RefreshSchedulerAsync()
    {
        RefreshFilteredItems();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OpenEditReminderDialog(CalendarReminderDto reminder)
    {
        try
        {
            var p = new DialogParameters<CreateCalendarReminderDialog>
            {
                { x => x.ExistingReminder, reminder }
            };
            var opts = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = false };
            var dlg  = await DialogService.ShowAsync<CreateCalendarReminderDialog>(string.Empty, p, opts);
            var res  = await dlg.Result;
            if (res is { Canceled: false, Data: CalendarReminderDto updated })
            {
                _remindersMap[updated.Id] = updated;
                var cat = updated.ItemType == CalendarItemType.Task ? "tasks" : "reminders";
                var idx = _allItems.FindIndex(i => i.EntityId == $"rem_{updated.Id}");
                var item = ToSchedulerItem(updated, cat);
                if (idx >= 0) _allItems[idx] = item;
                else _allItems.Add(item);
                if (!updated.IsCompleted)
                {
                    if (updated.ItemType == CalendarItemType.Reminder)
                    {
                        var ri = _activeReminders.FindIndex(r => r.Id == updated.Id);
                        if (ri >= 0) _activeReminders[ri] = updated; else _activeReminders.Insert(0, updated);
                    }
                    else
                    {
                        var ti = _activeTasks.FindIndex(t => t.Id == updated.Id);
                        if (ti >= 0) _activeTasks[ti] = updated; else _activeTasks.Insert(0, updated);
                    }
                }
                UpdateCount(cat); await RefreshSchedulerAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore durante l'apertura del dialogo di modifica promemoria.");
            AppNotification.ShowWarning("Si è verificato un errore durante la modifica del promemoria.");
        }
    }

    private void OnEventRendered(EventRenderedArgs<SchedulerItem> args)
    {
        if (!string.IsNullOrEmpty(args.Data.Color))
            args.Attributes = new Dictionary<string, object>
            {
                ["style"] = $"background:{args.Data.Color}!important;border-color:{args.Data.Color}!important;"
            };
    }

    private void UpdateCount(string key)
    {
        var cat = _categories.FirstOrDefault(c => c.Key == key);
        if (cat != null) cat.Count = _allItems.Count(i => i.CategoryKey == key);
    }

