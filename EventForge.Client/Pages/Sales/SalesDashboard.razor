@page "/sales/dashboard"
@using Microsoft.AspNetCore.Authorization
@using EventForge.DTOs.Store
@using EventForge.Client.Services.Store
@attribute [Authorize]
@inject IFiscalDrawerService FiscalDrawerService
@inject ITranslationService TranslationService
@inject NavigationManager NavigationManager
@inject ILogger<SalesDashboard> Logger
@inject IAppNotificationService AppNotification

<PageTitle>@TranslationService.GetTranslation("sales.dashboard", "Dashboard Vendite")</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <div class="d-flex align-center justify-space-between mb-4 flex-wrap gap-2">
        <div class="d-flex align-center gap-3">
            <MudIcon Icon="@Icons.Material.Outlined.BarChart" Size="Size.Large" Color="Color.Primary" />
            <div>
                <MudText Typo="Typo.h5">Dashboard Vendite</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @DateTime.Now.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("it-IT"))
                </MudText>
            </div>
        </div>
        <MudButton StartIcon="@Icons.Material.Outlined.Refresh" Variant="Variant.Outlined" Color="Color.Primary"
                   OnClick="@LoadDataAsync" Disabled="@_loading">
            Aggiorna
        </MudButton>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }

    @if (_dashboard is not null)
    {
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 border-success-l">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Vendite Oggi</MudText>
                        <MudText Typo="Typo.h5" Class="fw-bold" Color="Color.Success">
                            @FormatEuro(_dashboard.TodayTotalSales)
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @_dashboard.TodayTransactionCount transazioni
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 border-primary-l">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Questa Settimana</MudText>
                        <MudText Typo="Typo.h5" Class="fw-bold">@FormatEuro(_dashboard.WeekTotalSales)</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 border-secondary-l">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Questo Mese</MudText>
                        <MudText Typo="Typo.h5" Class="fw-bold">@FormatEuro(_dashboard.MonthTotalSales)</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Style="border-left: 4px solid var(--mud-palette-info);">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Saldo Cassetti</MudText>
                        <MudText Typo="Typo.h5" Class="fw-bold">@FormatEuro(_dashboard.TotalDrawerBalance)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @_dashboard.OpenSessionsCount / @_dashboard.ActiveDrawersCount attivi
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.subtitle2" Class="mb-3">Vendite Oggi per Metodo</MudText>
                    <MudStack Spacing="2">
                        <div class="d-flex justify-space-between align-center">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Money" Color="Color.Success" Size="Size.Small" />
                                <MudText Typo="Typo.body2">Contanti</MudText>
                            </div>
                            <MudText Typo="Typo.body1" Class="fw-semibold">@FormatEuro(_dashboard.TodayCashSales)</MudText>
                        </div>
                        <div class="d-flex justify-space-between align-center">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Outlined.CreditCard" Color="Color.Primary" Size="Size.Small" />
                                <MudText Typo="Typo.body2">Carta</MudText>
                            </div>
                            <MudText Typo="Typo.body1" Class="fw-semibold">@FormatEuro(_dashboard.TodayCardSales)</MudText>
                        </div>
                        <div class="d-flex justify-space-between align-center">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Outlined.MoreHoriz" Color="Color.Secondary" Size="Size.Small" />
                                <MudText Typo="Typo.body2">Altro</MudText>
                            </div>
                            <MudText Typo="Typo.body1" Class="fw-semibold">@FormatEuro(_dashboard.TodayOtherSales)</MudText>
                        </div>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="8">
                <MudPaper Class="pa-4" Elevation="1">
                    <div class="d-flex align-center justify-space-between mb-3">
                        <MudText Typo="Typo.subtitle2">Stato Cassetti</MudText>
                        <MudButton Size="Size.Small" StartIcon="@Icons.Material.Outlined.Inbox"
                                   Href="/store/fiscal-drawers" Variant="Variant.Text">
                            Gestisci
                        </MudButton>
                    </div>
                    @if (_dashboard.DrawerSummaries.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Nessun cassetto configurato.</MudText>
                    }
                    else
                    {
                        <MudSimpleTable Dense="true" Hover="true">
                            <thead>
                                <tr>
                                    <th>Cassetto</th>
                                    <th>Valuta</th>
                                    <th>Saldo</th>
                                    <th>Vendite sessione</th>
                                    <th>Sessione</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in _dashboard.DrawerSummaries)
                                {
                                    <tr>
                                        <td>@d.Name</td>
                                        <td>@d.CurrencyCode</td>
                                        <td class="fw-semibold">@FormatEuro(d.CurrentBalance)</td>
                                        <td>@FormatEuro(d.SessionTotalSales)</td>
                                        <td>
                                            @if (d.HasOpenSession)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success">Aperta</MudChip>
                                            }
                                            else
                                            {
                                                <MudChip T="string" Size="Size.Small">Chiusa</MudChip>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @if (_dashboard.WeeklySalesTrend.Count > 0)
        {
            <MudPaper Class="pa-4 mb-4" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mb-3">Andamento Settimanale</MudText>
                <MudSimpleTable Dense="true">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Vendite</th>
                            <th>Transazioni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in _dashboard.WeeklySalesTrend)
                        {
                            <tr>
                                <td>@p.Date.ToString("ddd dd/MM")</td>
                                <td class="fw-semibold">@FormatEuro(p.TotalSales)</td>
                                <td>@p.TransactionCount</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        }
    }
</MudContainer>

@code {
    private SalesDashboardDto? _dashboard;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _dashboard = await FiscalDrawerService.GetSalesDashboardAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading sales dashboard data.");
            AppNotification.ShowWarning("Si è verificato un errore nel caricamento del dashboard.");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static string FormatEuro(decimal amount) => $"€ {amount:N2}";
}
