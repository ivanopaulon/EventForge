@page "/sales/pos2026"
@using EventForge.Client.ViewModels
@using EventForge.Client.Models.Sales
@using EventForge.Client.Components.Pos26
@using EventForge.Client.Services
@using EventForge.Client.Shared.Components.Sales
@using EventForge.Client.Shared.Components.Dialogs
@using EventForge.Client.Shared.Components.Dialogs.Sales
@using EventForge.Client.Shared.Components.FiscalPrinting
@using EventForge.Client.Services.Sales
@using EventForge.Client.Services.Store
@using EventForge.DTOs.Analytics
@using EventForge.DTOs.Common
@using EventForge.DTOs.Constants
@using EventForge.DTOs.Sales
@using EventForge.DTOs.Products
@using EventForge.DTOs.Store
@using EventForge.DTOs.Business
@using EventForge.DTOs.FiscalPrinting
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@attribute [Authorize]
@inject POSViewModel ViewModel
@inject IDialogService DialogService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JSRuntime
@inject ISalesService SalesService
@inject IFiscalPrintingService FiscalPrintingService
@inject IFiscalDrawerService FiscalDrawerService
@inject IProductService ProductService
@inject IPaymentMethodService PaymentMethodService
@inject IAnalyticsService AnalyticsService
@inject IEntityManagementService EntityManagementService
@inject ITableManagementService TableManagementService
@inject EventForge.Client.Services.Sales.INoteFlagService NoteFlagService
@inject ILogger<POS2026> Logger

<PageTitle>POS 2026</PageTitle>
<PageLoadingOverlay Visible="ViewModel.IsLoading || _isLoadingProducts"
                    Message="Caricamento…" />

<div class="pos2026-wrap">

    @* ===== COLONNA SINISTRA ===== *@
    <div class="pos2026-left">

        @* Header operatore/cassa — riusa POSHeader esistente *@
        <POSHeader AvailableOperators="@ViewModel.AvailableOperators"
                   SelectedOperatorId="@ViewModel.SelectedOperatorId"
                   SelectedOperatorIdChanged="@OnOperatorIdChangedAsync"
                   AvailablePos="@ViewModel.AvailablePos"
                   SelectedPosId="@ViewModel.SelectedPosId"
                   SelectedPosIdChanged="@OnPosIdChangedAsync"
                   SelectedCustomer="@ViewModel.SelectedCustomer"
                   SelectedCustomerChanged="@OnSelectedCustomerChangedAsync"
                   SessionNumber="@ViewModel.CurrentSession?.Id"
                   IsSessionActive="@ViewModel.HasActiveSession"
                   IsUpdatingItems="@ViewModel.IsUpdatingItems"
                   LoadingTooltipText="Salvataggio in corso…"
                   LoadingSpinnerColor="@Color.Primary"
                   FiscalDrawerSummary="@_fiscalDrawerSummary"
                   OnOpenDrawerSessionClick="@OpenDrawerSessionAsync"
                   OnDepositClick="@(() => OpenDrawerTransactionDialogAsync(FiscalDrawerTransactionType.Deposit))"
                   OnWithdrawalClick="@(() => OpenDrawerTransactionDialogAsync(FiscalDrawerTransactionType.Withdrawal))"
                   HasFiscalPrinter="@_fiscalPrinterId.HasValue"
                   IsDailyClosureRequired="@(_fiscalPrinterStatus?.IsDailyClosureRequired == true)"
                   OnOpenPhysicalDrawerClick="@OpenPhysicalDrawerAsync"
                   OnDailyClosureClick="@OpenDailyClosureDialogAsync"
                   OnParkClick="@ParkSessionAsync"
                   OnCancelClick="@CancelSessionAsync" />

        @* Barra ricerca + chip cliente *@
        <Pos26SearchBar @ref="_searchBar"
                        SearchTerm="@_searchTerm"
                        SearchTermChanged="@OnSearchTermChanged"
                        Customer="@ViewModel.SelectedCustomer"
                        CustomerChanged="@OnSelectedCustomerChangedAsync"
                        OnBarcodeDetected="@HandleBarcodeAsync" />

        @* Barra ordinamenti *@
        <Pos26SortBar SortMode="@_sortMode"
                      OnSortChanged="@OnSortModeChangedAsync"
                      HasCustomer="@(ViewModel.SelectedCustomer != null)" />

        @* Filtro categorie *@
        <Pos26CategoryBar Categories="@_categories"
                          SelectedCategory="@_selectedCategory"
                          OnCategorySelected="@OnCategorySelectedAsync" />

        @* Banner contestuale *@
        <Pos26ContextBanner SortMode="@_sortMode"
                            Customer="@ViewModel.SelectedCustomer" />

        @* ===== TOOLBAR FUNZIONI: Note, Coupon, Tavolo, Sessioni parcheggiate ===== *@
        <div class="pos26-fn-toolbar">
            @* Pulsante Note ordine *@
            <button class="pos26-fn-btn @(_showNoteInput || (ViewModel.CurrentSession?.Notes.Any() == true) ? "pos26-fn-btn--active" : "")"
                    @onclick="ToggleNoteInput"
                    title="Note ordine">
                <MudIcon Icon="@Icons.Material.Outlined.Note" Size="Size.Small" />
                <span>Note</span>
                @if (ViewModel.CurrentSession?.Notes.Any() == true)
                {
                    <span class="pos26-fn-badge">@ViewModel.CurrentSession.Notes.Count</span>
                }
            </button>

            @* Pulsante Coupon *@
            <button class="pos26-fn-btn @(_showCouponInput || (ViewModel.ActiveCouponCodes?.Any() == true) ? "pos26-fn-btn--active" : "")"
                    @onclick="ToggleCouponInput"
                    title="Coupon">
                <MudIcon Icon="@Icons.Material.Outlined.LocalOffer" Size="Size.Small" />
                <span>Coupon</span>
                @if (ViewModel.ActiveCouponCodes?.Any() == true)
                {
                    <span class="pos26-fn-badge">@ViewModel.ActiveCouponCodes.Count</span>
                }
            </button>

            @* Pulsante Tavolo / Asporto *@
            <button class="pos26-fn-btn @(_showTablePicker ? "pos26-fn-btn--active" : "")"
                    @onclick="ToggleTablePickerAsync"
                    title="Tavolo / Asporto">
                <MudIcon Icon="@Icons.Material.Outlined.TableBar" Size="Size.Small" />
                <span>
                    @if (!string.IsNullOrEmpty(ViewModel.CurrentSession?.TableNumber))
                    { @($"T.{ViewModel.CurrentSession.TableNumber}") }
                    else if (ViewModel.CurrentSession?.SaleType == SaleTypes.Takeaway)
                    { @("Asporto") }
                    else
                    { @("Tavolo") }
                </span>
            </button>

            @* Sessioni parcheggiate *@
            <button class="pos26-fn-btn @(_showParkedSessions ? "pos26-fn-btn--active" : "")"
                    @onclick="ToggleParkedSessionsAsync"
                    title="Sessioni parcheggiate">
                <MudIcon Icon="@Icons.Material.Outlined.History" Size="Size.Small" />
                <span>Sospese</span>
            </button>
        </div>

        @* Input nota ordine *@
        @if (_showNoteInput)
        {
            <div class="pos26-fn-panel">
                @foreach (var nota in ViewModel.CurrentSession?.Notes ?? Enumerable.Empty<SessionNoteDto>())
                {
                    <div class="pos26-fn-note-item">
                        @if (!string.IsNullOrEmpty(nota.NoteFlagIcon))
                        {
                            <MudIcon Icon="@nota.NoteFlagIcon" Size="Size.Small" Class="mr-1"
                                     Style="@(!string.IsNullOrEmpty(nota.NoteFlagColor) ? $"color:{nota.NoteFlagColor}" : "")" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.StickyNote2" Size="Size.Small" Class="mr-1" />
                        }
                        <span>@nota.Text</span>
                    </div>
                }
                @* Selettore flag (visibile solo se ci sono più flag disponibili) *@
                @if (_noteFlags.Count > 1)
                {
                    <div class="pos26-fn-row" style="margin-bottom:4px;">
                        <select class="pos26-fn-input"
                                @bind="_selectedNoteFlagId">
                            @foreach (var flag in _noteFlags)
                            {
                                <option value="@flag.Id">@flag.Name</option>
                            }
                        </select>
                    </div>
                }
                <div class="pos26-fn-row">
                    <input class="pos26-fn-input"
                           type="text"
                           placeholder="Aggiungi nota…"
                           @bind="_orderNoteText"
                           @bind:event="oninput"
                           maxlength="500" />
                    <button class="pos26-fn-btn-add" @onclick="SaveOrderNoteAsync"
                            disabled="@(string.IsNullOrWhiteSpace(_orderNoteText) || !_selectedNoteFlagId.HasValue)">
                        Aggiungi
                    </button>
                    <button class="pos26-fn-btn-close" @onclick="ToggleNoteInput">✕</button>
                </div>
            </div>
        }

        @* Input coupon *@
        @if (_showCouponInput)
        {
            <div class="pos26-fn-panel">
                @foreach (var couponCode in ViewModel.ActiveCouponCodes ?? Enumerable.Empty<string>())
                {
                    <div class="pos26-fn-note-item">
                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Small" Class="mr-1" Style="color:var(--pos-green);" />
                        <span>@couponCode</span>
                    </div>
                }
                <div class="pos26-fn-row">
                    <input class="pos26-fn-input"
                           type="text"
                           placeholder="Codice coupon…"
                           @bind="_couponInput"
                           @bind:event="oninput"
                           maxlength="50" />
                    <button class="pos26-fn-btn-add" @onclick="ApplyCouponAsync"
                            disabled="@string.IsNullOrWhiteSpace(_couponInput)">
                        Applica
                    </button>
                    <button class="pos26-fn-btn-close" @onclick="ToggleCouponInput">✕</button>
                </div>
            </div>
        }

        @* Selettore tavolo / tipo vendita *@
        @if (_showTablePicker)
        {
            <div class="pos26-fn-panel pos26-fn-panel--table">
                <div class="pos26-fn-table-types">
                    <button class="pos26-fn-type-btn @(ViewModel.CurrentSession?.SaleType == SaleTypes.Retail ? "pos26-fn-type-btn--active" : "")"
                            @onclick='() => SetSaleTypeAsync(SaleTypes.Retail)'>
                        <MudIcon Icon="@Icons.Material.Outlined.StoreMallDirectory" Size="Size.Small" />
                        Banco
                    </button>
                    <button class="pos26-fn-type-btn @(ViewModel.CurrentSession?.SaleType == SaleTypes.Takeaway ? "pos26-fn-type-btn--active" : "")"
                            @onclick='() => SetSaleTypeAsync(SaleTypes.Takeaway)'>
                        <MudIcon Icon="@Icons.Material.Outlined.ShoppingBag" Size="Size.Small" />
                        Asporto
                    </button>
                    <button class="pos26-fn-btn-close pos26-fn-btn-close--inline" @onclick="() => _showTablePicker = false">✕</button>
                </div>
                @if (_availableTables.Any())
                {
                    <div class="pos26-fn-tables-grid">
                        @foreach (var table in _availableTables)
                        {
                            <button class="pos26-fn-table-btn @(ViewModel.CurrentSession?.TableNumber == table.TableNumber ? "pos26-fn-table-btn--active" : "")"
                                    @onclick="() => AssignTableAsync(table)">
                                @table.TableNumber
                                @if (!string.IsNullOrEmpty(table.TableName)) { <br /><small>@table.TableName</small> }
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="pos26-fn-empty">Nessun tavolo disponibile</div>
                }
            </div>
        }

        @* Pannello sessioni parcheggiate *@
        @if (_showParkedSessions)
        {
            <div class="pos26-fn-panel">
                <div class="pos26-fn-panel-header">
                    <span>Sessioni sospese</span>
                    <button class="pos26-fn-btn-close" @onclick="() => _showParkedSessions = false">✕</button>
                </div>
                @if (_parkedSessions.Any())
                {
                    @foreach (var parked in _parkedSessions)
                    {
                        <div class="pos26-fn-parked-row">
                            <div class="pos26-fn-parked-info">
                                <span class="pos26-fn-parked-id">@parked.Id.ToString()[..8]</span>
                                @if (!string.IsNullOrEmpty(parked.CustomerName))
                                { <span class="pos26-fn-parked-customer">@parked.CustomerName</span> }
                                <span class="pos26-fn-parked-total">€ @parked.FinalTotal.ToString("F2")</span>
                                <span class="pos26-fn-parked-items">@parked.Items.Count art.</span>
                            </div>
                            <button class="pos26-fn-btn-add" @onclick="() => ResumeParkedSessionAsync(parked)">
                                Riprendi
                            </button>
                        </div>
                    }
                }
                else
                {
                    <div class="pos26-fn-empty">Nessuna sessione sospesa</div>
                }
            </div>
        }

        @* Griglia articoli *@
        <div class="pos2026-product-area">
            <Pos26ProductGrid Products="@_filteredProducts"
                              CartQuantities="@_cartQuantities"
                              LastPurchaseIds="@_lastPurchaseIds"
                              BestSellerIds="@_bestSellerIds"
                              OnAddToCart="@OnAddProductToCartAsync"
                              OnLongPress="@OpenProductDetailAsync"
                              IsLoading="@_isLoadingProducts" />
        </div>

    </div>

    @* ===== COLONNA DESTRA ===== *@
    <div class="pos2026-right">

        <Pos26Receipt Session="@ViewModel.CurrentSession"
                      Customer="@ViewModel.SelectedCustomer"
                      Items="@ViewModel.CurrentSession?.Items"
                      Subtotal="@(ViewModel.CurrentSession?.OriginalTotal ?? 0m)"
                      TotalDiscount="@(ViewModel.CurrentSession?.DiscountAmount ?? 0m)"
                      TotalVat="@(ViewModel.CurrentSession?.TaxAmount ?? 0m)"
                      GrandTotal="@ViewModel.GrandTotal"
                      OnClearCart="@ClearCartAsync"
                      OnIncrease="@IncreaseQuantity"
                      OnDecrease="@DecreaseQuantity"
                      OnEditItemNotes="@EditItemNotesAsync" />

        <Pos26Numpad CanPay="@ViewModel.CanPay"
                     OnPay="@OpenPaymentDialogAsync"
                     OnCancel="@CancelSessionAsync"
                     OnApplyDiscount="@ApplyDiscountAsync"
                     OnApplyFixedDiscount="@ApplyFixedDiscountAsync" />

    </div>

</div>

@* Shortcut tastiera (stesso pattern POS.razor) *@
@if (ViewModel.HasActiveSession)
{
    <div class="pos2026-shortcuts-bar" aria-label="Scorciatoie tastiera">
        <span><strong>F2</strong> Paga</span>
        <span><strong>F3</strong> Parcheggia</span>
        <span><strong>F4</strong> Rimuovi ultimo</span>
        <span><strong>F8</strong> Scanner</span>
        <span><strong>F12</strong> Chiudi</span>
        <span><strong>ESC</strong> Annulla</span>
    </div>
}
