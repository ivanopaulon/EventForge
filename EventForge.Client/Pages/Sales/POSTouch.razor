@page "/sales/postouch"
@using EventForge.Client.ViewModels
@using EventForge.DTOs.Sales
@using EventForge.DTOs.Products
@using EventForge.DTOs.Store
@using EventForge.DTOs.Business
@using EventForge.DTOs.FiscalPrinting
@using EventForge.Client.Shared.Components.Business
@using EventForge.Client.Shared.Components.Common
@using EventForge.Client.Shared.Components.Sales
@using EventForge.Client.Shared.Components.Dialogs.Sales
@using EventForge.Client.Shared.Components.Dialogs
@using EventForge.Client.Shared.Components
@using EventForge.Client.Shared.Components.FiscalPrinting
@using EventForge.Client.Services.Sales
@using EventForge.Client.Services.Store
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@attribute [Authorize]
@inject POSViewModel ViewModel
@inject IDialogService DialogService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JSRuntime
@inject ISalesService SalesService
@inject IFiscalPrintingService FiscalPrintingService
@inject IFiscalDrawerService FiscalDrawerService
@inject ILogger<POSTouch> Logger

<PageTitle>@TranslationService.GetTranslation("sales.postouch", "Cassa Touch")</PageTitle>
<PageLoadingOverlay Visible="ViewModel.IsLoading"
                    Message="@TranslationService.GetTranslation("common.loading", "Caricamento...")" />

@if (_fiscalPrinterStatus?.IsDailyClosureRequired == true)
{
    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudText Style="flex:1">
                ⚠️ Il registratore di cassa richiede la chiusura giornaliera. Le nuove stampe potrebbero essere bloccate.
            </MudText>
            <MudButton Size="Size.Small"
                       Variant="Variant.Filled"
                       Color="Color.Warning"
                       OnClick="@OpenDailyClosureDialogAsync">
                Esegui Chiusura Ora
            </MudButton>
        </MudStack>
    </MudAlert>
}

@if (_fiscalDrawerSummary is not null && !_fiscalDrawerSummary.HasOpenSession)
{
    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudIcon Icon="@Icons.Material.Outlined.Inbox" Size="Size.Small" />
            <MudText Style="flex:1">Cassetto <strong>@_fiscalDrawerSummary.Name</strong>: sessione non aperta.</MudText>
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Info" OnClick="@OpenDrawerSessionAsync">
                Apri Sessione
            </MudButton>
        </MudStack>
    </MudAlert>
}
@if (_fiscalDrawerSummary is not null && _fiscalDrawerSummary.HasOpenSession)
{
    <MudPaper Elevation="0" Class="pa-2 mb-2 d-flex align-center gap-3 flex-wrap"
              Style="background: linear-gradient(90deg, #e8f5e9, #f1f8e9); border-radius:6px; border-left:4px solid var(--mud-palette-success);">
        <MudIcon Icon="@Icons.Material.Outlined.Inbox" Color="Color.Success" Size="Size.Small" />
        <MudText Typo="Typo.body2"><strong>@_fiscalDrawerSummary.Name</strong></MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Saldo: <strong>@($"€ {_fiscalDrawerSummary.CurrentBalance:N2}")</strong></MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Vendite: <strong>@($"€ {_fiscalDrawerSummary.SessionTotalSales:N2}")</strong></MudText>
        <MudSpacer />
        <MudButton Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.ArrowUpward"
                   Color="Color.Success" OnClick="@(() => OpenDrawerTransactionDialogAsync(FiscalDrawerTransactionType.Deposit))">
            Versamento
        </MudButton>
        <MudButton Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.ArrowDownward"
                   Color="Color.Warning" OnClick="@(() => OpenDrawerTransactionDialogAsync(FiscalDrawerTransactionType.Withdrawal))">
            Prelievo
        </MudButton>
    </MudPaper>
}

<!-- ======================================================
     STEP 1 — Operator not yet selected → show full-screen grid
     ====================================================== -->
@if (!ViewModel.SelectedOperatorId.HasValue)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
        <POSTouchOperatorGrid Operators="@ViewModel.AvailableOperators"
                              SelectedOperatorId="@ViewModel.SelectedOperatorId"
                              OnOperatorSelected="@OnOperatorCardSelectedAsync" />
    </MudContainer>
}

<!-- ======================================================
     STEP 2 — Operator selected but POS not yet selected
     ====================================================== -->
else if (!ViewModel.SelectedPosId.HasValue)
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">

        <!-- Selected operator reminder -->
        <div class="d-flex justify-center mb-3">
            <MudChip T="string"
                     Icon="@Icons.Material.Filled.Person"
                     Color="Color.Primary"
                     Size="Size.Small"
                     Variant="Variant.Outlined">
                @(ViewModel.AvailableOperators.FirstOrDefault(o => o.Id == ViewModel.SelectedOperatorId)?.Name ?? "—")
            </MudChip>
        </div>

        <div class="d-flex flex-column align-center mb-5">
            <MudText Typo="Typo.h5" Class="mb-1">
                @TranslationService.GetTranslation("sales.selectPos", "Seleziona Cassa")
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @TranslationService.GetTranslation("sales.selectPosHint", "Scegli il terminale da utilizzare")
            </MudText>
        </div>

        <MudGrid Spacing="3" Justify="Justify.Center">
            @foreach (var pos in ViewModel.AvailablePos)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Elevation="3"
                              Class="pos-touch-pos-card"
                              Style="cursor: pointer; border-radius: 16px;"
                              @onclick="@(() => OnPosCardSelectedAsync(pos))">
                        <MudStack AlignItems="AlignItems.Center" Spacing="1" Class="pa-5">
                            <MudIcon Icon="@Icons.Material.Filled.PointOfSale"
                                     Color="Color.Primary"
                                     Style="font-size: 2.5rem;" />
                            <MudText Typo="Typo.h6" Style="font-weight: 600; text-align: center;">
                                @pos.Name
                            </MudText>
                            @if (!string.IsNullOrEmpty(pos.Location))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @pos.Location
                                </MudText>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>

        <div class="d-flex justify-center mt-4">
            <MudButton Variant="Variant.Text"
                       StartIcon="@Icons.Material.Outlined.ArrowBack"
                       OnClick="@DeselectOperator">
                @TranslationService.GetTranslation("common.back", "Indietro")
            </MudButton>
        </div>
    </MudContainer>
}

<!-- ======================================================
     STEP 3 — Session active → main POS touch UI
     ====================================================== -->
else
{
    <!-- Compact top bar: operator + cassa (small) + customer + session actions -->
    <MudPaper Elevation="3" Class="pa-2 mb-2" Style="border-radius: 0 0 12px 12px; position: sticky; top: 0; z-index: 10;">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.NoWrap">

            <!-- Operator chip (small) -->
            <MudChip T="string"
                     Icon="@Icons.Material.Filled.Person"
                     Color="Color.Primary"
                     Size="Size.Small"
                     Variant="Variant.Filled"
                     Style="font-size: 0.75rem;">
                @(ViewModel.AvailableOperators.FirstOrDefault(o => o.Id == ViewModel.SelectedOperatorId)?.Name ?? "—")
            </MudChip>

            <!-- POS / Cassa chip (small) -->
            <MudChip T="string"
                     Icon="@Icons.Material.Filled.PointOfSale"
                     Color="Color.Default"
                     Size="Size.Small"
                     Variant="Variant.Outlined"
                     Style="font-size: 0.75rem;">
                @(ViewModel.AvailablePos.FirstOrDefault(p => p.Id == ViewModel.SelectedPosId)?.Name ?? "—")
            </MudChip>

            @if (ViewModel.IsUpdatingItems)
            {
                <MudProgressCircular Color="Color.Warning" Size="Size.Small" Indeterminate="true" />
            }

            <MudSpacer />

            <!-- Customer selector (compact) -->
            <div style="max-width: 200px; min-width: 120px;">
                <UnifiedBusinessPartySelector
                    SelectedBusinessParty="ViewModel.SelectedCustomer"
                    SelectedBusinessPartyChanged="@OnSelectedCustomerChangedAsync"
                    Title="@null"
                    Placeholder="@TranslationService.GetTranslation("sales.searchCustomer", "Cliente...")"
                    FilterByType="BusinessPartyType.Customer"
                    EditMode="EntityEditMode.QuickDialog"
                    CreateMode="EntityCreateMode.QuickDialog"
                    AllowQuickCreate="true"
                    AllowQuickEdit="true"
                    Disabled="@(!ViewModel.HasActiveSession)"
                    Dense="true" />
            </div>

            <!-- Park -->
            <MudTooltip Text="@TranslationService.GetTranslation("sales.parkTooltip", "Sospendi sessione (F3)")">
                <MudButton StartIcon="@Icons.Material.Outlined.Pause"
                           Color="Color.Warning"
                           Variant="Variant.Outlined"
                           Size="Size.Large"
                           OnClick="@ParkSessionAsync"
                           Disabled="@(!ViewModel.HasActiveSession)">
                    @TranslationService.GetTranslation("sales.park", "Sospendi")
                </MudButton>
            </MudTooltip>

            <!-- Cancel / Change operator -->
            <MudTooltip Text="@TranslationService.GetTranslation("sales.changeOperator", "Cambia operatore / annulla")">
                <MudButton StartIcon="@Icons.Material.Outlined.SwitchAccount"
                           Color="Color.Default"
                           Variant="Variant.Outlined"
                           Size="Size.Large"
                           OnClick="@AskCancelOrChangeAsync">
                    @TranslationService.GetTranslation("sales.change", "Cambia")
                </MudButton>
            </MudTooltip>

        </MudStack>
    </MudPaper>

    <!-- Main two-column layout -->
    <MudGrid Spacing="3" Class="px-2 pb-4">

        <!-- ============================================================
             LEFT COLUMN: Scanner + Keypad + Cart item edit
             ============================================================ -->
        <MudItem xs="12" lg="5">
            <MudStack Spacing="3">

                <!-- Product scanner -->
                <MudPaper Elevation="2" Class="pa-3" Style="border-radius: 12px;">
                    <UnifiedProductScanner
                        SelectedProduct="@_currentProduct"
                        SelectedProductChanged="@OnProductSelectedAsync"
                        Title="@TranslationService.GetTranslation("sales.scanProduct", "Scansiona Prodotto")"
                        Placeholder="@TranslationService.GetTranslation("sales.scanOrType", "Codice o nome...")"
                        SearchMode="ProductSearchMode.Both"
                        EditMode="ProductEditMode.Dialog"
                        CreateMode="ProductCreateMode.Dialog"
                        ShowProductInfo="false"
                        AllowClear="true"
                        AutoFocus="true"
                        Disabled="@(!ViewModel.HasActiveSession)"
                        OnProductWithCodeFound="@HandleProductWithCodeFoundAsync"
                        OnProductNotFound="@HandleProductNotFoundAsync" />
                </MudPaper>

                <!-- Keypad + mode toggle -->
                <MudPaper Elevation="2" Class="pa-3" Style="border-radius: 12px;">

                    <!-- Mode toggle -->
                    <MudButtonGroup Variant="Variant.Outlined"
                                    Size="Size.Medium"
                                    Class="mb-3 d-flex">
                        <MudButton Color="@(_keypadMode == KeypadMode.Quantity ? Color.Primary : Color.Default)"
                                   Variant="@(_keypadMode == KeypadMode.Quantity ? Variant.Filled : Variant.Outlined)"
                                   FullWidth="true"
                                   OnClick="@(() => SetKeypadMode(KeypadMode.Quantity))">
                            @TranslationService.GetTranslation("sales.quantity", "Qtà")
                        </MudButton>
                        <MudButton Color="@(_keypadMode == KeypadMode.Price ? Color.Primary : Color.Default)"
                                   Variant="@(_keypadMode == KeypadMode.Price ? Variant.Filled : Variant.Outlined)"
                                   FullWidth="true"
                                   OnClick="@(() => SetKeypadMode(KeypadMode.Price))">
                            @TranslationService.GetTranslation("sales.price", "Prezzo")
                        </MudButton>
                        <MudButton Color="@(_keypadMode == KeypadMode.Discount ? Color.Primary : Color.Default)"
                                   Variant="@(_keypadMode == KeypadMode.Discount ? Variant.Filled : Variant.Outlined)"
                                   FullWidth="true"
                                   OnClick="@(() => SetKeypadMode(KeypadMode.Discount))">
                            @TranslationService.GetTranslation("sales.discountMode", "Sc. %")
                        </MudButton>
                    </MudButtonGroup>

                    <!-- Keypad label (shows selected item context) -->
                    <POSTouchNumericKeypad @ref="_numericKeypad"
                                           Value="@_keypadValue"
                                           ValueChanged="@OnKeypadValueChanged"
                                           Label="@KeypadLabel"
                                           AllowDecimal="@(_keypadMode != KeypadMode.Quantity)" />

                    <!-- Apply button (visible when a cart item is selected) -->
                    <MudStack Row="true" Spacing="2" Class="mt-2">

                        @if (_selectedCartItem != null)
                        {
                            <!-- Apply to selected item -->
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       Size="Size.Large"
                                       StartIcon="@Icons.Material.Filled.Check"
                                       OnClick="@ApplyKeypadToSelectedItemAsync"
                                       Disabled="@ViewModel.IsUpdatingItems">
                                @TranslationService.GetTranslation("common.apply", "Applica")
                            </MudButton>

                            <!-- Deselect -->
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Color="Color.Default"
                                           Variant="Variant.Outlined"
                                           Size="Size.Large"
                                           OnClick="@DeselectCartItem" />
                        }
                        else
                        {
                            <!-- Hint when nothing selected -->
                            <MudText Typo="Typo.caption"
                                     Color="Color.Secondary"
                                     Class="d-flex align-center justify-center"
                                     Style="flex: 1; text-align: center; font-style: italic;">
                                @TranslationService.GetTranslation("sales.touchItemOrScan",
                                    "Tocca un articolo nel carrello per modificarlo, oppure scansiona un prodotto")
                            </MudText>
                        }

                    </MudStack>
                </MudPaper>

                <!-- Quick actions row -->
                @if (ViewModel.CurrentSession?.Items.Any() == true)
                {
                    <MudPaper Elevation="1" Class="pa-2" Style="border-radius: 12px;">
                        <MudStack Row="true" Spacing="1" Justify="Justify.SpaceAround" Wrap="Wrap.Wrap">

                            <MudButton Variant="Variant.Text"
                                       Color="Color.Warning"
                                       StartIcon="@Icons.Material.Outlined.Discount"
                                       Size="Size.Medium"
                                       OnClick="@ApplyGlobalDiscountAsync">
                                @TranslationService.GetTranslation("sales.discountShort", "Sconto")
                            </MudButton>

                            <MudButton Variant="Variant.Text"
                                       Color="Color.Success"
                                       StartIcon="@Icons.Material.Outlined.LocalOffer"
                                       Size="Size.Medium"
                                       OnClick="@ApplyCouponAsync">
                                @TranslationService.GetTranslation("sales.coupon", "Coupon")
                            </MudButton>

                            <MudButton Variant="Variant.Text"
                                       Color="Color.Info"
                                       StartIcon="@Icons.Material.Outlined.Note"
                                       Size="Size.Medium"
                                       OnClick="@AddSessionNoteAsync">
                                @TranslationService.GetTranslation("sales.notes", "Note")
                            </MudButton>

                            <MudButton Variant="Variant.Text"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Outlined.RemoveCircle"
                                       Size="Size.Medium"
                                       OnClick="@RemoveLastItemAsync">
                                @TranslationService.GetTranslation("sales.removeLastItem", "Rimuovi Ult.")
                            </MudButton>

                            <MudButton Variant="Variant.Text"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Outlined.DeleteSweep"
                                       Size="Size.Medium"
                                       OnClick="@ClearCartAsync">
                                @TranslationService.GetTranslation("sales.clearCart", "Svuota")
                            </MudButton>

                        </MudStack>
                    </MudPaper>
                }

            </MudStack>
        </MudItem>

        <!-- ============================================================
             RIGHT COLUMN: Cart list + Summary + Actions
             ============================================================ -->
        <MudItem xs="12" lg="7">
            <MudStack Spacing="3">

                <!-- Loading progress -->
                @if (ViewModel.IsUpdatingItems)
                {
                    <MudProgressLinear Color="Color.Primary"
                                       Indeterminate="true"
                                       Style="border-radius: 4px;" />
                }

                <!-- Cart list (scrollable) -->
                <div style="max-height: 55vh; overflow-y: auto; padding-right: 4px;">
                    <POSTouchCartList Items="@ViewModel.CurrentSession?.Items"
                                      SelectedItem="@_selectedCartItem"
                                      IsDisabled="@ViewModel.IsUpdatingItems"
                                      OnItemSelected="@OnCartItemSelectedAsync"
                                      OnItemEditRequested="@OpenLineEditDialogAsync"
                                      OnIncreaseQuantity="@IncreaseQuantityAsync"
                                      OnDecreaseQuantity="@DecreaseQuantityAsync"
                                      OnRemoveItem="@RemoveItemAsync" />
                </div>

                <!-- Totals summary -->
                @if (ViewModel.CurrentSession != null)
                {
                    <MudPaper Elevation="3" Class="pa-4" Style="border-radius: 12px;">

                        <MudStack Spacing="1">

                            @if (ViewModel.CurrentSession.DiscountAmount > 0)
                            {
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @TranslationService.GetTranslation("sales.subtotal", "Subtotale")
                                    </MudText>
                                    <MudText Typo="Typo.body2">
                                        @ViewModel.CurrentSession.OriginalTotal.ToString("C")
                                    </MudText>
                                </MudStack>

                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Color="Color.Warning">
                                        @TranslationService.GetTranslation("sales.discount", "Sconto")
                                    </MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Warning">
                                        -@ViewModel.CurrentSession.DiscountAmount.ToString("C")
                                    </MudText>
                                </MudStack>
                            }

                            @if (ViewModel.CurrentSession.TaxAmount > 0)
                            {
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @TranslationService.GetTranslation("sales.vat", "IVA")
                                    </MudText>
                                    <MudText Typo="Typo.body2">
                                        @ViewModel.CurrentSession.TaxAmount.ToString("C")
                                    </MudText>
                                </MudStack>
                            }

                            <MudDivider Class="my-1" />

                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6" Style="font-weight: 700;">
                                    @TranslationService.GetTranslation("sales.total", "TOTALE")
                                </MudText>
                                <MudText Typo="Typo.h4" Style="font-weight: 800; color: var(--mud-palette-primary);">
                                    @ViewModel.GrandTotal.ToString("C")
                                </MudText>
                            </MudStack>

                            <!-- Payments already added -->
                            @foreach (var payment in ViewModel.CurrentSession.Payments.Where(p => p.Status == PaymentStatusDto.Completed))
                            {
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Color="Color.Success">
                                        ✓ @payment.PaymentMethodName
                                    </MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Success">
                                        @payment.Amount.ToString("C")
                                    </MudText>
                                </MudStack>
                            }

                            @if (ViewModel.CurrentSession.RemainingAmount > 0)
                            {
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body1" Color="Color.Error" Style="font-weight: 600;">
                                        @TranslationService.GetTranslation("sales.remaining", "Da pagare")
                                    </MudText>
                                    <MudText Typo="Typo.body1" Color="Color.Error" Style="font-weight: 600;">
                                        @ViewModel.CurrentSession.RemainingAmount.ToString("C")
                                    </MudText>
                                </MudStack>
                            }

                        </MudStack>

                    </MudPaper>
                }

                <!-- Main action button -->
                <POSActionButton Session="@ViewModel.CurrentSession"
                                 IsSessionClosed="@ViewModel.IsSessionClosed"
                                 OnAddPayment="@AddPaymentAsync"
                                 OnCloseSale="@CloseSaleAsync"
                                 OnPrintReceipt="@PrintReceiptAsync" />

            </MudStack>
        </MudItem>

    </MudGrid>
}

<style>
    .pos-touch-pos-card {
        border: 2px solid transparent;
        transition: all 0.15s ease;
    }

    .pos-touch-pos-card:active {
        transform: scale(0.97);
        border-color: var(--mud-palette-primary);
    }
</style>

@code {
    // =====================================================================
    //  State
    // =====================================================================

    private ProductDto? _currentProduct;
    private SaleItemDto? _selectedCartItem;
    private decimal _keypadValue = 1m;
    private KeypadMode _keypadMode = KeypadMode.Quantity;
    private POSTouchNumericKeypad? _numericKeypad;

    private enum KeypadMode { Quantity, Price, Discount }

    // =====================================================================
    //  Lifecycle
    // =====================================================================

    protected override async Task OnInitializedAsync()
    {
        ViewModel.StateChanged += StateHasChanged;
        ViewModel.OnNotification += HandleNotification;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var username = authState.User.Identity?.Name;

        await ViewModel.InitializeAsync(username);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ConnectFiscalHubAsync();
        }
    }

    public async ValueTask DisposeAsync()
    {
        ViewModel.StateChanged -= StateHasChanged;
        ViewModel.OnNotification -= HandleNotification;
        ViewModel.Dispose();

        if (_fiscalHubConnection is not null)
        {
            try
            {
                if (_fiscalPrinterId.HasValue)
                    await _fiscalHubConnection.SendAsync("UnsubscribeFromPrinter", _fiscalPrinterId.Value);
                await _fiscalHubConnection.DisposeAsync();
            }
            catch { /* swallowed during disposal */ }
        }
    }

    // =====================================================================
    //  Operator & POS selection (touch cards)
    // =====================================================================

    private async Task OnOperatorCardSelectedAsync(StoreUserDto op)
    {
        ViewModel.SelectedOperatorId = op.Id;

        // If only one POS available auto-select it
        if (ViewModel.AvailablePos.Count == 1)
        {
            ViewModel.SelectedPosId = ViewModel.AvailablePos[0].Id;
        }

        await Task.CompletedTask;
    }

    private async Task OnPosCardSelectedAsync(StorePosDto pos)
    {
        ViewModel.SelectedPosId = pos.Id;
        await LoadFiscalDrawerAsync();
    }

    private void DeselectOperator()
    {
        ViewModel.SelectedOperatorId = null;
        ViewModel.SelectedPosId = null;
    }

    // =====================================================================
    //  Product handling
    // =====================================================================

    private async Task OnProductSelectedAsync(ProductDto? product)
    {
        if (product == null) return;

        var qty = (_keypadMode == KeypadMode.Quantity && _keypadValue > 0) ? _keypadValue : 1m;

        var result = await ViewModel.AddProductAsync(product);

        if (result.Success)
        {
            // If the keypad holds a quantity other than 1, override the added item's quantity
            if (qty != 1m && ViewModel.CurrentSession?.Items != null)
            {
                var addedItem = ViewModel.CurrentSession.Items.FirstOrDefault(i => i.ProductId == product.Id);
                if (addedItem != null)
                {
                    addedItem.Quantity = qty;
                    ViewModel.QueueItemUpdate(addedItem);
                }
            }

            _currentProduct = null;
            ResetKeypad();
            AppNotification.ShowSuccess($"✅ {product.Name} aggiunto");
        }
        else
        {
            AppNotification.ShowError(result.Error ?? "Errore");
        }
    }

    private Task HandleProductWithCodeFoundAsync(ProductWithCodeDto productWithCode)
    {
        // SelectedProductChanged has already been fired by UnifiedProductScanner before
        // OnProductWithCodeFound, so OnProductSelectedAsync was already called and the
        // product has been added to the cart. Do NOT call it again here to prevent double-add.
        return Task.CompletedTask;
    }

    private async Task HandleProductNotFoundAsync(string barcode)
    {
        var parameters = new DialogParameters { { "Barcode", barcode } };
        var dialog = await DialogService.ShowAsync<ProductNotFoundDialog>(
            TranslationService.GetTranslation("warehouse.productNotFound", "Prodotto non trovato"),
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });

        var result = await dialog.Result;

        if (result is { Canceled: false } && result.Data != null)
        {
            if (result.Data is string action && action == "skip") return;
            if (result.Data is ProductDto product) { await OnProductSelectedAsync(product); return; }
            if (result.Data is ProductNotFoundDialog.AssignResult assignResult)
            {
                await OnProductSelectedAsync(assignResult.Product);
            }
        }
    }

    private async Task OnSelectedCustomerChangedAsync(BusinessPartyDto? customer)
    {
        await ViewModel.UpdateSelectedCustomerAsync(customer);
    }

    // =====================================================================
    //  Keypad handling
    // =====================================================================

    private void OnKeypadValueChanged(decimal value)
    {
        _keypadValue = value;
    }

    private void SetKeypadMode(KeypadMode mode)
    {
        _keypadMode = mode;

        // Pre-fill keypad from selected item if one is selected
        if (_selectedCartItem != null)
        {
            _keypadValue = mode switch
            {
                KeypadMode.Quantity => _selectedCartItem.Quantity,
                KeypadMode.Price    => _selectedCartItem.UnitPrice,
                KeypadMode.Discount => _selectedCartItem.DiscountPercent,
                _                   => 0m
            };
            _numericKeypad?.SetValue(_keypadValue);
        }
        else
        {
            _keypadValue = mode == KeypadMode.Quantity ? 1m : 0m;
            _numericKeypad?.SetValue(_keypadValue);
        }
    }

    private string GetKeypadModeLabel() => _keypadMode switch
    {
        KeypadMode.Quantity => TranslationService.GetTranslation("sales.quantity", "Quantità"),
        KeypadMode.Price    => TranslationService.GetTranslation("sales.price", "Prezzo (€)"),
        KeypadMode.Discount => TranslationService.GetTranslation("sales.discount", "Sconto (%)"),
        _                   => string.Empty
    };

    private string KeypadLabel =>
        _selectedCartItem != null
            ? $"{_selectedCartItem.ProductName} — {GetKeypadModeLabel()}"
            : GetKeypadModeLabel();

    private void ResetKeypad()
    {
        _keypadMode = KeypadMode.Quantity;
        _keypadValue = 1m;
        _numericKeypad?.SetValue(1m);
    }

    // =====================================================================
    //  Cart item selection & editing
    // =====================================================================

    private Task OnCartItemSelectedAsync(SaleItemDto item)
    {
        _selectedCartItem = _selectedCartItem?.Id == item.Id ? null : item;

        if (_selectedCartItem != null)
        {
            // Pre-fill keypad with the right value for current mode
            _keypadValue = _keypadMode switch
            {
                KeypadMode.Quantity => _selectedCartItem.Quantity,
                KeypadMode.Price    => _selectedCartItem.UnitPrice,
                KeypadMode.Discount => _selectedCartItem.DiscountPercent,
                _                   => 1m
            };
            _numericKeypad?.SetValue(_keypadValue);
        }

        return Task.CompletedTask;
    }

    private void DeselectCartItem()
    {
        _selectedCartItem = null;
        ResetKeypad();
    }

    private async Task OpenLineEditDialogAsync(SaleItemDto item)
    {
        if (ViewModel.IsUpdatingItems) return;

        var parameters = new DialogParameters
        {
            [nameof(POSTouchLineEditDialog.Item)] = item
        };

        var dialog = await DialogService.ShowAsync<POSTouchLineEditDialog>(
            string.Empty,
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = false, CloseButton = false });

        var result = await dialog.Result;

        if (result is { Canceled: false } && result.Data is POSTouchLineEditDialog.EditResult editResult)
        {
            // Direct mutation + QueueItemUpdate is the established optimistic-update pattern
            // used throughout this page (see also ApplyKeypadToSelectedItemAsync).
            item.Quantity = editResult.Quantity;
            item.UnitPrice = editResult.UnitPrice;
            item.DiscountPercent = editResult.DiscountPercent;
            ViewModel.QueueItemUpdate(item);
        }
    }

    private async Task ApplyKeypadToSelectedItemAsync()
    {
        if (_selectedCartItem == null || ViewModel.IsUpdatingItems) return;

        switch (_keypadMode)
        {
            case KeypadMode.Quantity:
                if (_keypadValue <= 0) return;
                _selectedCartItem.Quantity = _keypadValue;
                break;

            case KeypadMode.Price:
                if (_keypadValue < 0) return;
                _selectedCartItem.UnitPrice = _keypadValue;
                break;

            case KeypadMode.Discount:
                if (_keypadValue is < 0 or > 100) return;
                _selectedCartItem.DiscountPercent = _keypadValue;
                break;
        }

        ViewModel.QueueItemUpdate(_selectedCartItem);
        DeselectCartItem();
        await Task.CompletedTask;
    }

    private void IncreaseQuantityAsync(SaleItemDto item)
    {
        if (ViewModel.IsUpdatingItems) return;
        item.Quantity++;
        ViewModel.QueueItemUpdate(item);
    }

    private void DecreaseQuantityAsync(SaleItemDto item)
    {
        if (ViewModel.IsUpdatingItems) return;
        if (item.Quantity > 1)
        {
            item.Quantity--;
            ViewModel.QueueItemUpdate(item);
        }
    }

    private async Task RemoveItemAsync(SaleItemDto item)
    {
        if (!ViewModel.HasActiveSession) return;

        if (item.Quantity > 1 || item.TotalAmount > 50)
        {
            bool? confirm = await DialogService.ShowMessageBoxAsync(
                TranslationService.GetTranslation("common.confirm", "Conferma"),
                TranslationService.GetTranslation("sales.confirmRemoveItem",
                    "Rimuovere {0} (x{1}) per {2}?",
                    item.ProductName, item.Quantity, item.TotalAmount.ToString("C")),
                yesText: TranslationService.GetTranslation("common.yes", "Sì"),
                cancelText: TranslationService.GetTranslation("common.no", "No"));

            if (confirm != true) return;
        }

        if (_selectedCartItem?.Id == item.Id) DeselectCartItem();

        var result = await ViewModel.RemoveItemAsync(item);
        if (!result.Success && result.Error != null)
            AppNotification.ShowError("❌ " + result.Error);
    }

