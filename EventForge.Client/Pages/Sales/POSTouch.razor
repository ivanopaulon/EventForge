    private async Task ApplyGlobalDiscountAsync()
    {
        var parameters = new DialogParameters
        {
            ["CurrentTotal"] = ViewModel.CurrentSession?.FinalTotal ?? 0m
        };

        var dialog = await DialogService.ShowAsync<GlobalDiscountDialog>(
            TranslationService.GetTranslation("sales.globalDiscountTitle", "Sconto Globale Carrello"),
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small });

        var result = await dialog.Result;
        if (result is { Canceled: false } && result.Data is decimal discountPercent)
        {
            var dto = new ApplyGlobalDiscountDto
            {
                DiscountPercent = discountPercent,
                Reason = TranslationService.GetTranslation("sales.globalDiscountReason", "Sconto globale POS")
            };
            var updated = await ViewModel.ApplyGlobalDiscountAsync(dto);
            if (updated != null)
                AppNotification.ShowSuccess($"✅ Sconto {discountPercent}% applicato — Nuovo totale: €{updated.FinalTotal:F2}");
            else
                AppNotification.ShowError("❌ Errore applicazione sconto");
        }
    }

    private async Task ApplyCouponAsync()
    {
        var dialog = await DialogService.ShowAsync<CouponInputDialog>(
            TranslationService.GetTranslation("sales.applyCoupon", "Applica Coupon"),
            new DialogOptions { MaxWidth = MaxWidth.Small });

        var dialogResult = await dialog.Result;
        if (dialogResult is not null && !dialogResult.Canceled && dialogResult.Data is string code && !string.IsNullOrWhiteSpace(code))
        {
            var (success, promotionName, error) = await ViewModel.ApplyCouponAsync(code);
            if (success) AppNotification.ShowSuccess($"✅ Coupon applicato: {promotionName}");
            else AppNotification.ShowWarning($"❌ {error}");
        }
    }

    private async Task AddSessionNoteAsync()
    {
        var parameters = new DialogParameters
        {
            ["SessionId"] = ViewModel.CurrentSession?.Id
        };

        var dialog = await DialogService.ShowAsync<SessionNoteDialog>(
            TranslationService.GetTranslation("sales.addSessionNote", "Aggiungi Nota Vendita"),
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small });

        var result = await dialog.Result;
        if (result is { Canceled: false } && result.Data is AddSessionNoteDto noteDto)
        {
            var updated = await ViewModel.AddSessionNoteAsync(noteDto);
            if (updated != null) AppNotification.ShowSuccess($"✅ Nota aggiunta: {noteDto.Text}");
            else AppNotification.ShowError("❌ Errore aggiunta nota");
        }
    }

    private async Task RemoveLastItemAsync()
    {
        if (ViewModel.CurrentSession?.Items.Any() != true) return;
        var lastItem = ViewModel.CurrentSession.Items.Last();
        var result = await ViewModel.RemoveItemAsync(lastItem);
        if (result.Success)
            AppNotification.ShowSuccess($"✅ {lastItem.ProductName} rimosso");
    }

    private async Task ClearCartAsync()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            TranslationService.GetTranslation("common.confirm", "Conferma"),
            TranslationService.GetTranslation("sales.clearCartConfirm", "Sei sicuro di voler svuotare il carrello?"),
            yesText: TranslationService.GetTranslation("sales.clearCart", "Svuota"),
            cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));

        if (confirmed == true)
        {
            var items = ViewModel.CurrentSession?.Items.ToList();
            if (items != null)
            {
                foreach (var item in items)
                    await ViewModel.RemoveItemAsync(item);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("sales.cartCleared", "Carrello svuotato"));
            }
        }
    }

    private async Task AddPaymentAsync()
    {
        if (!ViewModel.HasActiveSession) { AppNotification.ShowWarning("Nessuna sessione attiva"); return; }
        if (!ViewModel.CurrentSession!.Items.Any()) { AppNotification.ShowWarning("Aggiungi prodotti prima di pagare"); return; }
        if (ViewModel.CurrentSession.IsFullyPaid) { AppNotification.ShowInfo("Il conto è già saldato"); return; }

        var parameters = new DialogParameters
        {
            { "TotalAmount", ViewModel.CurrentSession.FinalTotal },
            { "AlreadyPaid", ViewModel.CurrentSession.Payments.Where(p => p.Status == PaymentStatusDto.Completed).Sum(p => p.Amount) },
            { "PaymentMethods", ViewModel.PaymentMethods }
        };

        var dialog = await DialogService.ShowAsync<PaymentDialog>(
            TranslationService.GetTranslation("sales.payBill", "Paga Conto"), parameters);

        var result = await dialog.Result;

        if (result is { Canceled: false } && result.Data is PaymentDialog.PaymentDialogResult paymentDialogResult)
        {
            var ok = 0; var ko = 0;
            foreach (var p in paymentDialogResult.Payments)
            {
                var r = await ViewModel.AddPaymentAsync(p.Method, p.Amount);
                if (r.Success) ok++; else ko++;
            }
            if (ok > 0) AppNotification.ShowSuccess(TranslationService.GetTranslation("sales.paymentSuccess", "Pagamento completato!"));
            if (ko > 0) AppNotification.ShowError("Errore durante il pagamento");
        }
    }

    private async Task CloseSaleAsync()
    {
        var sessionSnapshot = ViewModel.CurrentSession;
        var result = await ViewModel.CloseSaleAsync();

        if (!result.Success && result.Error != null) { AppNotification.ShowError(result.Error); return; }

        if (sessionSnapshot is not null && _fiscalPrinterId.HasValue)
            await TriggerFiscalPrintAsync(sessionSnapshot);
    }

    private async Task ParkSessionAsync()
    {
        var result = await ViewModel.ParkSessionAsync();
        if (!result.Success && result.Error != null)
            AppNotification.ShowError(result.Error);
    }

    private async Task AskCancelOrChangeAsync()
    {
        if (!ViewModel.HasActiveSession)
        {
            DeselectOperator();
            return;
        }

        bool? confirm = await DialogService.ShowMessageBoxAsync(
            TranslationService.GetTranslation("sales.cancelSession", "Annulla Sessione"),
            TranslationService.GetTranslation("sales.cancelSessionConfirm",
                "Sei sicuro di voler annullare questa sessione? Tutti i dati andranno persi."),
            yesText: TranslationService.GetTranslation("common.yes", "Sì"),
            cancelText: TranslationService.GetTranslation("common.no", "No"));

        if (confirm == true)
        {
            var result = await ViewModel.CancelSessionAsync();
            if (!result.Success && result.Error != null)
                AppNotification.ShowError(result.Error);
            else
                DeselectOperator();
        }
    }

    private async Task PrintReceiptAsync()
    {
        if (!ViewModel.HasActiveSession) return;
        try
        {
            var content = GenerateReceiptContent(ViewModel.CurrentSession!);
            await JSRuntime.InvokeVoidAsync("printReceipt", content);
            AppNotification.ShowInfo(TranslationService.GetTranslation("sales.printingReceipt", "Stampa scontrino in corso..."));
        }
        catch (Exception)
        {
            AppNotification.ShowError(TranslationService.GetTranslation("errors.printError", "Errore durante la stampa"));
        }
    }

    private static string GenerateReceiptContent(SaleSessionDto session)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("<!DOCTYPE html><html><head><meta charset='utf-8'>");
        sb.AppendLine("<style>body{font-family:'Courier New',monospace;width:80mm;margin:0 auto;}");
        sb.AppendLine("h1{text-align:center;font-size:18px;margin:10px 0;}");
        sb.AppendLine(".header{text-align:center;border-bottom:2px dashed #000;padding-bottom:10px;margin-bottom:10px;}");
        sb.AppendLine(".item{margin:5px 0;}.item-name{font-weight:bold;}");
        sb.AppendLine(".item-details{display:flex;justify-content:space-between;font-size:12px;}");
        sb.AppendLine(".totals{border-top:2px dashed #000;padding-top:10px;margin-top:10px;}");
        sb.AppendLine(".total-row{display:flex;justify-content:space-between;margin:3px 0;}");
        sb.AppendLine(".grand-total{font-size:16px;font-weight:bold;border-top:2px solid #000;padding-top:5px;margin-top:5px;}");
        sb.AppendLine("</style></head><body>");
        sb.AppendLine("<div class='header'><h1>SCONTRINO</h1>");
        sb.AppendLine($"<p>Sessione: #{session.Id.ToString("N")[..8]}</p>");
        sb.AppendLine($"<p>{DateTime.Now:dd/MM/yyyy HH:mm:ss}</p></div>");
        foreach (var item in session.Items)
        {
            sb.AppendLine("<div class='item'>");
            sb.AppendLine($"<div class='item-name'>{item.ProductName}</div>");
            sb.AppendLine("<div class='item-details'>");
            sb.Append($"<span>{item.Quantity} x {item.UnitPrice:C}");
            if (item.DiscountPercent > 0) sb.Append($" (-{item.DiscountPercent:F1}%)");
            sb.AppendLine("</span>");
            sb.AppendLine($"<span>{item.TotalAmount:C}</span></div></div>");
        }
        sb.AppendLine("<div class='totals'>");
        sb.AppendLine($"<div class='total-row grand-total'><span>TOTALE:</span><span>{session.FinalTotal:C}</span></div></div>");
        sb.AppendLine("<script>window.onload=function(){window.print();};</script></body></html>");
        return sb.ToString();
    }

