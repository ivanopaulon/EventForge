    /// <summary>
    /// Triggers fiscal printing after a successful sale closure.
    /// Builds a <see cref="FiscalReceiptData"/> from the closed session, including
    /// loyalty information if available, and calls the fiscal printing service.
    /// Falls back gracefully (toast notification) if the printer is offline.
    /// </summary>
    private async Task TriggerFiscalPrintAsync(SaleSessionDto session)
    {
        try
        {
            var receipt = BuildFiscalReceiptData(session);

            var printResult = await FiscalPrintingService.PrintReceiptAsync(
                _fiscalPrinterId!.Value, receipt);

            if (printResult is null)
            {
                Logger.LogWarning(
                    "FiscalPrintingService.PrintReceiptAsync returned null for session {SessionId}",
                    session.Id);
                AppNotification.ShowWarning(
                    TranslationService.GetTranslation(
                        "fiscal.printWarning",
                        "Stampa fiscale non disponibile. Controllare la stampante."));
                return;
            }

            if (printResult.Success)
            {
                Logger.LogInformation(
                    "Fiscal receipt printed successfully | Session={SessionId} ReceiptNo={ReceiptNo}",
                    session.Id, printResult.ReceiptNumber);

                AppNotification.ShowSuccess(
                    TranslationService.GetTranslation(
                        "fiscal.printSuccess",
                        $"Scontrino fiscale {printResult.ReceiptNumber} emesso correttamente."));
            }
            else
            {
                Logger.LogWarning(
                    "Fiscal printing failed | Session={SessionId} Error={Error}",
                    session.Id, printResult.ErrorMessage);

                AppNotification.ShowError(
                    TranslationService.GetTranslation(
                        "fiscal.printError",
                        $"Errore stampa fiscale: {printResult.ErrorMessage ?? "stampante non disponibile."}"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error during fiscal printing for session {SessionId}", session.Id);
            AppNotification.ShowError(
                TranslationService.GetTranslation(
                    "fiscal.printUnexpectedError",
                    "Errore imprevisto durante la stampa fiscale. Verificare la stampante."));
        }
    }

    /// <summary>
    /// Maps a closed <see cref="SaleSessionDto"/> to a <see cref="FiscalReceiptData"/>
    /// ready to be sent to the fiscal printer.
    /// </summary>
    private static FiscalReceiptData BuildFiscalReceiptData(SaleSessionDto session)
    {
        var items = session.Items.Select(item => new FiscalReceiptItem
        {
            Description = item.ProductName ?? item.ProductCode ?? "Articolo",
            Quantity = (decimal)(item.Quantity),
            UnitPrice = item.UnitPrice,
            VatCode = 1, // Default VAT code – mapping is handled server-side by IFiscalMappingService
            Department = 1
        }).ToList();

        var payments = session.Payments.Select(p => new FiscalPayment
        {
            Amount = p.Amount,
            MethodCode = 1, // Default – server-side mapping resolves the fiscal code
            Description = p.PaymentMethodName ?? "Pagamento"
        }).ToList();

        return new FiscalReceiptData
        {
            Items = items,
            Payments = payments
        };
    }
}
