@code {
    // ─── JS module ───────────────────────────────────────────────────────────
    private IJSObjectReference? _jsModule;

    // ─── State ───────────────────────────────────────────────────────────────
    [Parameter] public bool HideFab { get; set; }

    private bool _isPanelOpen;
    private bool _isMinimised;
    private bool _isLoading;

    private Guid _currentUserId;
    private Guid _currentTenantId;

    private List<ChatResponseDto> _chats = new();
    private ChatResponseDto? _selectedChat;
    private List<ChatMessageDto> _messages = new();

    private string _searchQuery = string.Empty;
    private string _newMessage = string.Empty;
    private bool _isTyping;

    private readonly HashSet<Guid> _typingUsers = new();
    private readonly Dictionary<Guid, CancellationTokenSource> _typingCts = new();
    private CancellationTokenSource? _myTypingCts;

    // ─── Computed ─────────────────────────────────────────────────────────────
    public int TotalUnread => _chats.Sum(c => c.UnreadCount);

    private IEnumerable<ChatResponseDto> FilteredChats =>
        string.IsNullOrWhiteSpace(_searchQuery)
            ? _chats
            : _chats.Where(c => GetChatName(c).Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

    // ─── Lifecycle ────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetCurrentUserAsync();
        if (user != null)
        {
            _currentUserId = user.Id;
            _currentTenantId = user.TenantId;
        }

        if (!RealtimeService.IsChatConnected)
        {
            await RealtimeService.StartChatConnectionAsync();
        }

        ChatService.ChatCreated += OnChatCreated;
        ChatService.MessageReceived += OnMessageReceived;
        ChatService.TypingIndicator += OnTypingIndicator;
        ChatService.UserOnlineStatusChanged += OnUserOnlineStatusChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _jsModule = await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./Shared/Components/FloatingChat.razor.js");
            }
            catch (Exception ex) { Logger.LogWarning(ex, "Could not import FloatingChat JS module"); }
        }
    }

    // ─── Panel lifecycle ──────────────────────────────────────────────────────
    public async Task OpenPanel()
    {
        _isPanelOpen = true;
        _isMinimised = false;
        await LoadChats();
    }

    private void MinimisePanel()
    {
        _isMinimised = true;
    }

    private async Task ClosePanel()
    {
        if (_selectedChat != null)
            await LeaveCurrentChat();

        _isPanelOpen = false;
        _isMinimised = false;
        _selectedChat = null;
        _messages.Clear();
        _typingUsers.Clear();
    }

    // ─── Chat list ────────────────────────────────────────────────────────────
    private async Task LoadChats()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            _chats = await ChatService.GetChatsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading chat list");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OpenChat(ChatResponseDto chat)
    {
        _selectedChat = chat;
        _messages.Clear();
        _typingUsers.Clear();
        _isLoading = true;
        StateHasChanged();

        try
        {
            _messages = await ChatService.GetMessagesAsync(chat.Id);
            await ChatService.MarkMessagesAsReadAsync(chat.Id);
            chat.UnreadCount = 0;

            try
            {
                await RealtimeService.JoinChatAsync(chat.Id);
            }
            catch (Exception ex)
            {
                // JoinChatAsync may be unavailable in some configurations
                Logger.LogWarning(ex, "Could not join SignalR chat room {ChatId}", chat.Id);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error opening chat {ChatId}", chat.Id);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }

        await ScrollToBottom();
    }

    private async Task BackToList()
    {
        if (_selectedChat != null)
            await LeaveCurrentChat();

        _selectedChat = null;
        _messages.Clear();
        _typingUsers.Clear();
        StateHasChanged();
    }

    private async Task LeaveCurrentChat()
    {
        if (_selectedChat == null) return;

        if (_isTyping)
        {
            _isTyping = false;
            try { await ChatService.UpdateTypingStatusAsync(_selectedChat.Id, false); }
            catch (Exception) { }
        }

        try
        {
            await RealtimeService.LeaveChatAsync(_selectedChat.Id);
        }
        catch (Exception)
        {
            // LeaveChatAsync may be unavailable in some configurations
        }

        CancelAllTypingTimers();
    }

    // ─── Messaging ────────────────────────────────────────────────────────────
    private async Task SendMessage()
    {
        if (_selectedChat == null || string.IsNullOrWhiteSpace(_newMessage)) return;

        var content = _newMessage.Trim();
        _newMessage = string.Empty;

        CancelMyTypingTimer();
        if (_isTyping)
        {
            _isTyping = false;
            try { await ChatService.UpdateTypingStatusAsync(_selectedChat.Id, false); }
            catch (Exception) { }
        }

        // Optimistic UI: show the message immediately before server confirmation
        var optimisticId = Guid.NewGuid();
        var optimisticMsg = new ChatMessageDto
        {
            Id = optimisticId,
            ChatId = _selectedChat.Id,
            SenderId = _currentUserId,
            SenderName = "Tu",
            Content = content,
            SentAt = DateTime.UtcNow
        };
        _messages.Add(optimisticMsg);
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            var dto = new SendMessageDto
            {
                ChatId = _selectedChat.Id,
                SenderId = _currentUserId,
                Content = content
            };
            var sent = await ChatService.SendMessageAsync(dto);

            // Replace optimistic message with the server-confirmed one
            var idx = _messages.FindIndex(m => m.Id == optimisticId);
            if (idx >= 0)
                _messages[idx] = sent;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error sending message to chat {ChatId}", _selectedChat.Id);
            // Remove optimistic message on failure
            _messages.RemoveAll(m => m.Id == optimisticId);
        }

        StateHasChanged();
        await ScrollToBottom();
    }

    private async Task OnMessageChanged(string? value)
    {
        _newMessage = value ?? string.Empty;

        if (_selectedChat == null) return;

        if (!string.IsNullOrEmpty(_newMessage))
        {
            if (!_isTyping)
            {
                _isTyping = true;
                try { await ChatService.UpdateTypingStatusAsync(_selectedChat.Id, true); }
                catch (Exception) { }
            }

            // Reset the auto-stop typing timer
            CancelMyTypingTimer();
            _myTypingCts = new CancellationTokenSource();
            var token = _myTypingCts.Token;
            var chatId = _selectedChat.Id;

            _ = Task.Run(async () =>
            {
                try
                {
                    await Task.Delay(3000, token);
                    if (!token.IsCancellationRequested)
                    {
                        await InvokeAsync(async () =>
                        {
                            _isTyping = false;
                            try { await ChatService.UpdateTypingStatusAsync(chatId, false); }
                            catch (Exception) { }
                        });
                    }
                }
                catch (TaskCanceledException) { }
            }, token);
        }
        else if (_isTyping)
        {
            // Input cleared → stop typing immediately
            CancelMyTypingTimer();
            _isTyping = false;
            try { await ChatService.UpdateTypingStatusAsync(_selectedChat.Id, false); }
            catch (Exception) { }
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private async Task ScrollToBottom()
    {
        try
        {
            if (_jsModule != null)
                await _jsModule.InvokeVoidAsync("scrollToBottom", "fc-scroll");
        }
        catch (Exception) { }
    }

    // ─── Real-time event handlers ─────────────────────────────────────────────
    private void OnChatCreated(ChatResponseDto chat)
    {
        if (!_chats.Any(c => c.Id == chat.Id))
        {
            _chats.Insert(0, chat);
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnMessageReceived(ChatMessageDto message)
    {
        if (_selectedChat != null && message.ChatId == _selectedChat.Id)
        {
            // Avoid duplicates (optimistic messages share the same content but different Id)
            if (!_messages.Any(m => m.Id == message.Id))
            {
                _messages.Add(message);
                InvokeAsync(async () =>
                {
                    StateHasChanged();
                    await ScrollToBottom();
                });
            }
        }
        else
        {
            // Increment unread counter for background chats
            var chat = _chats.FirstOrDefault(c => c.Id == message.ChatId);
            if (chat != null)
            {
                chat.UnreadCount++;
                // Update LastMessage preview
                chat.LastMessage = message;
                InvokeAsync(StateHasChanged);
            }
        }
    }

    private void OnTypingIndicator(TypingIndicatorDto indicator)
    {
        if (_selectedChat == null || indicator.ChatId != _selectedChat.Id) return;
        if (indicator.UserId == _currentUserId) return;

        if (indicator.IsTyping)
        {
            _typingUsers.Add(indicator.UserId);

            // Cancel any existing auto-clear for this user
            if (_typingCts.TryGetValue(indicator.UserId, out var existing))
            {
                existing.Cancel();
                existing.Dispose();
            }

            var cts = new CancellationTokenSource();
            _typingCts[indicator.UserId] = cts;
            var userId = indicator.UserId;

            _ = Task.Run(async () =>
            {
                try
                {
                    await Task.Delay(3000, cts.Token);
                    if (!cts.Token.IsCancellationRequested)
                    {
                        await InvokeAsync(() =>
                        {
                            _typingUsers.Remove(userId);
                            if (_typingCts.TryGetValue(userId, out var c))
                            {
                                _typingCts.Remove(userId);
                                c.Dispose();
                            }
                            StateHasChanged();
                        });
                    }
                }
                catch (TaskCanceledException) { }
            }, cts.Token);
        }
        else
        {
            _typingUsers.Remove(indicator.UserId);
            if (_typingCts.TryGetValue(indicator.UserId, out var cts))
            {
                cts.Cancel();
                cts.Dispose();
                _typingCts.Remove(indicator.UserId);
            }
        }

        InvokeAsync(StateHasChanged);
    }

    // ─── Timer helpers ────────────────────────────────────────────────────────
    private void CancelMyTypingTimer()
    {
        _myTypingCts?.Cancel();
        _myTypingCts?.Dispose();
        _myTypingCts = null;
    }

    private void CancelAllTypingTimers()
    {
        CancelMyTypingTimer();
        foreach (var cts in _typingCts.Values)
        {
            cts.Cancel();
            cts.Dispose();
        }
        _typingCts.Clear();
        _typingUsers.Clear();
    }

    // ─── Display helpers ──────────────────────────────────────────────────────
    private string GetChatName(ChatResponseDto chat)
    {
        if (chat.Type == ChatType.DirectMessage)
        {
            var other = chat.Members?.FirstOrDefault(m => m.UserId != _currentUserId);
            return other?.DisplayName ?? $"Chat {chat.Id.ToString()[..8]}";
        }
        return chat.Name ?? $"Chat {chat.Id.ToString()[..8]}";
    }

    private bool IsDirectMessageOnline(ChatResponseDto chat)
    {
        if (chat.Type != ChatType.DirectMessage) return false;
        var other = chat.Members?.FirstOrDefault(m => m.UserId != _currentUserId);
        return other?.IsOnline ?? false;
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : name[..Math.Min(2, name.Length)].ToUpper();
    }

    private static readonly string[] AvatarColors =
    {
        "#f44336", "#e91e63", "#9c27b0", "#673ab7",
        "#3f51b5", "#2196f3", "#009688", "#4caf50"
    };

    private static string GetAvatarHex(string name)
    {
        if (string.IsNullOrEmpty(name)) return AvatarColors[0];
        unchecked
        {
            var hash = name.Aggregate(0, (acc, c) => acc * 31 + c);
            // Use double-modulo to ensure a non-negative index even when hash is negative
            return AvatarColors[((hash % AvatarColors.Length) + AvatarColors.Length) % AvatarColors.Length];
        }
    }

    private static string FormatTime(DateTime dt)
    {
        var now = DateTime.UtcNow;
        if (dt.Date == now.Date) return dt.ToLocalTime().ToString("HH:mm");
        if (dt.Date == now.Date.AddDays(-1)) return "Ieri";
        return dt.ToLocalTime().ToString("dd/MM");
    }

    private void OnUserOnlineStatusChanged(Guid userId, bool isOnline)
    {
        // Update cached online status for members in the chat list
        foreach (var chat in _chats)
        {
            var member = chat.Members?.FirstOrDefault(m => m.UserId == userId);
            if (member != null)
            {
                member.IsOnline = isOnline;
            }
        }
        InvokeAsync(StateHasChanged);
    }

    // ─── Disposal ─────────────────────────────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        ChatService.ChatCreated -= OnChatCreated;
        ChatService.MessageReceived -= OnMessageReceived;
        ChatService.TypingIndicator -= OnTypingIndicator;
        ChatService.UserOnlineStatusChanged -= OnUserOnlineStatusChanged;

        CancelAllTypingTimers();

        if (_selectedChat != null)
        {
            try { await RealtimeService.LeaveChatAsync(_selectedChat.Id); }
            catch (Exception) { }
        }

        if (_jsModule != null)
        {
            try { await _jsModule.DisposeAsync(); }
            catch (Exception) { }
        }
    }
}
