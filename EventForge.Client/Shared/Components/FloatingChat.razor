@namespace EventForge.Client.Shared.Components
@using EventForge.DTOs.Chat
@inject IChatService ChatService
@inject IAuthService AuthService
@inject IRealtimeService RealtimeService
@inject IJSRuntime JS
@inject ILogger<FloatingChat> Logger
@implements IAsyncDisposable

<!-- Floating Action Button – visible when panel is closed or minimised -->
@if (!HideFab && (!_isPanelOpen || _isMinimised))
{
    <div class="fc-fab">
        <MudBadge Content="@TotalUnread" Color="Color.Error" Overlap="true" Visible="@(TotalUnread > 0)" Max="99">
            <MudFab Color="Color.Primary"
                    StartIcon="@Icons.Material.Filled.Chat"
                    Size="Size.Small"
                    OnClick="OpenPanel"
                    title="Chat"
                    aria-label="Apri chat" />
        </MudBadge>
    </div>
}

<!-- Floating Panel -->
@if (_isPanelOpen && !_isMinimised)
{
    <div class="fc-panel mud-elevation-8">

        <!-- Header -->
        <div class="fc-header mud-background-primary mud-theme-primary">
            @if (_selectedChat != null)
            {
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit" Size="Size.Small" OnClick="BackToList" />
                <MudAvatar Style="@($"background-color:{GetAvatarHex(GetChatName(_selectedChat))};color:#fff;width:32px;height:32px;min-width:32px;font-size:0.75rem;")" Size="Size.Small">
                    @GetInitials(GetChatName(_selectedChat))
                </MudAvatar>
                <div class="fc-header-info">
                    <span class="fc-header-title">@GetChatName(_selectedChat)</span>
                    @if (IsDirectMessageOnline(_selectedChat))
                    {
                        <span class="fc-online-label">● Online</span>
                    }
                </div>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.Chat" Color="Color.Inherit" Class="mr-2" />
                <span class="fc-header-title">Messaggi</span>
            }
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Remove" Color="Color.Inherit" Size="Size.Small" OnClick="MinimisePanel" title="Minimizza" />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" Size="Size.Small" OnClick="ClosePanel" title="Chiudi" />
        </div>

        @if (_isLoading)
        {
            <div class="fc-loading">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
            </div>
        }
        else if (_selectedChat == null)
        {
            <!-- Chat list view -->
            <div class="fc-search-bar">
                <MudTextField T="string"
                              Value="@_searchQuery"
                              ValueChanged="@(v => _searchQuery = v ?? string.Empty)"
                              Placeholder="Cerca chat..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Clearable="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Immediate="true"
                              Class="fc-search-field" />
            </div>

            <div class="fc-chat-list">
                @if (!_chats.Any())
                {
                    <div class="fc-empty">
                        <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Class="fc-empty-icon" />
                        <span>Nessuna chat</span>
                    </div>
                }
                else
                {
                    @foreach (var chat in FilteredChats)
                    {
                        <div class="fc-chat-item" @onclick="() => OpenChat(chat)">
                            <div class="fc-chat-avatar-wrap">
                                <MudAvatar Style="@($"background-color:{GetAvatarHex(GetChatName(chat))};color:#fff;font-size:0.8rem;")" Size="Size.Small">
                                    @GetInitials(GetChatName(chat))
                                </MudAvatar>
                                @if (IsDirectMessageOnline(chat))
                                {
                                    <span class="fc-online-dot"></span>
                                }
                            </div>
                            <div class="fc-chat-item-info">
                                <div class="fc-chat-item-header">
                                    <span class="fc-chat-item-name">@GetChatName(chat)</span>
                                    @if (chat.LastMessage != null)
                                    {
                                        <span class="fc-chat-item-time">@FormatTime(chat.LastMessage.SentAt)</span>
                                    }
                                </div>
                                <span class="fc-chat-item-preview">@(chat.LastMessage?.Content ?? "Nessun messaggio")</span>
                            </div>
                            @if (chat.UnreadCount > 0)
                            {
                                <MudBadge Content="@chat.UnreadCount" Color="Color.Primary" Overlap="false" Max="99" Class="fc-unread-badge" />
                            }
                        </div>
                    }
                }
            </div>
        }
        else
        {
            <!-- Conversation view -->
            <div class="fc-messages" id="fc-scroll">
                @if (!_messages.Any())
                {
                    <div class="fc-empty">
                        <span>Nessun messaggio. Inizia a scrivere!</span>
                    </div>
                }
                @foreach (var msg in _messages)
                {
                    var isMine = msg.SenderId == _currentUserId;
                    <div class="fc-msg-row @(isMine ? "fc-msg-row--mine" : "fc-msg-row--theirs")">
                        @if (!isMine)
                        {
                            <MudAvatar Style="@($"background-color:{GetAvatarHex(msg.SenderName ?? "?")};color:#fff;font-size:0.7rem;width:28px;height:28px;min-width:28px;")" Size="Size.Small">
                                @GetInitials(msg.SenderName ?? "?")
                            </MudAvatar>
                        }
                        <div class="fc-bubble @(isMine ? "fc-bubble--mine" : "fc-bubble--theirs")">
                            @if (!isMine && _selectedChat.Type != ChatType.DirectMessage)
                            {
                                <span class="fc-bubble-sender">@msg.SenderName</span>
                            }
                            <span class="fc-bubble-text">@msg.Content</span>
                            <span class="fc-bubble-time">@msg.SentAt.ToString("HH:mm")</span>
                        </div>
                    </div>
                }
                @if (_typingUsers.Count > 0)
                {
                    <div class="fc-msg-row fc-msg-row--theirs">
                        <div class="fc-typing-indicator">
                            <span class="fc-typing-dot"></span>
                            <span class="fc-typing-dot"></span>
                            <span class="fc-typing-dot"></span>
                        </div>
                    </div>
                }
            </div>

            <!-- Input bar -->
            <div class="fc-input-bar" @onkeydown="OnKeyDown">
                <MudTextField T="string"
                              Value="@_newMessage"
                              ValueChanged="@OnMessageChanged"
                              Placeholder="Scrivi un messaggio..."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Immediate="true"
                              Lines="1"
                              Class="fc-input-field" />
                <MudIconButton Icon="@Icons.Material.Filled.Send"
                               Color="Color.Primary"
                               OnClick="SendMessage"
                               Disabled="@(string.IsNullOrWhiteSpace(_newMessage))"
                               aria-label="Invia messaggio" />
            </div>
        }
    </div>
}

<style>
