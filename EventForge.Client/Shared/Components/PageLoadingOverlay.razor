@using MudBlazor
@implements IDisposable

@if (Visible)
{
    <MudOverlay Visible="@Visible" DarkBackground="true" AutoClose="false">
        <MudStack AlignItems="AlignItems.Center" Style="min-width: 320px; max-width: 480px;">

            <MudImage Src="@IconPath" Width="@Size" Height="@Size" Class="@AnimationClass" />
            <MudText Typo="Typo.h3" Style="color:white; font-weight:bold">
                EventForge
            </MudText>

            @if (!string.IsNullOrEmpty(Message))
            {
                <MudText Typo="Typo.h5" Style="color:white; font-weight:bold">@Message</MudText>
            }

            @if (ShowProgressLog && _progressLog.Count > 0)
            {
                <MudPaper Outlined="true" Class="pa-3 mt-2" Style="width:100%; background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.2);">
                    <MudStack Spacing="1">
                        @for (var i = 0; i < _progressLog.Count; i++)
                        {
                            var logMsg = _progressLog[i];
                            var logOpacity = i == 0 ? "1" : i == 1 ? "0.6" : "0.3";
                            var isFirst = i == 0;
                            <div class="d-flex align-center gap-2" style="opacity:@logOpacity">
                                @if (isFirst)
                                {
                                    <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Color="Color.Primary" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.CheckCircleOutline" Size="MudBlazor.Size.Small" Color="Color.Success" />
                                }
                                <MudText Typo="Typo.body2"
                                         Style="@(isFirst ? "color:white; font-weight:600" : "color:rgba(255,255,255,0.75)")">
                                    @logMsg
                                </MudText>
                            </div>
                        }
                    </MudStack>
                </MudPaper>
            }

            @if (ShowElapsedTime)
            {
                <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.6)">
                    ⏱ @((int)(DateTimeOffset.UtcNow - _startTime).TotalSeconds)s trascorsi
                </MudText>
            }

        </MudStack>
    </MudOverlay>
}

@code {
    // ── Parametri esistenti (backward compatible) ──
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string? Message { get; set; }
    [Parameter] public string IconPath { get; set; } = "trace.svg";
    [Parameter] public int Size { get; set; } = 96;
    [Parameter] public LoadingAnimationType Animation { get; set; } = LoadingAnimationType.Pulse;

    // ── Nuovi parametri opzionali ──
    [Parameter] public bool ShowProgressLog { get; set; } = false;
    [Parameter] public IReadOnlyList<string>? ProgressMessages { get; set; }
    [Parameter] public bool ShowElapsedTime { get; set; } = false;
    [Parameter] public int ProgressIntervalMs { get; set; } = 2500;

    private string AnimationClass => Animation switch
    {
        LoadingAnimationType.Blink => "anim-blink",
        LoadingAnimationType.Pulse => "anim-pulse",
        LoadingAnimationType.None => string.Empty,
        _ => "anim-pulse"
    };

    private readonly List<string> _progressLog = new();
    private DateTimeOffset _startTime;
    private CancellationTokenSource? _progressCts;
    private bool _wasVisible = false;

    public enum LoadingAnimationType { Blink, Pulse, None }

    protected override void OnParametersSet()
    {
        if (Visible && !_wasVisible)
        {
            _startTime = DateTimeOffset.UtcNow;
            _progressLog.Clear();
            if (ShowProgressLog && ProgressMessages?.Count > 0)
                StartProgressTracker();
        }
        else if (!Visible && _wasVisible)
        {
            StopProgressTracker();
            _progressLog.Clear();
        }
        _wasVisible = Visible;
    }

    private void StartProgressTracker()
    {
        StopProgressTracker();
        _progressCts = new CancellationTokenSource();
        _ = RunProgressTrackerAsync(_progressCts.Token);
    }

    private async Task RunProgressTrackerAsync(CancellationToken ct)
    {
        if (ProgressMessages == null || ProgressMessages.Count == 0) return;
        var msgIndex = 0;
        try
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(ProgressIntervalMs, ct);
                var msg = ProgressMessages[msgIndex % ProgressMessages.Count];
                _progressLog.Insert(0, msg);
                if (_progressLog.Count > 3)
                    _progressLog.RemoveAt(3);
                msgIndex++;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException) { /* expected */ }
    }

    private void StopProgressTracker()
    {
        _progressCts?.Cancel();
        _progressCts?.Dispose();
        _progressCts = null;
    }

    public void Dispose() => StopProgressTracker();
}

<style>
    .page-loading-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.35);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9998; /* below dialogs but above page content */
    }

    .page-loading-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 16px 24px;
        border-radius: 8px;
        backdrop-filter: blur(2px);
    }

    .loading-icon {
        display: block;
        object-fit: contain;
    }

    /* Blink animation: quick on/off visibility */
    .anim-blink {
        animation: blink 1.2s infinite ease-in-out;
    }

    @@keyframes blink {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.15; transform: scale(0.98); }
    }

    /* Pulse animation: soft scale + glow */
    .anim-pulse {
        animation: pulse 1.6s infinite ease-in-out;
        filter: drop-shadow(0 0 6px rgba(0,0,0,0.15));
    }

    @@keyframes pulse {
        0% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.06); opacity: 0.9; }
        100% { transform: scale(1); opacity: 1; }
    }

    @@media (prefers-reduced-motion: reduce) {
        .anim-blink, .anim-pulse {
            animation: none !important;
            transition: none !important;
        }
    }
</style>