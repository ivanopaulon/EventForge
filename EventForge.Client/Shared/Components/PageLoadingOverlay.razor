@using MudBlazor
@implements IDisposable

@if (Visible)
{
    <MudOverlay Visible="@Visible" DarkBackground="true" AutoClose="false"
                Style="backdrop-filter: blur(3px);">

        <div class="plo-card">

            @* Progress bar on top of the card *@
            <div class="plo-progress">
                <MudProgressLinear Color="@ProgressColor"
                                   Indeterminate="@(ProgressValue == null)"
                                   Value="@(ProgressValue ?? 0)"
                                   Max="100"
                                   Style="height:3px; border-radius: 4px 4px 0 0; margin:0;" />
            </div>

            <div class="plo-body">

                @* Left: logo *@
                <div class="plo-logo-col">
                    <img src="@IconPath"
                         width="@Size"
                         height="@Size"
                         class="plo-logo @AnimationClass"
                         alt="PRYM logo" />
                </div>

                @* Right: title + message + log *@
                <div class="plo-content-col">

                    <div class="plo-title">PRYM</div>
                    <div class="plo-divider"></div>

                    @if (!string.IsNullOrEmpty(Message))
                    {
                        <div class="plo-message">@Message</div>
                    }

                    @if (ShowProgressLog && _progressLog.Count > 0)
                    {
                        <div class="plo-log">
                            @for (var i = 0; i < _progressLog.Count; i++)
                            {
                                var logMsg = _progressLog[i];
                                var isFirst = i == 0;
                                var opacity = isFirst ? "1.0" : i == 1 ? "0.5" : "0.25";
                                <div class="plo-log-row @(isFirst ? "plo-log-active" : "")"
                                     style="opacity:@opacity">
                                    <span class="plo-log-icon">
                                        @if (isFirst)
                                        {
                                            <MudProgressCircular Size="MudBlazor.Size.Small"
                                                                 Indeterminate="true"
                                                                 Color="Color.Primary"
                                                                 Style="width:14px;height:14px;" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircleOutline"
                                                     Size="MudBlazor.Size.Small"
                                                     Style="color:#66bb6a;font-size:14px;" />
                                        }
                                    </span>
                                    <span class="plo-log-text @(isFirst ? "plo-log-text-active" : "")">
                                        @logMsg
                                    </span>
                                </div>
                            }
                        </div>
                    }

                    @if (ShowElapsedTime)
                    {
                        var elapsed = (int)(DateTimeOffset.UtcNow - _startTime).TotalSeconds;
                        <div class="plo-elapsed">
                            ⏱ @elapsed@(elapsed == 1 ? "s trascorso" : "s trascorsi")
                        </div>
                    }

                </div>
            </div>
        </div>
    </MudOverlay>
}

@code {
    // ── Parametri backward-compatible ──
    [Parameter] public bool Visible { get; set; }

    [Parameter]
    public bool IsVisible
    {
        get => Visible;
        set => Visible = value;
    }

    [Parameter] public string? Message { get; set; }
    [Parameter] public string IconPath { get; set; } = "trace.svg";
    [Parameter] public int Size { get; set; } = 96;
    [Parameter] public LoadingAnimationType Animation { get; set; } = LoadingAnimationType.Pulse;

    // ── Parametri progress log ──
    [Parameter] public bool ShowProgressLog { get; set; } = false;
    [Parameter] public IReadOnlyList<string>? ProgressMessages { get; set; }
    [Parameter] public bool ShowElapsedTime { get; set; } = false;
    [Parameter] public int ProgressIntervalMs { get; set; } = 2500;

    // ── Nuovi parametri: barra lineare ──
    /// <summary>null = indeterminate; 0–100 = determinate</summary>
    [Parameter] public double? ProgressValue { get; set; } = null;
    [Parameter] public Color ProgressColor { get; set; } = Color.Primary;

    public enum LoadingAnimationType { Blink, Pulse, None }

    private string AnimationClass => Animation switch
    {
        LoadingAnimationType.Blink => "anim-blink",
        LoadingAnimationType.Pulse => "anim-pulse",
        LoadingAnimationType.None  => string.Empty,
        _                          => "anim-pulse"
    };

    private readonly List<string> _progressLog = new();
    private DateTimeOffset _startTime;
    private CancellationTokenSource? _progressCts;
    private System.Threading.Timer? _elapsedTimer;
    private bool _wasVisible = false;

    protected override void OnParametersSet()
    {
        if (Visible && !_wasVisible)
        {
            _startTime = DateTimeOffset.UtcNow;
            _progressLog.Clear();

            if (ShowProgressLog && ProgressMessages?.Count > 0)
                StartProgressTracker();

            if (ShowElapsedTime)
                StartElapsedTimer();
        }
        else if (!Visible && _wasVisible)
        {
            StopProgressTracker();
            StopElapsedTimer();
            _progressLog.Clear();
        }
        _wasVisible = Visible;
    }

    private void StartProgressTracker()
    {
        StopProgressTracker();
        _progressCts = new CancellationTokenSource();
        _ = RunProgressTrackerAsync(_progressCts.Token);
    }

    private async Task RunProgressTrackerAsync(CancellationToken ct)
    {
        if (ProgressMessages == null || ProgressMessages.Count == 0) return;
        var msgIndex = 0;
        try
        {
            while (!ct.IsCancellationRequested)
            {
                // Insert first, then delay — so first message is immediate
                var msg = ProgressMessages[msgIndex % ProgressMessages.Count];
                _progressLog.Insert(0, msg);
                if (_progressLog.Count > 3) _progressLog.RemoveAt(3);
                msgIndex++;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(ProgressIntervalMs, ct);
            }
        }
        catch (TaskCanceledException) { }
    }

    private void StopProgressTracker()
    {
        _progressCts?.Cancel();
        _progressCts?.Dispose();
        _progressCts = null;
    }

    private void StartElapsedTimer()
    {
        StopElapsedTimer();
        _elapsedTimer = new System.Threading.Timer(_ =>
        {
            _ = InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private void StopElapsedTimer()
    {
        if (_elapsedTimer != null)
        {
            _elapsedTimer.Change(Timeout.Infinite, Timeout.Infinite);
            _elapsedTimer.Dispose();
            _elapsedTimer = null;
        }
    }

    public void Dispose()
    {
        StopProgressTracker();
        StopElapsedTimer();
    }
}

<style>
    /* ── Card container ── */
    .plo-card {
        background: rgba(18, 18, 32, 0.92);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.65);
        backdrop-filter: blur(8px);
        min-width: 340px;
        max-width: 540px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    /* ── Progress bar strip on top ── */
    .plo-progress {
        line-height: 0;
        font-size: 0;
    }

    /* ── Body: logo left + content right ── */
    .plo-body {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 20px;
        padding: 20px 24px 20px 20px;
    }

    /* ── Logo column ── */
    .plo-logo-col {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .plo-logo {
        display: block;
        object-fit: contain;
        filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.5));
    }

    /* ── Content column ── */
    .plo-content-col {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .plo-title {
        color: white;
        font-size: 1.35rem;
        font-weight: 800;
        letter-spacing: 0.5px;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
        line-height: 1.2;
    }

    .plo-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.15);
        margin: 2px 0;
    }

    .plo-message {
        color: rgba(255, 255, 255, 0.82);
        font-size: 0.9rem;
        font-weight: 500;
        line-height: 1.4;
    }

    /* ── Log panel ── */
    .plo-log {
        display: flex;
        flex-direction: column;
        gap: 3px;
        margin-top: 4px;
    }

    .plo-log-row {
        display: flex;
        align-items: center;
        gap: 8px;
        transition: opacity 0.4s ease;
    }

    .plo-log-active {
        border-left: 2px solid rgba(100, 160, 255, 0.75);
        padding-left: 6px;
        margin-left: -8px;
    }

    .plo-log-icon {
        flex-shrink: 0;
        width: 16px;
        height: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .plo-log-text {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.7);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .plo-log-text-active {
        color: white;
        font-weight: 600;
    }

    /* ── Elapsed ── */
    .plo-elapsed {
        color: rgba(255, 255, 255, 0.45);
        font-size: 0.72rem;
        margin-top: 4px;
    }

    /* ── Animations ── */
    .anim-blink {
        animation: plo-blink 1.2s infinite ease-in-out;
    }

    @@keyframes plo-blink {
        0%, 100% { opacity: 1;    transform: scale(1);    }
        50%       { opacity: 0.15; transform: scale(0.97); }
    }

    .anim-pulse {
        animation: plo-pulse 1.8s infinite ease-in-out;
    }

    @@keyframes plo-pulse {
        0%   { transform: scale(1);    filter: drop-shadow(0 0 10px rgba(100,160,255,0.3)); }
        50%  { transform: scale(1.07); filter: drop-shadow(0 0 20px rgba(100,160,255,0.6)); }
        100% { transform: scale(1);    filter: drop-shadow(0 0 10px rgba(100,160,255,0.3)); }
    }

    /* ── Mobile: stack vertically ── */
    @@media (max-width: 480px) {
        .plo-card {
            min-width: unset;
            max-width: 92vw;
            width: 92vw;
        }

        .plo-body {
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 12px;
            padding: 16px;
        }

        .plo-log-active {
            border-left: none;
            padding-left: 0;
            margin-left: 0;
        }
    }

    @@media (prefers-reduced-motion: reduce) {
        .anim-blink, .anim-pulse {
            animation: none !important;
        }
    }
</style>