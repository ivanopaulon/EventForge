@using EventForge.DTOs.Health
@using EventForge.DTOs.Profile
@using EventForge.DTOs.Auth
@using EventForge.Client.Services
@using EventForge.Client.Services.Updates
@using EventForge.Client.Shared.Components.Dialogs
@using System.IdentityModel.Tokens.Jwt
@inject IHealthService HealthService
@inject IProfileService ProfileService
@inject IAuthService AuthService
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject ILogger<HealthFooter> Logger
@implements IDisposable

<!-- 
    Health Footer Component (Minimal & Compact)
    
    A minimal health status indicator with fullscreen dialog view.
    Features:
    - Compact tab showing overall health status
    - Fullscreen dialog for detailed health information
    - Essential health information only (API, Database)
    - Auto-refresh health data every 30 seconds
-->

<!-- Floating Health Status Button -->
@if (!HideFab)
{
    <div class="hf-fab">
        <MudFab Color="@GetOverallHealthFabColor()" 
                StartIcon="@Icons.Material.Filled.Monitor" 
                Size="Size.Small"
                OnClick="OpenHealthDialog"
                title="@GetHealthStatusTitle()"
                aria-label="@TranslationService.GetTranslation("health.openDialog", "View health status")" />
    </div>
}

@code {
    [Parameter] public bool HideFab { get; set; }

    private DetailedHealthStatusDto? _healthData;
    private AgentStatusClientDto? _agentStatusData;
    private DateTime? _lastUpdated;
    private Timer? _refreshTimer;
    private string? _errorMessage;

    /// <summary>
    /// Refresh interval for health data in milliseconds. Default is 30 seconds.
    /// </summary>
    [Parameter] public int RefreshInterval { get; set; } = 30000;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Initial health data load
            await RefreshHealthData();
            
            // Set up periodic refresh
            _refreshTimer = new Timer(async _ => 
            {
                await InvokeAsync(async () =>
                {
                    await RefreshHealthData();
                    StateHasChanged();
                });
            }, null, RefreshInterval, RefreshInterval);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing HealthFooter.");
        }
    }

    private async Task RefreshHealthData()
    {
        try
        {
            _errorMessage = null;
            _healthData = await HealthService.GetDetailedHealthAsync();
            _agentStatusData = await HealthService.GetAgentStatusAsync();

            if (_healthData == null)
            {
                _errorMessage = "Unable to retrieve health status from server";
                Logger.LogWarning("Health service returned null");
            }
            else
            {
                _lastUpdated = DateTime.Now;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading health status: {ex.Message}";
            Logger.LogError(ex, "Health status refresh failed: {Message}", ex.Message);
        }
    }

    public async Task OpenHealthDialog()
    {
        if (_healthData == null)
        {
            await RefreshHealthData();
        }

        // Fetch session enrichment data (silently, don't block dialog opening)
        List<ActiveSessionDto>? activeSessions = null;
        UserDto? currentUser = null;
        DateTime? tokenExpiresAt = null;

        try
        {
            // Fetch active sessions
            activeSessions = await ProfileService.GetActiveSessionsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to fetch active sessions: {Message}", ex.Message);
        }

        try
        {
            // Fetch current user
            currentUser = await AuthService.GetCurrentUserAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to fetch current user: {Message}", ex.Message);
        }

        try
        {
            // Fetch token and extract expiry
            var token = await AuthService.GetAccessTokenAsync();
            if (!string.IsNullOrEmpty(token))
            {
                tokenExpiresAt = TryGetJwtExpiry(token);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to extract token expiry: {Message}", ex.Message);
        }

        var parameters = new DialogParameters
        {
            { "HealthData", _healthData },
            { "LastUpdated", _lastUpdated },
            { "OnRefreshRequested", EventCallback.Factory.Create(this, RefreshHealthData) },
            { "ActiveSessions", activeSessions },
            { "CurrentUser", currentUser },
            { "TokenExpiresAt", tokenExpiresAt },
            { "ErrorMessage", _errorMessage }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraExtraLarge,
            FullWidth = true,
            CloseButton = false,
            CloseOnEscapeKey = true,
            BackdropClick = false
        };

        await DialogService.ShowAsync<HealthStatusDialog>("", parameters, options);
    }

    private string GetHealthStatusTitle()
    {
        return $"{TranslationService.GetTranslation("health.status", "Status")}: {GetOverallHealthStatus()}";
    }

    #region Health Status Helpers

    private Color GetStatusColor(string? status)
    {
        if (string.IsNullOrEmpty(status)) return Color.Default;
        
        return status.ToLower() switch
        {
            "healthy" => Color.Success,
            "degraded" => Color.Warning,
            "unhealthy" or "error" => Color.Error,
            "disabled" => Color.Info,
            _ => Color.Default
        };
    }

    public Color GetOverallHealthFabColor()
    {
        if (_healthData == null) return Color.Default;

        var statuses = new List<string?>
        {
            _healthData.ApiStatus,
            _healthData.DatabaseStatus
        };

        // Agent offline → warning (amber), but doesn't escalate to error
        if (_agentStatusData is not null && !_agentStatusData.Reachable)
        {
            if (statuses.All(s => s?.ToLower() == "healthy"))
                return Color.Warning;
        }

        if (statuses.Any(s => s?.ToLower() == "unhealthy" || s?.ToLower() == "error"))
            return Color.Error;
        else if (statuses.Any(s => s?.ToLower() == "degraded" || s?.ToLower() == "warning"))
            return Color.Warning;
        else if (statuses.Any(s => s?.ToLower() == "healthy"))
            return Color.Success;
        else
            return Color.Default;
    }

    private string GetOverallHealthStatus()
    {
        if (_healthData == null) return "Unknown";

        var statuses = new List<string?>
        {
            _healthData.ApiStatus,
            _healthData.DatabaseStatus
        };

        if (statuses.Any(s => s?.ToLower() == "unhealthy" || s?.ToLower() == "error"))
            return "Unhealthy";
        else if (statuses.Any(s => s?.ToLower() == "degraded" || s?.ToLower() == "warning"))
            return "Degraded";
        else if (statuses.Any(s => s?.ToLower() == "healthy"))
            return "Healthy";
        else
            return "Unknown";
    }

    #endregion

    #region Helper Methods

    private string FormatUptime(TimeSpan uptime)
    {
        if (uptime.TotalDays >= 1)
            return $"{uptime.Days}d {uptime.Hours}h {uptime.Minutes}m";
        else if (uptime.TotalHours >= 1)
            return $"{uptime.Hours}h {uptime.Minutes}m";
        else
            return $"{uptime.Minutes}m {uptime.Seconds}s";
    }

    /// <summary>
    /// Extracts the expiration date from a JWT token without exposing sensitive claims.
    /// </summary>
    private DateTime? TryGetJwtExpiry(string token)
    {
        try
        {
            var handler = new JwtSecurityTokenHandler();
            if (handler.CanReadToken(token))
            {
                var jwtToken = handler.ReadJwtToken(token);
                // ValidTo is already in UTC
                return jwtToken.ValidTo;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to parse JWT expiry: {Message}", ex.Message);
        }
        return null;
    }

    #endregion

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}

<style>
    .hf-fab {
        position: fixed;
        bottom: 16px;
        right: 16px;
        z-index: 1300;
        cursor: pointer;
    }

    @@media (max-width: 420px) {
        .hf-fab {
            bottom: 16px;
            right: 16px;
        }
    }
</style>
