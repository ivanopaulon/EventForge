@namespace EventForge.Client.Shared.Components
@using EventForge.DTOs.Auth
@using EventForge.DTOs.Tenants
@using MudBlazor
@inject IAuthService AuthService
@inject IAuthenticationDialogService AuthDialogService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@implements IDisposable

<EFOverlay Visible="@_isVisible"
           Subtitle="@_subtitle"
           TopBar="@_topBar"
           ShowProgressBar="true"
           ProgressColor="@_progressColor"
           ProgressIndeterminate="@_progressIndeterminate"
           ProgressValue="@_progressValue"
           LogoAnim="EFOverlay.EFOverlayLogoAnim.Pulse"
           CardWidth="420px">

    @if (_isLoadingTenants)
    {
        @* Inline loading state — no nested overlay *@
        <div class="lov-loading-row">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary"
                                 Style="width:22px;height:22px;flex-shrink:0;" />
            <span class="lov-loading-text">@_subtitle</span>
        </div>
    }
    else if (_isChangePasswordMode)
    {
        <ChangePasswordForm IsMandatory="_changePasswordIsMandatory"
                            OnCompleted="HandlePasswordChangeCompleted"
                            OnCancelled="HandlePasswordChangeCancelled" />
    }
    else
    {
        @* Login form *@
        <MudForm @ref="form" @bind-IsValid="@_isFormValid">
            <MudStack Spacing="2">

                @if (_tenants?.Any() == true)
                {
                    <MudSelect T="string" @bind-Value="_selectedTenantId"
                               Label="@TranslationService.GetTranslation("auth.selectTenant", "Seleziona Tenant")"
                               Variant="Variant.Outlined"
                               Required="true"
                               Dense="true"
                               Margin="Margin.Dense"
                               Disabled="_isLoading">
                        @foreach (var t in _tenants)
                        {
                            <MudSelectItem Value="@t.Id.ToString()">@($"{t.DisplayName} ({t.Name})")</MudSelectItem>
                        }
                    </MudSelect>
                }
                else
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        @TranslationService.GetTranslation("auth.noTenantsAvailable", "Nessun tenant disponibile. Contatta l'amministratore.")
                    </MudAlert>
                }

                <MudTextField @bind-Value="_loginRequest.Username"
                              Label="@TranslationService.GetTranslation("auth.username", "Username")"
                              Variant="Variant.Outlined"
                              Required="true"
                              Disabled="_isLoading"
                              autocomplete="username"
                              Margin="Margin.Dense"
                              InputType="InputType.Text" />

                <MudTextField @bind-Value="_loginRequest.Password"
                              Label="@TranslationService.GetTranslation("auth.password", "Password")"
                              Variant="Variant.Outlined"
                              InputType="@_passwordInputType"
                              Required="true"
                              Disabled="_isLoading"
                              autocomplete="current-password"
                              Margin="Margin.Dense"
                              Adornment="Adornment.End"
                              AdornmentIcon="@_passwordVisibilityIcon"
                              OnAdornmentClick="TogglePasswordVisibility" />

                <MudCheckBox T="bool" @bind-Value="_loginRequest.RememberMe"
                             Label="@TranslationService.GetTranslation("auth.rememberMe", "Ricordami")"
                             Disabled="_isLoading" />

            </MudStack>
        </MudForm>

        @* Secondary action row: Cancel (left) + Change Password (right) *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mt-3">
            <MudButton Variant="Variant.Text" Color="Color.Default"
                       OnClick="Cancel" Disabled="_isLoading">
                @TranslationService.GetTranslation("common.cancel", "Annulla")
            </MudButton>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                       OnClick="OpenChangePasswordInline" Disabled="_isLoading">
                @TranslationService.GetTranslation("auth.changePassword", "Cambia Password")
            </MudButton>
        </MudStack>

        @* Primary action: full-width to prevent spinner+text wrapping *@
        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                   OnClick="HandleLogin" Class="mt-2"
                   Disabled="@(!_isFormValid || _isLoading || _tenants?.Any() != true)">
            <span class="lov-btn-content">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                         Style="width:16px;height:16px;flex-shrink:0;" />
                }
                @TranslationService.GetTranslation("auth.login", "Accedi")
            </span>
        </MudButton>
    }

</EFOverlay>

@code {
    private bool _isVisible = false;
    private bool _isFormValid = false;
    private bool _isLoading = false;
    private bool _isLoadingTenants = false;
    private bool _isChangePasswordMode = false;
    private bool _changePasswordIsMandatory = false;
    private MudForm form = null!;
    private readonly LoginRequestDto _loginRequest = new();
    private List<TenantResponseDto> _tenants = new();
    private string? _selectedTenantId;
    private bool _passwordVisible = false;
    private InputType _passwordInputType = InputType.Password;
    private string _passwordVisibilityIcon = Icons.Material.Filled.VisibilityOff;
    private TaskCompletionSource<bool>? _currentTcs;
    private const string SubtitleLoginError = "Credenziali non valide. Riprova.";
    private Color _progressColor = Color.Primary;
    private bool _progressIndeterminate = false;
    private double _progressValue = 0;
    private string _subtitle = "Accedi al sistema";

    private EFOverlay.EFOverlayTopBar _topBar => _progressColor switch
    {
        Color.Success => EFOverlay.EFOverlayTopBar.Success,
        Color.Error   => EFOverlay.EFOverlayTopBar.Error,
        _             => EFOverlay.EFOverlayTopBar.Primary
    };

    protected override void OnInitialized()
    {
        AuthDialogService.LoginRequested += OnLoginRequested;
    }

    private async Task OnLoginRequested(TaskCompletionSource<bool> tcs)
    {
        _currentTcs = tcs;
        _isVisible = true;
        _progressColor = Color.Primary;
        _progressIndeterminate = false;
        _progressValue = 0;
        _subtitle = "Accedi al sistema";
        await InvokeAsync(StateHasChanged);
        await LoadTenantsAsync();
    }

    private async Task LoadTenantsAsync()
    {
        _isLoadingTenants = true;
        _subtitle = "Connessione al server...";
        await InvokeAsync(StateHasChanged);
        try
        {
            _tenants = (await AuthService.GetAvailableTenantsAsync()).ToList();
            if (_tenants.Any())
                _selectedTenantId ??= _tenants.First().Id.ToString();
        }
        catch (Exception ex)
        {
            AppNotification.ShowError(TranslationService.GetTranslation("auth.tenantsLoadError",
                    "Errore nel caricamento dei tenant: {0}", ex.Message));
            _tenants = new List<TenantResponseDto>();
        }
        finally
        {
            _isLoadingTenants = false;
            _subtitle = "Accedi al sistema";
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleLogin()
    {
        await form.ValidateAsync();
        if (!_isFormValid) return;

        if (string.IsNullOrWhiteSpace(_selectedTenantId))
        {
            AppNotification.ShowWarning(TranslationService.GetTranslation("auth.tenantRequired", "Seleziona un tenant"));
            return;
        }

        _loginRequest.TenantCode = _selectedTenantId;
        _isLoading = true;
        _progressColor = Color.Primary;
        _progressIndeterminate = true;
        _subtitle = "Autenticazione in corso...";
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = await AuthService.LoginAsync(_loginRequest);
            if (result != null)
            {
                AppNotification.ShowSuccess(TranslationService.GetTranslation("auth.loginSuccess", "Login effettuato con successo!"));

                if (result.MustChangePassword)
                {
                    HandleMustChangePassword();
                }
                else
                {
                    _progressIndeterminate = false;
                    _progressValue = 100;
                    _progressColor = Color.Success;
                    CloseOverlay(true);
                }
            }
            else
            {
                _progressIndeterminate = false;
                _progressValue = 100;
                _progressColor = Color.Error;
                _subtitle = SubtitleLoginError;
                AppNotification.ShowError(TranslationService.GetTranslation("auth.loginFailed", "Login fallito. Verifica le credenziali."));
            }
        }
        catch (Exception ex)
        {
            _progressIndeterminate = false;
            _progressValue = 100;
            _progressColor = Color.Error;
            _subtitle = SubtitleLoginError;
            AppNotification.ShowError(TranslationService.GetTranslation("auth.loginError", "Errore durante il login: {0}", ex.Message));
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void HandleMustChangePassword()
    {
        _isChangePasswordMode = true;
        _changePasswordIsMandatory = true;
        _isLoading = false;
        _progressIndeterminate = false;
        _progressValue = 0;
        _progressColor = Color.Primary;
        _subtitle = "Cambio password richiesto";
        InvokeAsync(StateHasChanged);
    }

    private void OpenChangePasswordInline()
    {
        _isChangePasswordMode = true;
        _changePasswordIsMandatory = false;
        _subtitle = "Cambio password richiesto";
        InvokeAsync(StateHasChanged);
    }

    private async Task HandlePasswordChangeCompleted()
    {
        if (_changePasswordIsMandatory)
        {
            _progressIndeterminate = false;
            _progressValue = 100;
            _progressColor = Color.Success;
            CloseOverlay(true);
        }
        else
        {
            _isChangePasswordMode = false;
            _subtitle = "Accedi al sistema";
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandlePasswordChangeCancelled()
    {
        if (_changePasswordIsMandatory)
        {
            AppNotification.ShowWarning(TranslationService.GetTranslation("auth.passwordChangeRequired",
                    "Cambio password obbligatorio. Effettua il logout."));
            await AuthService.LogoutAsync();
            CloseOverlay(false);
        }
        else
        {
            _isChangePasswordMode = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void Cancel()
    {
        CloseOverlay(false);
    }

    private void CloseOverlay(bool success)
    {
        _isVisible = false;
        _isLoading = false;
        _isLoadingTenants = false;
        _isChangePasswordMode = false;
        _isFormValid = false;
        _loginRequest.Username = string.Empty;
        _loginRequest.Password = string.Empty;
        _selectedTenantId = null;
        var tcs = _currentTcs;
        _currentTcs = null;
        InvokeAsync(StateHasChanged);
        tcs?.SetResult(success);
    }

    private void TogglePasswordVisibility()
    {
        if (_passwordVisible)
        {
            _passwordVisible = false;
            _passwordInputType = InputType.Password;
            _passwordVisibilityIcon = Icons.Material.Filled.VisibilityOff;
        }
        else
        {
            _passwordVisible = true;
            _passwordInputType = InputType.Text;
            _passwordVisibilityIcon = Icons.Material.Filled.Visibility;
        }
    }

    public void Dispose()
    {
        AuthDialogService.LoginRequested -= OnLoginRequested;
    }
}

<style>
    /* ── Loading state row ── */
    .lov-loading-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 0 6px 0;
    }

    .lov-loading-text {
        color: rgba(255, 255, 255, 0.80);
        font-size: 0.9rem;
    }

    /* ── Login button: keep spinner + label on one line ── */
    .lov-btn-content {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        white-space: nowrap;
    }
</style>
