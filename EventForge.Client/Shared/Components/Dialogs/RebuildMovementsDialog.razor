@using EventForge.DTOs.Warehouse
@using EventForge.DTOs.Documents
@inject IStockReconciliationService StockReconciliationService
@inject IWarehouseService WarehouseService
@inject IDocumentTypeService DocumentTypeService
@inject ITranslationService TranslationService
@inject ILogger<RebuildMovementsDialog> Logger

<MudDialog Style="min-width:min(750px,95vw);">
    <TitleContent>
        <div class="d-flex align-center gap-3">
            <MudIcon Icon="@Icons.Material.Outlined.BuildCircle" Color="Color.Primary" />
            <MudText Typo="Typo.h6">
                @TranslationService.GetTranslation("rebuildMovements.title", "Ricostruzione Movimenti da Documenti")
            </MudText>
        </div>
    </TitleContent>

    <DialogContent>
        @* ── Step indicator ── *@
        <div class="d-flex align-center mb-5 px-1">
            @foreach (var (label, idx) in new[] { ("1. Filtri", 0), ("2. Anteprima", 1), ("3. Applicazione", 2) })
            {
                var isActive = _step == idx;
                var isDone = _step > idx;
                <div class="d-flex align-center flex-grow-1 @(idx == 2 ? "" : "")">
                    <div class="d-flex align-center gap-1">
                        <MudAvatar Size="Size.Small"
                                   Color="@(isDone ? Color.Success : isActive ? Color.Primary : Color.Default)"
                                   Variant="@(isActive || isDone ? Variant.Filled : Variant.Outlined)">
                            @if (isDone)
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.Check" Size="Size.Small" />
                            }
                            else
                            {
                                @(idx + 1)
                            }
                        </MudAvatar>
                        <MudText Typo="Typo.body2"
                                 Color="@(isActive ? Color.Primary : isDone ? Color.Success : Color.Default)"
                                 Style="@(isActive ? "font-weight:600" : "")">
                            @label
                        </MudText>
                    </div>
                    @if (idx < 2)
                    {
                        <MudDivider Class="mx-2 flex-grow-1" />
                    }
                </div>
            }
        </div>

        @* ══════════════════════ STEP 1 — FILTRI ══════════════════════ *@
        @if (_step == 0)
        {
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="_fromDate"
                                   Label="@TranslationService.GetTranslation("common.dateFrom", "Data Da")"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Clearable="true"
                                   DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="_toDate"
                                   Label="@TranslationService.GetTranslation("common.dateTo", "Data A")"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Clearable="true"
                                   DateFormat="dd/MM/yyyy" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="_warehouseId"
                               Label="@TranslationService.GetTranslation("stock.warehouse", "Magazzino")"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true">
                        @foreach (var w in _warehouses)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)w.Id)">@w.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="_documentTypeId"
                               Label="@TranslationService.GetTranslation("rebuildMovements.documentType", "Tipo Documento")"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true">
                        @foreach (var dt in _documentTypes)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)dt.Id)">@dt.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">
                        @TranslationService.GetTranslation("rebuildMovements.approvalStatus", "Stato Approvazione")
                    </MudText>
                    <div class="d-flex flex-column gap-0">
                        <MudCheckBox @bind-Value="_includeApproved" Dense="true" Color="Color.Success"
                                     Label="@TranslationService.GetTranslation("rebuildMovements.approved", "Approvato")" />
                        <MudCheckBox @bind-Value="_includePending" Dense="true" Color="Color.Warning"
                                     Label="@TranslationService.GetTranslation("rebuildMovements.pending", "In Attesa")" />
                        <MudCheckBox @bind-Value="_includeRejected" Dense="true" Color="Color.Error"
                                     Label="@TranslationService.GetTranslation("rebuildMovements.rejected", "Rifiutato")" />
                        <MudCheckBox @bind-Value="_includeNoneApproval" Dense="true" Color="Color.Default"
                                     Label="@TranslationService.GetTranslation("rebuildMovements.approvalNone", "Nessuna")" />
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">
                        @TranslationService.GetTranslation("rebuildMovements.documentStatus", "Stato Documento")
                    </MudText>
                    <div class="d-flex flex-column gap-0">
                        <MudCheckBox @bind-Value="_includeClosed" Dense="true" Color="Color.Primary"
                                     Label="@TranslationService.GetTranslation("rebuildMovements.closed", "Chiuso")" />
                        <MudCheckBox @bind-Value="_includeOpen" Dense="true" Color="Color.Info"
                                     Label="@TranslationService.GetTranslation("rebuildMovements.open", "Aperto")" />
                        <MudCheckBox @bind-Value="_includeDraft" Dense="true" Color="Color.Default"
                                     Label="@TranslationService.GetTranslation("rebuildMovements.draft", "Bozza")" />
                        <MudCheckBox @bind-Value="_includeCancelled" Dense="true" Color="Color.Error"
                                     Label="@TranslationService.GetTranslation("rebuildMovements.cancelled", "Annullato")" />
                    </div>
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-1" />
                    <MudCheckBox @bind-Value="_updateExisting" Dense="true" Color="Color.Warning"
                                 Label="@TranslationService.GetTranslation("rebuildMovements.updateExisting", "Aggiorna movimenti esistenti (data, quantità, tipo)")"
                                 Class="mt-1" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary ml-8">
                        @TranslationService.GetTranslation("rebuildMovements.updateExistingHint", "Se attivo, i movimenti già collegati ai documenti vengono riallineati con i dati del documento.")
                    </MudText>
                </MudItem>
            </MudGrid>
        }

        @* ══════════════════════ STEP 2 — ANTEPRIMA ══════════════════════ *@
        else if (_step == 1)
        {
            @if (_isLoading)
            {
                <div class="d-flex flex-column align-center justify-center pa-8 gap-3">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                    <MudText Typo="Typo.body1">
                        @TranslationService.GetTranslation("rebuildMovements.calculatingPreview", "Calcolo anteprima in corso...")
                    </MudText>
                </div>
            }
            else if (_previewResult != null)
            {
                @* Summary chips *@
                <MudGrid Spacing="2" Class="mb-4">
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3 text-center" Elevation="2">
                            <MudText Typo="Typo.h5">@_previewResult.DocumentsScanned</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @TranslationService.GetTranslation("rebuildMovements.documents", "Documenti")
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3 text-center" Elevation="2" Style="border-left: 3px solid var(--mud-palette-success);">
                            <MudText Typo="Typo.h5" Color="Color.Success">@_previewResult.MovementsCreated</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @TranslationService.GetTranslation("rebuildMovements.toCreate", "Da creare")
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3 text-center" Elevation="2" Style="border-left: 3px solid var(--mud-palette-warning);">
                            <MudText Typo="Typo.h5" Color="Color.Warning">@_previewResult.MovementsUpdated</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @TranslationService.GetTranslation("rebuildMovements.toUpdate", "Da aggiornare")
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3 text-center" Elevation="2" Style="border-left: 3px solid var(--mud-palette-info);">
                            <MudText Typo="Typo.h5" Color="Color.Info">@_previewResult.RowsAlreadyHadMovement</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @TranslationService.GetTranslation("rebuildMovements.alreadyPresent", "Già presenti")
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3 text-center" Elevation="2"
                                  Style="@(_previewResult.RowsSkippedNoLocation + _previewResult.Errors > 0 ? "border-left: 3px solid var(--mud-palette-warning);" : "")">
                            <MudText Typo="Typo.h5"
                                     Color="@(_previewResult.RowsSkippedNoLocation + _previewResult.Errors > 0 ? Color.Warning : Color.Default)">
                                @(_previewResult.RowsSkippedNoLocation + _previewResult.Errors)
                            </MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @TranslationService.GetTranslation("rebuildMovements.skippedOrErrors", "Saltati / Errori")
                            </MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                @if (_previewResult.MovementsCreated == 0)
                {
                    <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Outlined.CheckCircle">
                        @TranslationService.GetTranslation("rebuildMovements.nothingToCreate",
                            "Nessun movimento mancante trovato. Tutti i documenti filtrati hanno già un movimento di magazzino associato.")
                    </MudAlert>
                }
                else
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2">
                        @TranslationService.GetTranslation("rebuildMovements.previewDetail", "Dettaglio movimenti da creare")
                        @if (PreviewCreatedCount > _previewMaxRows)
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary ml-2" Style="display:inline;">
                                (mostrati @_previewMaxRows di @PreviewCreatedCount)
                            </MudText>
                        }
                    </MudText>
                    <div style="max-height:280px; overflow-y:auto;">
                        <MudTable Items="@PreviewCreatedItems"
                                  Dense="true" Striped="true" Hover="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>@TranslationService.GetTranslation("field.document", "Documento")</MudTh>
                                <MudTh>@TranslationService.GetTranslation("field.productName", "Prodotto")</MudTh>
                                <MudTh>@TranslationService.GetTranslation("field.type", "Tipo")</MudTh>
                                <MudTh Style="text-align:right;">@TranslationService.GetTranslation("field.quantity", "Qtà")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <MudText Typo="Typo.body2">@context.DocumentNumber</MudText>
                                </MudTd>
                                <MudTd>
                                    <MudText Typo="Typo.body2" Class="text-truncate" Style="max-width:200px;">@context.ProductName</MudText>
                                </MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(context.MovementType == "Inbound" ? Color.Success : Color.Warning)"
                                             Variant="Variant.Outlined">
                                        @(context.MovementType == "Inbound"
                                            ? TranslationService.GetTranslation("rebuildMovements.inbound", "↑ Entrata")
                                            : TranslationService.GetTranslation("rebuildMovements.outbound", "↓ Uscita"))
                                    </MudChip>
                                </MudTd>
                                <MudTd Style="text-align:right;">
                                    <MudText Typo="Typo.body2" Style="font-weight:600;">@context.Quantity.ToString("N2")</MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>
                }
            }
        }

        @* ══════════════════════ STEP 3 — APPLICAZIONE ══════════════════════ *@
        else if (_step == 2)
        {
            @if (_isLoading)
            {
                <div class="d-flex flex-column align-center justify-center pa-8 gap-3">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                    <MudText Typo="Typo.body1">
                        @TranslationService.GetTranslation("rebuildMovements.applying", "Creazione movimenti in corso...")
                    </MudText>
                </div>
            }
            else if (_applyResult != null)
            {
                <MudAlert Severity="@(_applyResult.Errors == 0 ? Severity.Success : Severity.Warning)" Class="mb-4">
                    @if (_applyResult.Errors == 0)
                    {
                        @TranslationService.GetTranslation("rebuildMovements.applySuccess", "Operazione completata con successo!")
                    }
                    else
                    {
                        @TranslationService.GetTranslationFormatted("rebuildMovements.applyPartial",
                            "Operazione completata con {0} errore/i.", _applyResult.Errors)
                    }
                </MudAlert>

                <MudGrid Spacing="2">
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3 text-center" Elevation="2" Style="border-left: 3px solid var(--mud-palette-success);">
                            <MudText Typo="Typo.h5" Color="Color.Success">@_applyResult.MovementsCreated</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @TranslationService.GetTranslation("rebuildMovements.movementsCreated", "Movimenti creati")
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    @if (_applyResult.MovementsUpdated > 0)
                    {
                        <MudItem xs="6" sm="3">
                            <MudPaper Class="pa-3 text-center" Elevation="2" Style="border-left: 3px solid var(--mud-palette-warning);">
                                <MudText Typo="Typo.h5" Color="Color.Warning">@_applyResult.MovementsUpdated</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @TranslationService.GetTranslation("rebuildMovements.movementsUpdated", "Movimenti aggiornati")
                                </MudText>
                            </MudPaper>
                        </MudItem>
                    }
                    @if (_applyResult.Errors > 0)
                    {
                        <MudItem xs="6" sm="3">
                            <MudPaper Class="pa-3 text-center" Elevation="2" Style="border-left: 3px solid var(--mud-palette-error);">
                                <MudText Typo="Typo.h5" Color="Color.Error">@_applyResult.Errors</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @TranslationService.GetTranslation("common.errors", "Errori")
                                </MudText>
                            </MudPaper>
                        </MudItem>
                    }
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3 text-center" Elevation="2">
                            <MudText Typo="Typo.h5">@_applyResult.DocumentsScanned</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @TranslationService.GetTranslation("rebuildMovements.documents", "Documenti")
                            </MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                @if (_applyResult.Items.Any(i => i.Status == "Error"))
                {
                    <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">
                        @TranslationService.GetTranslation("rebuildMovements.errorDetail", "Dettaglio errori")
                    </MudText>
                    <div style="max-height:200px; overflow-y:auto;">
                        <MudTable Items="@ApplyErrorItems"
                                  Dense="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>@TranslationService.GetTranslation("field.document", "Documento")</MudTh>
                                <MudTh>@TranslationService.GetTranslation("field.productName", "Prodotto")</MudTh>
                                <MudTh>@TranslationService.GetTranslation("common.error", "Errore")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd><MudText Typo="Typo.body2">@context.DocumentNumber</MudText></MudTd>
                                <MudTd><MudText Typo="Typo.body2">@context.ProductName</MudText></MudTd>
                                <MudTd><MudText Typo="Typo.caption" Color="Color.Error">@context.ErrorMessage</MudText></MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>
                }
            }
        }
    </DialogContent>

    <DialogActions>
        @if (_step < 2 || _isLoading)
        {
            <MudButton OnClick="Cancel" Disabled="_isLoading" Variant="Variant.Text">
                @TranslationService.GetTranslation("button.cancel", "Annulla")
            </MudButton>
        }

        @if (_step == 0)
        {
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="GoToPreviewAsync"
                       Disabled="_isLoading"
                       StartIcon="@Icons.Material.Outlined.Preview">
                @TranslationService.GetTranslation("rebuildMovements.preview", "Anteprima")
            </MudButton>
        }
        else if (_step == 1 && !_isLoading)
        {
            <MudButton Variant="Variant.Text"
                       OnClick="@(() => _step = 0)"
                       StartIcon="@Icons.Material.Outlined.NavigateBefore">
                @TranslationService.GetTranslation("common.back", "Indietro")
            </MudButton>
            @if (_previewResult?.MovementsCreated > 0 || _previewResult?.MovementsUpdated > 0)
            {
                var totalOps = (_previewResult?.MovementsCreated ?? 0) + (_previewResult?.MovementsUpdated ?? 0);
                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           OnClick="ApplyAsync"
                           StartIcon="@Icons.Material.Outlined.PlayArrow">
                    @TranslationService.GetTranslationFormatted("rebuildMovements.apply",
                        "Applica ({0} operazioni)", totalOps)
                </MudButton>
            }
        }
        else if (_step == 2 && !_isLoading)
        {
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="Close"
                       StartIcon="@Icons.Material.Outlined.Check">
                @TranslationService.GetTranslation("button.close", "Chiudi")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>
    /// Pre-selects a warehouse when opening the dialog from the stock overview page.
    /// </summary>
    [Parameter]
    public Guid? InitialWarehouseId { get; set; }

    private const int _previewMaxRows = 200;
    private int _step = 0;
    private bool _isLoading = false;

    // ── Filter state ──
    private DateTime? _fromDate;
    private DateTime? _toDate;
    private Guid? _warehouseId;
    private Guid? _documentTypeId;
    private bool _includeApproved = true;
    private bool _includePending = false;
    private bool _includeRejected = false;
    private bool _includeNoneApproval = false;
    private bool _includeClosed = true;
    private bool _includeOpen = false;
    private bool _includeDraft = false;
    private bool _includeCancelled = false;
    private bool _updateExisting = true;

    // ── Reference data ──
    private List<StorageFacilityDto> _warehouses = new();
    private List<DocumentTypeDto> _documentTypes = new();

    // ── Results ──
    private RebuildMovementsResultDto? _previewResult;
    private RebuildMovementsResultDto? _applyResult;

    // ── Computed helpers (avoid nested quotes in Razor attributes) ──
    private const string StatusCreated = "Created";
    private const string StatusError = "Error";
    private IEnumerable<RebuildMovementsRowResultDto> PreviewCreatedItems =>
        _previewResult?.Items.Where(i => i.Status == StatusCreated).Take(_previewMaxRows)
        ?? Enumerable.Empty<RebuildMovementsRowResultDto>();
    private int PreviewCreatedCount => _previewResult?.Items.Count(i => i.Status == StatusCreated) ?? 0;
    private IEnumerable<RebuildMovementsRowResultDto> ApplyErrorItems =>
        _applyResult?.Items.Where(i => i.Status == StatusError)
        ?? Enumerable.Empty<RebuildMovementsRowResultDto>();

    protected override async Task OnInitializedAsync()
    {
        _warehouseId = InitialWarehouseId;
        try
        {
            var warehousesTask = WarehouseService.GetStorageFacilitiesAsync();
            var docTypesTask = DocumentTypeService.GetAllDocumentTypesAsync();
            await Task.WhenAll(warehousesTask, docTypesTask);

            _warehouses = (await warehousesTask)?.Items?.ToList() ?? new();
            _documentTypes = (await docTypesTask)?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading reference data for RebuildMovementsDialog");
        }
    }

    private async Task GoToPreviewAsync()
    {
        _step = 1;
        _isLoading = true;
        _previewResult = null;
        StateHasChanged();
        try
        {
            var request = BuildRequest(dryRun: true);
            _previewResult = await StockReconciliationService.RebuildMovementsPreviewAsync(request);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error previewing rebuild movements");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ApplyAsync()
    {
        _step = 2;
        _isLoading = true;
        _applyResult = null;
        StateHasChanged();
        try
        {
            var request = BuildRequest(dryRun: false);
            _applyResult = await StockReconciliationService.RebuildMovementsExecuteAsync(request);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error executing rebuild movements");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private RebuildMovementsRequestDto BuildRequest(bool dryRun)
    {
        var approvalStatuses = new List<int>();
        if (_includeApproved) approvalStatuses.Add(2);      // ApprovalStatus.Approved
        if (_includePending) approvalStatuses.Add(1);       // ApprovalStatus.Pending
        if (_includeRejected) approvalStatuses.Add(3);      // ApprovalStatus.Rejected
        if (_includeNoneApproval) approvalStatuses.Add(0);  // ApprovalStatus.None

        var documentStatuses = new List<int>();
        if (_includeClosed) documentStatuses.Add(2);        // DocumentStatus.Closed
        if (_includeOpen) documentStatuses.Add(1);          // DocumentStatus.Open
        if (_includeDraft) documentStatuses.Add(0);         // DocumentStatus.Draft
        if (_includeCancelled) documentStatuses.Add(3);     // DocumentStatus.Cancelled

        return new RebuildMovementsRequestDto
        {
            DryRun = dryRun,
            FromDate = _fromDate.HasValue ? DateTime.SpecifyKind(_fromDate.Value, DateTimeKind.Utc) : null,
            ToDate = _toDate.HasValue ? DateTime.SpecifyKind(_toDate.Value, DateTimeKind.Utc) : null,
            WarehouseId = _warehouseId,
            DocumentTypeId = _documentTypeId,
            ApprovalStatuses = approvalStatuses.Count > 0 ? approvalStatuses : null,
            DocumentStatuses = documentStatuses.Count > 0 ? documentStatuses : null,
            UpdateExisting = _updateExisting
        };
    }

    private void Cancel() => MudDialog.Cancel();

    /// <summary>Returns the apply result so the caller can refresh stock data if movements were created.</summary>
    private void Close() => MudDialog.Close(DialogResult.Ok(_applyResult));
}
