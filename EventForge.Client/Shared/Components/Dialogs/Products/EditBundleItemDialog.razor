@using MudBlazor
@using Prym.DTOs.Products
@inject IProductService ProductService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject ILogger<EditBundleItemDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.Inventory"
          Title="@(_isEditMode
              ? TranslationService.GetTranslation("product.editBundleItem", "Modifica Componente Bundle")
              : TranslationService.GetTranslation("product.addBundleItem", "Aggiungi Componente Bundle"))"
          IsProcessing="@_isSaving"
          OnClose="Cancel">
    <ChildContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudGrid>
                <MudItem xs="12">
                    <MudAutocomplete T="ProductDto"
                                     @bind-Value="_selectedProduct"
                                     SearchFunc="@SearchProducts"
                                     Label="@($"{TranslationService.GetTranslation("field.componentProduct", "Prodotto Componente")} *")"
                                     Variant="Variant.Outlined"
                                     ToStringFunc="@(p => p != null ? $"{p.Name} ({p.Code})" : string.Empty)"
                                     Required="true"
                                     RequiredError="@TranslationService.GetTranslation("validation.componentProductRequired", "Il prodotto componente è obbligatorio")"
                    Margin="Margin.Dense"/>
                    <MudText Typo="Typo.caption" Class="mud-input-helper-text">
                        @TranslationService.GetTranslation("helperText.componentProduct", "Seleziona il prodotto da includere nel bundle")
                    </MudText>
                </MudItem>

                <MudItem xs="12">
                    <MudNumericField @bind-Value="_quantity"
                                     Label="@($"{TranslationService.GetTranslation("field.quantity", "Quantità")} *")"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="1"
                                     Max="10000"
                                     Required="true"
                                     RequiredError="@TranslationService.GetTranslation("validation.quantityRequired", "La quantità è obbligatoria")"
                                     HideSpinButtons="false" />
                    <MudText Typo="Typo.caption" Class="mud-input-helper-text">
                        @TranslationService.GetTranslation("helperText.bundleQuantity", "Quante unità di questo prodotto sono incluse nel bundle")
                    </MudText>
                </MudItem>
            </MudGrid>
        </MudForm>
    </ChildContent>
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Variant="Variant.Text"
                   Disabled="@_isSaving">
            @TranslationService.GetTranslation("button.cancel", "Annulla")
        </MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Outlined.Save"
                   Disabled="@(!_isValid || _selectedProduct == null || _isSaving)"
                   OnClick="Submit">
            @if (_isSaving)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">@TranslationService.GetTranslation("common.saving", "Salvataggio...")</MudText>
            }
            else
            {
                @TranslationService.GetTranslation("button.save", "Salva")
            }
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>When null the dialog operates in Add mode; when set it operates in Edit mode.</summary>
    [Parameter] public ProductBundleItemDto? BundleItem { get; set; }
    [Parameter] public Guid BundleProductId { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _isSaving;
    private bool _isEditMode;
    private int _quantity = 1;

    private ProductDto? _selectedProduct;
    private IEnumerable<ProductDto> _availableProducts = new List<ProductDto>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isEditMode = BundleItem != null;
            if (_isEditMode)
            {
                _quantity = BundleItem!.Quantity;
            }
            await LoadAvailableProductsAsync();
            if (_isEditMode)
            {
                _selectedProduct = _availableProducts.FirstOrDefault(p => p.Id == BundleItem!.ComponentProductId);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing EditBundleItemDialog.");
        }
    }

    private async Task LoadAvailableProductsAsync()
    {
        try
        {
            var result = await ProductService.GetProductsAsync();
            if (result?.Items != null)
            {
                _availableProducts = result.Items
                    .Where(p => p.Id != BundleProductId && p.Status == ProductStatus.Active)
                    .OrderBy(p => p.Name);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading available products");
            AppNotification.ShowError(TranslationService.GetTranslation("product.loadProductsError", "Errore nel caricamento dei prodotti"));
        }
    }

    private async Task<IEnumerable<ProductDto>> SearchProducts(string value, CancellationToken token)
    {
        await Task.Delay(50, token);
        if (string.IsNullOrWhiteSpace(value))
            return _availableProducts;
        return _availableProducts.Where(p =>
            p.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            p.Code.Contains(value, StringComparison.OrdinalIgnoreCase));
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        if (!_isValid || _selectedProduct == null) return;

        try
        {
            _isSaving = true;

            if (_isEditMode && BundleItem != null)
            {
                var updateDto = new UpdateProductBundleItemDto
                {
                    ComponentProductId = _selectedProduct.Id,
                    Quantity = _quantity
                };
                var updatedItem = await ProductService.UpdateProductBundleItemAsync(BundleItem.Id, updateDto);
                if (updatedItem != null)
                {
                    AppNotification.ShowSuccess(TranslationService.GetTranslation("product.bundleItemUpdated", "Componente aggiornato con successo"));
                    MudDialog.Close(DialogResult.Ok(updatedItem));
                }
                else
                {
                    AppNotification.ShowError(TranslationService.GetTranslation("messages.saveFailed", "Errore durante il salvataggio"));
                }
            }
            else
            {
                var createDto = new CreateProductBundleItemDto
                {
                    BundleProductId = BundleProductId,
                    ComponentProductId = _selectedProduct.Id,
                    Quantity = _quantity
                };
                var newItem = await ProductService.CreateProductBundleItemAsync(createDto);
                if (newItem != null)
                {
                    AppNotification.ShowSuccess(TranslationService.GetTranslation("product.bundleItemAdded", "Componente aggiunto con successo"));
                    MudDialog.Close(DialogResult.Ok(newItem));
                }
                else
                {
                    AppNotification.ShowError(TranslationService.GetTranslation("messages.saveFailed", "Errore durante il salvataggio"));
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving bundle item");
            AppNotification.ShowError(TranslationService.GetTranslation("messages.saveFailed", "Errore durante il salvataggio: {0}", ex.Message));
        }
        finally
        {
            _isSaving = false;
        }
    }
}
