@using Prym.DTOs.Documents
@using EventForge.Client.Services
@inject IDocumentHeaderService DocumentHeaderService
@inject IHttpClientService HttpClientService
@inject IJSRuntime JSRuntime
@inject ITranslationService TranslationService
@inject IAppNotificationService AppNotification
@inject ILogger<DocumentViewerDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.Description"
          Title="Visualizza Documento"
          IsProcessing="@_isLoading"
          OnClose="Close"
          MinWidth="min(600px, 95vw)">
    <ChildContent>
        <MudPaper Class="pa-3">
                @if (_isLoading)
                {
                    <div class="d-flex justify-center pa-4">
                        <MudProgressCircular Indeterminate="true" />
                    </div>
                }
                else if (_document == null)
                {
                    <MudAlert Severity="Severity.Warning">
                        @TranslationService.GetTranslation("documents.notFound", "Documento non trovato")
                    </MudAlert>
                }
                else
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-3">
                        #@_document.Number - @_document.Date.ToString("dd/MM/yyyy")
                    </MudText>

                    @if (_document.Rows?.Any() == true)
                    {
                        <EFTable TItem="DocumentRowDto"
                                 Items="_document.Rows"
                                 Dense="true"
                                 Hover="true"
                                 Striped="true"
                                 FixedHeader="true"
                                 Height="400px"
                                 ShowSearch="false"
                                 ShowFilters="false"
                                 ShowRefresh="false"
                                 ShowCreate="false"
                                 ShowExport="false"
                                 ShowColumnConfiguration="false"
                                 ShowFooter="false"
                                 AllowDragDropGrouping="false"
                                 ComponentKey="document-viewer-dialog-rows"
                                 InitialColumnConfigurations="@_rowColumns">
                            <HeaderContent Context="columns">
                                <MudTh>@TranslationService.GetTranslation("field.product", "Prodotto")</MudTh>
                                <MudTh>@TranslationService.GetTranslation("field.unitOfMeasure", "UM")</MudTh>
                                <MudTh >@TranslationService.GetTranslation("field.quantity", "Quantità")</MudTh>
                                <MudTh >@TranslationService.GetTranslation("field.unitPrice", "Prezzo")</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="r">
                                <MudTd DataLabel="@TranslationService.GetTranslation("field.product", "Prodotto")">@r.Description</MudTd>
                                <MudTd DataLabel="@TranslationService.GetTranslation("field.unitOfMeasure", "UM")">@r.UnitOfMeasure</MudTd>
                                <MudTd DataLabel="@TranslationService.GetTranslation("field.quantity", "Quantità")" >@r.Quantity.ToString("N2")</MudTd>
                                <MudTd DataLabel="@TranslationService.GetTranslation("field.unitPrice", "Prezzo")" >€@r.UnitPrice.ToString("N2")</MudTd>
                            </RowTemplate>
                        </EFTable>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">
                            @TranslationService.GetTranslation("documents.noRows", "Nessuna riga presente nel documento")
                        </MudAlert>
                    }
                }
            </MudPaper>
    </ChildContent>
    <DialogActions>
        @if (_document?.Rows?.Any() == true)
        {
            <MudButton StartIcon="@Icons.Material.Outlined.FileDownload"
                       Color="Color.Info"
                       Variant="Variant.Outlined"
                       OnClick="ExportToExcel"
                       Disabled="_isLoading">
                @TranslationService.GetTranslation("common.exportExcel", "Esporta Excel")
            </MudButton>
        }
        <MudButton OnClick="Close"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Outlined.Close">
            @TranslationService.GetTranslation("common.close","Chiudi")
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Guid DocumentHeaderId { get; set; }

    private DocumentHeaderDto? _document;
    private string _title = "";
    private bool _isLoading = true;

    private readonly List<EFTableColumnConfiguration> _rowColumns = new()
    {
        new() { PropertyName = "Description",   DisplayName = "Prodotto",  Order = 0 },
        new() { PropertyName = "UnitOfMeasure", DisplayName = "UM",        Order = 1 },
        new() { PropertyName = "Quantity",      DisplayName = "Quantità",  Order = 2 },
        new() { PropertyName = "UnitPrice",     DisplayName = "Prezzo",    Order = 3 },
    };

    protected override async Task OnInitializedAsync()
    {
        _title = TranslationService.GetTranslation("documents.view", "Visualizza documento");
        
        try
        {
            _document = await DocumentHeaderService.GetDocumentHeaderByIdAsync(DocumentHeaderId, includeRows: true);
            if (_document != null)
            {
                _title = _document.Number;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading document header {DocumentHeaderId}", DocumentHeaderId);
            _document = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Close() => MudDialog.Close();

    private async Task ExportToExcel()
    {
        if (_document?.Rows == null || !_document.Rows.Any()) return;

        try
        {
            _isLoading = true;
            StateHasChanged();

            var columns = new[]
            {
                new { PropertyName = "nr",          DisplayName = "N\u00b0",       NumberFormat = (string?)null, IsVisible = true },
                new { PropertyName = "productCode", DisplayName = "Codice",    NumberFormat = (string?)null, IsVisible = true },
                new { PropertyName = "description", DisplayName = "Descrizione",NumberFormat = (string?)null, IsVisible = true },
                new { PropertyName = "uom",         DisplayName = "UM",         NumberFormat = (string?)null, IsVisible = true },
                new { PropertyName = "quantity",    DisplayName = "Quantit\u00e0", NumberFormat = (string?)"#,##0.00",   IsVisible = true },
                new { PropertyName = "unitPrice",   DisplayName = "Prezzo",     NumberFormat = (string?)"#,##0.00\u20ac",IsVisible = true },
                new { PropertyName = "discount",    DisplayName = "Sconto %",   NumberFormat = (string?)"#,##0.00",   IsVisible = true },
                new { PropertyName = "vatRate",     DisplayName = "IVA %",      NumberFormat = (string?)"#,##0.00",   IsVisible = true },
                new { PropertyName = "lineTotal",   DisplayName = "Totale",     NumberFormat = (string?)"#,##0.00\u20ac",IsVisible = true }
            };

            var data = _document.Rows.Select((r, i) => new Dictionary<string, object?>
            {
                ["nr"]          = i + 1,
                ["productCode"] = r.ProductCode,
                ["description"] = r.Description,
                ["uom"]         = r.UnitOfMeasure,
                ["quantity"]    = r.Quantity,
                ["unitPrice"]   = r.UnitPrice,
                ["discount"]    = r.LineDiscount,
                ["vatRate"]     = r.VatRate,
                ["lineTotal"]   = r.LineTotal
            }).ToList();

            var request = new
            {
                options = new
                {
                    FileName = $"Documento_{_document.Number}",
                    SheetName = "Righe",
                    Columns = columns,
                    AutoFitColumns = true,
                    FreezeHeader = true,
                    AddAutoFilter = true
                },
                data
            };

            var responseStream = await HttpClientService.PostStreamAsync("api/v1/export/excel", request);
            using var ms = new MemoryStream();
            await responseStream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            var fileName = $"Documento_{_document.Number}_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            await JSRuntime.InvokeVoidAsync("downloadFileFromBytes", fileName, bytes);

            AppNotification.ShowSuccess(TranslationService.GetTranslation("common.exportSuccess", "Esportazione completata!"));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error exporting document {DocumentId}", DocumentHeaderId);
            AppNotification.ShowError(TranslationService.GetTranslation("common.exportError", "Errore nell'esportazione"));
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}
