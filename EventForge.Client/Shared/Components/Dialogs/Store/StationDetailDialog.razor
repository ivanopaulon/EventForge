@using Prym.DTOs.Station
@using EventForge.Client.ViewModels
@attribute [Authorize]
@inject StationDetailViewModel ViewModel
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<StationDetailDialog> Logger
@inject IAppNotificationService AppNotification
@implements IDisposable

<EFDialog Icon="@Icons.Material.Outlined.Kitchen"
          Title="@(ViewModel.IsNewEntity ? TranslationService.GetTranslation("station.newStation", "Nuova Stazione") : (ViewModel.Entity?.Name ?? string.Empty))"
          IsProcessing="@(ViewModel.IsLoading || ViewModel.IsSaving)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <ChildContent>
        @if (ViewModel.IsLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (!ViewModel.IsNewEntity && ViewModel.Entity == null)
        {
            <MudAlert Severity="Severity.Error">
                @TranslationService.GetTranslation("station.notFound", "Stazione non trovata")
            </MudAlert>
        }
        else if (ViewModel.Entity != null)
        {
            <MudTabs Elevation="0" Rounded="false" PanelClass="pa-4" Class="ef-tabs" ApplyEffectsToContainer="true">
                <MudTabPanel Text="Generale" Icon="@Icons.Material.Outlined.Info">
                    @if (!ViewModel.IsNewEntity)
                    {
                        <div class="d-flex align-center gap-4 flex-wrap mb-3">
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Color="Color.Primary" Size="Size.Medium">
                                    <MudIcon Icon="@Icons.Material.Outlined.Kitchen" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.body1" Class="fw-semibold">@ViewModel.Entity.Name</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        ID: @ViewModel.Entity.Id.ToString()[..8]... · @ViewModel.Entity.StationType
                                    </MudText>
                                </div>
                            </div>
                            <MudChip T="string" Size="Size.Medium" Color="GetStatusColor(ViewModel.Entity.Status)">
                                @GetStatusText(ViewModel.Entity.Status)
                            </MudChip>
                        </div>
                        <MudDivider Class="mb-3" />
                    }

                    <MudForm @ref="_form" Model="@ViewModel.Entity">
                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.Name"
                                               Label="@TranslationService.GetTranslation("field.name", "Nome")"
                                               Required="true"
                                               MaxLength="100"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <PrymSelect @bind-Value="ViewModel.Entity.Status"
                                            Label="@TranslationService.GetTranslation("field.status", "Status")"
                                            @bind-Value:after="HandleEntityChanged">
                                    @foreach (StationStatus status in Enum.GetValues(typeof(StationStatus)))
                                    {
                                        <MudSelectItem Value="@status">@GetStatusText(status)</MudSelectItem>
                                    }
                                </PrymSelect>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <PrymSelect @bind-Value="ViewModel.Entity.StationType"
                                            Label="@TranslationService.GetTranslation("field.stationType", "Tipo Stazione")"
                                            @bind-Value:after="HandleEntityChanged">
                                    @foreach (StationType type in Enum.GetValues(typeof(StationType)))
                                    {
                                        <MudSelectItem Value="@type">@GetTypeText(type)</MudSelectItem>
                                    }
                                </PrymSelect>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <PrymTextField @bind-Value="ViewModel.Entity.Location"
                                               Label="@TranslationService.GetTranslation("field.location", "Posizione")"
                                               MaxLength="50"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <PrymNumericField @bind-Value="ViewModel.Entity.SortOrder"
                                                  Label="@TranslationService.GetTranslation("field.sortOrder", "Ordine")"
                                                  Min="0"
                                                  @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudField Label="@TranslationService.GetTranslation("field.printsReceiptCopy", "Copia Scontrino")" Variant="Variant.Outlined">
                                    <PrymCheckBox T="bool" @bind-Value="ViewModel.Entity.PrintsReceiptCopy"
                                                  Label="Includi su scontrino fiscale"
                                                  @bind-Value:after="HandleEntityChanged" />
                                </MudField>
                            </MudItem>

                            <MudItem xs="12">
                                <PrymTextField @bind-Value="ViewModel.Entity.Description"
                                               Label="@TranslationService.GetTranslation("field.description", "Descrizione")"
                                               Lines="2"
                                               MaxLength="200"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>

                            <MudItem xs="12">
                                <PrymTextField @bind-Value="ViewModel.Entity.Notes"
                                               Label="@TranslationService.GetTranslation("field.notes", "Note")"
                                               Lines="3"
                                               MaxLength="200"
                                               @bind-Value:after="HandleEntityChanged" />
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                </MudTabPanel>
            </MudTabs>
        }
    </ChildContent>
    <DialogActions>
        <PrymButton Intent="PrymButton.ButtonIntent.Ghost" OnClick="Cancel" Disabled="ViewModel.IsSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </PrymButton>
        <PrymButton StartIcon="@Icons.Material.Filled.Save"
                    OnClick="SaveAsync" Disabled="ViewModel.IsSaving || ViewModel.IsLoading || ViewModel.Entity == null">
            @TranslationService.GetTranslation("common.save", "Salva")
        </PrymButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? EntityId { get; set; }

    private MudForm? _form;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ViewModel.StateChanged += OnViewModelStateChanged;
            await ViewModel.LoadEntityAsync(EntityId ?? Guid.Empty);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing StationDetailDialog.");
        }
    }

    private void HandleEntityChanged()
    {
        ViewModel.NotifyEntityChanged();
    }

    private async Task SaveAsync()
    {
        if (_form != null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid) return;
        }

        try
        {
            var success = await ViewModel.SaveEntityAsync();
            if (success)
            {
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving station.");
            AppNotification.ShowWarning("Si è verificato un errore nel salvataggio.");
        }
    }

    private async Task Cancel()
    {
        if (ViewModel.HasUnsavedChanges())
        {
            var result = await DialogService.ShowMessageBoxAsync(
                TranslationService.GetTranslation("common.confirm", "Conferma"),
                TranslationService.GetTranslation("common.unsavedChangesConfirm", "Ci sono modifiche non salvate. Vuoi salvare prima di uscire?"),
                yesText: TranslationService.GetTranslation("common.save", "Salva"),
                noText: TranslationService.GetTranslation("common.discard", "Non salvare"),
                cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
            if (result == null) return;
            if (result == true) { await SaveAsync(); return; }
        }
        MudDialog.Close();
    }

    private void OnViewModelStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private Color GetStatusColor(StationStatus status) => status switch
    {
        StationStatus.Active => Color.Success,
        StationStatus.Suspended => Color.Warning,
        StationStatus.Maintenance => Color.Info,
        StationStatus.Disabled => Color.Error,
        _ => Color.Default
    };

    private string GetStatusText(StationStatus status) => status switch
    {
        StationStatus.Active => TranslationService.GetTranslation("status.active", "Attivo"),
        StationStatus.Suspended => TranslationService.GetTranslation("status.suspended", "Sospeso"),
        StationStatus.Maintenance => TranslationService.GetTranslation("status.maintenance", "Manutenzione"),
        StationStatus.Disabled => TranslationService.GetTranslation("status.disabled", "Disabilitato"),
        _ => status.ToString()
    };

    private string GetTypeText(StationType type) => type switch
    {
        StationType.KDS => "KDS – Display Cucina",
        StationType.Kitchen => "Cucina",
        StationType.Bar => "Bar",
        StationType.Cocktail => "Cocktail / Mixology",
        StationType.Pizza => "Pizza",
        StationType.Takeaway => "Takeaway / Consegna",
        StationType.Counter => "Banco",
        StationType.POS => "POS – Cassa",
        _ => type.ToString()
    };

    public void Dispose()
    {
        ViewModel.StateChanged -= OnViewModelStateChanged;
    }
}
