@*
    UpdatesDialog — EFDialog + vertical MudTabs (same structure as HealthStatusDialog)
    SuperAdmin only. Two tabs: Available Packages + Installations.
*@
@namespace EventForge.Client.Shared.Components.Dialogs
@using EventForge.Client.Services.Updates
@inject IUpdateNotificationService UpdateNotification
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject IDialogService DialogService
@inject ILogger<UpdatesDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.SystemUpdate"
          Title="@TranslationService.GetTranslation("updates.dialog.title", "Gestione Aggiornamenti")"
          IsProcessing="@_isLoading"
          MinWidth="min(900px, 95vw)"
          MinHeight="@EFDialogDefaults.MinHeightTabbed"
          MaxHeight="calc(100vh - 48px)"
          OnClose="Close">
    <ChildContent>
        <MudTabs Position="Position.Left"
                 Rounded="true"
                 Border="true"
                 MinimumTabWidth="140px"
                 Class="updates-tabs">

            <!-- Tab 1: Pacchetti disponibili -->
            <MudTabPanel Text="Pacchetti"
                         Icon="@Icons.Material.Outlined.Inventory2">
                <MudStack Spacing="3" Class="pa-3">

                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.subtitle1">Pacchetti disponibili</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       Size="Size.Small"
                                       OnClick="LoadDataAsync"
                                       Disabled="@_isLoading"
                                       Title="Aggiorna" />
                    </MudStack>

                    @if (_isLoading)
                    {
                        <div class="text-center pa-4">
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(_packagesError))
                    {
                        <MudAlert Severity="Severity.Error">@_packagesError</MudAlert>
                    }
                    else if (_packages.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Nessun pacchetto disponibile.</MudText>
                    }
                    else
                    {
                        <MudTable Items="@_packages"
                                  Hover="true"
                                  Striped="true"
                                  Dense="true"
                                  Elevation="1"
                                  SelectedItem="_selectedPackage"
                                  SelectedItemChanged="@((PackageSummaryClientDto? p) => _selectedPackage = p)">
                            <HeaderContent>
                                <MudTh>Componente</MudTh>
                                <MudTh>Versione</MudTh>
                                <MudTh>Data caricamento</MudTh>
                                <MudTh>Dimensione</MudTh>
                                <MudTh>Stato</MudTh>
                                <MudTh>Modalità</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Componente">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(context!.Component == "Server" ? Color.Primary : Color.Info)"
                                             Text="@context!.Component" />
                                </MudTd>
                                <MudTd DataLabel="Versione">
                                    <MudText Typo="Typo.body2"><strong>v@context!.Version</strong></MudText>
                                </MudTd>
                                <MudTd DataLabel="Data caricamento">
                                    <MudText Typo="Typo.body2">@context!.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                </MudTd>
                                <MudTd DataLabel="Dimensione">
                                    <MudText Typo="Typo.body2">@FormatBytes(context!.FileSizeBytes)</MudText>
                                </MudTd>
                                <MudTd DataLabel="Stato">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@GetPackageStatusColor(context!.Status)"
                                             Text="@GetPackageStatusLabel(context!.Status)" />
                                </MudTd>
                                <MudTd DataLabel="Modalità">
                                    @if (context!.IsManualInstall)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                                 Icon="@Icons.Material.Outlined.PanTool"
                                                 Text="Manuale" />
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success"
                                                 Icon="@Icons.Material.Outlined.FlashOn"
                                                 Text="Automatico" />
                                    }
                                </MudTd>
                                <MudTd>
                                    <MudIconButton Icon="@Icons.Material.Outlined.Info"
                                                   Size="Size.Small"
                                                   Color="Color.Info"
                                                   OnClick="@(() => ShowPackageDetails(context!))"
                                                   Title="Dettagli" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>

                        @if (_packageDetails is not null)
                        {
                            <MudPaper Elevation="2" Class="pa-3">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                                    <MudText Typo="Typo.subtitle2">Dettagli pacchetto</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                   Size="Size.Small"
                                                   OnClick="@(() => _packageDetails = null)" />
                                </MudStack>
                                <MudGrid Spacing="1">
                                    <MudItem xs="4"><MudText Typo="Typo.body2"><strong>ID</strong></MudText></MudItem>
                                    <MudItem xs="8"><MudText Typo="Typo.caption"><code>@_packageDetails.Id</code></MudText></MudItem>
                                    @if (!string.IsNullOrEmpty(_packageDetails.ReleaseNotes))
                                    {
                                        <MudItem xs="4"><MudText Typo="Typo.body2"><strong>Note di rilascio</strong></MudText></MudItem>
                                        <MudItem xs="8"><MudText Typo="Typo.body2" Class="text-prewrap">@_packageDetails.ReleaseNotes</MudText></MudItem>
                                    }
                                    @if (!string.IsNullOrEmpty(_packageDetails.Checksum))
                                    {
                                        <MudItem xs="4"><MudText Typo="Typo.body2"><strong>Checksum SHA-256</strong></MudText></MudItem>
                                        <MudItem xs="8"><MudText Typo="Typo.caption" Class="text-breakall"><code>@_packageDetails.Checksum</code></MudText></MudItem>
                                    }
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                </MudStack>
            </MudTabPanel>

            <!-- Tab 2: Installazioni -->
            <MudTabPanel Text="Installazioni"
                         Icon="@Icons.Material.Outlined.Devices">
                <MudStack Spacing="3" Class="pa-3">

                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.subtitle1">Installazioni registrate</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       Size="Size.Small"
                                       OnClick="LoadDataAsync"
                                       Disabled="@_isLoading"
                                       Title="Aggiorna" />
                    </MudStack>

                    <!-- Inline package selector so the user can choose the package without switching tab -->
                    @if (_packages.Count > 0)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudText Typo="Typo.body2" Style="white-space:nowrap">Pacchetto:</MudText>
                            <MudSelect T="PackageSummaryClientDto?"
                                       Value="_selectedPackage"
                                       ValueChanged="@((PackageSummaryClientDto? p) => _selectedPackage = p)"
                                       Placeholder="— seleziona pacchetto —"
                                       Dense="true"
                                       Margin="Margin.Dense"
                                       Style="min-width:280px"
                                       Class="@(_selectedPackage is null ? "border-warning" : "")">
                                @foreach (var pkg in _packages)
                                {
                                    <MudSelectItem T="PackageSummaryClientDto?" Value="@pkg">
                                        @pkg.Component v@pkg.Version — @GetPackageStatusLabel(pkg.Status)
                                    </MudSelectItem>
                                }
                            </MudSelect>
                            @if (_selectedPackage is not null)
                            {
                                <MudChip T="string" Size="Size.Small"
                                         Color="@GetPackageStatusColor(_selectedPackage.Status)"
                                         Text="@($"{_selectedPackage.Component} v{_selectedPackage.Version}")" />
                            }
                        </MudStack>
                    }

                    @if (_selectedPackage is null)
                    {
                        <MudAlert Severity="Severity.Warning" Icon="@Icons.Material.Outlined.Warning">
                            Nessun pacchetto selezionato. Scegli un pacchetto dal menu sopra o dalla tab <strong>Pacchetti</strong>.
                        </MudAlert>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Outlined.Info" Dense="true">
                            Pacchetto selezionato: <strong>@_selectedPackage.Component v@_selectedPackage.Version</strong> —
                            clicca "Aggiorna" sull'installazione desiderata.
                        </MudAlert>
                    }

                    @if (_isLoading)
                    {
                        <div class="text-center pa-4">
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(_installationsError))
                    {
                        <MudAlert Severity="Severity.Error">@_installationsError</MudAlert>
                    }
                    else if (_installations.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Nessuna installazione registrata.</MudText>
                    }
                    else
                    {
                        <MudTable Items="@_installations"
                                  Hover="true"
                                  Striped="true"
                                  Dense="true"
                                  Elevation="1">
                            <HeaderContent>
                                <MudTh>Nome</MudTh>
                                <MudTh>Posizione</MudTh>
                                <MudTh>Server</MudTh>
                                <MudTh>Client</MudTh>
                                <MudTh>Stato</MudTh>
                                <MudTh>Azioni</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Nome">
                                    <MudText Typo="Typo.body2">@context.Name</MudText>
                                </MudTd>
                                <MudTd DataLabel="Posizione">
                                    <MudText Typo="Typo.caption">@(context.Location ?? "—")</MudText>
                                </MudTd>
                                <MudTd DataLabel="Server">
                                    <MudText Typo="Typo.body2">@(context.InstalledVersionServer ?? "—")</MudText>
                                </MudTd>
                                <MudTd DataLabel="Client">
                                    <MudText Typo="Typo.body2">@(context.InstalledVersionClient ?? "—")</MudText>
                                </MudTd>
                                <MudTd DataLabel="Stato">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@GetInstallationStatusColor(context.Status, context.IsConnected)"
                                             Text="@GetInstallationStatusLabel(context.Status, context.IsConnected)" />
                                </MudTd>
                                <MudTd DataLabel="Azioni">
                                    <MudButton Variant="Variant.Outlined"
                                               Size="Size.Small"
                                               Color="Color.Warning"
                                               StartIcon="@Icons.Material.Filled.SystemUpdate"
                                               Disabled="@(!context.IsConnected || _selectedPackage is null || _isSendingUpdate)"
                                               OnClick="@(() => ConfirmSendUpdateAsync(context))"
                                               Title="@(_selectedPackage is null ? "Seleziona prima un pacchetto" : "Invia aggiornamento")">
                                        Aggiorna
                                    </MudButton>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudStack>
            </MudTabPanel>

            <!-- Tab 3: In attesa di installazione -->
            <MudTabPanel Text="In attesa"
                         Icon="@Icons.Material.Outlined.HourglassBottom"
                         BadgeData="@(_pendingInstalls.Count > 0 ? _pendingInstalls.Count.ToString() : null)"
                         BadgeColor="Color.Warning">
                <MudStack Spacing="3" Class="pa-3">

                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.subtitle1">Pacchetti in attesa di installazione</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       Size="Size.Small"
                                       OnClick="LoadDataAsync"
                                       Disabled="@_isLoading"
                                       Title="Aggiorna" />
                    </MudStack>

                    @if (_isLoading)
                    {
                        <div class="text-center pa-4">
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(_pendingError))
                    {
                        <MudAlert Severity="Severity.Error">@_pendingError</MudAlert>
                    }
                    else if (_pendingInstalls.Count == 0)
                    {
                        <MudAlert Severity="Severity.Success" Icon="@Icons.Material.Outlined.CheckCircle">
                            Nessun pacchetto in attesa di approvazione.
                        </MudAlert>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">
                            I pacchetti seguenti sono stati scaricati dagli agenti e attendono l'approvazione dell'operatore per l'installazione.
                        </MudAlert>

                        <MudTable Items="@_pendingInstalls"
                                  Hover="true"
                                  Striped="true"
                                  Dense="true"
                                  Elevation="1">
                            <HeaderContent>
                                <MudTh>Installazione</MudTh>
                                <MudTh>Componente</MudTh>
                                <MudTh>Versione</MudTh>
                                <MudTh>Modalità</MudTh>
                                <MudTh>In coda dal</MudTh>
                                <MudTh>Stato</MudTh>
                                <MudTh>Azioni</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Installazione">
                                    <MudText Typo="Typo.body2">@context.InstallationName</MudText>
                                </MudTd>
                                <MudTd DataLabel="Componente">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(context.Component == "Server" ? Color.Primary : Color.Info)"
                                             Text="@(context.Component ?? "—")" />
                                </MudTd>
                                <MudTd DataLabel="Versione">
                                    <MudText Typo="Typo.body2"><strong>v@(context.Version)</strong></MudText>
                                </MudTd>
                                <MudTd DataLabel="Modalità">
                                    @if (context.IsManualInstall)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                                 Icon="@Icons.Material.Outlined.PanTool"
                                                 Text="Manuale" />
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success"
                                                 Icon="@Icons.Material.Outlined.FlashOn"
                                                 Text="Automatico" />
                                    }
                                </MudTd>
                                <MudTd DataLabel="In coda dal">
                                    <MudText Typo="Typo.body2">@context.QueuedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                </MudTd>
                                <MudTd DataLabel="Stato">
                                    @if (context.IsConnected)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Text="Online" />
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Text="Offline" />
                                    }
                                </MudTd>
                                <MudTd DataLabel="Azioni">
                                    <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                                                   Size="Size.Small"
                                                   Color="Color.Success"
                                                   Disabled="@(!context.IsConnected || _isActioning)"
                                                   OnClick="@(() => InstallNowAsync(context))"
                                                   Title="@(!context.IsConnected ? "Agente offline" : "Installa ora")" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudStack>
            </MudTabPanel>

        </MudTabs>

        <!-- Hub link footer -->
        @if (!string.IsNullOrEmpty(_hubUrl))
        {
            <div class="d-flex justify-content-end px-3 pb-2">
                <MudLink Href="@_hubUrl" Target="_blank"
                         Typo="Typo.caption"
                         Color="Color.Primary"
                         Class="d-flex align-items-center gap-1">
                    <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Size="Size.Small" />
                    Apri Management Hub
                </MudLink>
            </div>
        }
    </ChildContent>
</EFDialog>

<style>
    .updates-tabs .mud-tabs-panels {
        overflow-y: auto;
        flex: 1 1 auto;
        min-height: 0;
    }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private bool _isLoading = false;
    private bool _isSendingUpdate = false;
    private bool _isActioning = false;
    private string? _packagesError;
    private string? _installationsError;
    private string? _pendingError;
    private string? _hubUrl;

    private List<PackageSummaryClientDto> _packages = [];
    private List<InstallationSummaryClientDto> _installations = [];
    private List<PendingInstallClientDto> _pendingInstalls = [];

    private PackageSummaryClientDto? _selectedPackage;
    private PackageSummaryClientDto? _packageDetails;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadDataAsync();
            _hubUrl = await UpdateNotification.GetHubUrlAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OnInitializedAsync.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _packagesError = null;
        _installationsError = null;
        _pendingError = null;
        try
        {
            // Fetch packages and installations from UpdateHub independently so a partial failure
            // does not hide the other dataset. Agent proxy (pending installs) is also independent.
            var packagesTask = SafeFetchAsync(
                () => UpdateNotification.GetPackagesAsync(),
                result => _packages = result.ToList(),
                ex => _packagesError = ex.Message);

            var installationsTask = SafeFetchAsync(
                () => UpdateNotification.GetInstallationsAsync(),
                result => _installations = result.ToList(),
                ex => _installationsError = ex.Message);

            var pendingTask = SafeFetchAsync(
                () => UpdateNotification.GetPendingInstallsAsync(),
                result => _pendingInstalls = result.ToList(),
                ex => _pendingError = ex.Message);

            await Task.WhenAll(packagesTask, installationsTask, pendingTask);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static async Task SafeFetchAsync<T>(
        Func<Task<T>> fetch,
        Action<T> onSuccess,
        Action<Exception> onError)
    {
        try
        {
            onSuccess(await fetch());
        }
        catch (Exception ex)
        {
            onError(ex);
        }
    }

    private void ShowPackageDetails(PackageSummaryClientDto package)
    {
        _packageDetails = _packageDetails?.Id == package.Id ? null : package;
    }

    private async Task ConfirmSendUpdateAsync(InstallationSummaryClientDto installation)
    {
        if (_selectedPackage is null) return;

        var pkg = _selectedPackage;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Conferma aggiornamento",
            $"Inviare il pacchetto {pkg.Component} v{pkg.Version} all'installazione \"{installation.Name}\"?",
            yesText: "Invia aggiornamento",
            cancelText: "Annulla");

        if (confirmed == true)
        {
            await SendUpdateAsync(installation, pkg);
        }
    }

    private async Task SendUpdateAsync(InstallationSummaryClientDto installation, PackageSummaryClientDto package)
    {
        _isSendingUpdate = true;
        try
        {
            await UpdateNotification.TriggerUpdateAsync(installation.Id, package.Id);
            AppNotification.ShowSuccess($"Aggiornamento inviato a \"{installation.Name}\".");
        }
        catch (Exception ex)
        {
            AppNotification.ShowError($"Errore nell'invio dell'aggiornamento: {ex.Message}");
        }
        finally
        {
            _isSendingUpdate = false;
        }
    }

    private void Close() => MudDialog.Close();

    private async Task InstallNowAsync(PendingInstallClientDto item)
    {
        _isActioning = true;
        StateHasChanged();
        try
        {
            await UpdateNotification.TriggerInstallNowAsync(item.InstallationId, item.PackageId);
            AppNotification.ShowSuccess($"Installazione avviata per {item.Component} v{item.Version}.");
            await LoadDataAsync();
        }
        catch (Exception ex) { AppNotification.ShowError($"Errore: {ex.Message}"); }
        finally { _isActioning = false; }
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    private static Color GetPackageStatusColor(string? status) => status?.ToLowerInvariant() switch
    {
        "readytodeploy" => Color.Success,
        "deploying"     => Color.Warning,
        "deployed"      => Color.Info,
        "archived"      => Color.Default,
        _               => Color.Default
    };

    private static string GetPackageStatusLabel(string? status) => status?.ToLowerInvariant() switch
    {
        "readytodeploy" => "Pronto",
        "deploying"     => "In deploy",
        "deployed"      => "Distribuito",
        "archived"      => "Archiviato",
        _               => status ?? "—"
    };

    private static Color GetInstallationStatusColor(string? status, bool isConnected)
    {
        if (!isConnected) return Color.Default;
        return status?.ToLowerInvariant() switch
        {
            "online"   => Color.Success,
            "updating" => Color.Warning,
            "error"    => Color.Error,
            _          => Color.Success
        };
    }

    private static string GetInstallationStatusLabel(string? status, bool isConnected)
    {
        if (!isConnected) return "Offline";
        return status?.ToLowerInvariant() switch
        {
            "online"   => "Online",
            "updating" => "In aggiornamento",
            "error"    => "Errore",
            _          => "Online"
        };
    }
}
