@using Prym.DTOs.VatRates
@attribute [Authorize]
@inject IFinancialService FinancialService
@inject IAppNotificationService AppNotification
@inject IDialogService DialogService
@inject ITranslationService TranslationService
@inject ILogger<VatNatureDetailDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.Category"
          Title="@(_isCreateMode ? TranslationService.GetTranslation("drawer.title.creaNaturaIva", "Crea Nuova Natura IVA") : (_vatNature?.Name ?? string.Empty))"
          IsProcessing="@(_isLoading || _isSaving)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <ChildContent>
        @if (_isLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (!_isCreateMode && _vatNature == null)
        {
            <MudAlert Severity="Severity.Error">
                @TranslationService.GetTranslation("vatNature.notFound", "Natura IVA non trovata")
            </MudAlert>
        }
        else
        {
            <MudTabs Elevation="0" Rounded="false" PanelClass="pa-4" Class="ef-tabs" ApplyEffectsToContainer="true">
                <MudTabPanel Text="@TranslationService.GetTranslation("tab.general", "Generale")" Icon="@Icons.Material.Outlined.Info">
                    <MudForm @ref="_form">
                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <PrymTextField @bind-Value="_vatNature!.Code"
                                               Label="@($"{TranslationService.GetTranslation("drawer.field.codiceNaturaIva", "Codice")} *")"
                                               Required="true"
                                               RequiredError="@TranslationService.GetTranslation("drawer.error.codiceObbligatorio", "Il codice è obbligatorio")"
                                               MaxLength="10"
                                               Immediate="true"
                                               OnBlur="@HandleBlur"
                                               HelperText="@TranslationService.GetTranslation("drawer.helperText.codiceNaturaIva", "Codice della natura IVA (es. N1, N2, N3)")" />
                            </MudItem>

                            <MudItem xs="12" md="8">
                                <PrymTextField @bind-Value="_vatNature!.Name"
                                               Label="@($"{TranslationService.GetTranslation("drawer.field.nomeNaturaIva", "Nome")} *")"
                                               Required="true"
                                               RequiredError="@TranslationService.GetTranslation("drawer.error.nomeObbligatorio", "Il nome è obbligatorio")"
                                               MaxLength="100"
                                               Immediate="true"
                                               OnBlur="@HandleBlur"
                                               HelperText="@TranslationService.GetTranslation("drawer.helperText.nomeNaturaIva", "Nome descrittivo della natura IVA")" />
                            </MudItem>

                            <MudItem xs="12">
                                <PrymTextField @bind-Value="_vatNature!.Description"
                                               Label="@TranslationService.GetTranslation("drawer.field.descrizione", "Descrizione")"
                                               Lines="4"
                                               MaxLength="500"
                                               OnBlur="@HandleBlur"
                                               HelperText="@TranslationService.GetTranslation("drawer.helperText.descrizioneNaturaIva", "Descrizione dello scopo e utilizzo della natura IVA")" />
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                </MudTabPanel>
                <MudTabPanel Text="@TranslationService.GetTranslation("tab.audit", "Audit")" Icon="@Icons.Material.Outlined.History" Disabled="@_isCreateMode">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <PrymTextField T="string" Value="@(_vatNature?.Id.ToString() ?? string.Empty)"
                                           Label="@TranslationService.GetTranslation("field.id", "ID")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <PrymTextField T="string" Value="@(_vatNature?.CreatedAt.ToString("dd/MM/yyyy HH:mm") ?? string.Empty)"
                                           Label="@TranslationService.GetTranslation("field.createdAt", "Creato il")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <PrymTextField T="string" Value="@(_vatNature?.CreatedBy ?? string.Empty)"
                                           Label="@TranslationService.GetTranslation("field.createdBy", "Creato da")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <PrymTextField T="string" Value="@(_vatNature?.ModifiedAt?.ToString("dd/MM/yyyy HH:mm") ?? string.Empty)"
                                           Label="@TranslationService.GetTranslation("field.modifiedAt", "Modificato il")"
                                           ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <PrymTextField T="string" Value="@(_vatNature?.ModifiedBy ?? string.Empty)"
                                           Label="@TranslationService.GetTranslation("field.modifiedBy", "Modificato da")"
                                           ReadOnly="true" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
            </MudTabs>
        }
    </ChildContent>
    <DialogActions>
        <PrymButton Intent="PrymButton.ButtonIntent.Ghost" OnClick="Cancel" Disabled="_isSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </PrymButton>
        <PrymButton StartIcon="@Icons.Material.Filled.Save"
                    OnClick="SaveVatNatureAsync" Disabled="_isSaving || _isLoading || _vatNature == null">
            @TranslationService.GetTranslation("common.save", "Salva")
        </PrymButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? EntityId { get; set; }

    private VatNatureDto? _vatNature;
    private bool _isLoading = true;
    private bool _isCreateMode => EntityId == null || EntityId == Guid.Empty;
    private bool _isSaving = false;
    private MudForm? _form;

    private string _originalVatNatureSnapshot = string.Empty;
    private bool _hasLocalChanges = false;

    private static readonly System.Text.Json.JsonSerializerOptions _jsonOptions = new()
    {
        PropertyNameCaseInsensitive = true,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadVatNatureAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing VatNatureDetailDialog.");
        }
    }

    private async Task LoadVatNatureAsync()
    {
        _isLoading = true;
        try
        {
            if (_isCreateMode)
            {
                _vatNature = new VatNatureDto();
                _originalVatNatureSnapshot = SerializeVatNature(_vatNature);
            }
            else if (EntityId.HasValue)
            {
                var vatNature = await FinancialService.GetVatNatureAsync(EntityId.Value);
                _vatNature = vatNature;
                if (_vatNature != null)
                {
                    _originalVatNatureSnapshot = SerializeVatNature(_vatNature);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading VAT nature {EntityId}", EntityId);
            AppNotification.ShowError(TranslationService.GetTranslation("vatNature.loadError", "Errore nel caricamento della natura IVA"), exception: ex);
        }
        finally
        {
            _isLoading = false;
            _hasLocalChanges = false;
        }
    }

    private async Task SaveVatNatureAsync()
    {
        if (_vatNature == null || _form == null) return;
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _isSaving = true;
        try
        {
            if (_isCreateMode)
            {
                var createDto = new CreateVatNatureDto
                {
                    Code = _vatNature.Code,
                    Name = _vatNature.Name,
                    Description = _vatNature.Description
                };
                await FinancialService.CreateVatNatureAsync(createDto);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("messages.createSuccessful", "Creato con successo"));
            }
            else if (EntityId.HasValue)
            {
                var updateDto = new UpdateVatNatureDto
                {
                    Code = _vatNature.Code,
                    Name = _vatNature.Name,
                    Description = _vatNature.Description
                };
                await FinancialService.UpdateVatNatureAsync(EntityId.Value, updateDto);
                AppNotification.ShowSuccess(TranslationService.GetTranslation("messages.updateSuccessful", "Aggiornato con successo"));
            }

            _hasLocalChanges = false;
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving VAT nature");
            AppNotification.ShowError(TranslationService.GetTranslation("vatNature.saveError", "Errore nel salvataggio della natura IVA"), exception: ex);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void MarkChanged()
    {
        _hasLocalChanges = true;
    }

    private void HandleBlur(FocusEventArgs args)
    {
        MarkChanged();
    }

    private string SerializeVatNature(VatNatureDto? vatNature)
    {
        if (vatNature == null) return string.Empty;
        return System.Text.Json.JsonSerializer.Serialize(vatNature, _jsonOptions);
    }

    private bool HasUnsavedChanges()
    {
        if (_vatNature == null) return false;
        if (_hasLocalChanges) return true;
        var current = SerializeVatNature(_vatNature);
        return !string.Equals(current, _originalVatNatureSnapshot, StringComparison.Ordinal);
    }

    private async Task Cancel()
    {
        if (HasUnsavedChanges())
        {
            var result = await DialogService.ShowMessageBoxAsync(
                TranslationService.GetTranslation("common.confirm", "Conferma"),
                TranslationService.GetTranslation("vatNature.unsavedChangesConfirm", "Ci sono modifiche non salvate. Vuoi salvare prima di uscire?"),
                yesText: TranslationService.GetTranslation("common.save", "Salva"),
                noText: TranslationService.GetTranslation("common.discard", "Non salvare"),
                cancelText: TranslationService.GetTranslation("common.cancel", "Annulla"));
            if (result == null) return;
            if (result == true) { await SaveVatNatureAsync(); return; }
        }
        MudDialog.Close();
    }
}
