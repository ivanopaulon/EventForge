@using Prym.DTOs.Documents
@using Prym.DTOs.Business
@using Prym.DTOs.PriceLists
@using EventForge.Client.Shared.Components.Business
@using EventForge.Client.Shared.Components.Common
@inject IDocumentHeaderService DocumentHeaderService
@inject IPriceListService PriceListService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject ILogger<DocumentHeaderDialog> Logger

<EFDialog Icon="@(DocumentId.HasValue ? Icons.Material.Outlined.Edit : Icons.Material.Outlined.NoteAdd)"
          Title="@(DocumentId.HasValue
              ? TranslationService.GetTranslation("documents.editHeader", "Modifica Testata Documento")
              : TranslationService.GetTranslation("documents.newDocument", "Nuovo Documento"))"
          IsProcessing="@_isSaving"
          OnClose="@Cancel"
          MinWidth="min(680px, 95vw)">
    <ChildContent>
        <MudForm @ref="_form" Class="pa-4">
            <MudStack Spacing="3">

                <!-- Tipo Documento -->
                <MudSelect @bind-Value="_model.DocumentTypeId"
                           Label="@($"{TranslationService.GetTranslation("documents.documentType", "Tipo Documento")} *")"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Required="true"
                           Disabled="@(DocumentId.HasValue)">
                    @foreach (var type in DocumentTypes)
                    {
                        <MudSelectItem Value="@type.Id">@type.Name</MudSelectItem>
                    }
                </MudSelect>

                <!-- Serie / Data -->
                <MudGrid Spacing="2">
                    <MudItem xs="5">
                        <MudTextField @bind-Value="_model.Series"
                                      Label="@TranslationService.GetTranslation("documents.series", "Serie")"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="10" />
                    </MudItem>
                    <MudItem xs="7">
                        <MudDatePicker @bind-Date="_documentDate"
                                       Label="@($"{TranslationService.GetTranslation("documents.date", "Data Documento")} *")"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       DateFormat="dd/MM/yyyy"
                                       Editable="true" />
                    </MudItem>
                </MudGrid>

                <!-- Controparte -->
                <UnifiedBusinessPartySelector
                    SelectedBusinessParty="@_selectedBusinessParty"
                    SelectedBusinessPartyChanged="@OnBusinessPartyChanged"
                    Title="@TranslationService.GetTranslation("documents.businessPartner", "Controparte Commerciale")"
                    Placeholder="@TranslationService.GetTranslation("documents.searchBusinessParty", "Cerca per nome (min 2 caratteri)...")"
                    FilterByType="@GetBusinessPartyTypeFilter()"
                    EditMode="EntityEditMode.QuickDialog"
                    CreateMode="EntityCreateMode.QuickDialog"
                    DisplayMode="EntityDisplayMode.All"
                    PreferredCreateType="@GetBusinessPartyTypeFilter()"
                    ShowGroups="true"
                    ShowFiscalInfo="true"
                    ShowLocation="true"
                    AllowClear="true"
                    AutoFocus="false"
                    Dense="true" />

                <!-- Listino Prezzi -->
                <MudSelect @bind-Value="_model.PriceListId"
                           T="Guid?"
                           Label="@TranslationService.GetTranslation("documents.priceList", "Listino Prezzi")"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Clearable="true">
                    @foreach (var pl in _effectivePriceLists)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)pl.Id)">@pl.Name</MudSelectItem>
                    }
                </MudSelect>

                <!-- Note -->
                <MudTextField @bind-Value="_model.Notes"
                              Label="@TranslationService.GetTranslation("documents.notes", "Note")"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="2"
                              MaxLength="500"
                              Placeholder="@TranslationService.GetTranslation("documents.notesPlaceholder", "Note opzionali per il documento...")" />

            </MudStack>
        </MudForm>
    </ChildContent>
    <DialogActions>
        <MudButton OnClick="@Cancel"
                   Variant="Variant.Text"
                   Disabled="@_isSaving">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </MudButton>
        <MudButton OnClick="@ConfirmAsync"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Outlined.Save"
                   Disabled="@(!CanConfirm() || _isSaving)">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
            }
            @TranslationService.GetTranslation("common.confirm", "Conferma")
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>Set when editing an existing document header.</summary>
    [Parameter] public Guid? DocumentId { get; set; }

    /// <summary>Pre-filled model values (for both create and edit).</summary>
    [Parameter] public CreateDocumentHeaderDto InitialModel { get; set; } = new();

    /// <summary>Pre-selected business party (for edit).</summary>
    [Parameter] public BusinessPartyDto? InitialBusinessParty { get; set; }

    /// <summary>Available document types (passed from parent to avoid re-loading).</summary>
    [Parameter] public List<DocumentTypeDto> DocumentTypes { get; set; } = new();

    /// <summary>Available price lists (passed from parent to avoid re-loading).</summary>
    [Parameter] public List<PriceListDto> PriceLists { get; set; } = new();

    private MudForm _form = null!;
    private CreateDocumentHeaderDto _model = new();
    private DateTime? _documentDate;
    private BusinessPartyDto? _selectedBusinessParty;
    private bool _isSaving;

    private List<PriceListDto> _effectivePriceLists = new();

    protected override void OnInitialized()
    {
        // Deep-copy initial model so edits don't affect the caller's state until confirmed
        _model = new CreateDocumentHeaderDto
        {
            DocumentTypeId = InitialModel.DocumentTypeId,
            Series = InitialModel.Series,
            Number = InitialModel.Number,
            Date = InitialModel.Date == default ? DateTime.UtcNow : InitialModel.Date,
            BusinessPartyId = InitialModel.BusinessPartyId,
            Notes = InitialModel.Notes,
            PriceListId = InitialModel.PriceListId,
        };
        // Convert UTC to local time for the date picker
        _documentDate = _model.Date.ToLocalTime();
        _selectedBusinessParty = InitialBusinessParty;
        _effectivePriceLists = PriceLists.ToList();
    }

    private async Task OnBusinessPartyChanged(BusinessPartyDto? party)
    {
        _selectedBusinessParty = party;
        _model.PriceListId = null;

        _effectivePriceLists = PriceLists.ToList();

        if (party != null)
        {
            try
            {
                var bpLists = await PriceListService.GetPriceListsByBusinessPartyAsync(party.Id);
                if (bpLists?.Any() == true)
                {
                    _effectivePriceLists = _effectivePriceLists
                        .Concat(bpLists)
                        .GroupBy(p => p.Id)
                        .Select(g => g.First())
                        .OrderBy(p => p.Name)
                        .ToList();
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Error loading price lists for business party {BusinessPartyId}", party.Id);
            }
        }

        StateHasChanged();
    }

    private BusinessPartyType? GetBusinessPartyTypeFilter()
    {
        var selectedDocType = DocumentTypes.FirstOrDefault(dt => dt.Id == _model.DocumentTypeId);
        if (selectedDocType?.RequiredPartyType is not null &&
            selectedDocType.RequiredPartyType != BusinessPartyType.Both)
        {
            return selectedDocType.RequiredPartyType;
        }
        return null;
    }

    private bool CanConfirm()
        => _model.DocumentTypeId != Guid.Empty
           && _selectedBusinessParty != null
           && _documentDate.HasValue;

    private async Task ConfirmAsync()
    {
        if (!CanConfirm()) return;

        _isSaving = true;
        try
        {
            _model.BusinessPartyId = _selectedBusinessParty!.Id;
            _model.Date = _documentDate!.Value.ToUniversalTime();

            DocumentHeaderDto? result;

            if (DocumentId.HasValue)
            {
                var updateDto = new UpdateDocumentHeaderDto
                {
                    DocumentTypeId = _model.DocumentTypeId,
                    Series = _model.Series,
                    Number = _model.Number ?? string.Empty,
                    Date = _model.Date,
                    BusinessPartyId = _model.BusinessPartyId,
                    Notes = _model.Notes,
                    PriceListId = _model.PriceListId,
                };
                result = await DocumentHeaderService.UpdateDocumentHeaderAsync(DocumentId.Value, updateDto);
                if (result != null)
                    AppNotification.ShowSuccess(TranslationService.GetTranslation("documents.updateSuccess", "Documento aggiornato con successo"));
            }
            else
            {
                result = await DocumentHeaderService.CreateDocumentHeaderAsync(_model);
                if (result != null)
                    AppNotification.ShowSuccess(TranslationService.GetTranslation("documents.createSuccess", "Documento creato con successo"));
            }

            if (result != null)
            {
                MudDialog.Close(DialogResult.Ok(result));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving document header");
            AppNotification.ShowError(TranslationService.GetTranslation("documents.saveError", "Errore durante il salvataggio del documento"));
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
