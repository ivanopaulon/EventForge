@using Prym.DTOs.Documents
@using Prym.DTOs.Products
@using Prym.DTOs.UnitOfMeasures
@using Prym.DTOs.VatRates
@using Prym.DTOs.Common
@using EventForge.Client.Models.Documents
@using EventForge.Client.Services.Documents
@using EventForge.Client.Shared.Components.Products
@using MudBlazor

<EFDialog Icon="@(_isEditMode ? Icons.Material.Outlined.Edit : Icons.Material.Outlined.PlaylistAdd)"
          Title="@TranslationService.GetTranslation(_isEditMode ? "documents.editRow" : "documents.addRow", _isEditMode ? "Modifica Riga" : "Aggiungi Riga")"
          IsProcessing="@_isProcessing"
          OnClose="Cancel"
          MinWidth="min(1000px, 95vw)"
          MinHeight="520px"
          @onkeydown="@OnDialogKeyDown">
    <ChildContent>
        @if (!_isEditMode)
        {
            <div class="d-flex justify-end mb-3">
                <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                    <MudTooltip Text="@TranslationService.GetTranslation("documents.standardModeTooltip", "Modalità completa con tutti i campi")">
                        <MudButton StartIcon="@Icons.Material.Outlined.Edit"
                                   Color="@(_dialogMode == DialogMode.Standard ? Color.Primary : Color.Default)"
                                   Variant="@(_dialogMode == DialogMode.Standard ? Variant.Filled : Variant.Outlined)"
                                   OnClick="@(() => SetDialogMode(DialogMode.Standard))">
                            @TranslationService.GetTranslation("documents.standardMode", "Standard")
                        </MudButton>
                    </MudTooltip>

                    <MudTooltip Text="@TranslationService.GetTranslation("documents.continuousScanTooltip", "Scansione continua con barcode scanner")">
                        <MudButton StartIcon="@Icons.Material.Outlined.QrCodeScanner"
                                   Color="@(_dialogMode == DialogMode.ContinuousScan ? Color.Primary : Color.Default)"
                                   Variant="@(_dialogMode == DialogMode.ContinuousScan ? Variant.Filled : Variant.Outlined)"
                                   OnClick="@(() => SetDialogMode(DialogMode.ContinuousScan))">
                            @TranslationService.GetTranslation("documents.continuousScanMode", "Scan")
                            @if (_continuousScanCount > 0)
                            {
                                <MudBadge Content="@_continuousScanCount" Color="Color.Success" Overlap="true" Class="ml-2" />
                            }
                        </MudButton>
                    </MudTooltip>
                </MudButtonGroup>
            </div>
        }

        @if (_isProcessing)
        {
            <div class="save-progress"></div>
        }

        <div>
            @if (_isLoadingData)
            {
                <MudStack Spacing="2" Class="mb-4">
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                    <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Primary">
                        @TranslationService.GetTranslation("common.loading", "Caricamento in corso...")
                    </MudText>
                </MudStack>
            }

            @if (_validationErrors.Any())
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Variant="Variant.Filled"
                          CloseIcon="@Icons.Material.Filled.Close"
                          CloseIconClicked="@(() => _validationErrors.Clear())">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">
                        <b>@TranslationService.GetTranslation("validation.errors", "Errori di validazione"):</b>
                    </MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var error in _validationErrors)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Error" IconColor="Color.Error">
                                @error
                            </MudListItem>
                        }
                    </MudList>
                </MudAlert>
            }

            @if (_dialogMode == DialogMode.ContinuousScan)
            {
                <!-- CONTINUOUS SCAN MODE -->
                <MudStack Spacing="2">
                    <MudAlert Severity="Severity.Info" Dense="true">
                        @TranslationService.GetTranslation("documents.continuousScanInfo",
                            "Scansiona i codici a barre — ogni scansione aggiunge automaticamente 1 unità. I prodotti già presenti vengono aggiornati automaticamente.")
                    </MudAlert>

                    <UnifiedProductScanner @ref="_continuousScanRef"
                                           SelectedProductChanged="@HandleContinuousScanProductAsync"
                                           Title="@TranslationService.GetTranslation("documents.scanProduct", "Scansiona Prodotto")"
                                           Placeholder="@TranslationService.GetTranslation("documents.scanBarcode", "Scansiona codice a barre o cerca...")"
                                           ShowProductInfo="false"
                                           ShowCommercialInfo="false"
                                           SearchMode="ProductSearchMode.Both"
                                           EditMode="ProductEditMode.None"
                                           CreateMode="ProductCreateMode.Delegate"
                                           ContinuousReadMode="true"
                                           AllowClear="false"
                                           ShowCurrentStock="false"
                                           AutoFocus="true"
                                           AvailableUnits="@_state.Cache.AllUnitsOfMeasure"
                                           AvailableVatRates="@_state.Cache.AllVatRates"
                                           OnProductWithCodeFound="@HandleProductWithCodeFound"
                                           OnProductNotFound="@ShowProductNotFoundDialog" />

                    @if (_isProcessingContinuousScan)
                    {
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                    }

                    @if (_recentContinuousScans.Any())
                    {
                        <MudPaper Elevation="1" Class="pa-3" Style="max-height: 260px; overflow-y: auto;">
                            <MudText Typo="Typo.subtitle2" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="mr-1" />
                                @TranslationService.GetTranslation("documents.recentScans", "Ultimi Prodotti Scansionati")
                            </MudText>
                            <MudList T="string" Dense="true">
                                @foreach (var scan in _recentContinuousScans.Take(5))
                                {
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="w-full">
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2"><strong>@scan.ProductName</strong></MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @scan.Barcode · Qty: @scan.Quantity · €@scan.UnitPrice.ToString("F2")
                                                </MudText>
                                            </MudStack>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.AccessTime">
                                                @GetTimeAgo(scan.Timestamp)
                                            </MudChip>
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        </MudPaper>
                    }

                    <MudButton StartIcon="@Icons.Material.Filled.Check"
                               Variant="Variant.Filled"
                               Color="Color.Success"
                               OnClick="@(() => MudDialog.Close())"
                               Disabled="@(_continuousScanCount == 0)"
                               FullWidth="true">
                        @TranslationService.GetTranslation("documents.finalizeScans", "Finalizza e Chiudi") (@_continuousScanCount @TranslationService.GetTranslation("documents.scans", "scansioni"))
                    </MudButton>
                </MudStack>
            }

            @if (_dialogMode == DialogMode.Standard)
            {
                <!-- STANDARD MODE: Two-column layout -->
                <MudGrid Spacing="2">
                    <!-- Left column: product search + data fields + discounts + merge -->
                    <MudItem xs="12" md="8">
                        <MudStack Spacing="2">

                            <!-- Product Search -->
                            <UnifiedProductScanner @ref="_productScannerRef"
                                                   SelectedProduct="@_selectedProduct"
                                                   SelectedProductChanged="@OnProductSelectedAsync"
                                                   Title="@TranslationService.GetTranslation("documents.product", "Prodotto")"
                                                   Placeholder="@TranslationService.GetTranslation("documents.searchOrScanProduct", "Scansiona barcode o cerca per nome...")"
                                                   SearchHelperText="@TranslationService.GetTranslation("documents.searchProductHelper", "Premi Invio per cercare come barcode")"
                                                   ShowProductInfo="true"
                                                   ShowCommercialInfo="false"
                                                   SearchMode="ProductSearchMode.Both"
                                                   EditMode="ProductEditMode.Dialog"
                                                   CreateMode="ProductCreateMode.Delegate"
                                                   ContinuousReadMode="false"
                                                   AllowClear="true"
                                                   ShowCurrentStock="false"
                                                   AutoFocus="!_isEditMode"
                                                   AvailableUnits="@_state.Cache.AllUnitsOfMeasure"
                                                   AvailableVatRates="@_state.Cache.AllVatRates"
                                                   OnProductWithCodeFound="@HandleProductWithCodeFound"
                                                   OnProductNotFound="@ShowProductNotFoundDialog"
                                                   OnProductUpdated="@HandleProductUpdated" />

                            <!-- Recent Transactions -->
                            @if (_state.SelectedProduct != null)
                            {
                                <DocumentRowRecentTransactions ProductId="@_state.SelectedProduct.Id"
                                                               TransactionType="@DetermineTransactionType()"
                                                               PartyId="@GetBusinessPartyId()"
                                                               OnPriceApplied="@HandleRecentPriceAppliedWithFeedback"
                                                               MaxTransactions="3" />
                            }

                            <!-- Single row: Qty | UdM | Prezzo | IVA -->
                            <MudGrid Spacing="2">
                                <MudItem xs="6" sm="3">
                                    <MudNumericField @bind-Value="_model.Quantity"
                                                     Label="@TranslationService.GetTranslation("documents.quantity", "Quantità")"
                                                     Variant="Variant.Outlined"
                                                     Required="true"
                                                     Min="0.01m"
                                                     Step="1"
                                                     Adornment="Adornment.Start"
                                                     AdornmentIcon="@Icons.Material.Outlined.Numbers"
                                                     AdornmentColor="Color.Primary"
                                                     Margin="Margin.Dense" />
                                </MudItem>

                                <MudItem xs="6" sm="3">
                                    <MudSelect Value="_selectedUnitOfMeasureId"
                                               T="Guid?"
                                               ValueChanged="@OnUnitOfMeasureChanged"
                                               Label="@TranslationService.GetTranslation("products.unitOfMeasure", "U.M.")"
                                               Variant="Variant.Outlined"
                                               Adornment="Adornment.Start"
                                               AdornmentIcon="@Icons.Material.Outlined.Straighten"
                                               AdornmentColor="Color.Primary"
                                               Disabled="@(_availableUnits.Count == 0)"
                                               Margin="Margin.Dense">
                                        @foreach (var unit in _availableUnits)
                                        {
                                            var uom = _allUnitsOfMeasure.FirstOrDefault(u => u.Id == unit.UnitOfMeasureId);
                                            if (uom != null)
                                            {
                                                <MudSelectItem T="Guid?" Value="@uom.Id">@uom.Symbol - @uom.Name</MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="6" sm="3">
                                    <MudNumericField Value="_model.UnitPrice"
                                                     ValueChanged="@((decimal val) => OnPriceManuallyChanged(val))"
                                                     Label="@TranslationService.GetTranslation("documents.price", "Prezzo")"
                                                     Variant="Variant.Outlined"
                                                     Required="true"
                                                     Min="0"
                                                     Format="F2"
                                                     Adornment="Adornment.Start"
                                                     AdornmentIcon="@Icons.Material.Outlined.Euro"
                                                     AdornmentColor="Color.Success"
                                                     Class="@GetPriceFieldClass()"
                                                     Margin="Margin.Dense" />
                                </MudItem>

                                <MudItem xs="6" sm="3">
                                    <MudSelect Value="_selectedVatRateId"
                                               T="Guid?"
                                               ValueChanged="@OnVatRateChanged"
                                               Label="@TranslationService.GetTranslation("documents.vatRate", "IVA")"
                                               Variant="Variant.Outlined"
                                               Adornment="Adornment.Start"
                                               AdornmentIcon="@Icons.Material.Outlined.Percent"
                                               AdornmentColor="Color.Info"
                                               Margin="Margin.Dense">
                                        @foreach (var vatRate in _allVatRates)
                                        {
                                            <MudSelectItem T="Guid?" Value="@vatRate.Id">@vatRate.Name (@vatRate.Percentage%)</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                            </MudGrid>

                            <!-- Price source indicator -->
                            @if (_selectedProduct != null)
                            {
                                <MudTooltip Text="@GetPriceSourceTooltip()" Delay="300">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@(_model.AppliedPriceListId.HasValue ? Icons.Material.Outlined.PriceCheck : Icons.Material.Outlined.Info)"
                                                 Size="Size.Small"
                                                 Color="@GetPriceSourceColor()" />
                                        <MudText Typo="Typo.caption" Color="@GetPriceSourceColor()">
                                            @GetPriceSourceText()
                                        </MudText>
                                        @if (_model.IsPriceManual)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text"
                                                     Icon="@Icons.Material.Outlined.Edit">
                                                @TranslationService.GetTranslation("documents.manualOverride", "Modificato")
                                            </MudChip>
                                        }
                                    </MudStack>
                                </MudTooltip>
                            }

                            <!-- Discounts -->
                            <MudGrid Spacing="2">
                                <MudItem xs="12" sm="6">
                                    <MudNumericField Value="_model.LineDiscount"
                                                     ValueChanged="@((decimal val) => OnDiscountPercentChanged(val))"
                                                     Label="@TranslationService.GetTranslation("documents.discountPercent", "Sconto %")"
                                                     Variant="Variant.Outlined"
                                                     Min="0"
                                                     Max="100"
                                                     Step="0.1m"
                                                     Format="F2"
                                                     Adornment="Adornment.Start"
                                                     AdornmentIcon="@Icons.Material.Outlined.Percent"
                                                     AdornmentColor="Color.Warning"
                                                     Disabled="@(_model.LineDiscountValue > 0)"
                                                     HelperText="@(_model.LineDiscountValue > 0 ? TranslationService.GetTranslation("documents.discountPercentDisabled", "Disabilitato: sconto euro attivo") : "")"
                                                     Margin="Margin.Dense" />
                                </MudItem>

                                <MudItem xs="12" sm="6">
                                    <MudNumericField Value="_model.LineDiscountValue"
                                                     ValueChanged="@((decimal val) => OnDiscountAmountChanged(val))"
                                                     Label="@TranslationService.GetTranslation("documents.discountAmount", "Sconto €")"
                                                     Variant="Variant.Outlined"
                                                     Min="0"
                                                     Format="F2"
                                                     Adornment="Adornment.Start"
                                                     AdornmentIcon="@Icons.Material.Outlined.EuroSymbol"
                                                     AdornmentColor="Color.Warning"
                                                     Disabled="@(_model.LineDiscount > 0)"
                                                     HelperText="@(_model.LineDiscount > 0 ? TranslationService.GetTranslation("documents.discountAmountDisabled", "Disabilitato: sconto % attivo") : "")"
                                                     Margin="Margin.Dense" />
                                </MudItem>
                            </MudGrid>

                            <!-- Merge duplicates checkbox - always active in add mode -->
                            @if (!_isEditMode)
                            {
                                <MudCheckBox T="bool"
                                             @bind-Value="_model.MergeDuplicateProducts"
                                             Color="Color.Primary">
                                    @TranslationService.GetTranslation("documents.mergeDuplicates", "Somma quantità se l'articolo è già presente")
                                    <MudTooltip Text="@TranslationService.GetTranslation("documents.mergeDuplicatesHelp", "When enabled, if you add the same product with the same price, VAT and discounts, the quantity will be summed to the existing row instead of creating a new one")">
                                        <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Color="Color.Info" Class="ml-1" />
                                    </MudTooltip>
                                </MudCheckBox>
                            }

                        </MudStack>
                    </MudItem>

                    <!-- Right column: row summary -->
                    <MudItem xs="12" md="4">
                        <MudPaper Elevation="1" Class="pa-3 h-full">
                            <DocumentRowSummary NetSubtotal="@GetSubtotal()"
                                                VatAmount="@GetVatAmount()"
                                                TotalDiscount="@GetTotalDiscount()"
                                                LineTotal="@GetLineTotal()" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }

        </div>
    </ChildContent>
    <DialogActions>
        <MudStack Row="true" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center" Class="w-full">
            <MudStack Row="true" Spacing="2">
                <MudButton OnClick="Cancel" Variant="Variant.Outlined" Disabled="@_isProcessing">
                    @TranslationService.GetTranslation("common.close", "Chiudi")
                </MudButton>

                @if (_dialogMode != DialogMode.ContinuousScan)
                {
                    <MudButton Color="Color.Primary"
                               OnClick="SaveAndContinue"
                               Disabled="@(!IsValid() || _isProcessing)"
                               Class="@(_isProcessing ? "button-loading" : "")"
                               Variant="Variant.Filled">
                        @if (_isProcessing)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        else
                        {
                            <MudIcon Icon="@(_isEditMode ? Icons.Material.Outlined.Save : Icons.Material.Outlined.Add)" Class="mr-1" />
                        }
                        @TranslationService.GetTranslation(_isEditMode ? "common.save" : "documents.addAndContinue", _isEditMode ? "Salva" : "Aggiungi e Continua")
                    </MudButton>
                }
            </MudStack>
        </MudStack>
    </DialogActions>
</EFDialog>
