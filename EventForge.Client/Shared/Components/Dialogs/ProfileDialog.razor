@using EventForge.DTOs.Profile
@namespace EventForge.Client.Shared.Components.Dialogs
@inject IProfileService ProfileService
@inject IAuthService AuthService
@inject IAuthenticationDialogService AuthenticationDialogService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject ILogger<ProfileDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.Person"
          Title="@(_profile?.FullName ?? TranslationService.GetTranslation("profile.title", "Profilo"))"
          IsProcessing="@(_isLoading || _isSaving)"
          OnClose="Close"
          MinWidth="@EFDialogDefaults.MinWidthTabbed"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <ChildContent>
        @if (_isLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (_profile != null)
        {
            <!-- Avatar header strip -->
            <MudPaper Elevation="0" Class="pa-3 mb-3 border-divider-b">
                <div class="d-flex align-center gap-3">
                    <MudAvatar Class="avatar-64 avatar-primary">
                        @if (!string.IsNullOrEmpty(_profile.AvatarUrl))
                        {
                            <MudImage Src="@_profile.AvatarUrl" Alt="@_profile.FullName" />
                        }
                        else
                        {
                            @GetUserInitials()
                        }
                    </MudAvatar>
                    <div class="flex-grow-1">
                        <MudText Typo="Typo.subtitle1" Class="fw-semibold">@_profile.FullName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_profile.Email</MudText>
                        @if (_profile.Roles?.Any() == true)
                        {
                            <div class="d-flex flex-wrap gap-1 mt-1">
                                @foreach (var role in _profile.Roles)
                                {
                                    <MudChip T="string" Color="@GetRoleColor(role)" Size="Size.Small" Variant="Variant.Filled">@role</MudChip>
                                }
                            </div>
                        }
                    </div>
                    <div class="d-flex flex-column align-end gap-1">
                        <MudFileUpload T="IBrowserFile" Accept=".jpg,.jpeg,.png,.gif" FilesChanged="OnAvatarSelected">
                            <CustomContent Context="fileUpload">
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.CloudUpload"
                                           OnClick="@fileUpload.OpenFilePickerAsync">
                                    @TranslationService.GetTranslation("profile.uploadAvatar", "Cambia Avatar")
                                </MudButton>
                            </CustomContent>
                        </MudFileUpload>
                        @if (!string.IsNullOrEmpty(_profile.AvatarUrl))
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteAvatar">
                                @TranslationService.GetTranslation("profile.removeAvatar", "Rimuovi")
                            </MudButton>
                        }
                    </div>
                </div>
            </MudPaper>

            <MudTabs Position="Position.Left" Rounded="true" Border="true" MinimumTabWidth="160px">

                <!-- Informazioni -->
                <MudTabPanel Text="@TranslationService.GetTranslation("profile.information", "Informazioni")" Icon="@Icons.Material.Outlined.Person">
                    <div class="pa-3">
                        <MudGrid Spacing="3">
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_updateProfile.FirstName"
                                              Label="@TranslationService.GetTranslation("field.firstName", "Nome")"
                                              Variant="Variant.Outlined" Required="true"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_updateProfile.LastName"
                                              Label="@TranslationService.GetTranslation("field.lastName", "Cognome")"
                                              Variant="Variant.Outlined" Required="true"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_updateProfile.Email"
                                              Label="@TranslationService.GetTranslation("field.email", "Email")"
                                              Variant="Variant.Outlined" InputType="InputType.Email" Required="true"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_updateProfile.PhoneNumber"
                                              Label="@TranslationService.GetTranslation("field.phoneNumber", "Telefono")"
                                              Variant="Variant.Outlined"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect T="string" @bind-Value="_updateProfile.PreferredLanguage"
                                           Label="@TranslationService.GetTranslation("field.preferredLanguage", "Lingua preferita")"
                                           Variant="Variant.Outlined">
                                    <MudSelectItem T="string" Value="@("it")">Italiano</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("en")">English</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("es")">Español</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("fr")">Français</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_updateProfile.TimeZone"
                                              Label="@TranslationService.GetTranslation("field.timeZone", "Fuso orario")"
                                              Variant="Variant.Outlined" Placeholder="Europe/Rome"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12">
                                <div class="d-flex align-center gap-3">
                                    <MudIcon Icon="@Icons.Material.Outlined.CalendarToday" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @TranslationService.GetTranslation("profile.memberSince", "Membro dal") @_profile.CreatedAt.ToString("dd/MM/yyyy")
                                    </MudText>
                                    @if (_profile.LastLoginAt.HasValue)
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.Login" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @TranslationService.GetTranslation("profile.lastLogin", "Ultimo accesso") @_profile.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm")
                                        </MudText>
                                    }
                                </div>
                            </MudItem>
                            <MudItem xs="12" Class="d-flex justify-end">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           OnClick="UpdateProfile" Disabled="_isSaving">
                                    @if (_isSaving)
                                    {
                                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                        <MudText Class="ms-2">@TranslationService.GetTranslation("common.saving", "Salvataggio...")</MudText>
                                    }
                                    else
                                    {
                                        @TranslationService.GetTranslation("common.save", "Salva modifiche")
                                    }
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudTabPanel>

                <!-- Sicurezza -->
                <MudTabPanel Text="@TranslationService.GetTranslation("profile.security", "Sicurezza")" Icon="@Icons.Material.Outlined.Lock">
                    <div class="pa-3">
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_changePassword.CurrentPassword"
                                              Label="@TranslationService.GetTranslation("field.currentPassword", "Password attuale")"
                                              Variant="Variant.Outlined" InputType="InputType.Password" Required="true"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_changePassword.NewPassword"
                                              Label="@TranslationService.GetTranslation("field.newPassword", "Nuova password")"
                                              Variant="Variant.Outlined" InputType="InputType.Password" Required="true"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_changePassword.ConfirmPassword"
                                              Label="@TranslationService.GetTranslation("field.confirmPassword", "Conferma password")"
                                              Variant="Variant.Outlined" InputType="InputType.Password" Required="true"
                    Margin="Margin.Dense"/>
                            </MudItem>
                            <MudItem xs="12" Class="d-flex justify-end">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           OnClick="ChangePassword" Disabled="_isSaving">
                                    @TranslationService.GetTranslation("profile.changePassword", "Cambia Password")
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                        @if (_profile.PasswordChangedAt.HasValue)
                        {
                            <MudAlert Severity="Severity.Info" Class="mt-4">
                                @TranslationService.GetTranslation("profile.passwordLastChanged", "Ultima modifica password:")
                                @_profile.PasswordChangedAt.Value.ToString("dd/MM/yyyy HH:mm")
                            </MudAlert>
                        }
                    </div>
                </MudTabPanel>

                <!-- Notifiche -->
                <MudTabPanel Text="@TranslationService.GetTranslation("profile.notifications", "Notifiche")" Icon="@Icons.Material.Outlined.Notifications">
                    <div class="pa-3">
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudSwitch @bind-Value="_notificationPreferences.EmailNotificationsEnabled"
                                           Label="@TranslationService.GetTranslation("profile.emailNotifications", "Notifiche Email")"
                                           Color="Color.Primary" />
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("profile.emailNotificationsDescription", "Ricevi notifiche via email")
                                </MudText>
                            </MudItem>
                            <MudItem xs="12">
                                <MudSwitch @bind-Value="_notificationPreferences.PushNotificationsEnabled"
                                           Label="@TranslationService.GetTranslation("profile.pushNotifications", "Notifiche Push")"
                                           Color="Color.Primary" />
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("profile.pushNotificationsDescription", "Ricevi notifiche push sul dispositivo")
                                </MudText>
                            </MudItem>
                            <MudItem xs="12">
                                <MudSwitch @bind-Value="_notificationPreferences.InAppNotificationsEnabled"
                                           Label="@TranslationService.GetTranslation("profile.inAppNotifications", "Notifiche In-App")"
                                           Color="Color.Primary" />
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("profile.inAppNotificationsDescription", "Mostra notifiche nell'applicazione")
                                </MudText>
                            </MudItem>
                            <MudItem xs="12" Class="d-flex justify-end">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           OnClick="UpdateNotificationPreferences" Disabled="_isSaving">
                                    @TranslationService.GetTranslation("common.save", "Salva modifiche")
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudTabPanel>

                <!-- Sessioni -->
                <MudTabPanel Text="@TranslationService.GetTranslation("profile.sessions", "Sessioni")" Icon="@Icons.Material.Outlined.DevicesOther">
                    <div class="pa-3">
                        <MudText Typo="Typo.subtitle1" Class="mb-3">
                            @TranslationService.GetTranslation("profile.activeSessions", "Sessioni Attive")
                        </MudText>
                        <EFTable TItem="ActiveSessionDto"
                                 Items="@_activeSessions"
                                 Hover="true"
                                 Dense="true"
                                 IsLoading="@_isLoadingSessions"
                                 LoadingProgressColor="Color.Primary"
                                 Breakpoint="Breakpoint.Sm"
                                 ShowSearch="false"
                                 ShowFilters="false"
                                 ShowRefresh="false"
                                 ShowCreate="false"
                                 ShowExport="false"
                                 ShowColumnConfiguration="false"
                                 ShowFooter="false"
                                 AllowDragDropGrouping="false"
                                 ComponentKey="profile-dialog-active-sessions"
                                 InitialColumnConfigurations="@_sessionColumns">
                            <HeaderContent Context="columns">
                                <MudTh>@TranslationService.GetTranslation("field.browser", "Browser")</MudTh>
                                <MudTh>@TranslationService.GetTranslation("field.device", "Dispositivo")</MudTh>
                                <MudTh>@TranslationService.GetTranslation("field.ipAddress", "IP")</MudTh>
                                <MudTh>@TranslationService.GetTranslation("field.loginTime", "Accesso")</MudTh>
                                <MudTh>@TranslationService.GetTranslation("common.actions", "Azioni")</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="session">
                                <MudTd DataLabel="Browser">@session.Browser</MudTd>
                                <MudTd DataLabel="Dispositivo">@session.OperatingSystem - @session.DeviceType</MudTd>
                                <MudTd DataLabel="IP">@session.IpAddress</MudTd>
                                <MudTd DataLabel="Accesso">@session.LoginTime.ToString("dd/MM/yyyy HH:mm")</MudTd>
                                <MudTd>
                                    @if (!session.IsCurrentSession)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                                       OnClick="@(() => TerminateSession(session.Id))"
                                                       aria-label="@TranslationService.GetTranslation("profile.terminateSession", "Termina sessione")" />
                                    }
                                    else
                                    {
                                        <MudChip T="string" Color="Color.Success" Size="Size.Small">
                                            @TranslationService.GetTranslation("profile.current", "Corrente")
                                        </MudChip>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </EFTable>

                        @if (_activeSessions.Count > 1)
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.RemoveCircleOutline"
                                       OnClick="TerminateAllOtherSessions" Class="mt-3">
                                @TranslationService.GetTranslation("profile.terminateAllOtherSessions", "Termina tutte le altre sessioni")
                            </MudButton>
                        }

                        <MudDivider Class="my-4" />

                        <MudText Typo="Typo.subtitle1" Class="mb-3">
                            @TranslationService.GetTranslation("profile.loginHistory", "Cronologia Accessi")
                        </MudText>
                        <MudExpansionPanels>
                            @foreach (var entry in _loginHistory)
                            {
                                <MudExpansionPanel>
                                    <TitleContent>
                                        <div class="d-flex justify-space-between align-center w-full">
                                            <div>
                                                <MudIcon Icon="@(entry.WasSuccessful ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Error)"
                                                         Color="@(entry.WasSuccessful ? Color.Success : Color.Error)"
                                                         Size="Size.Small" Class="mr-2" />
                                                @entry.LoginTime.ToString("dd/MM/yyyy HH:mm")
                                            </div>
                                            <MudChip T="string" Color="@(entry.WasSuccessful ? Color.Success : Color.Error)" Size="Size.Small">
                                                @(entry.WasSuccessful ? TranslationService.GetTranslation("common.success", "Successo") : TranslationService.GetTranslation("common.failed", "Fallito"))
                                            </MudChip>
                                        </div>
                                    </TitleContent>
                                    <ChildContent>
                                        <MudGrid>
                                            <MudItem xs="6" sm="4">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Browser</MudText>
                                                <MudText>@entry.Browser</MudText>
                                            </MudItem>
                                            <MudItem xs="6" sm="4">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">IP</MudText>
                                                <MudText>@entry.IpAddress</MudText>
                                            </MudItem>
                                            @if (!entry.WasSuccessful && !string.IsNullOrEmpty(entry.FailureReason))
                                            {
                                                <MudItem xs="12">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Motivo</MudText>
                                                    <MudText Color="Color.Error">@entry.FailureReason</MudText>
                                                </MudItem>
                                            }
                                        </MudGrid>
                                    </ChildContent>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </div>
                </MudTabPanel>

            </MudTabs>
        }
    </ChildContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Close">
            @TranslationService.GetTranslation("common.close", "Chiudi")
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _isLoadingSessions = false;

    private UserProfileDto? _profile;
    private UpdateProfileDto _updateProfile = new();
    private ChangePasswordDto _changePassword = new();
    private UpdateNotificationPreferencesDto _notificationPreferences = new();
    private List<ActiveSessionDto> _activeSessions = new();
    private List<LoginHistoryDto> _loginHistory = new();

    private readonly List<EFTableColumnConfiguration> _sessionColumns = new()
    {
        new() { PropertyName = "Browser",         DisplayName = "Browser",     Order = 0 },
        new() { PropertyName = "OperatingSystem", DisplayName = "Dispositivo", Order = 1 },
        new() { PropertyName = "IpAddress",       DisplayName = "IP",          Order = 2 },
        new() { PropertyName = "LoginTime",       DisplayName = "Accesso",     Order = 3 },
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadProfile();
            await LoadSessions();
            await LoadLoginHistory();
        }
        catch (Exception ex)
        {
            AppNotification.ShowError($"Errore nel caricamento del profilo: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadProfile()
    {
        try
        {
            _profile = await ProfileService.GetProfileAsync();
            if (_profile != null)
            {
                _updateProfile = new UpdateProfileDto
                {
                    FirstName = _profile.FirstName,
                    LastName = _profile.LastName,
                    Email = _profile.Email,
                    PhoneNumber = _profile.PhoneNumber,
                    PreferredLanguage = _profile.PreferredLanguage,
                    TimeZone = _profile.TimeZone
                };
                _notificationPreferences = new UpdateNotificationPreferencesDto
                {
                    EmailNotificationsEnabled = _profile.EmailNotificationsEnabled,
                    PushNotificationsEnabled = _profile.PushNotificationsEnabled,
                    InAppNotificationsEnabled = _profile.InAppNotificationsEnabled
                };
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading profile.");
            AppNotification.ShowError(TranslationService.GetTranslation("error.loadProfileFailed", "Errore nel caricamento del profilo"));
        }
    }

    private async Task LoadSessions()
    {
        _isLoadingSessions = true;
        try
        {
            _activeSessions = await ProfileService.GetActiveSessionsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading active sessions.");
            AppNotification.ShowError(TranslationService.GetTranslation("error.loadSessionsFailed", "Errore nel caricamento delle sessioni"));
        }
        finally
        {
            _isLoadingSessions = false;
        }
    }

    private async Task LoadLoginHistory()
    {
        try
        {
            _loginHistory = await ProfileService.GetLoginHistoryAsync(30);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading login history.");
            AppNotification.ShowError(TranslationService.GetTranslation("error.loadLoginHistoryFailed", "Errore nel caricamento della cronologia"));
        }
    }

    private async Task UpdateProfile()
    {
        _isSaving = true;
        try
        {
            var updated = await ProfileService.UpdateProfileAsync(_updateProfile);
            if (updated != null)
            {
                _profile = updated;
                AppNotification.ShowSuccess(TranslationService.GetTranslation("profile.updateSuccess", "Profilo aggiornato con successo"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating profile.");
            AppNotification.ShowError(TranslationService.GetTranslation("error.updateProfileFailed", "Errore nell'aggiornamento del profilo"));
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task UpdateNotificationPreferences()
    {
        _isSaving = true;
        try
        {
            var updated = await ProfileService.UpdateNotificationPreferencesAsync(_notificationPreferences);
            if (updated != null)
            {
                _profile = updated;
                AppNotification.ShowSuccess(TranslationService.GetTranslation("profile.notificationsUpdateSuccess", "Preferenze notifiche aggiornate"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating notification preferences.");
            AppNotification.ShowError(TranslationService.GetTranslation("error.updateNotificationsFailed", "Errore nell'aggiornamento delle notifiche"));
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ChangePassword()
    {
        _isSaving = true;
        try
        {
            var success = await ProfileService.ChangePasswordAsync(_changePassword);
            if (success)
            {
                _changePassword = new ChangePasswordDto();
                AppNotification.ShowSuccess(TranslationService.GetTranslation("profile.passwordChangeSuccess", "Password aggiornata con successo"));
                await LoadProfile();
            }
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task OnAvatarSelected(IBrowserFile file)
    {
        if (file != null)
        {
            try
            {
                using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                var updated = await ProfileService.UploadAvatarAsync(stream, file.Name, file.ContentType);
                if (updated != null) _profile = updated;
            }
            catch (Exception ex)
            {
                AppNotification.ShowError($"Errore nel caricamento avatar: {ex.Message}");
            }
        }
    }

    private async Task DeleteAvatar()
    {
        try
        {
            var success = await ProfileService.DeleteAvatarAsync();
            if (success) await LoadProfile();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in DeleteAvatar.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task TerminateSession(Guid sessionId)
    {
        try
        {
            var success = await ProfileService.TerminateSessionAsync(sessionId);
            if (success) await LoadSessions();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in TerminateSession.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task TerminateAllOtherSessions()
    {
        try
        {
            var success = await ProfileService.TerminateAllOtherSessionsAsync();
            if (success) await LoadSessions();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in TerminateAllOtherSessions.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private void Close() => MudDialog.Close();

    private Color GetRoleColor(string role) => role.ToLower() switch
    {
        "superadmin" => Color.Error,
        "admin" => Color.Warning,
        "manager" => Color.Info,
        _ => Color.Primary
    };

    private string GetUserInitials()
    {
        if (_profile == null) return "?";
        var first = string.IsNullOrWhiteSpace(_profile.FirstName) ? null : _profile.FirstName!.Trim();
        var last = string.IsNullOrWhiteSpace(_profile.LastName) ? null : _profile.LastName!.Trim();
        if (string.IsNullOrEmpty(first) && string.IsNullOrEmpty(last))
        {
            var uname = _profile.Username ?? string.Empty;
            return !string.IsNullOrEmpty(uname) ? char.ToUpperInvariant(uname[0]).ToString() : "?";
        }
        var fi = !string.IsNullOrEmpty(first) ? char.ToUpperInvariant(first![0]).ToString() : "";
        var li = !string.IsNullOrEmpty(last) ? char.ToUpperInvariant(last![0]).ToString() : "";
        return $"{fi}{li}";
    }
}
