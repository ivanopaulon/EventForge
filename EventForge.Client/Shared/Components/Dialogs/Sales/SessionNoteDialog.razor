@using EventForge.Client.Services.Sales
@inject ITranslationService TranslationService
@inject INoteFlagService NoteFlagService
@inject IAppNotificationService AppNotification
@inject ILogger<SessionNoteDialog> Logger

<EFDialog Icon="@Icons.Material.Outlined.StickyNote2"
          Title="Nota Sessione"
          IsProcessing="false"
          OnClose="Cancel">
    
    <ChildContent>
        <MudSelect T="Guid"
                   @bind-Value="_selectedNoteFlagId"
                   Label="Categoria Nota"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Required="true"
                   HelperText="Seleziona la tipologia di nota">
            @if (_noteFlags != null)
            {
                @foreach (var flag in _noteFlags)
                {
                    <MudSelectItem T="Guid" Value="@flag.Id">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            @if (!string.IsNullOrEmpty(flag.Icon))
                            {
                                <MudIcon Icon="@flag.Icon" 
                                         Color="Color.Default" 
                                         Style="@($"color: {flag.Color ?? "#666"}")" 
                                         Size="Size.Small" />
                            }
                            <MudText>@flag.Name</MudText>
                        </MudStack>
                    </MudSelectItem>
                }
            }
        </MudSelect>
        
        <MudTextField @bind-Value="_noteText"
                      Label="@TranslationService.GetTranslation("sales.note", "Nota")"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Lines="4"
                      MaxLength="500"
                      Counter="500"
                      Class="mt-4"
                      HelperText="@TranslationService.GetTranslation("sales.noteHelper", "Inserisci una nota per questa vendita (max 500 caratteri)")" />
    </ChildContent>
    
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Variant="Variant.Text"
                   Disabled="false">
            @TranslationService.GetTranslation("common.cancel", "Annulla")
        </MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Outlined.Save"
                   OnClick="Submit"
                   Disabled="@(_selectedNoteFlagId == Guid.Empty || string.IsNullOrWhiteSpace(_noteText))">
            @TranslationService.GetTranslation("common.save", "Salva")
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid? SessionId { get; set; }
    
    private Guid _selectedNoteFlagId = Guid.Empty;
    private string _noteText = string.Empty;
    private List<NoteFlagDto>? _noteFlags;
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Carica flags attivi da backend
            _noteFlags = await NoteFlagService.GetActiveAsync();

            // Pre-seleziona primo flag se disponibile
            if (_noteFlags != null && _noteFlags.Count > 0)
            {
                _selectedNoteFlagId = _noteFlags.First().Id;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading note flags");
            AppNotification.ShowError(TranslationService.GetTranslation("error.loadFailed", "Errore durante il caricamento dei dati"));
        }
    }
    
    private void Submit()
    {
        var dto = new AddSessionNoteDto
        {
            NoteFlagId = _selectedNoteFlagId,
            Text = _noteText
        };
        
        MudDialog.Close(DialogResult.Ok(dto));
    }
    
    private void Cancel() => MudDialog.Cancel();
}
