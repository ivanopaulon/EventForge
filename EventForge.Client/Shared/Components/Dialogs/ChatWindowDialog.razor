@namespace EventForge.Client.Shared.Components.Dialogs
@using EventForge.DTOs.Chat
@inject IChatService ChatService
@inject IAuthService AuthService
@inject IRealtimeService RealtimeService
@inject IJSRuntime JS
@implements IAsyncDisposable

<MudDialog Style="width:min(480px,95vw);height:min(600px,90vh);display:flex;flex-direction:column;overflow:hidden;">
    <TitleContent>
        <div class="cwd-header">
            @if (_selectedChat != null)
            {
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                               Color="Color.Inherit"
                               Size="Size.Small"
                               OnClick="BackToList" />
                <MudAvatar Style="@($"background-color:{GetAvatarHex(GetChatName(_selectedChat))};color:#fff;width:32px;height:32px;min-width:32px;font-size:0.75rem;")"
                           Size="Size.Small">
                    @GetInitials(GetChatName(_selectedChat))
                </MudAvatar>
                <div class="cwd-header-info">
                    <span class="cwd-header-title">@GetChatName(_selectedChat)</span>
                    @if (IsDirectMessageOnline(_selectedChat))
                    {
                        <span class="cwd-online-label">● Online</span>
                    }
                </div>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.Chat" Color="Color.Inherit" Class="mr-2" />
                <span class="cwd-header-title">Messaggi</span>
            }
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Color="Color.Inherit"
                           Size="Size.Small"
                           OnClick="Close"
                           title="Chiudi" />
        </div>
    </TitleContent>
    <DialogContent>
        <div class="cwd-body">
            @if (_isLoading)
            {
                <div class="cwd-loading">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                </div>
            }
            else if (_selectedChat == null)
            {
                <!-- Chat list view -->
                <div class="cwd-search-bar">
                    <MudTextField T="string"
                                  Value="@_searchQuery"
                                  ValueChanged="@(v => _searchQuery = v ?? string.Empty)"
                                  Placeholder="Cerca chat..."
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Clearable="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  Class="cwd-search-field" />
                </div>

                <div class="cwd-chat-list">
                    @if (!_chats.Any())
                    {
                        <div class="cwd-empty">
                            <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Class="cwd-empty-icon" />
                            <span>Nessuna chat</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var chat in FilteredChats)
                        {
                            <div class="cwd-chat-item" @onclick="() => OpenChat(chat)">
                                <div class="cwd-chat-avatar-wrap">
                                    <MudAvatar Style="@($"background-color:{GetAvatarHex(GetChatName(chat))};color:#fff;font-size:0.8rem;")"
                                               Size="Size.Small">
                                        @GetInitials(GetChatName(chat))
                                    </MudAvatar>
                                    @if (IsDirectMessageOnline(chat))
                                    {
                                        <span class="cwd-online-dot"></span>
                                    }
                                </div>
                                <div class="cwd-chat-item-info">
                                    <div class="cwd-chat-item-header">
                                        <span class="cwd-chat-item-name">@GetChatName(chat)</span>
                                        @if (chat.LastMessage != null)
                                        {
                                            <span class="cwd-chat-item-time">@FormatTime(chat.LastMessage.SentAt)</span>
                                        }
                                    </div>
                                    <span class="cwd-chat-item-preview">@(chat.LastMessage?.Content ?? "Nessun messaggio")</span>
                                </div>
                                @if (chat.UnreadCount > 0)
                                {
                                    <MudBadge Content="@chat.UnreadCount"
                                              Color="Color.Primary"
                                              Overlap="false"
                                              Max="99"
                                              Class="cwd-unread-badge" />
                                }
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                <!-- Conversation view -->
                <div class="cwd-messages" id="cwd-scroll">
                    @if (!_messages.Any())
                    {
                        <div class="cwd-empty">
                            <span>Nessun messaggio. Inizia a scrivere!</span>
                        </div>
                    }
                    @foreach (var msg in _messages)
                    {
                        var isMine = msg.SenderId == _currentUserId;
                        <div class="cwd-msg-row @(isMine ? "cwd-msg-row--mine" : "cwd-msg-row--theirs")">
                            @if (!isMine)
                            {
                                <MudAvatar Style="@($"background-color:{GetAvatarHex(msg.SenderName ?? "?")};color:#fff;font-size:0.7rem;width:28px;height:28px;min-width:28px;")"
                                           Size="Size.Small">
                                    @GetInitials(msg.SenderName ?? "?")
                                </MudAvatar>
                            }
                            <div class="cwd-bubble @(isMine ? "cwd-bubble--mine" : "cwd-bubble--theirs")">
                                @if (!isMine && _selectedChat.Type != ChatType.DirectMessage)
                                {
                                    <span class="cwd-bubble-sender">@msg.SenderName</span>
                                }
                                <span class="cwd-bubble-text">@msg.Content</span>
                                <span class="cwd-bubble-time">@msg.SentAt.ToString("HH:mm")</span>
                            </div>
                        </div>
                    }
                    @if (_typingUsers.Count > 0)
                    {
                        <div class="cwd-msg-row cwd-msg-row--theirs">
                            <div class="cwd-typing-indicator">
                                <span class="cwd-typing-dot"></span>
                                <span class="cwd-typing-dot"></span>
                                <span class="cwd-typing-dot"></span>
                            </div>
                        </div>
                    }
                </div>

                <!-- Input bar -->
                <div class="cwd-input-bar" @onkeydown="OnKeyDown">
                    <MudTextField T="string"
                                  Value="@_newMessage"
                                  ValueChanged="@OnMessageChanged"
                                  Placeholder="Scrivi un messaggio..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  Lines="1"
                                  Class="cwd-input-field" />
                    <MudIconButton Icon="@Icons.Material.Filled.Send"
                                   Color="Color.Primary"
                                   OnClick="SendMessage"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newMessage))"
                                   aria-label="Invia messaggio" />
                </div>
            }
        </div>
    </DialogContent>
</MudDialog>

<style>
    .cwd-header {
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        min-height: 40px;
    }

    .cwd-header-info {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-width: 0;
    }

    .cwd-header-title {
        font-weight: 600;
        font-size: 0.95rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .cwd-online-label {
        font-size: 0.7rem;
        color: #4caf50;
        font-weight: 500;
    }

