    .cwd-bubble--mine {
        background: var(--mud-palette-primary);
        color: var(--mud-palette-primary-text);
        border-bottom-right-radius: 4px;
    }

    .cwd-bubble--theirs {
        background: var(--mud-palette-action-default-hover, #f0f0f0);
        color: var(--mud-palette-text-primary);
        border-bottom-left-radius: 4px;
    }

    .cwd-bubble-sender {
        font-size: 0.72rem;
        font-weight: 600;
        opacity: 0.8;
    }

    .cwd-bubble-text {
        line-height: 1.4;
    }

    .cwd-bubble-time {
        font-size: 0.68rem;
        opacity: 0.7;
        align-self: flex-end;
        margin-top: 2px;
    }

    .cwd-typing-indicator {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 10px 14px;
        background: var(--mud-palette-action-default-hover, #f0f0f0);
        border-radius: 16px;
        border-bottom-left-radius: 4px;
