    }

    .cwd-search-bar {
        padding: 8px 0 8px 0;
        flex-shrink: 0;
    }

    .cwd-search-field {
        width: 100%;
    }

    .cwd-chat-list {
        flex: 1;
        overflow-y: auto;
    }

    .cwd-chat-item {
        display: flex;
        align-items: center;
        padding: 10px 4px;
        gap: 10px;
        cursor: pointer;
        transition: background 0.15s;
        border-radius: 4px;
    }

    .cwd-chat-item:hover {
        background: var(--mud-palette-action-hover);
    }

    .cwd-chat-avatar-wrap {
        position: relative;
        flex-shrink: 0;
    }

    .cwd-online-dot {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 10px;
        height: 10px;
        background: #4caf50;
        border-radius: 50%;
        border: 2px solid var(--mud-palette-surface);
    }

    .cwd-chat-item-info {
        flex: 1;
        min-width: 0;
    }

    .cwd-chat-item-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .cwd-chat-item-name {
        font-weight: 600;
        font-size: 0.85rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .cwd-chat-item-time {
        font-size: 0.7rem;
        color: var(--mud-palette-text-secondary);
        flex-shrink: 0;
        margin-left: 4px;
    }

    .cwd-chat-item-preview {
        font-size: 0.78rem;
        color: var(--mud-palette-text-secondary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
    }

    .cwd-unread-badge {
        flex-shrink: 0;
    }

    .cwd-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        gap: 8px;
        color: var(--mud-palette-text-secondary);
        font-size: 0.85rem;
        padding: 24px;
    }

    .cwd-empty-icon {
        font-size: 2.5rem !important;
        opacity: 0.4;
    }

    .cwd-messages {
        flex: 1;
        overflow-y: auto;
        padding: 4px 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .cwd-msg-row {
        display: flex;
        align-items: flex-end;
        gap: 6px;
    }

    .cwd-msg-row--mine {
        flex-direction: row-reverse;
    }

    .cwd-bubble {
        max-width: 75%;
        padding: 8px 12px;
        border-radius: 16px;
        font-size: 0.85rem;
        display: flex;
        flex-direction: column;
        gap: 2px;
        word-break: break-word;
