@namespace EventForge.Client.Shared.Components.Dialogs.SystemDialogs
@using MudBlazor
@inject IUpdateNotificationService UpdateNotification
@implements IDisposable

<EFSystemDialog Title="PRYM"
                Subtitle="@_subtitle"
                TopBar="@_topBar"
                LogoAnim="EFSystemDialog.EFLogoAnim.Pulse"
                ShowProgressBar="@_showProgressBar"
                ProgressIndeterminate="@_progressIndeterminate"
                ProgressValue="@_progressValue"
                ProgressColor="@_progressColor"
                CardWidth="420px">

    @* ── Active download / install progress ── *@
    @if (UpdateNotification.IsActiveUpdate)
    {
        var p = UpdateNotification.CurrentProgress!;

        <div class="umsd-status-row">
            <MudIcon Icon="@Icons.Material.Filled.SystemUpdate"
                     Size="Size.Small"
                     Style="color:#247BFF" />
            <span class="umsd-label">Componente</span>
            <span class="umsd-value" style="color:#64aaff">@(p.Component ?? "—")</span>
            @if (!string.IsNullOrEmpty(p.Version))
            {
                <span class="umsd-version">v@p.Version</span>
            }
        </div>

        <div class="umsd-status-row">
            <MudIcon Icon="@Icons.Material.Outlined.Pending"
                     Size="Size.Small"
                     Style="color:#247BFF" />
            <span class="umsd-label">Fase</span>
            <span class="umsd-value" style="color:#64aaff">@TranslatePhase(p.Phase)</span>
        </div>

        @if (p.FormattedTotal != null || p.FormattedDownloaded != null)
        {
            <div class="umsd-status-row">
                <MudIcon Icon="@Icons.Material.Outlined.CloudDownload"
                         Size="Size.Small"
                         Style="color:rgba(255,255,255,0.45)" />
                <span class="umsd-label">Download</span>
                <span class="umsd-value" style="color:rgba(255,255,255,0.80)">
                    @if (p.FormattedTotal != null)
                    { @($"{p.FormattedDownloaded} / {p.FormattedTotal}") }
                    else
                    { @p.FormattedDownloaded }
                    @if (p.FormattedSpeed != null) { <span class="umsd-speed"> — @p.FormattedSpeed</span> }
                </span>
            </div>
        }

        <div class="umsd-progress-section">
            <MudProgressLinear Color="Color.Primary"
                               Value="@(p.PercentComplete ?? 0)"
                               Max="100"
                               Indeterminate="@(p.PercentComplete == null)"
                               Rounded="true"
                               Size="Size.Small"
                               Class="umsd-inline-progress" />
            @if (p.PercentComplete != null)
            {
                <span class="umsd-pct">@p.PercentComplete%</span>
            }
            @if (p.Eta != null)
            {
                <span class="umsd-eta">ETA @p.Eta</span>
            }
        </div>

        @if (!UpdateNotification.IsServerMaintenance)
        {
            <div class="umsd-message">
                Aggiornamento in corso. Non chiudere il browser e non navigare via da questa pagina.
            </div>
        }
    }

    @* ── Server maintenance (IIS restarting) ── *@
    @if (UpdateNotification.IsServerMaintenance)
    {
        <div class="umsd-divider-row"></div>
        <div class="umsd-status-row">
            <MudIcon Icon="@Icons.Material.Filled.SystemUpdate"
                     Size="Size.Small"
                     Style="color:#ffa726" />
            <span class="umsd-label">Componente</span>
            <span class="umsd-value umsd-warn">@(UpdateNotification.MaintenanceComponent ?? "Server")</span>
        </div>

        @if (!string.IsNullOrEmpty(UpdateNotification.MaintenanceVersion))
        {
            <div class="umsd-status-row">
                <MudIcon Icon="@Icons.Material.Outlined.NewReleases"
                         Size="Size.Small"
                         Style="color:#ffa726" />
                <span class="umsd-label">Versione</span>
                <span class="umsd-value umsd-warn">@UpdateNotification.MaintenanceVersion</span>
            </div>
        }

        <div class="umsd-message">
            Il server si riavvierà automaticamente al termine dell'aggiornamento.
            Questa finestra si chiuderà non appena il sistema tornerà online.
        </div>
    }

    @* ── Client update deployed — needs browser refresh ── *@
    @if (UpdateNotification.HasPendingClientUpdate)
    {
        <div class="umsd-divider-row"></div>
        <div class="umsd-client-update">
            <MudIcon Icon="@Icons.Material.Filled.BrowserUpdated"
                     Size="Size.Small"
                     Style="color:#66bb6a; margin-right:6px" />
            <span>
                Nuova versione client disponibile
                @if (!string.IsNullOrEmpty(UpdateNotification.ClientUpdateVersion))
                { <span> — <strong>v@UpdateNotification.ClientUpdateVersion</strong></span> }
            </span>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="ReloadPage"
                   Class="umsd-reload-btn">
            Ricarica la pagina
        </MudButton>
    }

</EFSystemDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;

    private bool _showProgressBar =>
        UpdateNotification.IsActiveUpdate || UpdateNotification.IsServerMaintenance;

    private bool _progressIndeterminate =>
        UpdateNotification.CurrentProgress?.PercentComplete == null;

    private double _progressValue =>
        UpdateNotification.CurrentProgress?.PercentComplete ?? 0;

    private Color _progressColor =>
        UpdateNotification.IsServerMaintenance ? Color.Warning : Color.Primary;

    private EFSystemDialog.EFTopBar _topBar
    {
        get
        {
            if (UpdateNotification.HasPendingClientUpdate && !UpdateNotification.IsActiveUpdate && !UpdateNotification.IsServerMaintenance)
                return EFSystemDialog.EFTopBar.Success;
            if (UpdateNotification.IsServerMaintenance)
                return EFSystemDialog.EFTopBar.Warning;
            return EFSystemDialog.EFTopBar.Primary;
        }
    }

    private string _subtitle
    {
        get
        {
            if (UpdateNotification.IsActiveUpdate)
            {
                var phase = UpdateNotification.CurrentProgress?.Phase;
                return string.IsNullOrEmpty(phase) || phase == "Downloading"
                    ? "Download aggiornamento in corso…"
                    : "Installazione aggiornamento in corso…";
            }
            if (UpdateNotification.IsServerMaintenance)
                return "Aggiornamento server — attendere prego";
            return "Nuovo client disponibile";
        }
    }

    protected override void OnInitialized()
    {
        UpdateNotification.StateChanged += OnStateChanged;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void ReloadPage() =>
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);

    public void Dispose() =>
        UpdateNotification.StateChanged -= OnStateChanged;

    private static string TranslatePhase(string? phase) => phase switch
    {
        "Downloading"               => "Download in corso",
        "VerifyingChecksum"         => "Verifica integrità",
        "BackingUp"                 => "Backup in corso",
        "RunningPreMigrations"      => "Migrazioni pre-deploy",
        "StoppingService"           => "Arresto servizio",
        "DeployingBinaries"         => "Deploy file",
        "StartingService"           => "Avvio servizio",
        "RunningPostMigrations"     => "Migrazioni post-deploy",
        "VerifyingHealth"           => "Verifica salute",
        "Completed"                 => "Completato",
        "Rollback"                  => "Ripristino backup",
        "AwaitingMaintenanceWindow" => "In attesa finestra manutenzione",
        _                           => "Operazione in corso"
    };
}

<style>
    .umsd-status-row {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
    }

    .umsd-label {
        color: rgba(255, 255, 255, 0.55);
        min-width: 80px;
    }

    .umsd-value  { font-weight: 600; }
    .umsd-warn   { color: #ffa726; }
    .umsd-version {
        margin-left: auto;
        font-size: 0.75rem;
        color: rgba(255,255,255,0.45);
    }
    .umsd-speed {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.55);
    }

    .umsd-progress-section {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 2px;
    }
    .umsd-inline-progress { flex: 1; }
    .umsd-pct {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.70);
        min-width: 36px;
        text-align: right;
    }
    .umsd-eta {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.45);
        white-space: nowrap;
    }

    .umsd-message {
        color: rgba(255, 255, 255, 0.75);
        font-size: 0.82rem;
        line-height: 1.45;
        font-style: italic;
    }

    .umsd-divider-row {
        height: 1px;
        background: rgba(255,255,255,0.10);
        margin: 4px 0;
    }

    .umsd-client-update {
        display: flex;
        align-items: center;
        color: #66bb6a;
        font-size: 0.88rem;
        font-weight: 600;
        flex-wrap: wrap;
        gap: 2px;
    }

    .umsd-reload-btn {
        align-self: flex-start;
        margin-top: 2px;
    }

    @@media (max-width: 480px) {
        .umsd-status-row { justify-content: center; }
    }
</style>
