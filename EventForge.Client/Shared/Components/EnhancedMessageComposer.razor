@using Prym.DTOs.Chat
@using Microsoft.AspNetCore.Authorization
@using EventForge.Client.Shared.Helpers
@using Syncfusion.Blazor.RichTextEditor
@attribute [Authorize]
@inject ITranslationService TranslationService
@inject IJSRuntime JSRuntime
@inject IAppNotificationService AppNotification
@inject IRealtimeService RealtimeService
@inject ILogger<EnhancedMessageComposer> Logger
@inject NavigationManager Navigation

<MudPaper Elevation="3" Class="pa-3 enhanced-message-composer" Style="@ComposerStyle">
    <!-- Reply indicator if replying to a message -->
    @if (ReplyToMessage != null)
    {
        <div class="reply-indicator mb-2 pa-2" style="background: var(--mud-palette-grey-lighten4); border-left: 3px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-start">
                <div class="flex-grow-1">
                    <MudText Typo="Typo.caption" Color="Color.Primary" Class="font-weight-bold">
                        @TranslationService.GetTranslation("chat.replyingTo", "Replying to") @ReplyToMessage.SenderName
                    </MudText>
                    <MudText Typo="Typo.body2" Class="text-truncate">
                        @ReplyToMessage.Content
                    </MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Size="Size.Small"
                               OnClick="@CancelReply"
                               aria-label="@TranslationService.GetTranslation("chat.cancelReply", "Cancel reply")" />
            </div>
        </div>
    }

    <!-- Main composer area -->
    <div class="d-flex align-center gap-2">

        <!-- Rich text editor with Syncfusion RTE (file attach and emoji are in the toolbar) -->
        <div class="flex-grow-1 position-relative">
            <SfRichTextEditor @ref="_rteRef"
                              Value="@MessageText"
                              ValueChanged="@OnRteValueChanged"
                              Placeholder="@GetPlaceholderText()"
                              Height="@RteHeight"
                              EnableXhtml="true">
                <RichTextEditorToolbarSettings Items="@ChatEditorConfig.ToolbarItems">
                    <RichTextEditorCustomToolbarItems>
                        <RichTextEditorCustomToolbarItem Name="AttachFile">
                            <Template>
                                <button type="button" class="e-btn e-tbar-btn rte-custom-btn" title="@TranslationService.GetTranslation("chat.attachFile", "Allega file")" @onclick="SelectFile">
                                    <span class="rte-custom-btn-icon">📎</span>
                                </button>
                            </Template>
                        </RichTextEditorCustomToolbarItem>
                        <RichTextEditorCustomToolbarItem Name="AddEmoji">
                            <Template>
                                <button type="button" class="e-btn e-tbar-btn rte-custom-btn" title="@TranslationService.GetTranslation("chat.addEmoji", "Emoji")" @onclick="ToggleEmojiPicker">
                                    <span class="rte-custom-btn-icon">😊</span>
                                </button>
                            </Template>
                        </RichTextEditorCustomToolbarItem>
                    </RichTextEditorCustomToolbarItems>
                </RichTextEditorToolbarSettings>
                <RichTextEditorImageSettings SaveUrl="@RteImageUploadUrl"
                                             Path="/api/v1/chat/image-uploads" />
                <RichTextEditorEvents OnActionComplete="@OnRteActionComplete"
                                      OnImageUploadSuccess="@OnRteImageUploadSuccess" />
            </SfRichTextEditor>
        </div>

        <!-- Send button -->
        <MudTooltip Text="@TranslationService.GetTranslation("chat.sendMessage", "Send message")">
            <MudIconButton Icon="@Icons.Material.Filled.Send"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           OnClick="@SendMessage"
                           Disabled="@(CanSend == false || IsSending)"
                           aria-label="@TranslationService.GetTranslation("chat.sendMessage", "Send message")" />
        </MudTooltip>
    </div>

    <!-- Emoji picker -->
    @if (ShowEmojiPicker)
    {
        <div class="emoji-picker mt-2 pa-2" style="background: var(--mud-palette-grey-lighten5); border-radius: 4px;">
            <div class="d-flex flex-wrap gap-1">
                @foreach (var emoji in CommonEmojis)
                {
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               Class="ef-compact-btn"
                               OnClick="@(() => InsertEmoji(emoji))"
                               tabindex="0"
                               aria-label="@($"Insert {emoji} emoji")">
                        @emoji
                    </MudButton>
                }
            </div>
        </div>
    }

    <!-- File attachments preview -->
    @if (PendingAttachments?.Any() == true)
    {
        <div class="attachments-preview mt-2">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                @TranslationService.GetTranslation("chat.attachments", "Attachments")
            </MudText>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var attachment in PendingAttachments)
                {
                    <MudChip T="string"
                             Text="@attachment.FileName"
                             StartIcon="@GetFileIcon(attachment.ContentType)"
                             OnClose="@(() => RemoveAttachment(attachment))"
                             Closable="true"
                             Size="Size.Small" />
                }
            </div>
        </div>
    }
</MudPaper>

<!-- Hidden file input – unique ID per component instance avoids conflicts when multiple composers are mounted -->
<InputFile @ref="fileInput" 
           OnChange="@HandleFileInputChanged"
           multiple 
           accept="*/*" 
           class="d-none" 
           id="@_fileInputId" />

<style>
.enhanced-message-composer {
    position: relative;
}

.format-buttons .mud-button-group > .mud-icon-button {
    border-radius: 0;
}

.format-buttons .mud-button-group > .mud-icon-button:first-child {
    border-top-left-radius: 4px;
    border-bottom-left-radius: 4px;
}

.format-buttons .mud-button-group > .mud-icon-button:last-child {
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
}

.mention-suggestions .mud-button:hover {
    background-color: var(--mud-palette-action-hover);
}

.emoji-picker .mud-button:hover {
    background-color: var(--mud-palette-action-hover);
}

.reply-indicator {
    border-radius: 4px;
}

.attachments-preview .mud-chip {
    max-width: 200px;
}

.rte-custom-btn {
    padding: 0 6px !important;
    min-width: 32px;
    height: 28px;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
}

.rte-custom-btn-icon {
    font-style: normal;
    line-height: 1;
}
</style>

@code {
    [Parameter] public ChatResponseDto? CurrentChat { get; set; }
    [Parameter] public ChatMessageDto? ReplyToMessage { get; set; }
    [Parameter] public EventCallback<SendMessageDto> OnSendMessage { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<IBrowserFile>> OnAttachFile { get; set; }
    [Parameter] public EventCallback OnCancelReply { get; set; }
    [Parameter] public List<MessageAttachmentDto>? PendingAttachments { get; set; }
    [Parameter] public EventCallback<MessageAttachmentDto> OnRemoveAttachment { get; set; }
    [Parameter] public string ComposerStyle { get; set; } = "";
    [Parameter] public bool IsSending { get; set; }
    [Parameter] public string RteHeight { get; set; } = "120px";
    /// <summary>
    /// When set, pre-populates the editor content (used in edit-message mode).
    /// </summary>
    [Parameter] public string? InitialContent { get; set; }

    // True when there is something to send (text or at least one pending attachment).
    private bool CanSend => !string.IsNullOrWhiteSpace(MessageText) || PendingAttachments?.Count > 0;

    private SfRichTextEditor? _rteRef;
    private InputFile? fileInput;
    private string MessageText = "";
    private bool ShowEmojiPicker = false;
    private readonly List<Guid> MentionedUserIds = new();
    private DateTime _lastTypingIndicatorSent = DateTime.MinValue;
    private static readonly TimeSpan TypingIndicatorThrottle = TimeSpan.FromSeconds(3);
    // Unique ID per instance – prevents conflicts when multiple composers are mounted simultaneously.
    private readonly string _fileInputId = $"ef-file-{Guid.NewGuid():N}";
    private bool _initialContentApplied;

    // Base URL for RTE image upload — uses the existing chat file upload endpoint
    private string RteImageUploadUrl =>
        Navigation.BaseUri.TrimEnd('/') + "/api/v1/chat/upload-image";

    private readonly string[] CommonEmojis =
    [
        "😀", "😃", "😄", "😁", "😆", "😅", "🤣", "😂", "🙂", "🙃",
        "😉", "😊", "😇", "😍", "🤩", "😘", "😗", "😚", "😙", "😋",
        "😎", "🤓", "🧐", "🤔", "😐", "😑", "😶", "🙄", "😏", "😣",
        "👍", "👎", "👌", "🤞", "✌️", "🤟", "🤘", "🤙", "👈", "👉",
        "❤️", "🧡", "💛", "💚", "💙", "💜", "🖤", "🤍", "🤎", "💔",
        "🔥", "💯", "💢", "💥", "💦", "💨", "🎉", "🎊", "👏", "🙌"
    ];

    protected override void OnParametersSet()
    {
        // Apply InitialContent once when the component first receives it (edit-message mode).
        if (!_initialContentApplied && !string.IsNullOrEmpty(InitialContent))
        {
            MessageText = InitialContent;
            _initialContentApplied = true;
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender) => Task.CompletedTask;

    private string GetPlaceholderText()
    {
        if (ReplyToMessage != null)
            return TranslationService.GetTranslation("chat.replyPlaceholder", $"Reply to {ReplyToMessage.SenderName}...");
        return TranslationService.GetTranslation("chat.typeMessage", "Type a message...");
    }

    private void OnRteValueChanged(string value)
    {
        MessageText = value;
        _ = SendTypingIndicator();
    }

    private async Task OnRteActionComplete(ActionCompleteEventArgs args)
    {
        // SfRichTextEditor intercepts Enter to insert <p> tags. We detect Ctrl+Enter or
        // a custom toolbar "send" action and call SendMessage. Because RTE doesn't
        // provide a reliable keyboard event from inside the iframe, users click the
        // Send button; Shift+Enter naturally inserts a new paragraph in the RTE.
        await Task.CompletedTask;
    }

    private void OnRteImageUploadSuccess(ImageSuccessEventArgs args)
    {
        // The RTE automatically replaces the base64 src with the URL returned by the server.
        // Nothing extra needed here; the value is updated via OnRteValueChanged.
    }

    private void ToggleEmojiPicker()
    {
        ShowEmojiPicker = !ShowEmojiPicker;
        StateHasChanged();
    }

    private async Task InsertEmoji(string emoji)
    {
        try
        {
            if (_rteRef is not null)
                await _rteRef.ExecuteCommandAsync(CommandName.InsertHTML, emoji);
            ShowEmojiPicker = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in InsertEmoji.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task SendMessage()
    {
        try
        {
            var hasText        = !string.IsNullOrWhiteSpace(MessageText);
            var hasAttachments = PendingAttachments?.Count > 0;
            if ((!hasText && !hasAttachments) || CurrentChat == null)
                return;

            var message = new SendMessageDto
            {
                ChatId = CurrentChat.Id,
                SenderId = Guid.Empty, // Will be set by the service
                Content = MessageText.Trim(),
                ReplyToMessageId = ReplyToMessage?.Id,
                MentionedUserIds = MentionedUserIds.ToList(),
                Format = MessageFormat.Html,
                Attachments = PendingAttachments?.ToList()
            };

            // Clear the composer — update Value binding then refresh the RTE component
            MessageText = string.Empty;
            if (_rteRef is not null)
                await _rteRef.RefreshUIAsync();
            MentionedUserIds.Clear();
            ShowEmojiPicker = false;

            await OnSendMessage.InvokeAsync(message);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in SendMessage.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task CancelReply()
    {
        try
        {
            await OnCancelReply.InvokeAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in CancelReply.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private async Task SendTypingIndicator()
    {
        if (CurrentChat == null) return;

        var now = DateTime.UtcNow;
        if (now - _lastTypingIndicatorSent < TypingIndicatorThrottle)
            return;

        _lastTypingIndicatorSent = now;

        try
        {
            await RealtimeService.SendTypingIndicatorAsync(CurrentChat.Id, isTyping: true);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to send typing indicator for chat {ChatId}.", CurrentChat.Id);
        }
    }

    private async Task HandleFileInputChanged(InputFileChangeEventArgs e)
    {
        const long maxFileSizeBytes = 50L * 1024 * 1024; // 50 MB — must match server limit
        try
        {
            var files = e.GetMultipleFiles(10);
            if (files.Count == 0) return;

            var oversized = files.Where(f => f.Size > maxFileSizeBytes).ToList();
            foreach (var f in oversized)
                AppNotification.ShowWarning(
                    TranslationService.GetTranslation("chat.fileTooLarge", $"Il file '{f.Name}' supera il limite massimo di 50 MB e non può essere allegato.")
                        .Replace("{name}", f.Name));

            var valid = files.Where(f => f.Size <= maxFileSizeBytes).ToList();
            if (valid.Count > 0)
                await OnAttachFile.InvokeAsync(valid);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error handling file input change.");
            AppNotification.ShowWarning("Si è verificato un errore durante la selezione del file.");
        }
    }

    private async Task SelectFile()
    {
        try
        {
            // Use the unique instance ID so multiple composers on the same page don't conflict.
            await JSRuntime.InvokeVoidAsync("eval", $"document.getElementById('{_fileInputId}').click()");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in SelectFile.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    private string GetFileIcon(string? contentType)
    {
        return contentType?.ToLower() switch
        {
            null => Icons.Material.Filled.AttachFile,
            var ct when ct.StartsWith("image/") => Icons.Material.Filled.Image,
            var ct when ct.StartsWith("video/") => Icons.Material.Filled.VideoFile,
            var ct when ct.StartsWith("audio/") => Icons.Material.Filled.AudioFile,
            var ct when ct.Contains("pdf") => Icons.Material.Filled.PictureAsPdf,
            var ct when ct.Contains("word") => Icons.Material.Filled.Description,
            var ct when ct.Contains("excel") => Icons.Material.Filled.TableChart,
            var ct when ct.Contains("powerpoint") => Icons.Material.Filled.Slideshow,
            _ => Icons.Material.Filled.AttachFile
        };
    }

    private void RemoveAttachment(MessageAttachmentDto attachment)
    {
        OnRemoveAttachment.InvokeAsync(attachment);
    }

    public void Dispose()
    {
        // Clean up any subscriptions or resources
    }
}