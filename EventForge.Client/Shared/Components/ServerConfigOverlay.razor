@namespace EventForge.Client.Shared.Components
@inject IServerConfigOverlayService OverlayService
@inject IDialogService DialogService
@implements IDisposable

@code {
    private static readonly DialogOptions _options = new()
    {
        BackdropClick = false,
        CloseButton = false,
        CloseOnEscapeKey = false,
        Position = DialogPosition.Center,
    };

    private IDialogReference? _dialogRef;

    protected override async Task OnInitializedAsync()
    {
        OverlayService.OnVisibilityChanged += OnVisibilityChanged;

        if (OverlayService.IsVisible)
            await OpenDialogAsync();
    }

    private void OnVisibilityChanged()
    {
        InvokeAsync(async () =>
        {
            if (OverlayService.IsVisible)
                await OpenDialogAsync();
            else
                await CloseDialogAsync();
        });
    }

    private async Task OpenDialogAsync()
    {
        if (_dialogRef is not null) return;
        _dialogRef = await DialogService.ShowAsync<ServerConfigSystemDialog>(string.Empty, _options);
        _ = _dialogRef.Result.ContinueWith(_ => InvokeAsync(() => _dialogRef = null));
    }

    private async Task CloseDialogAsync()
    {
        if (_dialogRef is null) return;
        DialogService.Close(_dialogRef);
        _ = await _dialogRef.Result;
        _dialogRef = null;
    }

    public void Dispose()
    {
        OverlayService.OnVisibilityChanged -= OnVisibilityChanged;
    }
}
