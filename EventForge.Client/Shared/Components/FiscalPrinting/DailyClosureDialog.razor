@namespace EventForge.Client.Shared.Components.FiscalPrinting
@using EventForge.DTOs.FiscalPrinting
@using EventForge.Client.Services
@using EventForge.Client.Shared.Components.Dialogs
@using MudBlazor
@inject IFiscalPrintingService FiscalPrintingService
@inject IAppNotificationService AppNotification
@inject ILogger<DailyClosureDialog> Logger

<EFDialog Icon="@Icons.Material.Filled.EventNote"
          Title="@("Chiusura Giornaliera Fiscale" + (!string.IsNullOrEmpty(_printerName) ? $" – {_printerName}" : string.Empty))"
          IsProcessing="@(_step == 2)"
          OnClose="Cancel"
          MinWidth="@EFDialogDefaults.MinWidthSimple"
          MinHeight="@EFDialogDefaults.MinHeightTabbed">
    <ChildContent>

        @* ─── Step indicator ─── *@
        <MudStepper @ref="_stepper" @bind-ActiveStepIndex="_step" Linear="true" Class="mb-4">
            <MudStep Title="Pre-Check"  Icon="@Icons.Material.Filled.CheckCircleOutline" />
            <MudStep Title="Conferma"   Icon="@Icons.Material.Filled.Warning" />
            <MudStep Title="In corso"   Icon="@Icons.Material.Filled.HourglassTop" />
            <MudStep Title="Completata" Icon="@Icons.Material.Filled.CheckCircle" />
        </MudStepper>

        @* ═══════════════════════════════════
           STEP 0 – Pre-check
           ═══════════════════════════════════ *@
        @if (_step == 0)
        {
            @if (_isLoadingPreCheck)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
                <MudText Align="Align.Center" Color="Color.Secondary">Caricamento dati giornata...</MudText>
            }
            else if (_preCheck is not null)
            {
                @* Open receipt warning *@
                @if (_preCheck.HasOpenReceipt)
                {
                    <MudAlert Severity="Severity.Error" Class="mb-3" Dense="false">
                        <b>⚠️ Scontrino Aperto</b> – C'è uno scontrino non chiuso sul registratore.
                        Annullare o finalizzare lo scontrino prima di procedere con la chiusura giornaliera.
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Success" Class="mb-3" Dense="true">
                        Nessuno scontrino aperto. Procedura disponibile. ✓
                    </MudAlert>
                }

                @* Drawer info *@
                @if (_preCheck.IsDrawerOpen)
                {
                    <MudAlert Severity="Severity.Info" Class="mb-2" Dense="true">
                        Cassetto contanti aperto (informativo – non blocca la chiusura).
                    </MudAlert>
                }

                @* Day summary *@
                <MudCard Elevation="0" Class="mt-3" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle2" Class="mb-3">Riepilogo Giornata</MudText>
                        <MudGrid Dense="true" Spacing="2">
                            <MudItem xs="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Data</MudText>
                                <MudText Typo="Typo.body2"><b>@_preCheck.CheckedAt.ToLocalTime().ToString("dd/MM/yyyy")</b></MudText>
                            </MudItem>
                            <MudItem xs="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Ultima chiusura</MudText>
                                <MudText Typo="Typo.body2">
                                    @(_preCheck.LastClosureDate.HasValue
                                        ? _preCheck.LastClosureDate.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        : "—")
                                </MudText>
                            </MudItem>
                            <MudItem xs="4">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Scontrini</MudText>
                                <MudText Typo="Typo.h6">@_preCheck.ReceiptCount</MudText>
                            </MudItem>
                            <MudItem xs="4">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Totale</MudText>
                                <MudText Typo="Typo.h6">@_preCheck.TotalAmount.ToString("C2")</MudText>
                            </MudItem>
                            <MudItem xs="4">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Di cui Contanti</MudText>
                                <MudText Typo="Typo.body2">@_preCheck.CashAmount.ToString("C2")</MudText>
                            </MudItem>
                            <MudItem xs="4">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Di cui Carte</MudText>
                                <MudText Typo="Typo.body2">@_preCheck.CardAmount.ToString("C2")</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            }
        }

        @* ═══════════════════════════════════
           STEP 1 – Conferma
           ═══════════════════════════════════ *@
        @if (_step == 1)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4">
                <b>⚠️ Operazione Irreversibile</b><br />
                La chiusura giornaliera resetta i contatori giornalieri del registratore fiscale.
                Questa operazione <b>non può essere annullata</b>.
            </MudAlert>

            <MudCheckBox T="bool" @bind-Value="_confirmedCheckbox" Color="Color.Warning" Class="mb-2">
                <MudText Typo="Typo.body2">
                    Confermo di voler procedere con la chiusura giornaliera fiscale per la data
                    <b>@DateTime.Today.ToString("dd/MM/yyyy")</b>.
                </MudText>
            </MudCheckBox>
        }

        @* ═══════════════════════════════════
           STEP 2 – Printing
           ═══════════════════════════════════ *@
        @if (_step == 2)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="4" Class="py-6">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.subtitle1">Stampa Z-Report in corso...</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Non spegnere la stampante e non aprire il coperchio.
                </MudText>
            </MudStack>
        }

        @* ═══════════════════════════════════
           STEP 3 – Completed
           ═══════════════════════════════════ *@
        @if (_step == 3)
        {
            @if (_closureResult?.Success == true)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    ✅ Chiusura Giornaliera Completata!
                </MudAlert>

                <MudCard Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle2" Class="mb-3">Dettagli Chiusura</MudText>
                        <MudGrid Dense="true" Spacing="2">
                            <MudItem xs="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">N° Z-Report</MudText>
                                <MudText Typo="Typo.body1"><b>@(_closureResult.ZReportNumber?.ToString() ?? "—")</b></MudText>
                            </MudItem>
                            <MudItem xs="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Data/Ora</MudText>
                                <MudText Typo="Typo.body2">@(_closureResult.ClosedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Scontrini</MudText>
                                <MudText Typo="Typo.body2">@_closureResult.ReceiptCount</MudText>
                            </MudItem>
                            <MudItem xs="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Totale</MudText>
                                <MudText Typo="Typo.body2">@_closureResult.TotalAmount.ToString("C2")</MudText>
                            </MudItem>
                            <MudItem xs="12">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Operatore</MudText>
                                <MudText Typo="Typo.body2">@(_closureResult.Operator ?? "—")</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>

                @* Download PDF – deferred to Sprint 5C *@
                <MudTooltip Text="PDF disponibile dopo Sprint 5C">
                    <MudButton StartIcon="@Icons.Material.Filled.PictureAsPdf"
                               Variant="Variant.Outlined" Color="Color.Secondary"
                               Class="mt-4" Disabled="true">
                        Scarica PDF Z-Report
                    </MudButton>
                </MudTooltip>
            }
            else
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">
                    ❌ Chiusura fallita: @(_closureResult?.ErrorMessage ?? "errore sconosciuto")
                </MudAlert>
            }
        }
    </ChildContent>

    <DialogActions>
        @if (_step == 0)
        {
            <MudButton OnClick="Cancel" Variant="Variant.Text">Annulla</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Warning"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="AdvanceFromPreCheck"
                       Disabled="@(!_preCheck?.CanProceed ?? true)">
                Procedi con Chiusura
            </MudButton>
        }
        else if (_step == 1)
        {
            <MudButton OnClick="@(() => _step = 0)" Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Indietro
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error"
                       OnClick="ExecuteClosureAsync"
                       Disabled="@(!_confirmedCheckbox)">
                Stampa Z-Report e Chiudi
            </MudButton>
        }
        else if (_step == 3)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="@(() => MudDialog.Close(DialogResult.Ok(_closureResult)))">
                Chiudi
            </MudButton>
        }
    </DialogActions>
</EFDialog>

@code {
    // ─────────────────────────────────────────────────────────
    //  Parameters
    // ─────────────────────────────────────────────────────────

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public Guid PrinterId { get; set; }
    [Parameter] public string? PrinterName { get; set; }

    // ─────────────────────────────────────────────────────────
    //  State
    // ─────────────────────────────────────────────────────────

    private MudStepper? _stepper;
    private int _step;
    private bool _isLoadingPreCheck = true;
    private bool _confirmedCheckbox;
    private DailyClosurePreCheckDto? _preCheck;
    private DailyClosureResultDto? _closureResult;
    private string? _printerName;

    // ─────────────────────────────────────────────────────────
    //  Lifecycle
    // ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _printerName = PrinterName;
            await LoadPreCheckDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing DailyClosureDialog.");
        }
    }

    // ─────────────────────────────────────────────────────────
    //  Step 0
    // ─────────────────────────────────────────────────────────

    private async Task LoadPreCheckDataAsync()
    {
        _isLoadingPreCheck = true;
        try
        {
            _preCheck = await FiscalPrintingService.GetDailyClosurePreCheckAsync(PrinterId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "LoadPreCheckDataAsync failed for printer {PrinterId}", PrinterId);
            AppNotification.ShowError("Impossibile caricare i dati di pre-check.");
        }
        finally
        {
            _isLoadingPreCheck = false;
        }
    }

    private void AdvanceFromPreCheck()
    {
        if (_preCheck?.CanProceed == true)
        {
            _confirmedCheckbox = false;
            _step = 1;
        }
    }

    // ─────────────────────────────────────────────────────────
    //  Step 1 → 2 → 3
    // ─────────────────────────────────────────────────────────

    private async Task ExecuteClosureAsync()
    {
        _step = 2; // show printing progress
        StateHasChanged();

        try
        {
            _closureResult = await FiscalPrintingService.ExecuteDailyClosureAsync(PrinterId);

            if (_closureResult?.Success == true)
                AppNotification.ShowSuccess("Chiusura giornaliera completata.");
            else
                AppNotification.ShowError($"Chiusura fallita: {_closureResult?.ErrorMessage}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "ExecuteClosureAsync failed for printer {PrinterId}", PrinterId);
            _closureResult = new DailyClosureResultDto
            {
                Success = false,
                ErrorMessage = ex.Message
            };
            AppNotification.ShowError("Errore imprevisto durante la chiusura.");
        }
        finally
        {
            _step = 3;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
