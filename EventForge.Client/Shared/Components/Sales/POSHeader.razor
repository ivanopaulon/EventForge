@using EventForge.DTOs.Store
@using EventForge.DTOs.Business
@using EventForge.DTOs.Sales
@using EventForge.Client.Shared.Components.Dialogs.Sales
@using EventForge.Client.Shared.Components.Business
@using EventForge.Client.Shared.Components.Common
@inject ITranslationService TranslationService
@inject IDialogService DialogService

@{
    var drawerOpen = FiscalDrawerSummary?.HasOpenSession == true;
    var drawerClosed = FiscalDrawerSummary is not null && !drawerOpen;
    var paperStyle = drawerOpen
        ? "background: linear-gradient(90deg, #e8f5e9, #f1f8e9); border-left: 4px solid var(--mud-palette-success);"
        : "background: var(--mud-palette-surface);";
}

<MudPaper Elevation="3" Class="pa-2 mb-2"
          Style="@($"border-radius: 0 0 12px 12px; position: sticky; top: 0; z-index: 10; {paperStyle}")">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">

        @* ── Operator ── *@
        @if (IsSessionActive && SelectedOperatorId.HasValue)
        {
            <MudChip T="string"
                     Icon="@Icons.Material.Filled.Person"
                     Color="Color.Primary"
                     Size="Size.Small"
                     Variant="Variant.Filled"
                     Style="font-size:0.75rem; cursor:default;">
                @(AvailableOperators?.FirstOrDefault(o => o.Id == SelectedOperatorId)?.Name ?? "—")
            </MudChip>
        }
        else if (!IsSessionActive)
        {
            <MudSelect T="Guid?"
                       Value="SelectedOperatorId"
                       ValueChanged="@OnOperatorChanged"
                       Label="@TranslationService.GetTranslation("sales.operator", "Operatore")"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Required="true"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.Person"
                       Style="min-width:140px; max-width:180px;">
                @if (AvailableOperators != null)
                {
                    @foreach (var op in AvailableOperators)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)op.Id)">@op.Name</MudSelectItem>
                    }
                }
            </MudSelect>
        }

        @* ── POS / Cassa ── *@
        @if (IsSessionActive && SelectedPosId.HasValue)
        {
            <MudChip T="string"
                     Icon="@Icons.Material.Filled.PointOfSale"
                     Color="Color.Default"
                     Size="Size.Small"
                     Variant="Variant.Outlined"
                     Style="font-size:0.75rem; cursor:default;">
                @(AvailablePos?.FirstOrDefault(p => p.Id == SelectedPosId)?.Name ?? "—")
            </MudChip>
        }
        else if (!IsSessionActive)
        {
            <MudSelect T="Guid?"
                       Value="SelectedPosId"
                       ValueChanged="@OnPosChanged"
                       Label="@TranslationService.GetTranslation("sales.pos", "Cassa")"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Required="true"
                       Disabled="@(!SelectedOperatorId.HasValue)"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.PointOfSale"
                       Style="min-width:120px; max-width:160px;">
                @if (AvailablePos != null)
                {
                    @foreach (var pos in AvailablePos)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)pos.Id)">@pos.Name</MudSelectItem>
                    }
                }
            </MudSelect>
        }

        @* ── Fiscal Drawer: no open session ── *@
        @if (drawerClosed)
        {
            <MudChip T="string"
                     Icon="@Icons.Material.Outlined.Inbox"
                     Color="Color.Warning"
                     Size="Size.Small"
                     Variant="Variant.Outlined"
                     Style="font-size:0.75rem;">
                @FiscalDrawerSummary!.Name
            </MudChip>
            <MudTooltip Text="Apri sessione cassetto">
                <MudIconButton Icon="@Icons.Material.Outlined.LockOpen"
                               Color="Color.Info"
                               Size="Size.Small"
                               OnClick="@OnOpenDrawerSessionClick" />
            </MudTooltip>
        }

        @* ── Fiscal Drawer: open session — name + balance + sales ── *@
        @if (drawerOpen)
        {
            <MudIcon Icon="@Icons.Material.Outlined.Inbox" Color="Color.Success" Size="Size.Small" />
            <MudText Typo="Typo.body2"><strong>@FiscalDrawerSummary!.Name</strong></MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Saldo: <strong>@($"€ {FiscalDrawerSummary!.CurrentBalance:N2}")</strong>
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Vendite: <strong>@($"€ {FiscalDrawerSummary!.SessionTotalSales:N2}")</strong>
            </MudText>
            <MudTooltip Text="Versamento">
                <MudIconButton Icon="@Icons.Material.Outlined.ArrowUpward"
                               Color="Color.Success"
                               Size="Size.Small"
                               OnClick="@OnDepositClick" />
            </MudTooltip>
            <MudTooltip Text="Prelievo">
                <MudIconButton Icon="@Icons.Material.Outlined.ArrowDownward"
                               Color="Color.Warning"
                               Size="Size.Small"
                               OnClick="@OnWithdrawalClick" />
            </MudTooltip>
        }

        @* ── Open physical drawer via fiscal printer ── *@
        @if (HasFiscalPrinter)
        {
            <MudTooltip Text="Apri cassetto (stampante fiscale)">
                <MudIconButton Icon="@Icons.Material.Outlined.OpenInBrowser"
                               Color="Color.Info"
                               Size="Size.Small"
                               OnClick="@OnOpenPhysicalDrawerClick" />
            </MudTooltip>
        }

        @* ── Daily closure required ── *@
        @if (IsDailyClosureRequired)
        {
            <MudTooltip Text="Chiusura giornaliera richiesta — clicca per eseguire">
                <MudIconButton Icon="@Icons.Material.Outlined.EventNote"
                               Color="Color.Warning"
                               Size="Size.Small"
                               OnClick="@OnDailyClosureClick" />
            </MudTooltip>
        }

        @* ── Loading spinner ── *@
        @if (IsUpdatingItems)
        {
            <MudTooltip Text="@LoadingTooltipText">
                <MudProgressCircular Size="Size.Small"
                                     Color="@LoadingSpinnerColor"
                                     Indeterminate="true" />
            </MudTooltip>
        }

        <MudSpacer />

        @* ── Customer selector (optional) ── *@
        @if (SelectedCustomerChanged.HasDelegate)
        {
            <div style="max-width: 200px; min-width: 120px;">
                <UnifiedBusinessPartySelector
                    SelectedBusinessParty="SelectedCustomer"
                    SelectedBusinessPartyChanged="@OnCustomerChanged"
                    Title="@null"
                    Placeholder="@TranslationService.GetTranslation("sales.searchCustomer", "Cliente...")"
                    FilterByType="BusinessPartyType.Customer"
                    EditMode="EntityEditMode.QuickDialog"
                    CreateMode="EntityCreateMode.QuickDialog"
                    DisplayMode="EntityDisplayMode.FiscalInfo | EntityDisplayMode.Contacts"
                    AllowQuickCreate="true"
                    AllowQuickEdit="true"
                    Disabled="@(!SelectedOperatorId.HasValue || !SelectedPosId.HasValue)"
                    Dense="true" />
            </div>
        }

        @* ── Session number chip ── *@
        @if (IsSessionActive && SessionNumber.HasValue)
        {
            var sessionStr = SessionNumber.Value.ToString();
            var displayId = sessionStr.Length >= 8 ? sessionStr.Substring(0, 8) : sessionStr;
            <MudChip T="string" Size="Size.Small"
                     Color="Color.Info"
                     Icon="@Icons.Material.Outlined.Receipt"
                     Variant="Variant.Text">
                #@displayId
            </MudChip>
        }

        @* ── Park ── *@
        <MudTooltip Text="@TranslationService.GetTranslation("sales.parkSession", "Parcheggia (F3)")">
            <MudIconButton Icon="@Icons.Material.Outlined.Pause"
                           Color="Color.Warning"
                           Size="Size.Small"
                           OnClick="@OnParkClick"
                           Disabled="@(!IsSessionActive)" />
        </MudTooltip>

        @* ── Cancel / Change ── *@
        <MudTooltip Text="@TranslationService.GetTranslation("sales.cancelSession", "Annulla / Cambia operatore")">
            <MudIconButton Icon="@Icons.Material.Outlined.SwitchAccount"
                           Color="Color.Default"
                           Size="Size.Small"
                           OnClick="@OnCancelClick" />
        </MudTooltip>

    </MudStack>
</MudPaper>

@code {
    // ── Operator ────────────────────────────────────────────────────────────

    [Parameter]
    public List<StoreUserDto>? AvailableOperators { get; set; }

    [Parameter]
    public Guid? SelectedOperatorId { get; set; }

    [Parameter]
    public EventCallback<Guid?> SelectedOperatorIdChanged { get; set; }

    // ── POS ─────────────────────────────────────────────────────────────────

    [Parameter]
    public List<StorePosDto>? AvailablePos { get; set; }

    [Parameter]
    public Guid? SelectedPosId { get; set; }

    [Parameter]
    public EventCallback<Guid?> SelectedPosIdChanged { get; set; }

    // ── Customer ─────────────────────────────────────────────────────────────

    [Parameter]
    public BusinessPartyDto? SelectedCustomer { get; set; }

    [Parameter]
    public EventCallback<BusinessPartyDto?> SelectedCustomerChanged { get; set; }

    // ── Session ──────────────────────────────────────────────────────────────

    [Parameter]
    public Guid? SessionNumber { get; set; }

    [Parameter]
    public bool IsSessionActive { get; set; }

    [Parameter]
    public EventCallback OnParkClick { get; set; }

    [Parameter]
    public EventCallback OnCancelClick { get; set; }

    [Parameter]
    public bool IsUpdatingItems { get; set; }

    [Parameter]
    public string LoadingTooltipText { get; set; } = string.Empty;

    [Parameter]
    public Color LoadingSpinnerColor { get; set; } = Color.Primary;

    // ── Fiscal Drawer ────────────────────────────────────────────────────────

    /// <summary>Summary of the fiscal drawer associated with the current POS. Null when none is configured.</summary>
    [Parameter]
    public FiscalDrawerSummaryDto? FiscalDrawerSummary { get; set; }

    /// <summary>Fired when the operator clicks "Apri sessione cassetto".</summary>
    [Parameter]
    public EventCallback OnOpenDrawerSessionClick { get; set; }

    /// <summary>Fired when the operator clicks the deposit (Versamento) icon button.</summary>
    [Parameter]
    public EventCallback OnDepositClick { get; set; }

    /// <summary>Fired when the operator clicks the withdrawal (Prelievo) icon button.</summary>
    [Parameter]
    public EventCallback OnWithdrawalClick { get; set; }

    // ── Fiscal Printer ───────────────────────────────────────────────────────

    /// <summary>True when a fiscal printer is associated with the current POS, enabling the open-drawer button.</summary>
    [Parameter]
    public bool HasFiscalPrinter { get; set; }

    /// <summary>True when the fiscal printer requires a daily closure (Z-report).</summary>
    [Parameter]
    public bool IsDailyClosureRequired { get; set; }

    /// <summary>Fired when the operator clicks the "open physical drawer" icon button.</summary>
    [Parameter]
    public EventCallback OnOpenPhysicalDrawerClick { get; set; }

    /// <summary>Fired when the operator clicks the daily-closure warning icon button.</summary>
    [Parameter]
    public EventCallback OnDailyClosureClick { get; set; }

    // ── Handlers ─────────────────────────────────────────────────────────────

    private async Task OnOperatorChanged(Guid? value)
    {
        SelectedOperatorId = value;
        await SelectedOperatorIdChanged.InvokeAsync(value);
    }

    private async Task OnPosChanged(Guid? value)
    {
        SelectedPosId = value;
        await SelectedPosIdChanged.InvokeAsync(value);
    }

    private async Task OnCustomerChanged(BusinessPartyDto? value)
    {
        SelectedCustomer = value;
        await SelectedCustomerChanged.InvokeAsync(value);
    }
}
