@using EventForge.DTOs.Sales
@inject ITranslationService TranslationService

@if (Items?.Any() == true)
{
    <div class="pos-touch-cart-list">
        @foreach (var item in Items)
        {
            var isSelected = SelectedItem?.Id == item.Id;

            <MudPaper Elevation="@(isSelected ? 4 : 1)"
                      Class="@GetItemClass(item)"
                      Style="cursor: pointer; border-radius: 12px; transition: all 0.15s ease;"
                      @onclick="@(() => SelectItem(item))">

                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-3">

                    <!-- Left: Product info -->
                    <MudStack Spacing="0" Style="flex: 1; min-width: 0;">
                        <MudText Typo="Typo.subtitle1"
                                 Style="font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            @item.ProductName
                        </MudText>
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            @if (!string.IsNullOrEmpty(item.ProductCode))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @item.ProductCode
                                </MudText>
                            }
                            @if (item.DiscountPercent > 0)
                            {
                                <MudChip T="string"
                                         Size="Size.Small"
                                         Color="Color.Warning"
                                         Variant="Variant.Text"
                                         Style="height: 20px; padding: 0 6px; font-size: 0.65rem;">
                                    -@item.DiscountPercent.ToString("F1")%
                                </MudChip>
                            }
                        </MudStack>
                    </MudStack>

                    <!-- Center: Quantity controls -->
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                       Size="Size.Medium"
                                       Color="@(isSelected ? Color.Primary : Color.Default)"
                                       Variant="Variant.Outlined"
                                       Style="min-width: 40px; height: 40px;"
                                       OnClick="@(() => DecreaseQty(item))"
                                       Disabled="@(IsDisabled || item.Quantity <= 1)" />

                        <MudText Typo="Typo.h6"
                                 Style="min-width: 36px; text-align: center; font-weight: 700;">
                            @FormatQty(item.Quantity)
                        </MudText>

                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                       Size="Size.Medium"
                                       Color="@(isSelected ? Color.Primary : Color.Default)"
                                       Variant="Variant.Outlined"
                                       Style="min-width: 40px; height: 40px;"
                                       OnClick="@(() => IncreaseQty(item))"
                                       Disabled="@IsDisabled" />
                    </MudStack>

                    <!-- Right: Prices + Delete -->
                    <MudStack AlignItems="AlignItems.End" Spacing="0" Style="min-width: 80px;">
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">
                            @item.TotalAmount.ToString("C")
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @item.UnitPrice.ToString("C") / cad
                        </MudText>
                    </MudStack>

                    <!-- Delete -->
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                   Size="Size.Medium"
                                   Color="Color.Error"
                                   Variant="Variant.Text"
                                   Style="min-width: 44px; height: 44px;"
                                   OnClick="@(() => DeleteItem(item))"
                                   Disabled="@IsDisabled" />

                </MudStack>

                <!-- Selected indicator bar -->
                @if (isSelected)
                {
                    <div style="height: 3px; background: var(--mud-palette-primary); border-radius: 0 0 12px 12px;" />
                }

            </MudPaper>
        }
    </div>
}
else
{
    <!-- Empty state -->
    <div class="d-flex flex-column align-center justify-center pa-6"
         style="min-height: 200px; opacity: 0.5;">
        <MudIcon Icon="@Icons.Material.Outlined.ShoppingCart"
                 Style="font-size: 3rem; margin-bottom: 12px;" />
        <MudText Typo="Typo.body1">
            @TranslationService.GetTranslation("sales.emptyCart", "Carrello vuoto")
        </MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            @TranslationService.GetTranslation("sales.scanProductHint", "Scansiona un prodotto per iniziare")
        </MudText>
    </div>
}

<style>
    .pos-touch-cart-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .pos-touch-cart-item {
        border: 2px solid transparent;
    }

    .pos-touch-cart-item--selected {
        border-color: var(--mud-palette-primary) !important;
    }

    .pos-touch-cart-item:active {
        transform: scale(0.99);
    }
</style>

@code {
    [Parameter] public List<SaleItemDto>? Items { get; set; }
    [Parameter] public SaleItemDto? SelectedItem { get; set; }
    [Parameter] public EventCallback<SaleItemDto> OnItemSelected { get; set; }
    [Parameter] public EventCallback<SaleItemDto> OnIncreaseQuantity { get; set; }
    [Parameter] public EventCallback<SaleItemDto> OnDecreaseQuantity { get; set; }
    [Parameter] public EventCallback<SaleItemDto> OnRemoveItem { get; set; }
    [Parameter] public bool IsDisabled { get; set; }

    private async Task SelectItem(SaleItemDto item)
    {
        await OnItemSelected.InvokeAsync(item);
    }

    private async Task IncreaseQty(SaleItemDto item)
    {
        if (IsDisabled) return;
        await OnIncreaseQuantity.InvokeAsync(item);
    }

    private async Task DecreaseQty(SaleItemDto item)
    {
        if (IsDisabled) return;
        await OnDecreaseQuantity.InvokeAsync(item);
    }

    private async Task DeleteItem(SaleItemDto item)
    {
        if (IsDisabled) return;
        await OnRemoveItem.InvokeAsync(item);
    }

    private string GetItemClass(SaleItemDto item) =>
        SelectedItem?.Id == item.Id
            ? "pos-touch-cart-item pos-touch-cart-item--selected"
            : "pos-touch-cart-item";

    private static string FormatQty(decimal qty) =>
        qty == Math.Floor(qty) ? ((int)qty).ToString() : qty.ToString("G");
}
