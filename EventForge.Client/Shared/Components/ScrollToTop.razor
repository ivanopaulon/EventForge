@namespace EventForge.Client.Shared.Components
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (_visible && !HideFab)
{
    <div class="ef-scroll-to-top">
        <MudTooltip Text="Torna in cima" Placement="Placement.Left">
            <MudFab Color="Color.Primary"
                    StartIcon="@Icons.Material.Filled.KeyboardArrowUp"
                    Size="Size.Small"
                    OnClick="ScrollToTopAsync"
                    aria-label="Torna in cima alla pagina" />
        </MudTooltip>
    </div>
}

@code {
    [Parameter] public bool HideFab { get; set; }

    /// <summary>
    /// Scroll offset in pixels before the button becomes visible. Default: 300.
    /// </summary>
    [Parameter] public int Threshold { get; set; } = 300;

    /// <summary>Exposes scroll visibility for parent components.</summary>
    public bool IsVisible => _visible;

    private bool _visible = false;
    private IJSObjectReference? _module;
    private DotNetObjectReference<ScrollToTop>? _selfRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/EventForge.Client/Shared/Components/ScrollToTop.razor.js");
            await _module.InvokeVoidAsync("initScrollListener", _selfRef, Threshold);
        }
    }

    [JSInvokable]
    public void OnScrollChanged(bool visible)
    {
        if (_visible != visible)
        {
            _visible = visible;
            InvokeAsync(StateHasChanged);
        }
    }

    public async Task ScrollToTopAsync()
    {
        if (_module is not null)
            await _module.InvokeVoidAsync("scrollToTop");
    }

    public async ValueTask DisposeAsync()
    {
        _selfRef?.Dispose();
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { /* ignore disposal errors */ }
        }
    }
}
