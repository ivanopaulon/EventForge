@namespace EventForge.Client.Shared.Components
@using EventForge.DTOs.Chat
@using EventForge.DTOs.Notifications
@using EventForge.Client.Shared.Components.Dialogs
@using EventForge.Client.Pages.Chat
@inject IChatService ChatService
@inject INotificationService NotificationService
@inject IDialogService DialogService
@inject IUpdateNotificationService UpdateNotification
@inject NavigationManager NavigationManager
@implements IDisposable

<!-- Child components: their panels render normally, only their individual FABs are hidden -->
<FloatingProfile @ref="_profileRef" HideFab="true" />
<HealthFooter @ref="_healthRef" HideFab="true" />

<!-- Speed Dial container -->
<div class="ef-speed-dial @(_isOpen ? "ef-speed-dial--open" : "")">

    <!-- Action items — stack upward from the trigger FAB -->
    <div class="ef-speed-dial-actions">

        <!-- Planned events shortcut -->
        <div class="ef-speed-dial-action">
            <MudTooltip Text="Prossimi eventi" Placement="Placement.Left">
                <MudFab Color="Color.Primary"
                        StartIcon="@Icons.Material.Outlined.EventNote"
                        Size="Size.Small"
                        OnClick="OnPlannedEventsClick"
                        aria-label="Vai agli eventi pianificati" />
            </MudTooltip>
        </div>

        <!-- Expired / completed events shortcut -->
        <div class="ef-speed-dial-action">
            <MudTooltip Text="Ultimi eventi scaduti" Placement="Placement.Left">
                <MudFab Color="Color.Secondary"
                        StartIcon="@Icons.Material.Outlined.EventBusy"
                        Size="Size.Small"
                        OnClick="OnExpiredEventsClick"
                        aria-label="Vai agli eventi scaduti" />
            </MudTooltip>
        </div>

        <!-- Notifications with unread badge -->
        <div class="ef-speed-dial-action">
            <MudTooltip Text="Notifiche" Placement="Placement.Left">
                <MudBadge Content="@_unreadNotifications"
                          Color="Color.Error"
                          Overlap="true"
                          Visible="@(_unreadNotifications > 0)"
                          Max="99">
                    <MudFab Color="Color.Primary"
                            StartIcon="@Icons.Material.Outlined.Notifications"
                            Size="Size.Small"
                            OnClick="OnNotificationsClick"
                            aria-label="Centro notifiche" />
                </MudBadge>
            </MudTooltip>
        </div>

        <!-- Chat with unread badge -->
        <div class="ef-speed-dial-action">
            <MudTooltip Text="Chat" Placement="Placement.Left">
                <MudBadge Content="@_totalUnread"
                          Color="Color.Error"
                          Overlap="true"
                          Visible="@(_totalUnread > 0)"
                          Max="99">
                    <MudFab Color="Color.Primary"
                            StartIcon="@Icons.Material.Filled.Chat"
                            Size="Size.Small"
                            OnClick="OnChatClick"
                            aria-label="Apri chat" />
                </MudBadge>
            </MudTooltip>
        </div>

        <!-- Health status (bottommost in the stack, nearest to profile row) -->
        <div class="ef-speed-dial-action">
            <MudTooltip Text="Stato sistema" Placement="Placement.Left">
                <MudFab Color="@(_healthRef?.GetOverallHealthFabColor() ?? Color.Default)"
                        StartIcon="@Icons.Material.Filled.Monitor"
                        Size="Size.Small"
                        OnClick="OnHealthClick"
                        aria-label="Stato salute sistema" />
            </MudTooltip>
        </div>

        @* Aggiornamenti — solo SuperAdmin *@
        @if (_profileRef?.IsSuperAdmin == true)
        {
            var _totalUpdatesBadge = UpdateNotification.AvailableUpdatesCount + UpdateNotification.PendingManualInstallsCount;
            <div class="ef-speed-dial-action">
                <MudTooltip Text="@(_totalUpdatesBadge > 0 ? $"Aggiornamenti ({UpdateNotification.AvailableUpdatesCount} disponibili, {UpdateNotification.PendingManualInstallsCount} in attesa)" : "Aggiornamenti")"
                            Placement="Placement.Left">
                    <MudBadge Content="@_totalUpdatesBadge"
                              Color="@(UpdateNotification.PendingManualInstallsCount > 0 ? Color.Error : Color.Warning)"
                              Overlap="true"
                              Visible="@(_totalUpdatesBadge > 0)"
                              Max="99">
                        <MudFab Color="Color.Secondary"
                                StartIcon="@Icons.Material.Filled.SystemUpdate"
                                Size="Size.Small"
                                OnClick="OnUpdatesClick"
                                aria-label="Gestione aggiornamenti" />
                    </MudBadge>
                </MudTooltip>
            </div>
        }

    </div>

    <!-- Profile row: outside the overflow:hidden container so the sub-menu can expand left freely -->
    <div class="ef-profile-row @(_isOpen ? "ef-profile-row--open" : "")">

        <!-- Horizontal sub-menu — expands to the left of the profile FAB -->
        <div class="ef-profile-submenu @(_profileMenuOpen ? "ef-profile-submenu--open" : "")">

            <!-- Logout (far-left — most destructive action, kept farthest) -->
            <div class="ef-profile-submenu-item">
                <MudTooltip Text="Logout" Placement="Placement.Top">
                    <MudFab Color="Color.Error"
                            StartIcon="@Icons.Material.Filled.Logout"
                            Size="Size.Small"
                            OnClick="OnLogoutClick"
                            aria-label="Logout" />
                </MudTooltip>
            </div>

            @if (_profileRef?.IsSuperAdmin == true)
            {
                <div class="ef-profile-submenu-item">
                    <MudTooltip Text="Admin Dashboard" Placement="Placement.Top">
                        <MudFab Color="Color.Primary"
                                StartIcon="@Icons.Material.Outlined.AdminPanelSettings"
                                Size="Size.Small"
                                OnClick="OnAdminDashboardClick"
                                aria-label="Admin Dashboard" />
                    </MudTooltip>
                </div>
            }

            <!-- Font Preferences -->
            <div class="ef-profile-submenu-item">
                <MudTooltip Text="Preferenze Font" Placement="Placement.Top">
                    <MudFab Color="Color.Default"
                            StartIcon="@Icons.Material.Filled.FontDownload"
                            Size="Size.Small"
                            OnClick="OnFontPreferencesClick"
                            aria-label="Preferenze Font" />
                </MudTooltip>
            </div>

            <!-- Navigate to Profile (rightmost — closest to the trigger, most frequent action) -->
            <div class="ef-profile-submenu-item">
                <MudTooltip Text="Vai al Profilo" Placement="Placement.Top">
                    <MudFab Color="Color.Secondary"
                            StartIcon="@Icons.Material.Filled.Person"
                            Size="Size.Small"
                            OnClick="OnNavigateToProfileClick"
                            aria-label="Vai al profilo" />
                </MudTooltip>
            </div>

        </div>

        <!-- Profile trigger button -->
        <MudTooltip Text="Profilo" Placement="Placement.Left">
            <MudFab Color="Color.Secondary"
                    StartIcon="@(_profileMenuOpen ? Icons.Material.Filled.Close : Icons.Material.Filled.AccountCircle)"
                    Size="Size.Small"
                    OnClick="ToggleProfileMenu"
                    aria-label="Profilo utente" />
        </MudTooltip>

    </div>

    <!-- Main trigger FAB -->
    <MudFab Color="Color.Primary"
            StartIcon="@(_isOpen ? Icons.Material.Filled.Close : Icons.Material.Filled.Apps)"
            Size="Size.Medium"
            OnClick="ToggleMenu"
            aria-label="Menu azioni rapide"
            aria-expanded="@_isOpen" />

</div>

@code {
    private bool _isOpen = false;
    private bool _profileMenuOpen = false;
    private FloatingProfile? _profileRef;
    private HealthFooter? _healthRef;
    private int _unreadNotifications = 0;
    private int _totalUnread = 0;
    private List<ChatResponseDto> _chatList = new();

    protected override async Task OnInitializedAsync()
    {
        ChatService.MessageReceived += OnChatMessageReceived;
        ChatService.ChatCreated += OnChatCreated;
        NotificationService.StatsUpdated += OnNotificationStatsUpdated;
        UpdateNotification.StateChanged += OnUpdateStateChanged;
        try
        {
            var stats = await NotificationService.GetNotificationStatsAsync();
            _unreadNotifications = stats.UnreadCount;
        }
        catch
        {
            // Stats loading is best-effort; don't fail if unavailable
        }

        try
        {
            _chatList = await ChatService.GetChatsAsync();
            _totalUnread = _chatList.Sum(c => c.UnreadCount);
        }
        catch
        {
            // Chat stats loading is best-effort
        }
    }

    private void OnChatMessageReceived(ChatMessageDto message)
    {
        var chat = _chatList.FirstOrDefault(c => c.Id == message.ChatId);
        if (chat != null)
        {
            chat.UnreadCount++;
            chat.LastMessage = message;
            _totalUnread = _chatList.Sum(c => c.UnreadCount);
        }
        else
        {
            // Unknown chat: increment counter directly without storing a partial object
            _totalUnread++;
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnChatCreated(ChatResponseDto chat)
    {
        if (!_chatList.Any(c => c.Id == chat.Id))
            _chatList.Add(chat);
        _totalUnread = _chatList.Sum(c => c.UnreadCount);
        InvokeAsync(StateHasChanged);
    }

    private void OnNotificationStatsUpdated(NotificationStatsDto stats)
        => InvokeAsync(() => { _unreadNotifications = stats.UnreadCount; StateHasChanged(); });

    private void ToggleMenu()
    {
        _isOpen = !_isOpen;
        if (!_isOpen) _profileMenuOpen = false;
    }

    private void ToggleProfileMenu() => _profileMenuOpen = !_profileMenuOpen;

    private async Task OnChatClick()
    {
        _isOpen = false;
        _profileMenuOpen = false;
        await DialogService.ShowAsync<ChatDialog>(
            string.Empty,
            new DialogOptions
            {
                BackdropClick    = false,
                CloseButton      = false,
                CloseOnEscapeKey = true
            });
    }

    private async Task OnHealthClick()
    {
        _isOpen = false;
        _profileMenuOpen = false;
        if (_healthRef != null)
            await _healthRef.OpenHealthDialog();
    }

    private async Task OnUpdatesClick()
    {
        _isOpen = false;
        _profileMenuOpen = false;
        await DialogService.ShowAsync<UpdatesDialog>(
            string.Empty,
            EFDialogDefaults.Options);
    }

    private void OnUpdateStateChanged()
        => InvokeAsync(StateHasChanged);

    private async Task OnNotificationsClick()
    {
        _isOpen = false;
        _profileMenuOpen = false;
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };
        await DialogService.ShowAsync<NotificationCenterDialog>("Centro notifiche", options);
    }

    private void OnPlannedEventsClick()
    {
        _isOpen = false;
        _profileMenuOpen = false;
        NavigationManager.NavigateTo("/events/management?filter=planned");
    }

    private void OnExpiredEventsClick()
    {
        _isOpen = false;
        _profileMenuOpen = false;
        NavigationManager.NavigateTo("/events/management?filter=completed");
    }

    private async Task OnNavigateToProfileClick()
    {
        _isOpen = false;
        _profileMenuOpen = false;
        if (_profileRef != null)
            await _profileRef.NavigateToProfile();
    }

    private async Task OnFontPreferencesClick()
    {
        _isOpen = false;
        _profileMenuOpen = false;
        if (_profileRef != null)
            await _profileRef.OpenFontPreferences();
    }

    private void OnAdminDashboardClick()
    {
        _isOpen = false;
        _profileMenuOpen = false;
        _profileRef?.OpenAdminDashboard();
    }

    private async Task OnLogoutClick()
    {
        _isOpen = false;
        _profileMenuOpen = false;
        if (_profileRef != null)
            await _profileRef.HandleLogout();
    }

    public void Dispose()
    {
        ChatService.MessageReceived -= OnChatMessageReceived;
        ChatService.ChatCreated -= OnChatCreated;
        NotificationService.StatsUpdated -= OnNotificationStatsUpdated;
        UpdateNotification.StateChanged -= OnUpdateStateChanged;
    }
}

<style>
    /* ── Main speed-dial container ──────────────────────────────────────── */
    .ef-speed-dial {
        position: fixed;
        bottom: 16px;
        right: 16px;
        z-index: 1300;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 8px;
    }

    /* ── Standard vertical action stack (5 items: PlannedEvents, ExpiredEvents, Notifications, Chat, Health) ─ */
    .ef-speed-dial-actions {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 8px;
        overflow: hidden;
        max-height: 0;
        opacity: 0;
        pointer-events: none;
        transition: max-height 0.35s ease, opacity 0.25s ease;
    }

    .ef-speed-dial--open .ef-speed-dial-actions {
        max-height: 360px;
        opacity: 1;
        pointer-events: auto;
    }

    .ef-speed-dial-action {
        transform: translateY(12px) scale(0.85);
        opacity: 0;
        transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .ef-speed-dial--open .ef-speed-dial-action {
        transform: translateY(0) scale(1);
        opacity: 1;
    }

    /* Stagger: Health (5th, nearest) first, then Chat, Notifications, ExpiredEvents, PlannedEvents */
    .ef-speed-dial--open .ef-speed-dial-action:nth-child(5) { transition-delay: 0s; }
    .ef-speed-dial--open .ef-speed-dial-action:nth-child(4) { transition-delay: 0.06s; }
    .ef-speed-dial--open .ef-speed-dial-action:nth-child(3) { transition-delay: 0.12s; }
    .ef-speed-dial--open .ef-speed-dial-action:nth-child(2) { transition-delay: 0.18s; }
    .ef-speed-dial--open .ef-speed-dial-action:nth-child(1) { transition-delay: 0.24s; }

    /* Remove shadows from all speed-dial FABs */
    .ef-speed-dial .mud-fab,
    .ef-profile-row .mud-fab,
    .ef-profile-submenu .mud-fab {
        box-shadow: none !important;
    }

    .ef-speed-dial .mud-fab:hover,
    .ef-profile-row .mud-fab:hover,
    .ef-profile-submenu .mud-fab:hover {
        box-shadow: none !important;
    }

    /* ── Profile row: outside overflow:hidden — sub-menu can expand left ── */
    .ef-profile-row {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
        height: 0;
        overflow: visible;
        opacity: 0;
        pointer-events: none;
        transition: height 0.2s ease, opacity 0.2s ease;
    }

    .ef-profile-row--open {
        height: 40px;
        opacity: 1;
        pointer-events: auto;
    }

    /* ── Horizontal profile sub-menu (expands left) ─────────────────────── */
    .ef-profile-submenu {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 8px;
        overflow: hidden;
        max-width: 0;
        opacity: 0;
        pointer-events: none;
        white-space: nowrap;
        transition: max-width 0.3s ease, opacity 0.2s ease;
    }

    .ef-profile-submenu--open {
        max-width: 280px;
        opacity: 1;
        pointer-events: auto;
    }

    .ef-profile-submenu-item {
        flex-shrink: 0;
    }

    @@media (max-width: 420px) {
        .ef-speed-dial {
            bottom: 16px;
            right: 16px;
        }
    }
</style>
