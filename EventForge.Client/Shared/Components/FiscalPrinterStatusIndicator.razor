@namespace EventForge.Client.Shared.Components
@using Prym.DTOs.FiscalPrinting
@using MudBlazor
@using Microsoft.AspNetCore.SignalR.Client
@inject IFiscalPrintingService FiscalPrintingService
@inject IDialogService DialogService
@inject ILogger<FiscalPrinterStatusIndicator> Logger
@inject IAppNotificationService AppNotification
@implements IAsyncDisposable

@* 
    FiscalPrinterStatusIndicator
    Coloured badge showing real-time status of a single fiscal printer.
    Colours:  Green  = online, no issues
              Yellow = warning (paper low, daily closure required, memory almost full)
              Red    = critical error (paper out, cover open, head error, fiscal memory full)
              Grey   = offline / unknown
    Click    → opens a detail dialog (MudDialog).
    Receives push updates via the SignalR /hubs/fiscal-printer hub.
*@

<MudTooltip Text="@TooltipText" Arrow="true" Placement="Placement.Bottom">
    <MudChip T="string"
             Size="Size.Small"
             Color="@BadgeColor"
             Icon="@BadgeIcon"
             OnClick="@ShowDetailDialog"
             aria-label="@($"Stampante fiscale: {StatusSummary}")"
             Class="fiscal-printer-indicator cursor-pointer">
        @StatusSummary
    </MudChip>
</MudTooltip>

@code {
    // -------------------------------------------------------------------------
    //  Parameters
    // -------------------------------------------------------------------------

    /// <summary>Unique identifier of the fiscal printer to monitor.</summary>
    [Parameter, EditorRequired] public Guid PrinterId { get; set; }

    /// <summary>Display name of the printer (used in tooltip and dialog).</summary>
    [Parameter] public string PrinterName { get; set; } = "Stampante Fiscale";

    // -------------------------------------------------------------------------
    //  State
    // -------------------------------------------------------------------------

    private FiscalPrinterStatus? _status;
    private HubConnection? _hubConnection;

    // -------------------------------------------------------------------------
    //  Lifecycle
    // -------------------------------------------------------------------------

    protected override async Task OnInitializedAsync()
    {
        // Load initial cached status
        try
        {
            _status = await FiscalPrintingService.GetStatusAsync(PrinterId);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Could not load initial status for printer {PrinterId}", PrinterId);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _hubConnection is not null) return;

        await ConnectToHubAsync();
    }

    // -------------------------------------------------------------------------
    //  SignalR
    // -------------------------------------------------------------------------

    private async Task ConnectToHubAsync()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl("/hubs/fiscal-printer")
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<Guid, FiscalPrinterStatus>("PrinterStatusUpdated", OnPrinterStatusUpdated);
            _hubConnection.On<Guid, string>("ClosureRequired", OnClosureRequired);
            _hubConnection.On<Guid>("CriticalClosureMissing", OnCriticalClosureMissing);

            _hubConnection.Reconnected += async _ =>
            {
                try { await _hubConnection.SendAsync("SubscribeToPrinter", PrinterId); }
                catch (Exception ex) { Logger.LogWarning(ex, "FiscalPrinterStatusIndicator: failed to re-subscribe to printer {PrinterId} after reconnect", PrinterId); }
            };

            await _hubConnection.StartAsync();
            await _hubConnection.SendAsync("SubscribeToPrinter", PrinterId);

            Logger.LogDebug("FiscalPrinterStatusIndicator: subscribed to printer {PrinterId}", PrinterId);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex,
                "FiscalPrinterStatusIndicator: could not connect to SignalR hub for printer {PrinterId}",
                PrinterId);
        }
    }

    private void OnPrinterStatusUpdated(Guid printerId, FiscalPrinterStatus status)
    {
        if (printerId != PrinterId) return;
        _status = status;
        InvokeAsync(StateHasChanged);
    }

    private void OnClosureRequired(Guid printerId, string printerName)
    {
        if (printerId != PrinterId) return;
        Logger.LogInformation("ClosureRequired received for printer {PrinterId}", printerId);
        InvokeAsync(StateHasChanged);
    }

    private void OnCriticalClosureMissing(Guid printerId)
    {
        if (printerId != PrinterId) return;
        Logger.LogWarning("CriticalClosureMissing received for printer {PrinterId}", printerId);
        InvokeAsync(StateHasChanged);
    }

    // -------------------------------------------------------------------------
    //  Dialog
    // -------------------------------------------------------------------------

    private async Task ShowDetailDialog()
    {
        try
        {
            var parameters = new DialogParameters
            {
                ["PrinterId"] = PrinterId,
                ["PrinterName"] = PrinterName,
                ["Status"] = _status
            };

            await DialogService.ShowAsync<FiscalPrinterStatusDialog>(
                $"Stato stampante: {PrinterName}",
                parameters,
                new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in ShowDetailDialog.");
            AppNotification.ShowWarning("Si è verificato un errore imprevisto.");
        }
    }

    // -------------------------------------------------------------------------
    //  Computed display helpers
    // -------------------------------------------------------------------------

    private Color BadgeColor => _status switch
    {
        null => Color.Default,
        { IsOnline: false } => Color.Default,
        { IsFiscalMemoryFull: true } or { IsPaperOut: true } or { IsCoverOpen: true }
            or { IsHeadError: true } or { IsCutterError: true } => Color.Error,
        { IsPaperLow: true } or { IsDailyClosureRequired: true }
            or { IsFiscalMemoryAlmostFull: true } => Color.Warning,
        _ => Color.Success
    };

    private string BadgeIcon => _status switch
    {
        null => Icons.Material.Filled.HelpOutline,
        { IsOnline: false } => Icons.Material.Filled.CloudOff,
        { IsFiscalMemoryFull: true } or { IsPaperOut: true } or { IsCoverOpen: true }
            or { IsHeadError: true } or { IsCutterError: true } => Icons.Material.Filled.Error,
        { IsPaperLow: true } or { IsDailyClosureRequired: true }
            or { IsFiscalMemoryAlmostFull: true } => Icons.Material.Filled.Warning,
        _ => Icons.Material.Filled.CheckCircle
    };

    private string StatusSummary => _status switch
    {
        null => "N/D",
        { IsOnline: false } => "Offline",
        { IsFiscalMemoryFull: true } => "Memoria piena",
        { IsPaperOut: true } => "Carta esaurita",
        { IsCoverOpen: true } => "Coperchio aperto",
        { IsHeadError: true } => "Errore testina",
        { IsCutterError: true } => "Errore taglierina",
        { IsDailyClosureRequired: true } => "Chiusura richiesta",
        { IsFiscalMemoryAlmostFull: true } => "Memoria quasi piena",
        { IsPaperLow: true } => "Carta in esaurimento",
        _ => "OK"
    };

    private string TooltipText
    {
        get
        {
            if (_status is null) return $"{PrinterName}: stato non disponibile";
            if (!_status.IsOnline) return $"{PrinterName}: OFFLINE – {_status.LastError ?? "nessun dettaglio"}";

            var issues = new List<string>();
            if (_status.IsFiscalMemoryFull) issues.Add("Memoria fiscale piena");
            if (_status.IsPaperOut) issues.Add("Carta esaurita");
            if (_status.IsCoverOpen) issues.Add("Coperchio aperto");
            if (_status.IsHeadError) issues.Add("Errore testina");
            if (_status.IsCutterError) issues.Add("Errore taglierina");
            if (_status.IsDailyClosureRequired) issues.Add("Chiusura giornaliera richiesta");
            if (_status.IsFiscalMemoryAlmostFull) issues.Add("Memoria fiscale quasi piena (>90%)");
            if (_status.IsPaperLow) issues.Add("Carta in esaurimento");

            return issues.Count > 0
                ? $"{PrinterName}: {string.Join(", ", issues)}"
                : $"{PrinterName}: operativo";
        }
    }

    // -------------------------------------------------------------------------
    //  IAsyncDisposable
    // -------------------------------------------------------------------------

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            try
            {
                await _hubConnection.SendAsync("UnsubscribeFromPrinter", PrinterId);
                await _hubConnection.DisposeAsync();
            }
            catch { /* intentionally swallowed during disposal */ }
            _hubConnection = null;
        }
    }
}
