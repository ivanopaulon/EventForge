<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- ═══════════════════════════════════════════════════════════════════
         MIME Types — richiesti per Blazor WebAssembly
         .wasm  → application/wasm          (file runtime WebAssembly)
         .br    → application/brotli        (asset pre-compressi Brotli)
         .gz    → application/gzip          (asset pre-compressi Gzip)
         .dat   → application/octet-stream  (bundle dati Blazor)
         .blat  → application/octet-stream  (binary lazy-load Blazor)
         ═══════════════════════════════════════════════════════════════════ -->
    <staticContent>
      <remove fileExtension=".wasm" />
      <mimeMap fileExtension=".wasm" mimeType="application/wasm" />
      <remove fileExtension=".br" />
      <mimeMap fileExtension=".br" mimeType="application/brotli" />
      <remove fileExtension=".gz" />
      <mimeMap fileExtension=".gz" mimeType="application/gzip" />
      <remove fileExtension=".dat" />
      <mimeMap fileExtension=".dat" mimeType="application/octet-stream" />
      <remove fileExtension=".blat" />
      <mimeMap fileExtension=".blat" mimeType="application/octet-stream" />
    </staticContent>

    <!-- ═══════════════════════════════════════════════════════════════════
         SPA Fallback — tutte le richieste di navigazione che non corrispondono
         a un file o cartella fisica vengono reindirizzate a index.html.
         Necessario per il client-side routing di Blazor WASM.
         Richiede IIS URL Rewrite Module 2.1.
         ═══════════════════════════════════════════════════════════════════ -->
    <rewrite>
      <rules>
        <rule name="SPA Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- ═══════════════════════════════════════════════════════════════════
         Documento di default
         ═══════════════════════════════════════════════════════════════════ -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- ═══════════════════════════════════════════════════════════════════
         Compressione — statica abilitata; dinamica disabilitata perché
         i file Blazor WASM sono già pre-compressi (.br / .gz).
         ═══════════════════════════════════════════════════════════════════ -->
    <urlCompression doStaticCompression="true" doDynamicCompression="false" />

    <!-- ═══════════════════════════════════════════════════════════════════
         Header di sicurezza
         ═══════════════════════════════════════════════════════════════════ -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
