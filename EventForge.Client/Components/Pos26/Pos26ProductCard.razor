@* Pos26ProductCard — singola card articolo nella griglia POS 2026 *@
@using Prym.DTOs.Products
@implements IDisposable

<div class="pos26-product-card @(CartQuantity > 0 ? "pos26-product-card--in-cart" : "")"
     @onclick="HandleTap"
     @onpointerdown="OnPointerDown"
     @onpointerup="OnPointerUp"
     @onpointerleave="OnPointerLeave"
     title="@Product.Name — €@(Product.DefaultPrice?.ToString("F2") ?? "–")">

    @* Badge quantità *@
    @if (CartQuantity > 0)
    {
        <span class="pos26-qty-badge">@CartQuantity</span>
    }

    @* Badge articolo *@
    @if (IsLastPurchase)
    {
        <span class="pos26-badge pos26-badge--green">Tuo</span>
    }
    else if (IsBestSeller)
    {
        <span class="pos26-badge pos26-badge--amber">Top</span>
    }

    @if (IsPromo)
    {
        <span class="pos26-badge pos26-badge--red pos26-badge--promo">Promo</span>
    }

    @* Immagine / emoji *@
    <div class="pos26-product-img">
        @if (!string.IsNullOrEmpty(Product.ThumbnailUrl))
        {
            <img src="@Product.ThumbnailUrl" alt="@Product.Name" loading="lazy" />
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                     Size="Size.Medium"
                     Style="color:var(--pos-dark-muted);" />
        }
    </div>

    @* Info *@
    <div class="pos26-product-info">
        <span class="pos26-product-name">@TruncateName(Product.Name)</span>
        <span class="pos26-product-price">@FormatPrice(Product.DefaultPrice)</span>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ProductDto Product { get; set; } = null!;
    [Parameter] public int CartQuantity { get; set; }
    [Parameter] public bool IsLastPurchase { get; set; }
    [Parameter] public bool IsBestSeller { get; set; }
    [Parameter] public EventCallback<ProductDto> OnAddToCart { get; set; }
    /// <summary>
    /// Triggered when the user long-presses (≥500 ms) the card.
    /// Parent can use this to open a product detail/variant dialog.
    /// </summary>
    [Parameter] public EventCallback<ProductDto> OnLongPress { get; set; }

    // Long-press detection (>500ms)
    private CancellationTokenSource? _longPressCts;
    private bool _longPressTriggered;

    // IsPromo always returns false until ProductDto exposes a promotional-price property.
    private bool IsPromo => false;

    private async Task HandleTap()
    {
        if (_longPressTriggered) return;
        await OnAddToCart.InvokeAsync(Product);
    }

    private const int LongPressThresholdMs = 500;

    private void OnPointerDown(PointerEventArgs args)
    {
        _longPressTriggered = false;
        _longPressCts?.Cancel();
        _longPressCts?.Dispose();
        _longPressCts = new CancellationTokenSource();
        var token = _longPressCts.Token;
        _ = Task.Delay(LongPressThresholdMs, token).ContinueWith(
            async t =>
            {
                if (t.IsCompletedSuccessfully)
                    try
                    {
                        await InvokeAsync(async () =>
                        {
                            _longPressTriggered = true;
                            if (OnLongPress.HasDelegate)
                                await OnLongPress.InvokeAsync(Product);
                            else
                                StateHasChanged();
                        });
                    }
                    catch (ObjectDisposedException) { /* component disposed — ignore */ }
            },
            TaskScheduler.Default);
    }

    private void OnPointerUp(PointerEventArgs _)
    {
        _longPressCts?.Cancel();
        _longPressCts?.Dispose();
        _longPressCts = null;
    }

    private void OnPointerLeave(PointerEventArgs _)
    {
        _longPressCts?.Cancel();
        _longPressCts?.Dispose();
        _longPressCts = null;
        _longPressTriggered = false;
    }

    private static string TruncateName(string name) =>
        name.Length > 22 ? name[..20] + "…" : name;

    private static string FormatPrice(decimal? price) =>
        price.HasValue ? $"€{price.Value:F2}" : "–";

    public void Dispose()
    {
        _longPressCts?.Cancel();
        _longPressCts?.Dispose();
    }
}
