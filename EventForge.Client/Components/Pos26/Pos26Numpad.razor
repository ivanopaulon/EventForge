@* Pos26Numpad — tastierino numerico scuro con sconto e tasto PAGA *@

<div class="pos26-numpad">
    @* Display *@
    <div class="pos26-numpad-display">
        <span class="pos26-numpad-mode">@_modeLabel</span>
        <span class="pos26-numpad-value">@(_input.Length > 0 ? _input : "0")</span>
    </div>

    @* Griglia tasti *@
    <div class="pos26-numpad-grid">
        @foreach (var key in _keys)
        {
            <button class="pos26-numpad-key @key.Css"
                    style="@key.Style"
                    @onclick="() => HandleKey(key.Value)"
                    title="@key.Label"
                    disabled="@key.Disabled">
                @if (!string.IsNullOrEmpty(key.Icon))
                {
                    <MudIcon Icon="@key.Icon" Size="Size.Small" />
                }
                else
                {
                    @key.Label
                }
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public decimal Value { get; set; }
    [Parameter] public EventCallback<decimal> ValueChanged { get; set; }
    [Parameter] public EventCallback OnPay { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback<decimal> OnApplyDiscount { get; set; }
    [Parameter] public bool CanPay { get; set; }

    // TODO: aggiungere altri tasti funzione (Note, Tavolo, Coperto) se implementati nel progetto originale

    private string _input = string.Empty;
    private bool _discountMode = false;

    private string _modeLabel => _discountMode ? "Sconto %" : "Qtà / Importo";

    private record KeyDef(string Value, string Label, string Icon = "", string Css = "", string Style = "", bool Disabled = false);

    private List<KeyDef> _keys => BuildKeys();

    private List<KeyDef> BuildKeys()
    {
        var keys = new List<KeyDef>
        {
            new("7", "7"), new("8", "8"), new("9", "9"),
            new("4", "4"), new("5", "5"), new("6", "6"),
            new("1", "1"), new("2", "2"), new("3", "3"),
            new(",", ","), new("0", "0"),
            new("back", "", Icons.Material.Outlined.Backspace, "pos26-numpad-key--back",
                "background:var(--pos-red-key); color:#fff;"),
            // Tasto sconto %
            new("%sc", "%sc", "", "pos26-numpad-key--discount",
                "background:var(--pos-accent); color:#fff;"),
            // PAGA
            new("PAGA", "PAGA", "", "pos26-numpad-key--pay",
                $"background:var(--pos-green); color:#fff; opacity:{(CanPay ? "1" : ".4")};",
                !CanPay),
            // Annulla
            new("ANNULLA", "Annulla", "", "pos26-numpad-key--cancel",
                "background:var(--pos-dark-border); color:var(--pos-dark-text);")
        };
        return keys;
    }

    private async Task HandleKey(string key)
    {
        switch (key)
        {
            case "back":
                if (_input.Length > 0)
                    _input = _input[..^1];
                break;
            case "%sc":
                if (!_discountMode)
                {
                    _discountMode = true;
                    _input = string.Empty;
                }
                else
                {
                    // Applica sconto
                    if (decimal.TryParse(_input.Replace(',', '.'),
                            System.Globalization.NumberStyles.Any,
                            System.Globalization.CultureInfo.InvariantCulture, out var pct))
                    {
                        await OnApplyDiscount.InvokeAsync(pct);
                    }
                    _discountMode = false;
                    _input = string.Empty;
                }
                break;
            case "PAGA":
                if (CanPay)
                    await OnPay.InvokeAsync();
                break;
            case "ANNULLA":
                _input = string.Empty;
                _discountMode = false;
                await OnCancel.InvokeAsync();
                break;
            case ",":
                if (!_input.Contains(',') && !_input.Contains('.'))
                    _input += ",";
                break;
            default:
                if (_input.Length < 10)
                    _input += key;
                break;
        }

        if (decimal.TryParse(_input.Replace(',', '.'),
                System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var val))
        {
            await ValueChanged.InvokeAsync(val);
        }
        else if (_input.Length == 0)
        {
            await ValueChanged.InvokeAsync(0m);
        }
    }
}
