@* Pos26ContextBanner — striscia contestuale colorata sotto CategoryBar *@
@using EventForge.Client.Models.Sales
@using Prym.DTOs.Business

@if (!string.IsNullOrEmpty(BannerText))
{
    var bannerStyle = $"background:{_bg}; color:{_fg};";
    <div class="pos26-context-banner" style="@bannerStyle">
        <MudIcon Icon="@_icon" Size="Size.Small" Class="mr-1" Style="@($"color:{_fg};")" />
        <span>@BannerText</span>
    </div>
}

@code {
    [Parameter] public Pos26SortMode SortMode { get; set; }
    [Parameter] public BusinessPartyDto? Customer { get; set; }

    private string BannerText => BuildBannerText();
    private string _bg = "#F5F5F5";
    private string _fg = "#666";
    private string _icon = Icons.Material.Outlined.Info;

    protected override void OnParametersSet()
    {
        (_bg, _fg, _icon) = SortMode switch
        {
            Pos26SortMode.UltimiAcquisti when Customer != null
                => ("#EEEDFE", "#3C3489", Icons.Material.Outlined.History),
            Pos26SortMode.BestSeller
                => ("#FAEEDA", "#633806", Icons.Material.Outlined.TrendingUp),
            Pos26SortMode.UltimiAcquisti
                => ("#FAEEDA", "#633806", Icons.Material.Outlined.TrendingUp), // fallback no cliente
            Pos26SortMode.Prezzo
                => ("#E1F5EE", "#085041", Icons.Material.Outlined.EuroSymbol),
            _   => ("#F5F5F5", "#666666", Icons.Material.Outlined.Sort)
        };
    }

    private string BuildBannerText()
    {
        return SortMode switch
        {
            Pos26SortMode.UltimiAcquisti when Customer != null
                => $"Articoli acquistati da {Customer.Name}",
            Pos26SortMode.UltimiAcquisti
                => "Nessun cliente selezionato — visualizzazione best seller",
            Pos26SortMode.BestSeller
                => "Articoli più venduti",
            Pos26SortMode.Alfabetico
                => "Ordinamento alfabetico A→Z",
            Pos26SortMode.Prezzo
                => "Ordinamento per prezzo crescente",
            Pos26SortMode.Categoria
                => "Ordinamento per categoria",
            _ => string.Empty
        };
    }
}
