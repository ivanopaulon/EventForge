@namespace EventForge.Client.Layout
@inherits LayoutComponentBase
@using EventForge.Client.Constants
@using Prym.DTOs.Configuration
@using Prym.DTOs.Common
@using Prym.DTOs.Station
@using EventForge.Client.Shared.Components
@using Microsoft.AspNetCore.SignalR.Client
@inject IAuthService AuthService
@inject ISessionKeepaliveService SessionKeepaliveService
@inject IThemeService ThemeService
@inject IFontPreferencesService FontPreferencesService
@inject NavigationManager NavigationManager
@inject IAuthenticationDialogService AuthenticationDialogService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject ILogger<MainLayout> Logger
@inject IDialogService DialogService
@inject IBrandingService BrandingService
@inject IServerConfigOverlayService ServerConfigOverlayService
@inject IFiscalPrintingService FiscalPrintingService
@inject IHttpClientService HttpClientService
@implements IAsyncDisposable

<MudThemeProvider @ref="_mudThemeProvider" Theme="_currentTheme" IsDarkMode="@ThemeService.IsDarkMode" />

<MudLayout>
    <!-- AppBar: [Menu] [Home] [ThemeToggle] ---- [Logo] -->
    <MudAppBar Elevation="1" role="banner" Class="ef-appbar">
        <MudTooltip Text="@TranslationService.GetTranslation("navigation.menu", "Menu")">
            <MudIconButton Icon="@Icons.Material.Outlined.Menu"
                           Edge="Edge.Start"
                           OnClick="@(() => _drawerOpen = !_drawerOpen)"
                           aria-label="@TranslationService.GetTranslation("navigation.openMenu", "Open navigation menu")"
                           aria-expanded="@_drawerOpen"
                           aria-controls="navigation-drawer"
                           Class="ef-menu-button">
            </MudIconButton>
        </MudTooltip>
        <MudTooltip Text="@TranslationService.GetTranslation("navigation.home", "Home")">
            <MudIconButton Icon="@Icons.Material.Outlined.Home"
                           Color="Color.Inherit"
                           OnClick="@(() => NavigationManager.NavigateTo("/"))"
                           aria-label="@TranslationService.GetTranslation("navigation.home", "Home")"
                           Class="ef-menu-button">
            </MudIconButton>
        </MudTooltip>
        <MudTooltip Text="@(ThemeService.IsDarkMode ? TranslationService.GetTranslation("theme.switchLight", "Passa al tema chiaro") : TranslationService.GetTranslation("theme.switchDark", "Passa al tema scuro"))">
            <MudIconButton Icon="@(ThemeService.IsDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="@(async () => await ThemeService.ToggleThemeAsync())"
                           aria-label="@(ThemeService.IsDarkMode ? TranslationService.GetTranslation("theme.switchLight", "Passa al tema chiaro") : TranslationService.GetTranslation("theme.switchDark", "Passa al tema scuro"))"
                           Class="ef-menu-button">
            </MudIconButton>
        </MudTooltip>
        <MudSpacer />
        <img src="@GetLogoSrc()"
             alt="@($"{(_branding?.ApplicationName ?? "PRYM")} Logo")"
             class="ef-appbar-logo mx-2"
             style="height:@((_branding?.LogoHeight ?? 32))px; width:auto;" />
    </MudAppBar>
    
    @if (_isAuthenticated)
    {
        <!-- Navigation drawer with accessibility improvements -->
        <MudDrawer @bind-Open="@_drawerOpen" 
                   ClipMode="DrawerClipMode.Docked"
                   Elevation="1"
                   Variant="@DrawerVariant.Responsive"
                   Width="280px"
                   id="navigation-drawer"
                   Class="ef-drawer"
                   aria-label="@TranslationService.GetTranslation("navigation.mainMenu", "Main navigation menu")">
            <NavMenu />
        </MudDrawer>
    }

    @if (FiscalPrintingService.IsClosureOverdue && !_closureOverdueDismissed && _isManagerOrAbove)
    {
        <MudAppBar Elevation="0" Dense="true" Style="top:64px; background:transparent; pointer-events:none;">
            <MudAlert Severity="Severity.Error"
                      Dense="true"
                      Style="width:100%; pointer-events:all;"
                      NoIcon="false">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                    <MudText Class="flex-1">
                        ⚠️ <strong>CHIUSURA GIORNALIERA NON ESEGUITA</strong> — Alcune stampanti fiscali richiedono la chiusura immediata.
                    </MudText>
                    <MudButton Size="Size.Small"
                               Variant="Variant.Filled"
                               Color="Color.Error"
                               OnClick="@(() => NavigationManager.NavigateTo("/admin/fiscal-printers"))">
                        Vai alla Chiusura
                    </MudButton>
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   Color="Color.Inherit"
                                   OnClick="@DismissClosureOverdue"
                                   aria-label="Ignora" />
                </MudStack>
            </MudAlert>
        </MudAppBar>
    }
    
    <!-- Main content area with proper semantic structure -->
    <MudMainContent Class="mt-12 pa-2 pa-sm-4 main-content-with-footer" role="main">
        @Body
    </MudMainContent>
</MudLayout>

<!-- Global Loading Overlay - centralized modal loading component (backed by PageLoadingOverlay/EFSystemDialog) -->
<GlobalLoadingOverlay />

<!-- Connection Lost Overlay - monitors server connectivity -->
<ConnectionLostOverlay />

<!-- Floating FAB Speed Dial - consolidates Profile, Health, Chat and Scroll-to-Top -->
<FloatingFabMenu />

<!-- Login Overlay - fullscreen login card replacing MudDialog -->
<LoginOverlay />

<!-- Server Config Overlay - allows runtime server URL configuration -->
<ServerConfigOverlay />

<!-- Update/Maintenance Overlay - shows non-dismissable dialog on Server maintenance or Client update -->
<UpdateMaintenanceOverlay />

<!-- Download Notification Snackbar - shows incoming package info, manual-install switch and Install Now button -->
<UpdateDownloadSnackbar />

<!-- Log Cleanup Notification Snackbar - notifies SuperAdmin users when scheduled log cleanup runs -->
<LogCleanupNotificationSnackbar />

@code {
    private bool _drawerOpen = true;
    private bool _isAuthenticated = false;
    private MudThemeProvider? _mudThemeProvider;
    private MudTheme _currentTheme = new();
    private readonly SemaphoreSlim _authStateLock = new(1, 1);
    private BrandingConfigurationDto? _branding;

    // ── Fiscal overdue banner ──────────────────────────────────────────────────
    private bool _closureOverdueDismissed = false;
    private bool _isManagerOrAbove = false;
    private HubConnection? _fiscalHubConnection;
    private bool _fiscalHubStarted = false;
    private List<Guid> _fiscalPrinterIds = new();

    protected override async Task OnInitializedAsync()
    {
        AuthService.OnAuthenticationStateChanged += OnAuthenticationStateChanged;
        ThemeService.OnThemeChanged += OnThemeChanged;
        FontPreferencesService.OnPreferencesChanged += OnFontPreferencesChanged;
        TranslationService.LanguageChanged += OnLanguageChanged;
        NavigationManager.LocationChanged += OnLocationChanged;
        FiscalPrintingService.ClosureStatusChanged += OnClosureStatusChanged;
        
        // Subscribe to session keepalive events
        SessionKeepaliveService.OnRefreshSuccess += OnSessionRefreshSuccess;
        SessionKeepaliveService.OnRefreshFailure += OnSessionRefreshFailure;
        SessionKeepaliveService.OnSessionWarning += OnSessionWarning; // NEW
        
        await ThemeService.InitializeAsync();
        await FontPreferencesService.InitializeAsync();
        await CheckAuthenticationState();
        
        // Load branding configuration
        await LoadBrandingAsync();
        
        UpdateTheme();
    }

    private async Task LoadBrandingAsync()
    {
        try
        {
            _branding = await BrandingService.GetBrandingAsync();
            Logger.LogInformation("Branding configuration loaded: {ApplicationName}", _branding?.ApplicationName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading branding configuration, using defaults");
            _branding = null; // Will use defaults in bindings
        }
    }

    private void OnThemeChanged()
    {
        UpdateTheme();
        InvokeAsync(StateHasChanged);
    }

    private void OnFontPreferencesChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLanguageChanged(object? sender, string newLanguage)
    {
        InvokeAsync(StateHasChanged);
    }

    private void UpdateTheme()
    {
        _currentTheme = EventForgeTheme.GetMudTheme(ThemeService.CurrentTheme);
    }

    private string GetLogoSrc()
    {
        var configuredUrl = _branding?.LogoUrl;
        if (string.IsNullOrEmpty(configuredUrl) || configuredUrl == "/logoWhite.svg")
            return ThemeService.IsDarkMode ? "/logoWhite.svg" : "/logo.svg";
        return configuredUrl;
    }

    private string GetPageTitle()
    {
        var currentPath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var routePath = "/" + currentPath.Split('?')[0].Split('#')[0];

        return routePath.ToLower() switch
        {
            "/" => TranslationService.GetTranslation("navigation.home", "Home"),
            "/admin" => TranslationService.GetTranslation("navigation.admin", "Administration"),
            "/events" => TranslationService.GetTranslation("navigation.events", "Events"),
            "/notifications" => TranslationService.GetTranslation("navigation.notifications", "Notifications"),
            "/chat" => TranslationService.GetTranslation("navigation.chat", "Chat"),
            "/profile" => TranslationService.GetTranslation("navigation.profile", "Profile"),
            "/settings" => TranslationService.GetTranslation("navigation.settings", "Settings"),
            "/superadmin" => TranslationService.GetTranslation("navigation.superadmin", "Super Admin"),
            var path when path.StartsWith("/superadmin/") => TranslationService.GetTranslation("navigation.superadmin", "Super Admin"),
            var path when path.StartsWith("/admin/") => TranslationService.GetTranslation("navigation.admin", "Administration"),
            _ => TranslationService.GetTranslation("navigation.eventforge", "PRYM")
        };
    }

    private async Task CheckAuthenticationState()
    {
        // Use semaphore to prevent race conditions from concurrent calls
        await _authStateLock.WaitAsync();
        try
        {
            var wasAuthenticated = _isAuthenticated;
            _isAuthenticated = await AuthService.IsAuthenticatedAsync();
            
            // Start or stop session keepalive based on authentication state
            if (_isAuthenticated && !wasAuthenticated)
            {
                // User just logged in - start the keepalive service
                Logger.LogInformation("User authenticated, starting session keepalive service");
                SessionKeepaliveService.Start();

                // Check roles and start fiscal hub if appropriate
                _isManagerOrAbove = await AuthService.IsInRoleAsync("Admin")
                    || await AuthService.IsInRoleAsync("Manager")
                    || await AuthService.IsInRoleAsync("StoreManager")
                    || await AuthService.IsSuperAdminAsync();

                if (_isManagerOrAbove && !_fiscalHubStarted)
                    _ = Task.Run(ConnectFiscalHubAsync);
            }
            else if (!_isAuthenticated && wasAuthenticated)
            {
                // User just logged out - stop the keepalive service
                Logger.LogInformation("User logged out, stopping session keepalive service");
                SessionKeepaliveService.Stop();
                _isManagerOrAbove = false;
            }
            
            StateHasChanged();
        }
        finally
        {
            _authStateLock.Release();
        }
    }

    // ── Fiscal overdue banner helpers ─────────────────────────────────────────

    private void OnClosureStatusChanged() => InvokeAsync(StateHasChanged);

    private void DismissClosureOverdue()
    {
        _closureOverdueDismissed = true;
        StateHasChanged();
    }

    private async Task ConnectFiscalHubAsync()
    {
        _fiscalHubStarted = true;
        try
        {
            _fiscalHubConnection = new HubConnectionBuilder()
                .WithUrl("/hubs/fiscal-printer")
                .WithAutomaticReconnect()
                .Build();

            _fiscalHubConnection.On<Guid, string>("ClosureRequired", (_, _) =>
            {
                FiscalPrintingService.SetClosureOverdue(true);
                _closureOverdueDismissed = false;
            });

            _fiscalHubConnection.Reconnected += async _ =>
            {
                foreach (var id in _fiscalPrinterIds)
                {
                    try { await _fiscalHubConnection.SendAsync("SubscribeToPrinter", id); }
                    catch (Exception ex) { Logger.LogWarning(ex, "MainLayout: failed to re-subscribe to printer {PrinterId} after reconnect", id); }
                }
            };

            await _fiscalHubConnection.StartAsync();

            // Subscribe to all fiscal printers so we receive their ClosureRequired events
            try
            {
                var printerPage = await HttpClientService.GetAsync<PagedResult<PrinterDto>>(
                    "api/v1/stations/printers?page=1&pageSize=100");
                var fiscalPrinters = printerPage?.Items?.Where(p => p.IsFiscalPrinter).ToList() ?? [];
                _fiscalPrinterIds = fiscalPrinters.Select(p => p.Id).ToList();
                foreach (var p in fiscalPrinters)
                    await _fiscalHubConnection.SendAsync("SubscribeToPrinter", p.Id);

                Logger.LogDebug("MainLayout: subscribed to {Count} fiscal printer(s)", fiscalPrinters.Count);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "MainLayout: could not load fiscal printers for hub subscription");
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "MainLayout: could not connect to fiscal printer SignalR hub");
            _fiscalHubStarted = false;
        }
    }

    private async void OnAuthenticationStateChanged()
    {
        try
        {
            await CheckAuthenticationState();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unhandled exception in OnAuthenticationStateChanged.");
        }
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        try
        {
            Logger.LogDebug("Navigation detected: {Uri}", e.Location);

            // Close the drawer on navigation (DrawerVariant.Responsive handles desktop visibility)
            _drawerOpen = false;

            // Trigger token refresh on every navigation (sliding expiration)
            if (await AuthService.IsAuthenticatedAsync())
            {
                Logger.LogDebug("User authenticated, triggering sliding expiration refresh on navigation");

                // Fire and forget - don't wait for refresh to complete
                _ = Task.Run(async () =>
                {
                    try
                    {
                        var refreshed = await AuthService.RefreshTokenAsync();
                        if (refreshed)
                        {
                            Logger.LogDebug("Token refreshed successfully on navigation");
                        }
                    }
                    catch (Exception ex)
                    {
                        Logger.LogWarning(ex, "Failed to refresh token on navigation");
                    }
                });
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error handling navigation change");
        }
    }

    private async Task ShowLoginDialogAsync()
    {
        var result = await AuthenticationDialogService.ShowLoginDialogAsync();
        if (result)
        {
            // Reload authentication state after successful login
            await CheckAuthenticationState();
        }
    }

    private void OnSessionRefreshSuccess()
    {
        // Optional: Show subtle success notification
        // Commented out to avoid noise, but can be enabled if desired
        Logger.LogDebug("Session token refreshed successfully");
        
        // Uncomment to show success notification:
        // InvokeAsync(() =>
        // {
        //     Snackbar.Add(
        //         TranslationService.GetTranslation("session.refreshSuccess", "Sessione rinnovata automaticamente"),
        //         Severity.Success,
        //         config => { config.VisibleStateDuration = 2000; }
        //     );
        // });
    }

    private void OnSessionRefreshFailure(string errorMessage)
    {
        Logger.LogWarning("Session token refresh failed: {Error}", errorMessage);
        
        InvokeAsync(() =>
        {
            AppNotification.ShowError(
                TranslationService.GetTranslation("session.refreshFailure", "Impossibile rinnovare la sessione. Salva il lavoro e rieffettua il login.")
            );
        });
    }

    private void OnSessionWarning(int minutesRemaining)
    {
        Logger.LogInformation("Session warning: {Minutes} minutes remaining", minutesRemaining);
        
        InvokeAsync(() =>
        {
            // Show warning only when truly critical (<= 10 minutes remaining)
            if (minutesRemaining <= 10)
            {
                AppNotification.ShowWarning(
                    TranslationService.GetTranslation("session.expiringWarning", 
                        $"Sessione in scadenza tra {minutesRemaining} min. Salva il lavoro. / Session expiring in {minutesRemaining} min. Save your work.")
                );
            }
        });
    }

    public async ValueTask DisposeAsync()
    {
        AuthService.OnAuthenticationStateChanged -= OnAuthenticationStateChanged;
        ThemeService.OnThemeChanged -= OnThemeChanged;
        FontPreferencesService.OnPreferencesChanged -= OnFontPreferencesChanged;
        TranslationService.LanguageChanged -= OnLanguageChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
        FiscalPrintingService.ClosureStatusChanged -= OnClosureStatusChanged;
        SessionKeepaliveService.OnRefreshSuccess -= OnSessionRefreshSuccess;
        SessionKeepaliveService.OnRefreshFailure -= OnSessionRefreshFailure;
        SessionKeepaliveService.OnSessionWarning -= OnSessionWarning; // NEW
        
        // Ensure the keepalive service is stopped when the layout is disposed
        SessionKeepaliveService.Stop();
        
        // Dispose the semaphore
        _authStateLock.Dispose();

        if (_fiscalHubConnection is not null)
        {
            try { await _fiscalHubConnection.DisposeAsync(); }
            catch { /* intentionally swallowed during disposal */ }
        }
    }
}
