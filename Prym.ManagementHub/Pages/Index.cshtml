@page
@model Prym.ManagementHub.Pages.IndexModel
@using Prym.ManagementHub.Data.Entities
@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageSection"] = "Hub";
}

<!-- Page header -->
<div class="ef-page-header">
    <div class="ef-page-title">
        <div class="ef-page-title-icon monitoring"><i class="bi bi-grid-1x2-fill"></i></div>
        <div>
            <h1>Dashboard</h1>
            <p class="ef-page-subtitle">Panoramica installazioni e pacchetti</p>
        </div>
    </div>
    <a href="/" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-clockwise"></i>Aggiorna
    </a>
</div>

@if (TempData["Error"] is string errMsg)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i><span>@errMsg</span>
    </div>
}

<!-- KPI row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card blue">
            <div class="ef-kpi-label"><i class="bi bi-pc-display-horizontal me-1"></i>Installazioni</div>
            <div class="ef-kpi-value">@Model.TotalInstallations</div>
            <div class="ef-kpi-sub">totali registrate</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card green">
            <div class="ef-kpi-label"><i class="bi bi-wifi me-1"></i>Online</div>
            <div class="ef-kpi-value">@Model.OnlineCount</div>
            <div class="ef-kpi-sub">connesse ora</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card @(Model.OfflineCount > 0 ? "amber" : "green")">
            <div class="ef-kpi-label"><i class="bi bi-wifi-off me-1"></i>Offline</div>
            <div class="ef-kpi-value">@Model.OfflineCount</div>
            <div class="ef-kpi-sub">non raggiungibili</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card @(Model.ReadyPackages.Count > 0 ? "amber" : "cyan")">
            <div class="ef-kpi-label"><i class="bi bi-box-seam me-1"></i>Pacchetti</div>
            <div class="ef-kpi-value">@Model.PackageCount</div>
            <div class="ef-kpi-sub">@Model.ReadyPackages.Count pronti al deploy</div>
        </div>
    </div>
</div>

<!-- Packages ready -->
@if (Model.ReadyPackages.Count > 0)
{
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-box-seam-fill fs-5 flex-shrink-0"></i>
        <div>
            <strong>@Model.ReadyPackages.Count pacchett@(Model.ReadyPackages.Count == 1 ? "o pronto" : "i pronti") al deploy.</strong>
            Seleziona un'installazione e premi <em>Invia</em>, oppure usa <em>Broadcast</em> per tutte.
        </div>
    </div>

    <div class="ef-card mb-4">
        <div class="ef-card-header">
            <i class="bi bi-box-seam-fill"></i>Pacchetti pronti al deploy
            <span class="ef-badge ef-badge-warning ms-1">@Model.ReadyPackages.Count</span>
        </div>
        <div class="ef-card-body p-0">
            <div class="ef-table-wrap">
                <table class="ef-table">
                    <thead>
                        <tr>
                            <th>Componente</th>
                            <th>Versione</th>
                            <th>Note</th>
                            <th>Commit</th>
                            <th>Caricato</th>
                            <th>Dimensione</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pkg in Model.ReadyPackages)
                        {
                            <tr>
                                <td>
                                    <span class="ef-badge @(pkg.Component == PackageComponent.Server ? "ef-badge-blue" : "ef-badge-info")">
                                        @pkg.Component
                                    </span>
                                </td>
                                <td><code>@pkg.Version</code></td>
                                <td class="text-muted">@(pkg.ReleaseNotes ?? "—")</td>
                                <td><code class="text-muted" style="font-size:.72rem">@(pkg.GitCommit?[..Math.Min(8, pkg.GitCommit?.Length ?? 0)] ?? "—")</code></td>
                                <td class="text-muted" style="font-size:.78rem">@pkg.UploadedAt.ToString("dd/MM/yy HH:mm")</td>
                                <td class="text-muted" style="font-size:.78rem">@(Math.Round(pkg.FileSizeBytes / 1_048_576.0, 1)) MB</td>
                                <td>
                                    <div class="d-flex gap-1 flex-wrap">
                                        <form method="post" asp-page-handler="BroadcastUpdate" class="d-inline">
                                            <input type="hidden" name="packageId" value="@pkg.Id" />
                                            <button type="submit" class="btn btn-sm btn-warning"
                                                    onclick="return confirm('Broadcast @pkg.Component @pkg.Version a TUTTE le installazioni online?')">
                                                <i class="bi bi-broadcast me-1"></i>Broadcast
                                            </button>
                                        </form>
                                        <form method="post" asp-page-handler="ArchivePackage" class="d-inline">
                                            <input type="hidden" name="packageId" value="@pkg.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary"
                                                    onclick="return confirm('Archiviare @pkg.Component @pkg.Version?')">
                                                <i class="bi bi-archive me-1"></i>Archivia
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- Installations table -->
<div class="ef-card">
    <div class="ef-card-header">
        <i class="bi bi-pc-display-horizontal"></i>Installazioni
        <span class="ef-badge ef-badge-neutral ms-1">@Model.TotalInstallations</span>
    </div>
    <div class="ef-card-body p-0">
        <div class="ef-table-wrap">
            <table class="ef-table">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Posizione</th>
                        <th>Componenti</th>
                        <th>Server</th>
                        <th>Client</th>
                        <th>Stato</th>
                        <th>Ultimo contatto</th>
                        <th>Aggiornamento</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inst in Model.Installations)
                    {
                        var badgeCls = inst.Status switch
                        {
                            InstallationStatus.Online   => "ef-badge-success",
                            InstallationStatus.Updating => "ef-badge-warning",
                            InstallationStatus.Error    => "ef-badge-danger",
                            _                           => "ef-badge-neutral"
                        };
                        var rowCls = inst.Status == InstallationStatus.Error ? "row-danger"
                                   : inst.Status == InstallationStatus.Updating ? "row-warning"
                                   : "";
                        <tr class="@rowCls">
                            <td class="fw-600">@inst.Name</td>
                            <td class="text-muted">@(inst.Location ?? "—")</td>
                            <td class="text-muted" style="font-size:.78rem">@inst.Components</td>
                            <td><code class="text-muted">@(inst.InstalledVersionServer ?? "—")</code></td>
                            <td><code class="text-muted">@(inst.InstalledVersionClient ?? "—")</code></td>
                            <td><span class="ef-badge @badgeCls">@inst.Status</span></td>
                            <td class="text-muted" style="font-size:.78rem;white-space:nowrap">
                                @(inst.LastSeen?.ToString("dd/MM HH:mm:ss") ?? "Mai")
                            </td>
                            <td>
                                @if (Model.ReadyPackages.Count > 0 && inst.Status == InstallationStatus.Online)
                                {
                                    <div class="d-flex gap-1 flex-wrap">
                                        @foreach (var pkg in Model.ReadyPackages)
                                        {
                                            <form method="post" asp-page-handler="SendUpdate">
                                                <input type="hidden" name="installationId" value="@inst.Id" />
                                                <input type="hidden" name="packageId" value="@pkg.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-secondary"
                                                        title="Invia @pkg.Component @pkg.Version">
                                                    <i class="bi bi-upload me-1"></i>@pkg.Component @pkg.Version
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Installations.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="bi bi-pc-display fs-4 d-block mb-2"></i>
                                Nessuna installazione registrata.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


@section Scripts {
<script>
// Auto-refresh dashboard every 60 seconds to pick up online/offline status changes.
(function() {
    const timer = setTimeout(() => window.location.reload(), 60000);
    // Cancel auto-refresh if the user opens a modal to prevent data loss.
    document.addEventListener('show.bs.modal', () => clearTimeout(timer));
})();
</script>
}
