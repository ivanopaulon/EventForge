@page
@model Prym.ManagementHub.Pages.HistoryModel
@using Prym.ManagementHub.Data.Entities
@{
    ViewData["Title"] = "Cronologia";
    ViewData["PageSection"] = "Hub";
    int succeeded  = Model.History.Count(r => r.History.Status == UpdateHistoryStatus.Succeeded);
    int failed     = Model.History.Count(r => r.History.Status == UpdateHistoryStatus.Failed);
    int inProgress = Model.History.Count(r => r.History.Status == UpdateHistoryStatus.InProgress);
    int rolledBack = Model.History.Count(r => r.History.RolledBack);
}

<div class="ef-page-header">
    <div class="ef-page-title">
        <div class="ef-page-title-icon blue"><i class="bi bi-clock-history"></i></div>
        <div>
            <h1>Cronologia aggiornamenti</h1>
            <p class="ef-page-subtitle">Registro degli aggiornamenti inviati alle installazioni (@Model.TotalCount totali, pagina @Model.CurrentPage di @Model.TotalPages)</p>
        </div>
    </div>
    <span class="ef-badge ef-badge-neutral">@Model.History.Count su @Model.TotalCount eventi</span>
</div>

@if (TempData["Success"] is string okMsg)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-check-circle-fill"></i><span>@okMsg</span>
    </div>
}
@if (TempData["Error"] is string errMsg)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-exclamation-triangle-fill"></i><span>@errMsg</span>
    </div>
}

<!-- KPI -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card green">
            <div class="ef-kpi-label"><i class="bi bi-check-circle me-1"></i>Completati</div>
            <div class="ef-kpi-value">@succeeded</div>
            <div class="ef-kpi-sub">su questa pagina</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card @(failed > 0 ? "amber" : "green")">
            <div class="ef-kpi-label"><i class="bi bi-x-circle me-1"></i>Falliti</div>
            <div class="ef-kpi-value">@failed</div>
            <div class="ef-kpi-sub">su questa pagina</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card @(inProgress > 0 ? "amber" : "cyan")">
            <div class="ef-kpi-label"><i class="bi bi-arrow-repeat me-1"></i>In corso</div>
            <div class="ef-kpi-value">@inProgress</div>
            <div class="ef-kpi-sub">su questa pagina</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card @(rolledBack > 0 ? "amber" : "cyan")">
            <div class="ef-kpi-label"><i class="bi bi-arrow-counterclockwise me-1"></i>Rollback</div>
            <div class="ef-kpi-value">@rolledBack</div>
            <div class="ef-kpi-sub">su questa pagina</div>
        </div>
    </div>
</div>

<!-- Tabella cronologia -->
<div class="ef-card">
    <div class="ef-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span><i class="bi bi-clock-history me-2"></i>Storico aggiornamenti</span>
        <div class="d-flex gap-2 flex-wrap align-items-center">
            <form method="get" class="d-flex gap-2 flex-wrap align-items-center">
                <select name="status" class="form-select form-select-sm" style="max-width:180px"
                        onchange="this.form.submit()">
                    <option value="" selected="@(string.IsNullOrEmpty(Model.FilterStatus) ? "selected" : null)">Tutti gli stati</option>
                    <option value="Succeeded" selected="@(Model.FilterStatus == "Succeeded" ? "selected" : null)">Completati</option>
                    <option value="Failed" selected="@(Model.FilterStatus == "Failed" ? "selected" : null)">Falliti</option>
                    <option value="InProgress" selected="@(Model.FilterStatus == "InProgress" ? "selected" : null)">In corso</option>
                    <option value="RolledBack" selected="@(Model.FilterStatus == "RolledBack" ? "selected" : null)">Rollback</option>
                </select>
                <input type="text" name="installation" class="form-control form-control-sm" style="max-width:220px"
                       value="@Model.FilterInstallation" placeholder="🔍 Filtra installazione…" />
                <button type="submit" class="btn btn-sm btn-outline-secondary">Filtra</button>
                @if (!string.IsNullOrEmpty(Model.FilterStatus) || !string.IsNullOrEmpty(Model.FilterInstallation))
                {
                    <a href="/history" class="btn btn-sm btn-outline-secondary">✕ Reset</a>
                }
            </form>
            <!-- Purge -->
            <button type="button" class="btn btn-sm btn-outline-danger"
                    data-bs-toggle="modal" data-bs-target="#purgeModal"
                    title="Elimina record storici completati/falliti">
                <i class="bi bi-trash me-1"></i>Purge
            </button>
        </div>
    </div>
    <div class="ef-card-body p-0">
        <div class="ef-table-wrap">
            <table class="ef-table" id="histTable">
                <thead>
                    <tr>
                        <th>Stato</th>
                        <th>Installazione</th>
                        <th>Componente</th>
                        <th>Versione</th>
                        <th>Da → A</th>
                        <th>Fase</th>
                        <th>Avviato il</th>
                        <th>Completato il</th>
                        <th>Durata</th>
                        <th>Errore</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.History)
                {
                    var h = row.History;
                    var statusCss = h.Status switch {
                        UpdateHistoryStatus.Succeeded  => "ef-badge-success",
                        UpdateHistoryStatus.Failed     => "ef-badge-danger",
                        UpdateHistoryStatus.InProgress => "ef-badge-warning",
                        UpdateHistoryStatus.RolledBack => "ef-badge-neutral",
                        _                              => "ef-badge-neutral"
                    };
                    var rowCss = h.Status == UpdateHistoryStatus.Failed ? "row-danger"
                               : h.Status == UpdateHistoryStatus.InProgress ? "row-warning"
                               : "";
                    var duration = h.CompletedAt.HasValue
                        ? (h.CompletedAt.Value - h.StartedAt).TotalSeconds
                        : (double?)null;
                    var compCss  = row.Component == PackageComponent.Server ? "ef-badge-blue" : "ef-badge-info";
                    <tr class="@rowCss"
                        data-status="@h.Status.ToString().ToLower()"
                        data-search="@row.InstallationName.ToLower()">
                        <td>
                            <span class="ef-badge @statusCss">
                                @if (h.RolledBack) { <i class="bi bi-arrow-counterclockwise me-1"></i> }
                                @h.Status
                            </span>
                        </td>
                        <td class="fw-semibold small">@row.InstallationName</td>
                        <td>
                            @if (row.Component.HasValue)
                            {
                                <span class="ef-badge @compCss">@row.Component</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td><code class="text-muted">@row.PackageVersion</code></td>
                        <td class="small text-muted" style="white-space:nowrap">
                            <code>@(h.FromVersion ?? "—")</code>
                            <i class="bi bi-arrow-right mx-1"></i>
                            <code>@(h.ToVersion ?? "—")</code>
                        </td>
                        <td class="text-muted small">@(h.PhaseDescription ?? "—")</td>
                        <td class="text-muted small" style="white-space:nowrap">
                            <span title="@h.StartedAt.ToString("u")">@h.StartedAt.ToString("dd/MM/yy HH:mm:ss")</span>
                        </td>
                        <td class="text-muted small" style="white-space:nowrap">
                            @if (h.CompletedAt.HasValue)
                            {
                                <span title="@h.CompletedAt.Value.ToString("u")">@h.CompletedAt.Value.ToString("dd/MM/yy HH:mm:ss")</span>
                            }
                            else { <span>—</span> }
                        </td>
                        <td class="text-muted small">
                            @if (duration.HasValue)
                            {
                                @(duration < 60
                                    ? $"{(int)duration}s"
                                    : $"{(int)(duration / 60)}m {(int)(duration % 60)}s")
                            }
                            else { <span>—</span> }
                        </td>
                        <td class="text-danger small" style="max-width:200px">
                            @if (!string.IsNullOrEmpty(h.ErrorMessage))
                            {
                                <span title="@h.ErrorMessage">
                                    @(h.ErrorMessage.Length > 60 ? h.ErrorMessage[..60] + "…" : h.ErrorMessage)
                                </span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                    </tr>
                }
                @if (!Model.History.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center text-muted py-5">
                            <i class="bi bi-clock-history fs-3 d-block mb-2"></i>
                            Nessun aggiornamento registrato. La cronologia apparirà qui dopo il primo deploy.
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="ef-card-body border-top d-flex justify-content-between align-items-center flex-wrap gap-2 py-2 px-3">
            <span class="text-muted small">
                Pagina @Model.CurrentPage di @Model.TotalPages
                (@((Model.CurrentPage - 1) * Prym.ManagementHub.Pages.HistoryModel.PageSize + 1)–@Math.Min(Model.CurrentPage * Prym.ManagementHub.Pages.HistoryModel.PageSize, Model.TotalCount) di @Model.TotalCount)
            </span>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Page("/history", new { page = Model.CurrentPage - 1, status = Model.FilterStatus, installation = Model.FilterInstallation })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @{
                        int startPg = Math.Max(1, Model.CurrentPage - 2);
                        int endPg   = Math.Min(Model.TotalPages, startPg + 4);
                        startPg = Math.Max(1, endPg - 4);
                    }
                    @for (int pg = startPg; pg <= endPg; pg++)
                    {
                        <li class="page-item @(pg == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Page("/history", new { page = pg, status = Model.FilterStatus, installation = Model.FilterInstallation })">@pg</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="@Url.Page("/history", new { page = Model.CurrentPage + 1, status = Model.FilterStatus, installation = Model.FilterInstallation })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- ── Modal purge ─────────────────────────────────────────────────────── -->
<div class="modal fade" id="purgeModal" tabindex="-1" aria-labelledby="purgeModalLabel">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post" asp-page-handler="Purge">
            @Html.AntiForgeryToken()
            <div class="modal-content ef-modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="purgeModalLabel">
                        <i class="bi bi-trash me-2 text-danger"></i>Purge cronologia
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning py-2 small mb-3">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Elimina i record di cronologia <strong>completati o falliti</strong> più vecchi di N giorni.
                        Gli aggiornamenti <em>in corso</em> non vengono eliminati. L'operazione è irreversibile.
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Elimina record precedenti a <span class="text-danger">*</span></label>
                        <div class="input-group" style="max-width:200px">
                            <input type="number" name="olderThanDays" class="form-control" value="30" min="1" max="3650" required />
                            <span class="input-group-text">giorni fa</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annulla</button>
                    <button type="submit" class="btn btn-danger"
                            onclick="return confirm('Eliminare definitivamente i record di cronologia precedenti al limite selezionato?')">
                        <i class="bi bi-trash me-1"></i>Purge
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
