@page
@model Prym.Server.Pages.Dashboard.HealthModel
@using Microsoft.Extensions.Diagnostics.HealthChecks
@{
    ViewData["Title"] = "Health Checks";
    ViewData["PageSection"] = "Monitoring";
    var overall = Model.Report?.Status ?? HealthStatus.Unhealthy;
    string overallType = overall == HealthStatus.Healthy ? "success" : overall == HealthStatus.Degraded ? "warning" : "danger";
    string overallIcon = overall == HealthStatus.Healthy ? "bi-check-circle-fill" : overall == HealthStatus.Degraded ? "bi-exclamation-circle-fill" : "bi-x-circle-fill";
}

<div class="ef-page-header">
    <div class="ef-page-title">
        <div class="ef-page-title-icon monitoring"><i class="bi bi-heart-pulse-fill"></i></div>
        <div><h1>Health Checks</h1><p class="ef-page-subtitle">Stato di salute di tutti i servizi registrati</p></div>
    </div>
    <a href="/dashboard/health" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-clockwise"></i>Aggiorna</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}
else if (Model.Report == null)
{
    <div class="alert alert-warning">Nessun dato disponibile.</div>
}
else
{
    <div class="alert alert-@overallType d-flex align-items-center gap-2 mb-4">
        <i class="bi @overallIcon fs-5"></i>
        <strong>Stato generale: @overall</strong>
        <span class="ms-auto" style="font-size:.75rem;opacity:.7">
            Durata totale: @Model.Report.TotalDuration.TotalMilliseconds.ToString("N0") ms
        </span>
    </div>

    <div class="row g-3">
        @foreach (var entry in Model.Report.Entries.OrderBy(e => e.Value.Status))
        {
            string badgeClass, iconClass;
            if (entry.Value.Status == HealthStatus.Healthy)
            { badgeClass = "ef-badge-success"; iconClass = "bi-check-circle-fill text-success"; }
            else if (entry.Value.Status == HealthStatus.Degraded)
            { badgeClass = "ef-badge-warning"; iconClass = "bi-exclamation-circle-fill text-warning"; }
            else
            { badgeClass = "ef-badge-danger";  iconClass = "bi-x-circle-fill text-danger"; }

            <div class="col-md-6">
                <div class="ef-card h-100" style="border-left: 3px solid var(--ef-@(entry.Value.Status == HealthStatus.Healthy ? "success" : entry.Value.Status == HealthStatus.Degraded ? "warning" : "danger"))">
                    <div class="ef-card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="mb-0 d-flex align-items-center gap-2">
                                <i class="bi @iconClass"></i>@entry.Key
                            </h6>
                            <span class="ef-badge @badgeClass">@entry.Value.Status</span>
                        </div>
                        @if (!string.IsNullOrEmpty(entry.Value.Description))
                        {
                            <p class="text-muted mb-1" style="font-size:.8rem">@entry.Value.Description</p>
                        }
                        <div style="font-size:.75rem;color:var(--ef-text-subtle)">
                            <i class="bi bi-stopwatch me-1"></i>@entry.Value.Duration.TotalMilliseconds.ToString("N0") ms
                        </div>
                        @if (entry.Value.Exception != null)
                        {
                            <div class="mt-2 p-2 rounded" style="background:var(--ef-danger-bg);font-size:.75rem;color:var(--ef-danger)">
                                <i class="bi bi-bug me-1"></i>@entry.Value.Exception.Message
                            </div>
                        }
                        @if (entry.Value.Data.Any())
                        {
                            <ul class="mt-2 mb-0 list-unstyled" style="font-size:.75rem">
                                @foreach (var kv in entry.Value.Data)
                                {
                                    <li><span class="text-muted">@kv.Key:</span> @kv.Value</li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <p class="mt-3" style="font-size:.72rem;color:var(--ef-text-subtle)">
        <i class="bi bi-clock me-1"></i>Aggiornato: @DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")
        &mdash; <a href="/health" target="_blank">JSON endpoint <i class="bi bi-box-arrow-up-right"></i></a>
    </p>
}
