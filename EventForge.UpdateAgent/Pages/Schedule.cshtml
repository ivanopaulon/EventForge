@page
@model ScheduleModel
@{
    ViewData["Title"] = "Schedule";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-calendar-check me-2"></i>Maintenance Windows</h5>
    <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="bi bi-plus-lg me-1"></i>Add Window
    </button>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success alert-dismissible"><button type="button" class="btn-close" data-bs-dismiss="alert"></button>@ok</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger alert-dismissible"><button type="button" class="btn-close" data-bs-dismiss="alert"></button>@err</div>
}

@if (Model.Windows.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-1"></i>No maintenance windows configured — updates install <strong>immediately</strong> after download.
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Days</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Active now?</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Windows.Count; i++)
                    {
                        var w = Model.Windows[i];
                        var days = w.DaysOfWeek.Count == 0 ? "Every day" : string.Join(", ", w.DaysOfWeek.Select(d => d.ToString()[..3]));
                        <tr>
                            <td>@(i + 1)</td>
                            <td>@days</td>
                            <td><code>@w.StartTime</code></td>
                            <td><code>@w.EndTime</code></td>
                            <td>
                                @if (Model.ActiveWindowIndex == i)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                <form method="post" asp-page-handler="DeleteWindow" class="d-inline">
                                    <input type="hidden" name="index" value="@i" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Delete window @(i+1)?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <p class="text-muted small">
        <i class="bi bi-info-circle me-1"></i>Changes take effect immediately. The service does not need to be restarted.
    </p>
}

<!-- Add Window Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="AddWindow">
                <div class="modal-header">
                    <h5 class="modal-title">Add Maintenance Window</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Days of week <span class="text-muted small">(none = every day)</span></label>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (DayOfWeek day in Enum.GetValues<DayOfWeek>())
                            {
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="checkbox" name="days" value="@((int)day)" id="day_@day" />
                                    <label class="form-check-label" for="day_@day">@day.ToString()[..3]</label>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col">
                            <label class="form-label">Start time</label>
                            <input type="time" class="form-control" name="startTime" value="02:00" required />
                        </div>
                        <div class="col">
                            <label class="form-label">End time</label>
                            <input type="time" class="form-control" name="endTime" value="04:00" required />
                        </div>
                    </div>
                    <p class="text-muted small mt-2">Overnight windows (e.g. 23:00 → 01:00) are supported.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>
