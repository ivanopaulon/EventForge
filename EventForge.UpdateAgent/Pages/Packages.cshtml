@page
@model PackagesModel
@using EventForge.UpdateAgent.Services
@{
    ViewData["Title"] = "Pacchetti";
}

<!-- Page header -->
<div class="ef-page-header">
    <div class="ef-page-title">
        <div class="ef-page-title-icon monitoring"><i class="bi bi-box-seam"></i></div>
        <div>
            <h1>Pacchetti</h1>
            <p class="ef-page-subtitle">Pacchetti disponibili, in download, pronti all'installazione e installati</p>
        </div>
    </div>
    <a href="/packages" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-clockwise"></i>Aggiorna
    </a>
</div>

<!-- ── Versioni installate ──────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card blue">
            <div class="ef-kpi-label"><i class="bi bi-hdd-network me-1"></i>Server</div>
            <div class="ef-kpi-value" style="font-size:1.15rem">@(Model.ServerVersion ?? "—")</div>
            <div class="ef-kpi-sub">Versione installata</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ef-kpi-card cyan">
            <div class="ef-kpi-label"><i class="bi bi-window me-1"></i>Client</div>
            <div class="ef-kpi-value" style="font-size:1.15rem">@(Model.ClientVersion ?? "—")</div>
            <div class="ef-kpi-sub">Versione installata</div>
        </div>
    </div>
</div>

<!-- ── Pacchetti disponibili (annunciati dall'Hub) ───────────────────── -->
<div class="ef-card mb-4">
    <div class="ef-card-header">
        <i class="bi bi-cloud-arrow-down-fill"></i>
        Pacchetti disponibili
        <span class="ef-badge ef-badge-neutral ms-1">@Model.NotifiedPackages.Count</span>
    </div>
    <div class="ef-card-body @(Model.NotifiedPackages.Count == 0 ? "" : "p-0")">
        @if (Model.NotifiedPackages.Count == 0)
        {
            <div class="alert alert-success d-flex align-items-center gap-2 mb-0">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <span>Nessun pacchetto disponibile annunciato dall'Hub.</span>
            </div>
        }
        else
        {
            <div class="ef-table-wrap">
                <table class="ef-table">
                    <thead>
                        <tr>
                            <th>Componente</th>
                            <th>Versione</th>
                            <th>Note di rilascio</th>
                            <th>Ricevuto</th>
                            <th>Stato</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pkg in Model.NotifiedPackages)
                        {
                            <tr>
                                <td>
                                    <span class="ef-badge @(pkg.Component.Equals("Server", StringComparison.OrdinalIgnoreCase) ? "ef-badge-blue" : "ef-badge-info")">
                                        @pkg.Component
                                    </span>
                                </td>
                                <td><code>@pkg.Version</code></td>
                                <td class="text-muted small">
                                    @if (!string.IsNullOrWhiteSpace(pkg.ReleaseNotes))
                                    {
                                        <span title="@pkg.ReleaseNotes">
                                            @(pkg.ReleaseNotes!.Length > 80 ? pkg.ReleaseNotes[..80] + "…" : pkg.ReleaseNotes)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-muted small">@pkg.ReceivedAt.ToLocalTime().ToString("dd/MM HH:mm:ss")</td>
                                <td>
                                    @if (pkg.WasNewer)
                                    {
                                        <span class="ef-badge ef-badge-info">Aggiornamento richiesto</span>
                                    }
                                    else
                                    {
                                        <span class="ef-badge ef-badge-neutral">Già aggiornato</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- ── In download ───────────────────────────────────────────────────── -->
@if (Model.DownloadingPackages.Count > 0)
{
    <div class="ef-card mb-4">
        <div class="ef-card-header">
            <i class="bi bi-cloud-download-fill text-primary"></i>
            In download
            <span class="ef-badge ef-badge-blue ms-1">@Model.DownloadingPackages.Count</span>
        </div>
        <div class="ef-card-body p-0">
            <div class="ef-table-wrap">
                <table class="ef-table">
                    <thead>
                        <tr>
                            <th>Componente</th>
                            <th>Versione</th>
                            <th>Stato</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cmd in Model.DownloadingPackages)
                        {
                            var (stateCls, stateLabel) = cmd.State switch {
                                CommandState.Downloading    => ("ef-badge-blue", "Download in corso"),
                                CommandState.Received       => ("ef-badge-neutral", "Ricevuto"),
                                CommandState.DownloadFailed => ("ef-badge-danger", "Download fallito"),
                                _                           => ("ef-badge-neutral", cmd.State.ToString())
                            };
                            var isDownloading = cmd.State == CommandState.Downloading;
                            <tr>
                                <td>
                                    <span class="ef-badge @(cmd.Component.Equals("Server", StringComparison.OrdinalIgnoreCase) ? "ef-badge-blue" : "ef-badge-info")">
                                        @cmd.Component
                                    </span>
                                </td>
                                <td><code>@cmd.Version</code></td>
                                <td>
                                    <span class="ef-badge @stateCls @(isDownloading ? "pulse-badge" : "")">
                                        @if (isDownloading) { <i class="bi bi-arrow-repeat me-1 spin"></i> }
                                        @stateLabel
                                    </span>
                                    @if (cmd.State == CommandState.DownloadFailed && !string.IsNullOrEmpty(cmd.ErrorMessage))
                                    {
                                        <div class="text-danger" style="font-size:.72rem;margin-top:2px" title="@cmd.ErrorMessage">
                                            @(cmd.ErrorMessage!.Length > 80 ? cmd.ErrorMessage[..80] + "…" : cmd.ErrorMessage)
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- ── Pronti all'installazione ──────────────────────────────────────── -->
<div class="ef-card mb-4">
    <div class="ef-card-header">
        <i class="bi bi-hourglass-split"></i>
        Pronti all'installazione
        <span class="ef-badge @(Model.ReadyPackages.Count > 0 ? "ef-badge-warning" : "ef-badge-neutral") ms-1">@Model.ReadyPackages.Count</span>
    </div>
    <div class="ef-card-body @(Model.ReadyPackages.Count == 0 ? "" : "p-0")">
        @if (Model.ReadyPackages.Count == 0)
        {
            <span class="ef-badge ef-badge-success"><i class="bi bi-check me-1"></i>Nessun aggiornamento in attesa</span>
        }
        else
        {
            <div class="ef-table-wrap">
                <table class="ef-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Componente</th>
                            <th>Versione</th>
                            <th>Modalità</th>
                            <th>In coda dal</th>
                            <th>File</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (item, idx) in Model.ReadyPackages.Select((p, i) => (p, i)))
                        {
                            <tr>
                                <td><span class="ef-badge ef-badge-neutral">@(idx + 1)</span></td>
                                <td>
                                    <span class="ef-badge @(item.Command.Component.Equals("Server", StringComparison.OrdinalIgnoreCase) ? "ef-badge-blue" : "ef-badge-info")">
                                        @item.Command.Component
                                    </span>
                                </td>
                                <td><code>@item.Command.Version</code></td>
                                <td>
                                    @if (item.IsManualInstall)
                                    {
                                        <span class="ef-badge ef-badge-warning">Manuale 🔒</span>
                                    }
                                    else
                                    {
                                        <span class="ef-badge ef-badge-success">Auto</span>
                                    }
                                </td>
                                <td class="text-muted small">@item.QueuedAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                                <td>
                                    @if (System.IO.File.Exists(item.LocalZipPath))
                                    {
                                        <span class="ef-badge ef-badge-success"><i class="bi bi-check"></i>Su disco</span>
                                    }
                                    else
                                    {
                                        <span class="ef-badge ef-badge-danger"><i class="bi bi-x"></i>Mancante</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- ── Installati ────────────────────────────────────────────────────── -->
<div class="ef-card mb-4">
    <div class="ef-card-header">
        <i class="bi bi-check2-circle"></i>
        Installati
        <span class="ef-badge ef-badge-neutral ms-1">@Model.InstalledPackages.Count</span>
    </div>
    <div class="ef-card-body @(Model.InstalledPackages.Count == 0 ? "" : "p-0")">
        @if (Model.InstalledPackages.Count == 0)
        {
            <p class="text-muted mb-0" style="font-size:.85rem">Nessun pacchetto installato registrato in questa sessione.</p>
        }
        else
        {
            <div class="ef-table-wrap">
                <table class="ef-table">
                    <thead>
                        <tr>
                            <th>Componente</th>
                            <th>Versione</th>
                            <th>Stato</th>
                            <th>Aggiornato</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cmd in Model.InstalledPackages)
                        {
                            var (stateCls, stateLabel) = cmd.State switch {
                                CommandState.Installing => ("ef-badge-warning", "Installazione in corso"),
                                CommandState.Installed  => ("ef-badge-success", "Installato"),
                                CommandState.Failed     => ("ef-badge-danger", "Fallito"),
                                _                       => ("ef-badge-neutral", cmd.State.ToString())
                            };
                            var isInstalling = cmd.State == CommandState.Installing;
                            <tr>
                                <td>
                                    <span class="ef-badge @(cmd.Component.Equals("Server", StringComparison.OrdinalIgnoreCase) ? "ef-badge-blue" : "ef-badge-info")">
                                        @cmd.Component
                                    </span>
                                </td>
                                <td><code>@cmd.Version</code></td>
                                <td>
                                    <span class="ef-badge @stateCls @(isInstalling ? "pulse-badge" : "")">
                                        @if (isInstalling) { <i class="bi bi-arrow-repeat me-1 spin"></i> }
                                        @stateLabel
                                    </span>
                                    @if (cmd.State == CommandState.Failed && !string.IsNullOrEmpty(cmd.ErrorMessage))
                                    {
                                        <div class="text-danger" style="font-size:.72rem;margin-top:2px" title="@cmd.ErrorMessage">
                                            @(cmd.ErrorMessage!.Length > 80 ? cmd.ErrorMessage[..80] + "…" : cmd.ErrorMessage)
                                        </div>
                                    }
                                </td>
                                <td class="text-muted small">
                                    @((cmd.StateChangedAt ?? cmd.ReceivedAt).ToLocalTime().ToString("dd/MM HH:mm:ss"))
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
