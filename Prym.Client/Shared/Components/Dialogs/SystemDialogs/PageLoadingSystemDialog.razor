@namespace Prym.Client.Shared.Components.Dialogs.SystemDialogs
@using MudBlazor
@implements IDisposable

<EFSystemDialog Title="PRYM"
                Subtitle="@State?.Message"
                TopBar="EFSystemDialog.EFTopBar.Primary"
                ShowProgressBar="true"
                ProgressColor="@(State?.ProgressColor ?? Color.Primary)"
                ProgressIndeterminate="@(State?.ProgressValue == null)"
                ProgressValue="@(State?.ProgressValue ?? 0)"
                LogoAnim="@_logoAnim"
                CardWidth="400px">

    @if (State?.ShowProgressLog == true && _progressLog.Count > 0)
    {
        <div class="plsd-log">
            @for (var i = 0; i < _progressLog.Count; i++)
            {
                var logMsg = _progressLog[i];
                var isFirst = i == 0;
                var opacity = isFirst ? "1.0" : i == 1 ? "0.5" : "0.25";
                <div class="plsd-log-row @(isFirst ? "plsd-log-active" : "")"
                     style="opacity:@opacity">
                    <span class="plsd-log-icon">
                        @if (isFirst)
                        {
                            <MudProgressCircular Size="MudBlazor.Size.Small"
                                                 Indeterminate="true"
                                                 Color="Color.Primary"
                                                 Style="width:14px;height:14px;" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircleOutline"
                                     Size="MudBlazor.Size.Small"
                                     Style="color:#66bb6a;font-size:14px;" />
                        }
                    </span>
                    <span class="plsd-log-text @(isFirst ? "plsd-log-text-active" : "")">
                        @logMsg
                    </span>
                </div>
            }
        </div>
    }

    @if (State?.ShowElapsedTime == true)
    {
        var elapsed = (int)(DateTimeOffset.UtcNow - _startTime).TotalSeconds;
        <div class="plsd-elapsed">⏱ @elapsed@(elapsed == 1 ? "s trascorso" : "s trascorsi")</div>
    }

</EFSystemDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public PageLoadingState? State { get; set; }

    private readonly List<string> _progressLog = [];
    private DateTimeOffset _startTime = DateTimeOffset.UtcNow;
    private CancellationTokenSource? _progressCts;
    private System.Threading.Timer? _elapsedTimer;
    private PageLoadingState? _subscribedState;

    private EFSystemDialog.EFLogoAnim _logoAnim => State?.Animation switch
    {
        PageLoadingState.AnimationType.Pulse => EFSystemDialog.EFLogoAnim.Pulse,
        PageLoadingState.AnimationType.Blink => EFSystemDialog.EFLogoAnim.Pulse,
        _ => EFSystemDialog.EFLogoAnim.None
    };

    protected override void OnParametersSet()
    {
        if (State != _subscribedState)
        {
            if (_subscribedState is not null)
                _subscribedState.Changed -= OnStateChanged;

            _subscribedState = State;

            if (_subscribedState is not null)
                _subscribedState.Changed += OnStateChanged;

            RestartTimers();
        }
    }

    private void OnStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void RestartTimers()
    {
        StopProgressTracker();
        StopElapsedTimer();
        _progressLog.Clear();
        _startTime = DateTimeOffset.UtcNow;

        if (State?.ShowProgressLog == true && State.ProgressMessages?.Count > 0)
            StartProgressTracker();

        if (State?.ShowElapsedTime == true)
            StartElapsedTimer();
    }

    private void StartProgressTracker()
    {
        _progressCts = new CancellationTokenSource();
        _ = RunProgressTrackerAsync(_progressCts.Token);
    }

    private async Task RunProgressTrackerAsync(CancellationToken ct)
    {
        if (State?.ProgressMessages is null || State.ProgressMessages.Count == 0) return;
        var msgIndex = 0;
        try
        {
            while (!ct.IsCancellationRequested)
            {
                var msg = State.ProgressMessages[msgIndex % State.ProgressMessages.Count];
                _progressLog.Insert(0, msg);
                if (_progressLog.Count > 3) _progressLog.RemoveAt(3);
                msgIndex++;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(State.ProgressIntervalMs, ct);
            }
        }
        catch (TaskCanceledException) { }
    }

    private void StopProgressTracker()
    {
        _progressCts?.Cancel();
        _progressCts?.Dispose();
        _progressCts = null;
    }

    private void StartElapsedTimer()
    {
        _elapsedTimer = new System.Threading.Timer(_ =>
        {
            _ = InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private void StopElapsedTimer()
    {
        if (_elapsedTimer is not null)
        {
            _elapsedTimer.Change(Timeout.Infinite, Timeout.Infinite);
            _elapsedTimer.Dispose();
            _elapsedTimer = null;
        }
    }

    public void Dispose()
    {
        if (_subscribedState is not null)
            _subscribedState.Changed -= OnStateChanged;

        StopProgressTracker();
        StopElapsedTimer();
    }
}

<style>
    /* ── Progress log panel ── */
    .plsd-log {
        display: flex;
        flex-direction: column;
        gap: 3px;
        margin-top: 2px;
    }

    .plsd-log-row {
        display: flex;
        align-items: center;
        gap: 8px;
        transition: opacity 0.4s ease;
    }

    .plsd-log-active {
        border-left: 2px solid rgba(100, 160, 255, 0.75);
        padding-left: 6px;
        margin-left: -8px;
    }

    .plsd-log-icon {
        flex-shrink: 0;
        width: 16px;
        height: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .plsd-log-text {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.7);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .plsd-log-text-active {
        color: white;
        font-weight: 600;
    }

    /* ── Elapsed time ── */
    .plsd-elapsed {
        color: rgba(255, 255, 255, 0.45);
        font-size: 0.72rem;
        margin-top: 2px;
    }

    @@media (max-width: 480px) {
        .plsd-log-active {
            border-left: none;
            padding-left: 0;
            margin-left: 0;
        }
    }
</style>
