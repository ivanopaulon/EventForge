@*
    Audit History Dialog — EFDialog + EFTable
    Replaced MudAppBar+MudTimeline with EFDialog wrapper and EFTable for better readability.
*@

@using MudBlazor
@using Prym.DTOs.Audit
@inject ITranslationService TranslationService
@inject IAppNotificationService AppNotification

<EFDialog Icon="@Icons.Material.Outlined.History"
          Title="@GetDialogTitle()"
          IsProcessing="@_isLoading"
          MinWidth="min(900px, 95vw)"
          MaxHeight="calc(100vh - 48px)"
          OnClose="CloseDialog">
    <ChildContent>
        <PageLoadingOverlay Visible="@_isLoading"
                            Message="@TranslationService.GetTranslation("audit.loadingHistory", "Caricamento cronologia...")"
                            ShowProgressLog="true"
                            ProgressMessages="@_auditProgressMessages"
                            ShowElapsedTime="true"
                            ProgressIntervalMs="2200" />

        @if (!_isLoading)
        {
            <MudExpansionPanels Elevation="0" Class="mb-3">
                <MudExpansionPanel Text="@TranslationService.GetTranslation("audit.advancedFilters", "Filtri Avanzati")"
                                   Icon="@Icons.Material.Outlined.FilterList"
                                   Dense="true">
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="3">
                            <MudSelect T="string" @bind-Value="_operationFilter" @bind-Value:after="OnFilterChanged"
                                       Label="@TranslationService.GetTranslation("audit.operationType", "Tipo Operazione")"
                                       Variant="Variant.Outlined"
                                       Clearable="true"
                                       Dense="true">
                                <MudSelectItem Value="@("")">@TranslationService.GetTranslation("common.all", "Tutti")</MudSelectItem>
                                <MudSelectItem Value="@("Created")">@TranslationService.GetTranslation("audit.created", "Creato")</MudSelectItem>
                                <MudSelectItem Value="@("Updated")">@TranslationService.GetTranslation("audit.updated", "Modificato")</MudSelectItem>
                                <MudSelectItem Value="@("Deleted")">@TranslationService.GetTranslation("audit.deleted", "Eliminato")</MudSelectItem>
                                <MudSelectItem Value="@("Activated")">@TranslationService.GetTranslation("audit.activated", "Attivato")</MudSelectItem>
                                <MudSelectItem Value="@("Deactivated")">@TranslationService.GetTranslation("audit.deactivated", "Disattivato")</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField @bind-Value="_userFilter" @bind-Value:after="OnFilterChanged"
                                          Label="@TranslationService.GetTranslation("audit.filterByUser", "Filtra per utente")"
                                          Placeholder="@TranslationService.GetTranslation("audit.userPlaceholder", "Nome utente...")"
                                          Variant="Variant.Outlined"
                                          Clearable="true"
                                          Dense="true" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudDatePicker @bind-Date="_fromDate" @bind-Date:after="OnFilterChanged"
                                           Label="@TranslationService.GetTranslation("audit.fromDate", "Da data")"
                                           Variant="Variant.Outlined"
                                           Dense="true" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudDatePicker @bind-Date="_toDate" @bind-Date:after="OnFilterChanged"
                                           Label="@TranslationService.GetTranslation("audit.toDate", "A data")"
                                           Variant="Variant.Outlined"
                                           Dense="true" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_fieldFilter" @bind-Value:after="OnFilterChanged"
                                          Label="@TranslationService.GetTranslation("audit.filterByField", "Filtra per campo")"
                                          Placeholder="@TranslationService.GetTranslation("audit.fieldPlaceholder", "Nome campo modificato...")"
                                          Variant="Variant.Outlined"
                                          Clearable="true"
                                          Dense="true" />
                        </MudItem>
                    </MudGrid>
                    <div class="d-flex justify-end mt-3">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Outlined.Clear"
                                   OnClick="@ClearFilters"
                                   Size="Size.Small">
                            @TranslationService.GetTranslation("audit.clearFilters", "Cancella filtri")
                        </MudButton>
                    </div>
                </MudExpansionPanel>
            </MudExpansionPanels>

            @if (!_filteredAuditLogs.Any())
            {
                <div class="d-flex flex-column align-center justify-center pa-8">
                    <MudIcon Icon="@Icons.Material.Outlined.HistoryToggleOff"
                             Size="Size.Large"
                             Color="Color.Default"
                             Class="mb-4" />
                    <MudText Typo="Typo.h6" Class="mb-2">
                        @(_auditLogs.Any() ?
                            TranslationService.GetTranslation("audit.noMatchingHistory", "Nessuna cronologia corrispondente ai filtri") :
                            TranslationService.GetTranslation("audit.noHistory", "Nessuna cronologia"))
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        @(_auditLogs.Any() ?
                            TranslationService.GetTranslation("audit.noMatchingHistoryDescription", "Modifica i filtri per vedere più risultati.") :
                            TranslationService.GetTranslation("audit.noHistoryDescription", "Non sono state trovate modifiche per questo elemento."))
                    </MudText>
                    @if (_auditLogs.Any())
                    {
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Outlined.Clear"
                                   OnClick="@ClearFilters"
                                   Class="mt-2">
                            @TranslationService.GetTranslation("audit.clearFilters", "Cancella filtri")
                        </MudButton>
                    }
                </div>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="mb-2 mud-text-secondary">
                    @TranslationService.GetTranslationFormatted("audit.showingResults", "Visualizzazione {0} di {1} modifiche", _filteredAuditLogs.Count(), _auditLogs.Count)
                </MudText>

                <EFTable @ref="_auditTable"
                         TItem="AuditLogDto"
                         Items="@_filteredAuditLogs"
                         Dense="true"
                         Hover="true"
                         Striped="true"
                         ShowSearch="false"
                         ShowFilters="false"
                         ShowRefresh="false"
                         ShowCreate="false"
                         ShowExport="false"
                         ShowColumnConfiguration="false"
                         ShowFooter="true"
                         AllowDragDropGrouping="false"
                         ComponentKey="audit-history-dialog-logs"
                         InitialColumnConfigurations="@_auditColumns">
                    <HeaderContent Context="columnConfigurations">
                        <MudTh></MudTh>
                        <MudTh>
                            <MudTableSortLabel SortBy="@(new Func<AuditLogDto, object>(x => x.Timestamp))">
                                @TranslationService.GetTranslation("audit.timestamp", "Timestamp")
                            </MudTableSortLabel>
                        </MudTh>
                        <MudTh>
                            <MudTableSortLabel SortBy="@(new Func<AuditLogDto, object>(x => x.Action))">
                                @TranslationService.GetTranslation("audit.action", "Azione")
                            </MudTableSortLabel>
                        </MudTh>
                        <MudTh>
                            <MudTableSortLabel SortBy="@(new Func<AuditLogDto, object>(x => x.UserName))">
                                @TranslationService.GetTranslation("audit.user", "Utente")
                            </MudTableSortLabel>
                        </MudTh>
                        <MudTh>@TranslationService.GetTranslation("audit.changes", "Modifiche")</MudTh>
                        <MudTh>@TranslationService.GetTranslation("audit.notes", "Note")</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="log">
                        <MudTd>
                            @if (log.Changes?.Any() == true)
                            {
                                <MudIconButton Icon="@(_expandedRows.Contains(log.Id) ? Icons.Material.Outlined.ExpandLess : Icons.Material.Outlined.ExpandMore)"
                                               Size="Size.Small"
                                               OnClick="@(() => ToggleRow(log.Id))"
                                               Title="@TranslationService.GetTranslation("common.details", "Dettagli")" />
                            }
                        </MudTd>
                        <MudTd DataLabel="@TranslationService.GetTranslation("audit.timestamp", "Timestamp")">
                            @log.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")
                        </MudTd>
                        <MudTd DataLabel="@TranslationService.GetTranslation("audit.action", "Azione")">
                            <MudChip T="string"
                                     Color="@GetAuditColor(log.Action)"
                                     Size="Size.Small"
                                     Icon="@GetAuditIcon(log.Action)">
                                @TranslationService.GetTranslation($"audit.action.{log.Action.ToLower()}", log.Action)
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="@TranslationService.GetTranslation("audit.user", "Utente")">
                            @log.UserName
                        </MudTd>
                        <MudTd DataLabel="@TranslationService.GetTranslation("audit.changes", "Modifiche")">
                            @if (log.Changes?.Any() == true)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                    @log.Changes.Count @TranslationService.GetTranslation("audit.fields", "campi")
                                </MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="@TranslationService.GetTranslation("audit.notes", "Note")">
                            <MudText Typo="Typo.body2"
                                     Style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                @log.Notes
                            </MudText>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">
                            @TranslationService.GetTranslation("audit.noHistory", "Nessuna cronologia")
                        </MudText>
                    </NoRecordsContent>
                </EFTable>

                @foreach (var log in _filteredAuditLogs.Where(l => _expandedRows.Contains(l.Id)))
                {
                    <MudPaper Elevation="1" Class="mt-1 mb-2 pa-3">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" Class="mr-1" />
                            @TranslationService.GetTranslation("audit.fieldChanges", "Dettaglio modifiche") — @log.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")
                        </MudText>
                        <MudSimpleTable Dense="true" Bordered="false" Striped="true">
                            <thead>
                                <tr>
                                    <th>@TranslationService.GetTranslation("audit.field", "Campo")</th>
                                    <th>@TranslationService.GetTranslation("audit.oldValue", "Precedente")</th>
                                    <th>@TranslationService.GetTranslation("audit.newValue", "Nuovo")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var change in log.Changes)
                                {
                                    <tr>
                                        <td><strong>@TranslationService.GetTranslation($"field.{change.FieldName.ToLower()}", change.FieldName)</strong></td>
                                        <td><del class="mud-text-secondary">@change.OldValue</del></td>
                                        <td><strong>@change.NewValue</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                }
            }
        }
    </ChildContent>
    <DialogActions>
        <MudIconButton Icon="@Icons.Material.Outlined.Refresh"
                       OnClick="@LoadAuditHistory"
                       Title="@TranslationService.GetTranslation("common.refresh", "Aggiorna")" />
        <MudSpacer />
        <MudButton Variant="Variant.Text" OnClick="CloseDialog" Color="Color.Default">
            @TranslationService.GetTranslation("button.close", "Chiudi")
        </MudButton>
    </DialogActions>
</EFDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private bool _isLoading = false;
    private List<AuditLogDto> _auditLogs = new();
    private HashSet<Guid> _expandedRows = new();
    private EFTable<AuditLogDto> _auditTable = null!;

    private static readonly IReadOnlyList<string> _auditProgressMessages = new[]
    {
        "Recupero cronologia...",
        "Ordinamento eventi...",
        "Preparazione visualizzazione..."
    };

    // Filter state
    private string _operationFilter = string.Empty;
    private string _userFilter = string.Empty;
    private string _fieldFilter = string.Empty;
    private DateTime? _fromDate;
    private DateTime? _toDate;

    private readonly List<EFTableColumnConfiguration> _auditColumns = new()
    {
        new() { PropertyName = "Expand",    DisplayName = "",          Order = 0, IsVisible = true },
        new() { PropertyName = "Timestamp", DisplayName = "Timestamp", Order = 1, IsVisible = true },
        new() { PropertyName = "Action",    DisplayName = "Azione",    Order = 2, IsVisible = true },
        new() { PropertyName = "UserName",  DisplayName = "Utente",    Order = 3, IsVisible = true },
        new() { PropertyName = "Changes",   DisplayName = "Modifiche", Order = 4, IsVisible = true },
        new() { PropertyName = "Notes",     DisplayName = "Note",      Order = 5, IsVisible = true },
    };

    private IEnumerable<AuditLogDto> _filteredAuditLogs =>
        _auditLogs.Where(log =>
            (string.IsNullOrEmpty(_operationFilter) || log.Action.Contains(_operationFilter, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(_userFilter) || log.UserName.Contains(_userFilter, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(_fieldFilter) || log.Changes.Any(c => c.FieldName.Contains(_fieldFilter, StringComparison.OrdinalIgnoreCase))) &&
            (!_fromDate.HasValue || log.Timestamp >= _fromDate.Value) &&
            (!_toDate.HasValue || log.Timestamp <= _toDate.Value.AddDays(1))
        ).OrderByDescending(l => l.Timestamp);

    [Parameter] public string EntityType { get; set; } = string.Empty;
    [Parameter] public Guid? EntityId { get; set; }
    [Parameter] public string EntityName { get; set; } = string.Empty;

    private string GetDialogTitle()
    {
        var title = TranslationService.GetTranslation("audit.historyDialog.title", "Cronologia Modifiche");
        if (!string.IsNullOrEmpty(EntityName))
            title += $" — {EntityType}: {EntityName}";
        return title;
    }

    private void ToggleRow(Guid id)
    {
        if (!_expandedRows.Add(id))
            _expandedRows.Remove(id);
        StateHasChanged();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (EntityId.HasValue && MudDialog != null)
        {
            await LoadAuditHistory();
        }
    }

    private async Task LoadAuditHistory()
    {
        if (!EntityId.HasValue) return;

        try
        {
            _isLoading = true;
            _expandedRows.Clear();
            StateHasChanged();

            // TODO: Replace with actual audit service call when implemented
            await Task.Delay(1000);

            _auditLogs = new List<AuditLogDto>
            {
                new AuditLogDto
                {
                    Id = Guid.NewGuid(),
                    EntityType = EntityType,
                    EntityId = EntityId.Value,
                    Action = "Created",
                    Timestamp = DateTime.Now.AddDays(-7),
                    UserName = "admin@example.com",
                    Notes = "Entity created during system initialization",
                    Changes = new List<AuditFieldChangeDto>
                    {
                        new AuditFieldChangeDto { FieldName = "Name", OldValue = "", NewValue = EntityName },
                        new AuditFieldChangeDto { FieldName = "Status", OldValue = "", NewValue = "Active" },
                        new AuditFieldChangeDto { FieldName = "CreatedAt", OldValue = "", NewValue = DateTime.Now.AddDays(-7).ToString("yyyy-MM-dd HH:mm:ss") }
                    }
                },
                new AuditLogDto
                {
                    Id = Guid.NewGuid(),
                    EntityType = EntityType,
                    EntityId = EntityId.Value,
                    Action = "Updated",
                    Timestamp = DateTime.Now.AddDays(-3),
                    UserName = "user@example.com",
                    Notes = "Details updated by user request",
                    Changes = new List<AuditFieldChangeDto>
                    {
                        new AuditFieldChangeDto { FieldName = "Description", OldValue = "Old description", NewValue = "Updated description with more details" },
                        new AuditFieldChangeDto { FieldName = "ModifiedAt", OldValue = DateTime.Now.AddDays(-7).ToString("yyyy-MM-dd HH:mm:ss"), NewValue = DateTime.Now.AddDays(-3).ToString("yyyy-MM-dd HH:mm:ss") }
                    }
                },
                new AuditLogDto
                {
                    Id = Guid.NewGuid(),
                    EntityType = EntityType,
                    EntityId = EntityId.Value,
                    Action = "Activated",
                    Timestamp = DateTime.Now.AddHours(-6),
                    UserName = "manager@example.com",
                    Notes = "Activated after review completion",
                    Changes = new List<AuditFieldChangeDto>
                    {
                        new AuditFieldChangeDto { FieldName = "IsActive", OldValue = "false", NewValue = "true" },
                        new AuditFieldChangeDto { FieldName = "ActivatedBy", OldValue = "", NewValue = "manager@example.com" }
                    }
                }
            };
        }
        catch (Exception ex)
        {
            AppNotification.ShowError(TranslationService.GetTranslationFormatted("error.loadAuditHistory",
                "Errore nel caricamento della cronologia: {0}", ex.Message));
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnFilterChanged()
    {
        await Task.CompletedTask;
        StateHasChanged();
    }

    private async Task ClearFilters()
    {
        _operationFilter = string.Empty;
        _userFilter = string.Empty;
        _fieldFilter = string.Empty;
        _fromDate = null;
        _toDate = null;
        await Task.CompletedTask;
        StateHasChanged();
    }

    private void CloseDialog()
    {
        MudDialog.Close();
    }

    private Color GetAuditColor(string action)
    {
        return action?.ToLower() switch
        {
            "created" => Color.Success,
            "updated" => Color.Primary,
            "deleted" => Color.Error,
            "activated" => Color.Success,
            "deactivated" => Color.Warning,
            _ => Color.Default
        };
    }

    private string GetAuditIcon(string action)
    {
        return action?.ToLower() switch
        {
            "created" => Icons.Material.Outlined.Add,
            "updated" => Icons.Material.Outlined.Edit,
            "deleted" => Icons.Material.Outlined.Delete,
            "activated" => Icons.Material.Filled.CheckCircle,
            "deactivated" => Icons.Material.Filled.Cancel,
            _ => Icons.Material.Filled.Circle
        };
    }

    public class AuditLogDto
    {
        public Guid Id { get; set; }
        public string EntityType { get; set; } = string.Empty;
        public Guid EntityId { get; set; }
        public string Action { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; }
        public string UserName { get; set; } = string.Empty;
        public string Notes { get; set; } = string.Empty;
        public List<AuditFieldChangeDto> Changes { get; set; } = new();
    }

    public class AuditFieldChangeDto
    {
        public string FieldName { get; set; } = string.Empty;
        public string OldValue { get; set; } = string.Empty;
        public string NewValue { get; set; } = string.Empty;
    }
}
