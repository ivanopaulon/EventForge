<div class="management-page-header">
    <!-- Top row: icon + title (left), ExtraActions (right) -->
    <div class="d-flex align-center justify-space-between flex-wrap gap-2">
        <div class="d-flex align-center gap-2 flex-wrap">
            <MudIcon Icon="@Icon" Color="@IconColor" Size="Size.Small" />
            <MudText Typo="@TitleTypo" Class="management-page-header-title">@Title</MudText>
        </div>
        @if (ExtraActions != null)
        {
            <div class="d-flex align-center gap-1 flex-wrap">
                @ExtraActions
            </div>
        }
    </div>

    <!-- Breadcrumb row -->
    @if (BreadcrumbItems != null && BreadcrumbItems.Count > 0)
    {
        <MudBreadcrumbs Items="BreadcrumbItems" Class="pa-0 management-page-header-breadcrumbs" />
    }

    <!-- Optional sub-content (subtitle, description, etc.) -->
    @if (SubContent != null)
    {
        <div class="management-page-header-subcontent">
            @SubContent
        </div>
    }

    <MudDivider Class="mt-1" />
</div>

@code {
    /// <summary>Page title text. Required.</summary>
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;

    /// <summary>Icon identifier (e.g. Icons.Material.Outlined.Percent). Required.</summary>
    [Parameter, EditorRequired] public string Icon { get; set; } = string.Empty;

    /// <summary>Color of the icon. Default: Primary.</summary>
    [Parameter] public Color IconColor { get; set; } = Color.Primary;

    /// <summary>Typography variant for the title. Default: h6.</summary>
    [Parameter] public Typo TitleTypo { get; set; } = Typo.h6;

    /// <summary>Optional breadcrumb navigation items shown below the title.</summary>
    [Parameter] public List<BreadcrumbItem>? BreadcrumbItems { get; set; }

    /// <summary>Optional slot for extra action buttons displayed to the right of the title row.</summary>
    [Parameter] public RenderFragment? ExtraActions { get; set; }

    /// <summary>Optional slot for additional content rendered below the title row (e.g. subtitle, description).</summary>
    [Parameter] public RenderFragment? SubContent { get; set; }
}
