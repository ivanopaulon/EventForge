@page "/management/analytics"
@using Microsoft.AspNetCore.Authorization
@using Prym.DTOs.Analytics
@using Prym.Client.Shared.Components
@using MudBlazor
@attribute [Authorize]
@inject IAnalyticsService AnalyticsService
@inject IAuthService AuthService
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject ILogger<AnalyticsDashboard> Logger

<PageTitle>@TranslationService.GetTranslation("analytics.title", "Analytics & Reportistica")</PageTitle>
<PageLoadingOverlay Visible="_isLoading"
                    Message="@TranslationService.GetTranslation("messages.loadingPage", "Caricamento pagina...")" />

@if (!_isLoading)
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">
        <MudText Typo="Typo.h4" Class="mb-4">
            @TranslationService.GetTranslation("analytics.title", "Analytics & Reportistica")
        </MudText>

        <!-- Filter bar -->
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <!-- Quick period presets -->
            <MudStack Row="true" Spacing="1" Class="mb-3" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="align-self-center mr-2">
                    @TranslationService.GetTranslation("analytics.quickPeriod", "Periodo rapido:")
                </MudText>
                <MudButton Variant="@(_activePeriod == "today" ? Variant.Filled : Variant.Outlined)"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="@(() => SetQuickPeriod("today"))">
                    @TranslationService.GetTranslation("analytics.period.today", "Oggi")
                </MudButton>
                <MudButton Variant="@(_activePeriod == "7d" ? Variant.Filled : Variant.Outlined)"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="@(() => SetQuickPeriod("7d"))">
                    @TranslationService.GetTranslation("analytics.period.last7days", "Ultimi 7gg")
                </MudButton>
                <MudButton Variant="@(_activePeriod == "30d" ? Variant.Filled : Variant.Outlined)"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="@(() => SetQuickPeriod("30d"))">
                    @TranslationService.GetTranslation("analytics.period.last30days", "Ultimi 30gg")
                </MudButton>
                <MudButton Variant="@(_activePeriod == "6m" ? Variant.Filled : Variant.Outlined)"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="@(() => SetQuickPeriod("6m"))">
                    @TranslationService.GetTranslation("analytics.period.last6months", "Ultimi 6 mesi")
                </MudButton>
                <MudButton Variant="@(_activePeriod == "custom" ? Variant.Filled : Variant.Outlined)"
                           Color="Color.Secondary"
                           Size="Size.Small"
                           OnClick="@(() => _activePeriod = "custom")">
                    @TranslationService.GetTranslation("analytics.period.custom", "Personalizzato")
                </MudButton>
            </MudStack>

            <MudDivider Class="mb-3" />

            <MudGrid Spacing="2" AlignItems="Center">
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Label="@TranslationService.GetTranslation("analytics.dateFrom", "Data inizio")"
                                   Date="_filter.DateFrom"
                                   DateChanged="@(v => { _filter.DateFrom = v; _activePeriod = "custom"; })"
                                   DateFormat="dd/MM/yyyy"
                                   Clearable="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Label="@TranslationService.GetTranslation("analytics.dateTo", "Data fine")"
                                   Date="_filter.DateTo"
                                   DateChanged="@(v => { _filter.DateTo = v; _activePeriod = "custom"; })"
                                   DateFormat="dd/MM/yyyy"
                                   Clearable="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudSelect T="string" Label="@TranslationService.GetTranslation("analytics.groupBy", "Raggruppa per")"
                               @bind-Value="_filter.GroupBy">
                        <MudSelectItem Value="@("month")">@TranslationService.GetTranslation("analytics.groupBy.month", "Mese")</MudSelectItem>
                        <MudSelectItem Value="@("week")">@TranslationService.GetTranslation("analytics.groupBy.week", "Settimana")</MudSelectItem>
                        <MudSelectItem Value="@("day")">@TranslationService.GetTranslation("analytics.groupBy.day", "Giorno")</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudSelect T="int" Label="@TranslationService.GetTranslation("analytics.top", "Top N")"
                               @bind-Value="_topValue">
                        <MudSelectItem Value="5">Top 5</MudSelectItem>
                        <MudSelectItem Value="10">Top 10</MudSelectItem>
                        <MudSelectItem Value="20">Top 20</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="@LoadDataAsync"
                               Disabled="_isLoadingData"
                               FullWidth="true">
                        @TranslationService.GetTranslation("common.refresh", "Aggiorna")
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (_isLoadingData)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
        }

        <!-- Tabs -->
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

            <!-- Tab 1: Vendite -->
            <MudTabPanel Text="@TranslationService.GetTranslation("analytics.tab.sales", "Vendite")"
                         Icon="@Icons.Material.Filled.TrendingUp">
                @if (_salesData is null)
                {
                    <MudText Color="Color.Secondary" Class="mt-4">
                        @TranslationService.GetTranslation("analytics.noData", "Nessun dato disponibile")
                    </MudText>
                }
                else
                {
                    <!-- KPI Cards -->
                    <MudGrid Spacing="3" Class="mb-4">
                        <MudItem xs="12" sm="4">
                            <MudPaper Elevation="2" Class="pa-4">
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("analytics.sales.totalRevenue", "Fatturato Totale")
                                </MudText>
                                <MudText Typo="Typo.h5">@_salesData.TotalRevenue.ToString("N2")</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudPaper Elevation="2" Class="pa-4">
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("analytics.sales.totalDocuments", "N. Documenti")
                                </MudText>
                                <MudText Typo="Typo.h5">@_salesData.TotalDocuments</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudPaper Elevation="2" Class="pa-4">
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("analytics.sales.avgOrderValue", "Valore Medio Ordine")
                                </MudText>
                                <MudText Typo="Typo.h5">@_salesData.AverageOrderValue.ToString("N2")</MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    <!-- Sales trend chart -->
                    @if (_salesSeries.Count > 0)
                    {
                        <MudPaper Elevation="1" Class="pa-4 mb-4">
                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                @TranslationService.GetTranslation("analytics.sales.trendChart", "Trend Vendite")
                            </MudText>
                            <MudChart T="double" ChartType="ChartType.Line"
                                      ChartSeries="@_salesSeries"
                                      ChartLabels="@_salesLabels"
                                      Width="100%" Height="300px" />
                        </MudPaper>
                    }

                    <!-- Top products table -->
                    @if (_salesData.TopProducts.Count > 0)
                    {
                        <MudPaper Elevation="1" Class="pa-4">
                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                @TranslationService.GetTranslation("analytics.sales.topProducts", "Top Prodotti")
                            </MudText>
                            <MudSimpleTable Dense="true" Hover="true">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>@TranslationService.GetTranslation("analytics.product", "Prodotto")</th>
                                        <th>@TranslationService.GetTranslation("analytics.quantity", "Quantità")</th>
                                        <th>@TranslationService.GetTranslation("analytics.revenue", "Fatturato")</th>
                                        <th>@TranslationService.GetTranslation("analytics.discount", "Sconto")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in _salesData.TopProducts)
                                    {
                                        <tr>
                                            <td>@p.Rank</td>
                                            <td>@p.ProductName</td>
                                            <td>@p.TotalQuantity.ToString("N2")</td>
                                            <td>@p.TotalRevenue.ToString("N2")</td>
                                            <td>@p.TotalDiscount.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                    }
                    else
                    {
                        <MudText Color="Color.Secondary">
                            @TranslationService.GetTranslation("analytics.noData", "Nessun dato disponibile")
                        </MudText>
                    }
                }
            </MudTabPanel>

            <!-- Tab 2: Promozioni -->
            <MudTabPanel Text="@TranslationService.GetTranslation("analytics.tab.promotions", "Promozioni")"
                         Icon="@Icons.Material.Filled.LocalOffer">
                @if (_promotionData is null)
                {
                    <MudText Color="Color.Secondary" Class="mt-4">
                        @TranslationService.GetTranslation("analytics.noData", "Nessun dato disponibile")
                    </MudText>
                }
                else
                {
                    <!-- KPI Cards -->
                    <MudGrid Spacing="3" Class="mb-4">
                        <MudItem xs="12" sm="4">
                            <MudPaper Elevation="2" Class="pa-4">
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("analytics.promotions.active", "Promozioni Attive")
                                </MudText>
                                <MudText Typo="Typo.h5">@_promotionData.TotalActivePromotions</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudPaper Elevation="2" Class="pa-4">
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("analytics.promotions.usesThisMonth", "Utilizzi Questo Mese")
                                </MudText>
                                <MudText Typo="Typo.h5">@_promotionData.TotalUsesThisMonth</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudPaper Elevation="2" Class="pa-4">
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("analytics.promotions.totalDiscount", "Sconto Totale Erogato")
                                </MudText>
                                <MudText Typo="Typo.h5">@_promotionData.TotalDiscountThisMonth.ToString("N2")</MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    <!-- Usage trend chart -->
                    @if (_promotionSeries.Count > 0)
                    {
                        <MudPaper Elevation="1" Class="pa-4 mb-4">
                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                @TranslationService.GetTranslation("analytics.promotions.usageTrend", "Trend Utilizzi Mensili")
                            </MudText>
                            <MudChart T="double" ChartType="ChartType.Bar"
                                      ChartSeries="@_promotionSeries"
                                      ChartLabels="@_promotionLabels"
                                      Width="100%" Height="300px" />
                        </MudPaper>
                    }

                    <!-- Top promotions table -->
                    @if (_promotionData.TopPromotions.Count > 0)
                    {
                        <MudPaper Elevation="1" Class="pa-4">
                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                @TranslationService.GetTranslation("analytics.promotions.topPromotions", "Top Promozioni")
                            </MudText>
                            <MudSimpleTable Dense="true" Hover="true">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>@TranslationService.GetTranslation("analytics.name", "Nome")</th>
                                        <th>@TranslationService.GetTranslation("analytics.uses", "Utilizzi")</th>
                                        <th>@TranslationService.GetTranslation("analytics.totalSavings", "Risparmio Totale")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in _promotionData.TopPromotions)
                                    {
                                        <tr>
                                            <td>@p.Rank</td>
                                            <td>@p.PromotionName</td>
                                            <td>@p.UsageCount</td>
                                            <td>@p.TotalSavings.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                    }
                    else
                    {
                        <MudText Color="Color.Secondary">
                            @TranslationService.GetTranslation("analytics.noData", "Nessun dato disponibile")
                        </MudText>
                    }
                }
            </MudTabPanel>

            <!-- Tab 3: Pricing -->
            <MudTabPanel Text="@TranslationService.GetTranslation("analytics.tab.pricing", "Pricing")"
                         Icon="@Icons.Material.Filled.PriceCheck">
                @if (_pricingData is null)
                {
                    <MudText Color="Color.Secondary" Class="mt-4">
                        @TranslationService.GetTranslation("analytics.noData", "Nessun dato disponibile")
                    </MudText>
                }
                else
                {
                    <!-- KPI Cards -->
                    <MudGrid Spacing="3" Class="mb-4">
                        <MudItem xs="12" sm="6">
                            <MudPaper Elevation="2" Class="pa-4">
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("analytics.pricing.manualOverrides", "Override Manuali Totali")
                                </MudText>
                                <MudText Typo="Typo.h5">@_pricingData.TotalManualOverrides</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudPaper Elevation="2" Class="pa-4">
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("analytics.pricing.automaticPercentage", "% Pricing Automatico")
                                </MudText>
                                <MudText Typo="Typo.h5">@_pricingData.AutomaticPricingPercentage.ToString("N1")%</MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    <!-- Manual overrides trend chart -->
                    @if (_pricingSeries.Count > 0)
                    {
                        <MudPaper Elevation="1" Class="pa-4 mb-4">
                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                @TranslationService.GetTranslation("analytics.pricing.overrideTrend", "Trend Override Manuali")
                            </MudText>
                            <MudChart T="double" ChartType="ChartType.Line"
                                      ChartSeries="@_pricingSeries"
                                      ChartLabels="@_pricingLabels"
                                      Width="100%" Height="300px" />
                        </MudPaper>
                    }

                    <!-- Top price lists table -->
                    @if (_pricingData.TopPriceLists.Count > 0)
                    {
                        <MudPaper Elevation="1" Class="pa-4">
                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                @TranslationService.GetTranslation("analytics.pricing.topPriceLists", "Top Listini Usati")
                            </MudText>
                            <MudSimpleTable Dense="true" Hover="true">
                                <thead>
                                    <tr>
                                        <th>@TranslationService.GetTranslation("analytics.priceList", "Listino")</th>
                                        <th>@TranslationService.GetTranslation("analytics.timesApplied", "Volte Applicato")</th>
                                        <th>@TranslationService.GetTranslation("analytics.documentCount", "N. Documenti")</th>
                                        <th>@TranslationService.GetTranslation("analytics.avgDiscount", "Sconto Medio")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pl in _pricingData.TopPriceLists)
                                    {
                                        <tr>
                                            <td>@pl.PriceListName</td>
                                            <td>@pl.TimesApplied</td>
                                            <td>@pl.DocumentCount</td>
                                            <td>@pl.AverageDiscount.ToString("N1")%</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                    }
                    else
                    {
                        <MudText Color="Color.Secondary">
                            @TranslationService.GetTranslation("analytics.noData", "Nessun dato disponibile")
                        </MudText>
                    }
                }
            </MudTabPanel>

        </MudTabs>
    </MudContainer>
}

@code {
    private bool _isLoading = true;
    private bool _isLoadingData;
    private string _activePeriod = "6m";

    private AnalyticsFilterDto _filter = new()
    {
        DateFrom = DateTime.Today.AddMonths(-6),
        DateTo = DateTime.Today,
        GroupBy = "month",
        Top = 10
    };

    private int _topValue = 10;

    private SalesAnalyticsDashboardDto? _salesData;
    private PromotionAnalyticsDashboardDto? _promotionData;
    private PricingAnalyticsDashboardDto? _pricingData;

    // Chart series and labels
    private List<ChartSeries<double>> _salesSeries = new();
    private string[] _salesLabels = Array.Empty<string>();

    private List<ChartSeries<double>> _promotionSeries = new();
    private string[] _promotionLabels = Array.Empty<string>();

    private List<ChartSeries<double>> _pricingSeries = new();
    private string[] _pricingLabels = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user is null)
            {
                Logger.LogWarning("Unauthenticated access attempt to Analytics Dashboard");
                return;
            }

            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during Analytics Dashboard initialization");
            AppNotification.ShowError(TranslationService.GetTranslation("errors.loadFailed", "Errore durante il caricamento dei dati"));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadDataAsync()
    {
        if (_isLoadingData)
            return;

        _isLoadingData = true;
        _filter.Top = _topValue;

        try
        {
            var (sales, promotions, pricing) = await LoadAllDataAsync(_filter);

            _salesData = sales;
            _promotionData = promotions;
            _pricingData = pricing;

            BuildChartData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading analytics data");
            AppNotification.ShowError(TranslationService.GetTranslation("errors.loadFailed", "Errore durante il caricamento dei dati"));
        }
        finally
        {
            _isLoadingData = false;
            StateHasChanged();
        }
    }

    private async Task<(SalesAnalyticsDashboardDto?, PromotionAnalyticsDashboardDto?, PricingAnalyticsDashboardDto?)> LoadAllDataAsync(AnalyticsFilterDto filter)
    {
        using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
        var ct = cts.Token;

        var salesTask = AnalyticsService.GetSalesAnalyticsAsync(filter, ct);
        var promotionsTask = AnalyticsService.GetPromotionAnalyticsAsync(filter, ct);
        var pricingTask = AnalyticsService.GetPricingAnalyticsAsync(filter, ct);

        await Task.WhenAll(salesTask, promotionsTask, pricingTask);

        return (salesTask.Result, promotionsTask.Result, pricingTask.Result);
    }

    private void BuildChartData()
    {
        BuildSalesChartData();
        BuildPromotionChartData();
        BuildPricingChartData();
    }

    private void BuildSalesChartData()
    {
        if (_salesData?.SalesTrend is null || _salesData.SalesTrend.Count == 0)
        {
            _salesSeries = new();
            _salesLabels = Array.Empty<string>();
            return;
        }

        _salesLabels = _salesData.SalesTrend.Select(p => p.Date).ToArray();
        _salesSeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double>
            {
                Name = TranslationService.GetTranslation("analytics.sales.totalRevenue", "Fatturato"),
                Data = new ChartData<double>(_salesData.SalesTrend.Select(p => (double)p.TotalAmount).ToArray())
            }
        };
    }

    private void BuildPromotionChartData()
    {
        if (_promotionData?.UsageTrend is null || _promotionData.UsageTrend.Count == 0)
        {
            _promotionSeries = new();
            _promotionLabels = Array.Empty<string>();
            return;
        }

        _promotionLabels = _promotionData.UsageTrend.Select(p => p.Date).ToArray();
        _promotionSeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double>
            {
                Name = TranslationService.GetTranslation("analytics.uses", "Utilizzi"),
                Data = new ChartData<double>(_promotionData.UsageTrend.Select(p => (double)p.UsageCount).ToArray())
            }
        };
    }

    private void BuildPricingChartData()
    {
        if (_pricingData?.ManualOverridesTrend is null || _pricingData.ManualOverridesTrend.Count == 0)
        {
            _pricingSeries = new();
            _pricingLabels = Array.Empty<string>();
            return;
        }

        _pricingLabels = _pricingData.ManualOverridesTrend.Select(p => p.Date).ToArray();
        _pricingSeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double>
            {
                Name = TranslationService.GetTranslation("analytics.pricing.manualOverrides", "Override Manuali"),
                Data = new ChartData<double>(_pricingData.ManualOverridesTrend.Select(p => (double)p.Count).ToArray())
            }
        };
    }

    /// <summary>Sets a quick period preset and updates the filter dates.</summary>
    private void SetQuickPeriod(string period)
    {
        _activePeriod = period;
        var today = DateTime.Today;
        // All ranges are inclusive: DateFrom..DateTo, so "7 days" = today-6 days through today (7 days total).
        (_filter.DateFrom, _filter.DateTo) = period switch
        {
            "today" => ((DateTime?)today,               (DateTime?)today),
            "7d"    => ((DateTime?)today.AddDays(-6),   (DateTime?)today),
            "30d"   => ((DateTime?)today.AddDays(-29),  (DateTime?)today),
            "6m"    => ((DateTime?)today.AddMonths(-6), (DateTime?)today),
            _       => (_filter.DateFrom, _filter.DateTo)
        };
    }
}
