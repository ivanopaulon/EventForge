@page "/management/promotions/new"
@using Microsoft.AspNetCore.Authorization
@using Prym.DTOs.Promotions
@using Prym.Client.Shared.Components
@using MudBlazor
@attribute [Authorize]
@inject IPromotionClientService PromotionService
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject IAppNotificationService AppNotification
@inject ITranslationService TranslationService
@inject ILogger<PromotionNew> Logger

<PageTitle>@TranslationService.GetTranslation("promotion.new", "Nuova Promozione")</PageTitle>
<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <PageLoadingOverlay Visible="_isLoading || _isSaving"
                        Message="@(_isSaving ? TranslationService.GetTranslation("common.saving", "Salvataggio...") : TranslationService.GetTranslation("messages.loadingPage", "Caricamento pagina..."))" />

    @if (!_isLoading)
    {
        <!-- Breadcrumb -->
        <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2" />

        <!-- Page Header -->
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <div class="d-flex justify-space-between align-center flex-wrap gap-2">
                <div class="d-flex align-center gap-2">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                   Color="Color.Primary"
                                   OnClick="@(() => NavigationManager.NavigateTo("/management/promotions"))"
                                   Size="Size.Medium"
                                   title="@TranslationService.GetTranslation("promotion.backToList", "Torna a Promozioni")" />
                    <MudText Typo="Typo.h5">
                        <MudIcon Icon="@Icons.Material.Outlined.AddCircleOutline" Class="mr-2" />
                        @TranslationService.GetTranslation("promotion.create", "Nuova Promozione")
                    </MudText>
                </div>
            </div>
        </MudPaper>

        <!-- Form -->
        <MudPaper Elevation="2" Class="pa-4">
            <EditForm Model="_model" OnValidSubmit="CreatePromotion">
                <DataAnnotationsValidator />
                <MudGrid Spacing="3">

                    <!-- Main fields -->
                    <MudItem xs="12" md="8">
                        <MudPaper Elevation="0" Class="pa-4">
                            <MudGrid Spacing="3">

                                <!-- Nome -->
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="_model.Name"
                                                  Label="@($"{TranslationService.GetTranslation("field.name", "Nome")} *")"
                                                  Variant="Variant.Outlined"
                                                  Required="true"
                                                  MaxLength="100"
                                                  Class="ef-input" />
                                    <ValidationMessage For="() => _model.Name" />
                                </MudItem>

                                <!-- Descrizione -->
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="_model.Description"
                                                  Label="@TranslationService.GetTranslation("field.description", "Descrizione")"
                                                  Variant="Variant.Outlined"
                                                  Lines="3"
                                                  MaxLength="500"
                                                  Class="ef-input" />
                                </MudItem>

                                <!-- Date inizio / fine -->
                                <MudItem xs="12" md="6">
                                    <MudDatePicker @bind-Date="_startDate"
                                                   Label="@($"{TranslationService.GetTranslation("field.startDate", "Data Inizio")} *")"
                                                   Variant="Variant.Outlined"
                                                   DateFormat="dd/MM/yyyy"
                                                   Required="true" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudDatePicker @bind-Date="_endDate"
                                                   Label="@($"{TranslationService.GetTranslation("field.endDate", "Data Fine")} *")"
                                                   Variant="Variant.Outlined"
                                                   DateFormat="dd/MM/yyyy"
                                                   Required="true" />
                                </MudItem>

                                @if (_dateError)
                                {
                                    <MudItem xs="12">
                                        <MudAlert Severity="Severity.Error" Dense="true">
                                            @TranslationService.GetTranslation("validation.endDateAfterStart", "La data di fine deve essere successiva alla data di inizio")
                                        </MudAlert>
                                    </MudItem>
                                }

                                <!-- Priorità -->
                                <MudItem xs="12" md="6">
                                    <MudNumericField @bind-Value="_model.Priority"
                                                     Label="@TranslationService.GetTranslation("field.priority", "Priorità")"
                                                     Variant="Variant.Outlined"
                                                     Min="0"
                                                     Class="ef-numeric"
                                                     HelperText="@TranslationService.GetTranslation("promotion.priorityHint", "Valore più alto = maggiore priorità")" />
                                </MudItem>

                                <!-- Max Utilizzi -->
                                <MudItem xs="12" md="6">
                                    <MudNumericField @bind-Value="_model.MaxUses"
                                                     Label="@TranslationService.GetTranslation("field.maxUses", "Max Utilizzi")"
                                                     Variant="Variant.Outlined"
                                                     Placeholder="@TranslationService.GetTranslation("promotion.unlimited", "Illimitato")"
                                                     Class="ef-numeric"
                                                     HelperText="@TranslationService.GetTranslation("promotion.maxUsesHint", "Lasciare vuoto per utilizzi illimitati")" />
                                </MudItem>

                                <!-- Codice Coupon -->
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_model.CouponCode"
                                                  Label="@TranslationService.GetTranslation("field.couponCode", "Codice Coupon")"
                                                  Variant="Variant.Outlined"
                                                  MaxLength="50"
                                                  Class="ef-input"
                                                  HelperText="@TranslationService.GetTranslation("promotion.couponHint", "Facoltativo: richiede inserimento del codice per attivare")" />
                                </MudItem>

                                <!-- Importo Minimo Ordine -->
                                <MudItem xs="12" md="6">
                                    <MudNumericField @bind-Value="_model.MinOrderAmount"
                                                     Label="@TranslationService.GetTranslation("field.minOrderAmount", "Importo Minimo Ordine")"
                                                     Variant="Variant.Outlined"
                                                     Format="F2"
                                                     Adornment="Adornment.Start"
                                                     AdornmentText="€"
                                                     Class="ef-numeric" />
                                </MudItem>

                                <!-- Combinabile -->
                                <MudItem xs="12">
                                    <MudSwitch @bind-Value="_model.IsCombinable"
                                               Label="@TranslationService.GetTranslation("field.isCombinable", "Combinabile con altre promozioni")"
                                               Color="Color.Info" />
                                </MudItem>

                            </MudGrid>
                        </MudPaper>
                    </MudItem>

                    <!-- Right: action buttons and info -->
                    <MudItem xs="12" md="4">
                        <MudStack Spacing="2">
                            <MudButton ButtonType="ButtonType.Submit"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       FullWidth="true"
                                       Disabled="_isSaving">
                                @TranslationService.GetTranslation("promotion.create", "Crea Promozione")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       StartIcon="@Icons.Material.Outlined.Cancel"
                                       FullWidth="true"
                                       OnClick="@(() => NavigationManager.NavigateTo("/management/promotions"))">
                                @TranslationService.GetTranslation("common.cancel", "Annulla")
                            </MudButton>

                            <MudPaper Elevation="1" Class="pa-3 mt-2">
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Class="mr-1" />
                                    @TranslationService.GetTranslation("promotion.createNote.title", "Nota")
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @TranslationService.GetTranslation("promotion.createNote.body", "Le regole di applicazione della promozione (tipo sconto, prodotti coinvolti, ecc.) potranno essere configurate nella pagina di dettaglio dopo la creazione.")
                                </MudText>
                            </MudPaper>
                        </MudStack>
                    </MudItem>

                </MudGrid>
            </EditForm>
        </MudPaper>
    }
</MudContainer>

@code {
    private bool _isLoading = true;
    private bool _isSaving;

    private CreatePromotionDto _model = new()
    {
        StartDate = DateTime.Today,
        EndDate = DateTime.Today.AddMonths(1),
        Priority = 0,
        IsCombinable = true
    };

    private DateTime? _startDate;
    private DateTime? _endDate;
    private List<BreadcrumbItem> _breadcrumbs = new();

    private bool _dateError => _startDate.HasValue && _endDate.HasValue && _endDate.Value < _startDate.Value;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var isAuthenticated = await AuthService.IsAuthenticatedAsync();
            if (!isAuthenticated)
            {
                NavigationManager.NavigateTo("/login");
                return;
            }

            _startDate = _model.StartDate;
            _endDate = _model.EndDate;

            _breadcrumbs = new List<BreadcrumbItem>
            {
                new(TranslationService.GetTranslation("nav.home", "Home"), href: "/"),
                new(TranslationService.GetTranslation("nav.management", "Gestione"), href: null, disabled: true),
                new(TranslationService.GetTranslation("nav.promotions", "Promozioni"), href: "/management/promotions"),
                new(TranslationService.GetTranslation("promotion.create", "Nuova Promozione"), href: null, disabled: true)
            };
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing PromotionNew page");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CreatePromotion()
    {
        if (_dateError) return;

        if (_startDate.HasValue)
            _model.StartDate = _startDate.Value;
        if (_endDate.HasValue)
            _model.EndDate = _endDate.Value;

        _isSaving = true;
        try
        {
            var created = await PromotionService.CreateAsync(_model);
            AppNotification.ShowSuccess(TranslationService.GetTranslationFormatted("promotion.created",
                    "Promozione '{0}' creata con successo.", created.Name));
            NavigationManager.NavigateTo($"/management/promotions/{created.Id}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating promotion");
            AppNotification.ShowError(TranslationService.GetTranslation("promotion.createError", "Errore durante la creazione della promozione"));
        }
        finally
        {
            _isSaving = false;
        }
    }
}
