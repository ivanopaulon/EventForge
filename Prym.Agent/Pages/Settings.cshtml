@page
@model SettingsModel
@{
    ViewData["Title"] = "Impostazioni";
    ViewData["PageSection"] = "Agent";
    ViewData["InstallationId"] = Model.Options.InstallationId;
    ViewData["InstallationName"] = Model.Options.InstallationName;
}

<!-- Page header -->
<div class="ef-page-header">
    <div class="ef-page-title">
        <div class="ef-page-title-icon settings"><i class="bi bi-sliders"></i></div>
        <div>
            <h1>Impostazioni</h1>
            <p class="ef-page-subtitle">Configurazione dell'agent — le modifiche richiedono riavvio del servizio</p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <form method="post" asp-page-handler="ReRegister">
            <button type="submit" class="btn btn-outline-secondary btn-sm"
                    onclick="return confirm('Ri-registra questa installazione all\'Hub?\nVerrà inviata una nuova chiamata RegisterInstallation via SignalR.')">
                <i class="bi bi-arrow-repeat me-1"></i>Ri-registra all'Hub
            </button>
        </form>
    </div>
</div>

<div class="alert alert-info d-flex align-items-center gap-2 mb-4" style="font-size:.82rem">
    <i class="bi bi-info-circle-fill fs-5 flex-shrink-0"></i>
    <span>Le modifiche vengono scritte in <code>appsettings.json</code> e diventano effettive al <strong>prossimo riavvio</strong> del servizio Windows.</span>
</div>

@if (Model.Options.UI.Password == "Admin#123!")
{
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-shield-exclamation fs-5 flex-shrink-0"></i>
        <div>
            <strong>Stai usando le credenziali di default</strong> — <code>admin / Admin#123!</code>.<br />
            Cambia la password nella sezione <em>UI Locale</em> qui sotto prima di esporre l'agent in rete.
        </div>
    </div>
}

<form method="post" asp-page-handler="Save">

<!-- ═══ 1. IDENTITÀ ════════════════════════════════════════════════════ -->
<div class="ef-card mb-4">
    <div class="ef-card-header"><i class="bi bi-fingerprint"></i>Identità</div>
    <div class="ef-card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Installation ID <span class="ef-badge ef-badge-neutral">sola lettura</span></label>
                <input class="form-control" readonly value="@Model.Options.InstallationId" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Installation Code <span class="ef-badge ef-badge-neutral">sola lettura</span></label>
                <input class="form-control font-monospace" readonly value="@Model.Options.InstallationCode"
                       placeholder="Generato al primo avvio" style="font-size:.8rem" />
                <div class="form-text">Identificativo univoco permanente <code>EF-{host}-{timestamp}-{random}</code>. Usato per l'auto-enrollment Hub.</div>
            </div>
            <div class="col-md-6">
                <label class="form-label">Nome installazione</label>
                <input class="form-control" name="InstallationName" value="@Model.Options.InstallationName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Posizione fisica</label>
                <input class="form-control" name="Location" value="@Model.Options.Location"
                       placeholder="es. Magazzino Nord – PC-03" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Tag (separati da virgola)</label>
                <input class="form-control" name="Tags" value="@string.Join(", ", Model.Options.Tags)"
                       placeholder="es. production, milan" />
            </div>
        </div>
    </div>
</div>

<!-- ═══ 2. CONNESSIONE HUB ═════════════════════════════════════════════ -->
<div class="ef-card mb-4">
    <div class="ef-card-header"><i class="bi bi-cloud-fill"></i>Connessione Hub</div>
    <div class="ef-card-body">
        <div class="row g-3">
            <div class="col-md-8">
                <label class="form-label">Hub URL (SignalR) <span class="ef-badge ef-badge-warning">riavvio</span></label>
                <input class="form-control" name="HubUrl" value="@Model.Options.HubUrl"
                       placeholder="https://updatehub.example.com/hubs/update" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Hub Base URL <span class="ef-badge ef-badge-warning">riavvio</span></label>
                <input class="form-control" name="HubBaseUrl" value="@Model.Options.HubBaseUrl"
                       placeholder="https://updatehub.example.com" />
            </div>
            <div class="col-md-8">
                <label class="form-label">API Key <span class="ef-badge ef-badge-warning">riavvio</span></label>
                <input class="form-control" name="ApiKey" type="password" value="@Model.Options.ApiKey"
                       autocomplete="off" placeholder="Lasciare vuoto per auto-enrollment" />
                <div class="form-text text-muted">Vuoto = l'agent richiederà automaticamente una chiave al prossimo avvio usando l'Enrollment Token.</div>
            </div>
            <div class="col-md-4">
                <label class="form-label">Enrollment Token <span class="ef-badge ef-badge-info">auto-registrazione</span></label>
                <input class="form-control" name="EnrollmentToken" type="password" value="@Model.Options.EnrollmentToken"
                       autocomplete="off" placeholder="Token condiviso con l'Hub" />
                <div class="form-text text-muted">Segreto condiviso. Se API Key è vuota, l'agent chiama <code>POST /api/v1/enrollments</code> e salva la chiave ricevuta.</div>
            </div>
            <div class="col-md-2">
                <label class="form-label">Heartbeat (sec)</label>
                <input class="form-control" name="HeartbeatIntervalSeconds" type="number" min="10" max="3600"
                       value="@Model.Options.HeartbeatIntervalSeconds" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Reconnect (sec)</label>
                <input class="form-control" name="ReconnectDelaySeconds" type="number" min="5" max="300"
                       value="@Model.Options.ReconnectDelaySeconds" />
            </div>
        </div>
    </div>
</div>

<!-- ═══ 3. DOWNLOAD ════════════════════════════════════════════════════ -->
<div class="ef-card mb-4">
    <div class="ef-card-header"><i class="bi bi-cloud-download-fill"></i>Download</div>
    <div class="ef-card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Timeout per-richiesta (minuti)</label>
                <input class="form-control" name="DownloadTimeoutMinutes" type="number" min="1" max="120"
                       value="@Model.Options.DownloadTimeoutMinutes" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Max retry download</label>
                <input class="form-control" name="DownloadMaxRetries" type="number" min="0" max="20"
                       value="@Model.Options.DownloadMaxRetries" />
            </div>
            <div class="col-md-4">
                <label class="form-label" style="visibility:hidden">—</label>
                <div class="ef-card p-3" style="background:#f8fafc">
                    <div class="ef-kpi-sub">Backoff: 5 s → 15 s → 30 s → 60 s → 120 s</div>
                    <div class="ef-kpi-sub mt-1">Resume HTTP Range abilitato (best-effort)</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══ 4. INSTALLAZIONE ════════════════════════════════════════════════ -->
<div class="ef-card mb-4">
    <div class="ef-card-header"><i class="bi bi-gear-fill"></i>Installazione</div>
    <div class="ef-card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Health check — max tentativi</label>
                <input class="form-control" name="Install_HealthCheckMaxAttempts" type="number" min="1" max="30"
                       value="@Model.Options.Install.HealthCheckMaxAttempts" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Health check — delay (sec)</label>
                <input class="form-control" name="Install_HealthCheckDelaySeconds" type="number" min="1" max="60"
                       value="@Model.Options.Install.HealthCheckDelaySeconds" />
            </div>
            <div class="col-md-3">
                <label class="form-label">IIS warmup delay (sec)</label>
                <input class="form-control" name="Install_IisWarmupDelaySeconds" type="number" min="0" max="120"
                       value="@Model.Options.Install.IisWarmupDelaySeconds" />
            </div>
            <div class="col-md-3">
                <label class="form-label">SQL command timeout (sec)</label>
                <input class="form-control" name="Install_SqlCommandTimeoutSeconds" type="number" min="30" max="3600"
                       value="@Model.Options.Install.SqlCommandTimeoutSeconds" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Intervallo check scheduler (sec)</label>
                <input class="form-control" name="Install_ScheduledCheckIntervalSeconds" type="number" min="10" max="3600"
                       value="@Model.Options.Install.ScheduledCheckIntervalSeconds" />
            </div>
        </div>
    </div>
</div>

<!-- ═══ 5. BACKUP ══════════════════════════════════════════════════════ -->
<div class="ef-card mb-4">
    <div class="ef-card-header"><i class="bi bi-archive-fill"></i>Backup</div>
    <div class="ef-card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Max backup da conservare <span class="ef-badge ef-badge-neutral">0 = illimitato</span></label>
                <input class="form-control" name="Backup_MaxBackupsToKeep" type="number" min="0" max="100"
                       value="@Model.Options.Backup.MaxBackupsToKeep" />
            </div>
            <div class="col-md-9">
                <label class="form-label">Percorso backup <span class="ef-badge ef-badge-neutral">vuoto = &lt;AppDir&gt;/backups</span></label>
                <input class="form-control" name="Backup_RootPath" value="@Model.Options.Backup.RootPath"
                       placeholder="C:\Prym\Backups" />
            </div>
        </div>
    </div>
</div>

<!-- ═══ 6. LOG ═════════════════════════════════════════════════════════ -->
<div class="ef-card mb-4">
    <div class="ef-card-header"><i class="bi bi-journals"></i>Log</div>
    <div class="ef-card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Retention (giorni)</label>
                <input class="form-control" name="Logging_RetentionDays" type="number" min="1" max="365"
                       value="@Model.Options.Logging.RetentionDays" />
            </div>
            <div class="col-md-9">
                <label class="form-label">Directory log <span class="ef-badge ef-badge-neutral">vuoto = &lt;AppDir&gt;/logs</span></label>
                <input class="form-control" name="Logging_DirectoryPath" value="@Model.Options.Logging.DirectoryPath"
                       placeholder="C:\Prym\Logs" />
            </div>
        </div>
    </div>
</div>

<!-- ═══ 7. UI LOCALE ═══════════════════════════════════════════════════ -->
<div class="ef-card mb-4">
    <div class="ef-card-header"><i class="bi bi-window-stack"></i>UI Locale</div>
    <div class="ef-card-body">
        <div class="alert alert-neutral d-flex gap-2 mb-3 p-2" style="background:#f8fafc;border:1px solid var(--ef-border);border-radius:var(--ef-radius-sm);font-size:.78rem">
            <i class="bi bi-info-circle text-muted"></i>
            <span>
                Credenziali default: <code>admin</code> / <code>Admin#123!</code> — modificabili qui.
                Lasciare username o password <strong>vuoti</strong> disabilita completamente la UI (restituisce 503).
                Le credenziali cambiate si applicano <strong>immediatamente</strong> senza riavvio.
            </span>
        </div>
        <div class="row g-3">
            <div class="col-md-2">
                <label class="form-label">Porta <span class="ef-badge ef-badge-warning">riavvio</span></label>
                <input class="form-control" name="UI_Port" type="number" min="1024" max="65535"
                       value="@Model.Options.UI.Port" />
            </div>
            <div class="col-md-5">
                <label class="form-label">Username</label>
                <input class="form-control" name="UI_Username" value="@Model.Options.UI.Username"
                       autocomplete="off" />
            </div>
            <div class="col-md-5">
                <label class="form-label">Password</label>
                <input class="form-control" name="UI_Password" type="password" value="@Model.Options.UI.Password"
                       autocomplete="new-password" />
            </div>
        </div>
    </div>
</div>

<!-- ═══ 8. COMPONENTI ══════════════════════════════════════════════════ -->
<div class="ef-card mb-4">
    <div class="ef-card-header"><i class="bi bi-puzzle-fill"></i>Componenti</div>
    <div class="ef-card-body">

        <h6 class="mb-3" style="font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--ef-text-muted)">
            <span class="ef-badge ef-badge-blue me-2">Server</span>
        </h6>
        <div class="row g-3 mb-4">
            <div class="col-md-2 d-flex align-items-center">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="serverEnabled" name="Server_Enabled"
                           @(Model.Options.Components.Server.Enabled ? "checked" : "") />
                    <label class="form-check-label" for="serverEnabled">Abilitato</label>
                </div>
            </div>
            <div class="col-md-5">
                <label class="form-label">Deploy path</label>
                <input class="form-control" name="Server_DeployPath" value="@Model.Options.Components.Server.DeployPath"
                       placeholder="C:\inetpub\wwwroot\Prym" />
            </div>
            <div class="col-md-5">
                <label class="form-label">Health check URL</label>
                <input class="form-control" name="Server_HealthCheckUrl" value="@Model.Options.Components.Server.HealthCheckUrl"
                       placeholder="https://localhost/health" />
            </div>
            <div class="col-md-4">
                <label class="form-label">IIS Site Name</label>
                <input class="form-control" name="Server_IISSiteName" value="@Model.Options.Components.Server.IISSiteName"
                       placeholder="Prym" />
            </div>
            <div class="col-md-4">
                <label class="form-label">IIS App Pool Name</label>
                <input class="form-control" name="Server_AppPoolName" value="@Model.Options.Components.Server.AppPoolName"
                       placeholder="Prym" />
            </div>
            <div class="col-md-4">
                <label class="form-label">SQL Connection String</label>
                <input class="form-control" name="Server_ConnectionString" type="password"
                       value="@Model.Options.Components.Server.ConnectionString"
                       placeholder="Server=.;Database=Prym;..." autocomplete="off" />
            </div>
        </div>

        <h6 class="mb-3" style="font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--ef-text-muted)">
            <span class="ef-badge ef-badge-info me-2">Client</span>
        </h6>
        <div class="row g-3">
            <div class="col-md-2 d-flex align-items-center">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="clientEnabled" name="Client_Enabled"
                           @(Model.Options.Components.Client.Enabled ? "checked" : "") />
                    <label class="form-check-label" for="clientEnabled">Abilitato</label>
                </div>
            </div>
            <div class="col-md-10">
                <label class="form-label">Deploy path</label>
                <input class="form-control" name="Client_DeployPath" value="@Model.Options.Components.Client.DeployPath"
                       placeholder="C:\Prym\Client" />
            </div>
        </div>
    </div>
</div>

<!-- ═══ SAVE ════════════════════════════════════════════════════════════ -->
<div class="d-flex gap-3 mb-4">
    <button type="submit" class="btn btn-primary">
        <i class="bi bi-floppy-fill me-1"></i>Salva configurazione
    </button>
    <a href="/settings" class="btn btn-outline-secondary">
        <i class="bi bi-x me-1"></i>Annulla
    </a>
</div>

</form>
