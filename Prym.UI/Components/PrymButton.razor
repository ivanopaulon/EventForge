<MudButton Variant="_resolvedVariant"
           Color="_resolvedColor"
           StartIcon="@StartIcon"
           EndIcon="@EndIcon"
           Size="Size"
           Disabled="Disabled"
           FullWidth="FullWidth"
           OnClick="OnClick"
           Href="@Href"
           HtmlTag="@HtmlTag"
           Class="@Class"
           Style="@Style">
    @ChildContent
</MudButton>

@code {
    public enum ButtonIntent { Primary, Secondary, Ghost, Danger, Warning }

    [Parameter] public ButtonIntent          Intent       { get; set; } = ButtonIntent.Primary;
    [Parameter] public MudBlazor.Variant?    Variant      { get; set; }
    [Parameter] public MudBlazor.Color?      Color        { get; set; }
    [Parameter] public string?               StartIcon    { get; set; }
    [Parameter] public string?               EndIcon      { get; set; }
    [Parameter] public Size                  Size         { get; set; } = Size.Medium;
    [Parameter] public bool                  Disabled     { get; set; } = false;
    [Parameter] public bool                  FullWidth    { get; set; } = false;
    [Parameter] public EventCallback         OnClick      { get; set; }
    [Parameter] public string?               Href         { get; set; }
    [Parameter] public string                HtmlTag      { get; set; } = "button";
    [Parameter] public string?               Class        { get; set; }
    [Parameter] public string?               Style        { get; set; }
    [Parameter] public RenderFragment?       ChildContent { get; set; }

    private MudBlazor.Variant _resolvedVariant => Variant ?? Intent switch
    {
        ButtonIntent.Secondary => MudBlazor.Variant.Outlined,
        ButtonIntent.Ghost     => MudBlazor.Variant.Text,
        _                      => MudBlazor.Variant.Filled,
    };

    private MudBlazor.Color _resolvedColor => Color ?? Intent switch
    {
        ButtonIntent.Danger   => MudBlazor.Color.Error,
        ButtonIntent.Warning  => MudBlazor.Color.Warning,
        ButtonIntent.Ghost    => MudBlazor.Color.Default,
        _                     => MudBlazor.Color.Primary,
    };
}
